<Application x:Class="UnoTetris.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Colors -->
      <SolidColorBrush x:Key="GameBackgroundBrush" Color="#0F0F1E" />
      <SolidColorBrush x:Key="GridBackgroundBrush" Color="#1A1A2E" />
      <SolidColorBrush x:Key="GridBorderBrush" Color="#2A2A3E" />
      <SolidColorBrush x:Key="CellBorderBrush" Color="#252538" />
      <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#16213E" />
      <SolidColorBrush x:Key="AccentBrush" Color="#00D9FF" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0C0" />
      
      <!-- Styles -->
      <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      </Style>
      
      <Style x:Key="ScoreLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
      </Style>
      
      <Style x:Key="ScoreValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      </Style>
      
      <Style x:Key="GameButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#0F0F1E" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="32,12" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>

</Application>
