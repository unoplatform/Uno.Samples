<Page x:Class="UnoTetris.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoTetris"
      Background="{StaticResource GameBackgroundBrush}">
  
  <Grid Padding="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock Text="TETRIS" 
               Style="{StaticResource TitleTextStyle}"
               HorizontalAlignment="Center"
               Margin="0,0,0,24" />

    <!-- Game Area -->
    <Grid Grid.Row="1" MaxWidth="800" HorizontalAlignment="Center">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Left Panel - Next Piece -->
      <Border Grid.Column="0" 
              Background="{StaticResource PanelBackgroundBrush}"
              CornerRadius="12"
              Padding="20"
              Margin="0,0,16,0"
              VerticalAlignment="Top"
              Width="160"
              Translation="0,0,16">
        <Border.Shadow>
          <ThemeShadow />
        </Border.Shadow>
        <StackPanel>
          <TextBlock Text="NEXT" 
                     Style="{StaticResource ScoreLabelStyle}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,12" />
          <Canvas x:Name="NextPieceCanvas" 
                  Width="120" 
                  Height="120"
                  HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Center - Game Grid -->
      <Border Grid.Column="1"
              Background="{StaticResource GridBackgroundBrush}"
              BorderBrush="{StaticResource GridBorderBrush}"
              BorderThickness="2"
              CornerRadius="12"
              Padding="12"
              Translation="0,0,32">
        <Border.Shadow>
          <ThemeShadow />
        </Border.Shadow>
        <Canvas x:Name="GameCanvas" 
                Width="300" 
                Height="600" />
      </Border>

      <!-- Right Panel - Score & Controls -->
      <StackPanel Grid.Column="2" 
                  Spacing="16"
                  Margin="16,0,0,0"
                  Width="200">
        
        <!-- Score Panel -->
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="12"
                Padding="20"
                Translation="0,0,16">
          <Border.Shadow>
            <ThemeShadow />
          </Border.Shadow>
          <StackPanel Spacing="8">
            <TextBlock Text="SCORE" Style="{StaticResource ScoreLabelStyle}" />
            <TextBlock x:Name="ScoreText" 
                       Text="0" 
                       Style="{StaticResource ScoreValueStyle}" />
            
            <TextBlock Text="LEVEL" 
                       Style="{StaticResource ScoreLabelStyle}"
                       Margin="0,16,0,0" />
            <TextBlock x:Name="LevelText" 
                       Text="1" 
                       Style="{StaticResource ScoreValueStyle}" />
            
            <TextBlock Text="LINES" 
                       Style="{StaticResource ScoreLabelStyle}"
                       Margin="0,16,0,0" />
            <TextBlock x:Name="LinesText" 
                       Text="0" 
                       Style="{StaticResource ScoreValueStyle}" />
          </StackPanel>
        </Border>

        <!-- Controls Panel -->
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="12"
                Padding="20"
                Translation="0,0,16">
          <Border.Shadow>
            <ThemeShadow />
          </Border.Shadow>
          <StackPanel Spacing="12">
            <TextBlock Text="CONTROLS" 
                       Style="{StaticResource ScoreLabelStyle}"
                       Margin="0,0,0,8" />
            
            <Button x:Name="StartButton"
                    Content="START"
                    Style="{StaticResource GameButtonStyle}"
                    Click="StartButton_Click" />
            
            <Button x:Name="StopButton"
                    Content="STOP"
                    Style="{StaticResource GameButtonStyle}"
                    Click="StopButton_Click"
                    IsEnabled="False"
                    Opacity="0.5" />
            
            <ToggleButton x:Name="AutoPlayToggle"
                          Content="Auto-play"
                          Margin="0,4,0,0"
                          HorizontalAlignment="Stretch"
                          Checked="AutoPlayToggle_Changed"
                          Unchecked="AutoPlayToggle_Changed" />
          </StackPanel>
        </Border>

        <!-- Info Panel -->
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="12"
                Padding="16"
                Translation="0,0,16">
          <Border.Shadow>
            <ThemeShadow />
          </Border.Shadow>
          <StackPanel Spacing="8">
            <TextBlock Text="KEYBOARD" 
                       Style="{StaticResource ScoreLabelStyle}"
                       Margin="0,0,0,4" />
            <StackPanel Spacing="4">
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="←→" FontWeight="SemiBold" /> 
                <Run Text="Move" />
              </TextBlock>
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="↑ / Space" FontWeight="SemiBold" /> 
                <Run Text="Rotate" />
              </TextBlock>
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="↓" FontWeight="SemiBold" /> 
                <Run Text="Soft drop" />
              </TextBlock>
              <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="Enter" FontWeight="SemiBold" /> 
                <Run Text="Hard drop" />
              </TextBlock>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>

    <!-- Game Over Overlay -->
    <Grid x:Name="GameOverOverlay" 
          Grid.RowSpan="2"
          Background="#CC000000"
          Visibility="Collapsed">
      <Border Background="{StaticResource PanelBackgroundBrush}"
              CornerRadius="16"
              Padding="48"
              MaxWidth="400"
              Translation="0,0,64">
        <Border.Shadow>
          <ThemeShadow />
        </Border.Shadow>
        <StackPanel Spacing="24" HorizontalAlignment="Center">
          <TextBlock Text="GAME OVER" 
                     FontSize="36"
                     FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}"
                     HorizontalAlignment="Center" />
          
          <StackPanel Spacing="8">
            <TextBlock Text="Final Score" 
                       Style="{StaticResource ScoreLabelStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="FinalScoreText" 
                       Text="0"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
          
          <Button Content="PLAY AGAIN"
                  Style="{StaticResource GameButtonStyle}"
                  Click="PlayAgain_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Page>
