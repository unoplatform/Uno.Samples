<Page x:Class="GridWatch.Presentation.AlertsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:converters="using:GridWatch.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      x:Name="PageRoot">

    <Page.Resources>
        <converters:AlertSeverityBrushConverter x:Key="SeverityBrushConverter" />
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardSurfaceBrush}"
                BorderBrush="{ThemeResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xEA8F;"
                          FontSize="20"
                          Foreground="{ThemeResource StatusWarningBrush}" />
                <TextBlock x:Uid="Alerts_Title"
                           FontFamily="{ThemeResource InterFontFamily}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <Border Background="{ThemeResource StatusCriticalBrush}"
                        CornerRadius="2"
                        Padding="8,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CriticalCount}"
                               FontFamily="{ThemeResource MonoFontFamily}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{ThemeResource OnAccentBrush}"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Severity Filter Row -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardSurfaceBrush}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Uid="FilterLabel"
                           FontFamily="{ThemeResource InterFontFamily}"
                           FontSize="13"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           VerticalAlignment="Center" />
                <Button x:Uid="FilterAllButton"
                        Command="{Binding FilterAll}"
                        CornerRadius="4"
                        Padding="14,6"
                        FontFamily="{ThemeResource InterFontFamily}"
                        FontSize="12" />
                <Button x:Uid="FilterCriticalButton"
                        Command="{Binding FilterCritical}"
                        CornerRadius="4"
                        Padding="14,6"
                        FontFamily="{ThemeResource InterFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource StatusCriticalBrush}" />
                <Button x:Uid="FilterWarningButton"
                        Command="{Binding FilterWarning}"
                        CornerRadius="4"
                        Padding="14,6"
                        FontFamily="{ThemeResource InterFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource StatusWarningBrush}" />
                <Button x:Uid="FilterInfoButton"
                        Command="{Binding FilterInfo}"
                        CornerRadius="4"
                        Padding="14,6"
                        FontFamily="{ThemeResource InterFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource StatusOnlineBrush}" />
            </StackPanel>
        </Border>

        <!-- Alerts List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16">
            <ItemsControl ItemsSource="{Binding FilteredAlerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Background="{ThemeResource CardSurfaceBrush}"
                                BorderBrush="{ThemeResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid Padding="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Severity Indicator -->
                                <Border Grid.Column="0"
                                        Width="4"
                                        CornerRadius="2"
                                        Background="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"
                                        Margin="0,0,14,0" />

                                <!-- Content -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}"
                                                CornerRadius="2"
                                                Padding="6,3"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Severity}"
                                                       FontFamily="{ThemeResource InterFontFamily}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{ThemeResource OnAccentBrush}" />
                                        </Border>
                                        <TextBlock Text="{Binding FacilityName}"
                                                   FontFamily="{ThemeResource InterFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Message}"
                                               FontFamily="{ThemeResource InterFontFamily}"
                                               FontSize="14"
                                               Foreground="{ThemeResource PrimaryTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TimestampDisplay}"
                                           FontFamily="{ThemeResource MonoFontFamily}"
                                           FontSize="11"
                                           Foreground="{ThemeResource SecondaryTextBrush}"
                                           VerticalAlignment="Top"
                                           Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
