<Page x:Class="GridWatch.Presentation.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds,SoftInput">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Center login card -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardSurfaceBrush}"
                CornerRadius="8"
                Padding="40,36"
                MinWidth="360"
                MaxWidth="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="24">

                <!-- Header -->
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE945;"
                               FontSize="40"
                               Foreground="{ThemeResource BrandAccentBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="LoginPage_Title"
                               FontSize="26"
                               FontWeight="Bold"
                               FontFamily="{ThemeResource InterFontFamily}"
                               Foreground="{ThemeResource PrimaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="LoginPage_Subtitle"
                               FontSize="13"
                               FontFamily="{ThemeResource InterFontFamily}"
                               Foreground="{ThemeResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Divider -->
                <utu:Divider />

                <!-- Form fields -->
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="LoginPage_UsernameLabel"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="{ThemeResource InterFontFamily}"
                                   Foreground="{ThemeResource SecondaryTextBrush}" />
                        <TextBox x:Name="UsernameBox"
                                 x:Uid="UsernameBox"
                                 Text="{Binding Username, Mode=TwoWay}"
                                 FontFamily="{ThemeResource InterFontFamily}"
                                 FontSize="14"
                                 CornerRadius="4" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="LoginPage_PasswordLabel"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="{ThemeResource InterFontFamily}"
                                   Foreground="{ThemeResource SecondaryTextBrush}" />
                        <PasswordBox x:Name="PasswordBox"
                                     x:Uid="PasswordBox"
                                     Password="{Binding Password, Mode=TwoWay}"
                                     FontFamily="{ThemeResource InterFontFamily}"
                                     FontSize="14"
                                     CornerRadius="4" />
                    </StackPanel>
                </StackPanel>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="12"
                           FontFamily="{ThemeResource InterFontFamily}"
                           Foreground="{ThemeResource StatusCriticalBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{Binding HasError}"
                           TextWrapping="Wrap" />

                <!-- Login button -->
                <Button x:Uid="SignInButton"
                        Command="{Binding Login}"
                        HorizontalAlignment="Stretch"
                        FontFamily="{ThemeResource InterFontFamily}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        CornerRadius="4"
                        Padding="0,12"
                        Background="{ThemeResource BrandAccentBrush}"
                        Foreground="{ThemeResource OnAccentBrush}" />

                <!-- Hint -->
                <TextBlock x:Uid="DemoCredentialsHint"
                           FontSize="11"
                           FontFamily="{ThemeResource InterFontFamily}"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Opacity="0.7" />

            </StackPanel>
        </Border>
    </Grid>
</Page>
