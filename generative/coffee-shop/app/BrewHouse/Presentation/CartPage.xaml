<Page x:Class="BrewHouse.Presentation.CartPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource CoffeeBackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CoffeeBackgroundBrush}"
                    Padding="20,16,20,12"
                    BorderBrush="{ThemeResource CoffeeSubtleOverlayBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock x:Uid="Cart_PageTitle"
                               Style="{StaticResource PageTitleTextBlockStyle}" />
                    <TextBlock Text="{Binding Totals.ItemCountText}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </StackPanel>
            </Border>

            <!-- Empty Cart State -->
            <ScrollViewer Grid.Row="1"
                          Visibility="{Binding Totals.IsEmpty}"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16"
                            Padding="40,60,40,40">
                    <TextBlock Text="&#x2615;"
                               FontSize="72"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="CartEmpty_Title"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{ThemeResource CoffeeTextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="CartEmpty_Subtitle"
                               Style="{StaticResource BodyTextBlockStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Border Background="{ThemeResource CoffeeChipBackgroundBrush}"
                            CornerRadius="16"
                            Padding="20,16"
                            Margin="0,8,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock x:Uid="PopularChoicesLabel"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource CoffeeAccentBrush}"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <Border Background="{ThemeResource CoffeeSurfaceBrush}"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock x:Uid="PopularLatte"
                                               FontSize="13"
                                               Foreground="{ThemeResource CoffeePrimaryBrush}" />
                                </Border>
                                <Border Background="{ThemeResource CoffeeSurfaceBrush}"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock x:Uid="PopularCroissant"
                                               FontSize="13"
                                               Foreground="{ThemeResource CoffeePrimaryBrush}" />
                                </Border>
                                <Border Background="{ThemeResource CoffeeSurfaceBrush}"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock x:Uid="PopularMatcha"
                                               FontSize="13"
                                               Foreground="{ThemeResource CoffeePrimaryBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Cart Content -->
            <Grid Grid.Row="1"
                  Visibility="{Binding Totals.HasItems}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Cart Items List -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Hidden"
                              Padding="0,0,0,8">
                    <StackPanel Spacing="0" Padding="16,12,16,0">

                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CoffeeSurfaceBrush}"
                                            CornerRadius="16"
                                            Padding="12"
                                            BorderBrush="{ThemeResource CoffeeSubtleOverlayBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Product Image -->
                                            <Border Grid.Column="0"
                                                    CornerRadius="10"
                                                    Width="72"
                                                    Height="72">
                                                <Image Source="{Binding ImageUrl}"
                                                       Width="72"
                                                       Height="72"
                                                       Stretch="UniformToFill" />
                                            </Border>

                                            <!-- Product Info -->
                                            <StackPanel Grid.Column="1"
                                                        Padding="12,4,8,4"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource ItemNameTextBlockStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="13"
                                                           Foreground="{ThemeResource CoffeeAccentBrush}"
                                                           FontWeight="SemiBold">
                                                    <Run Text="$" />
                                                    <Run Text="{Binding PriceFormatted}" />
                                                </TextBlock>
                                                <TextBlock FontSize="12"
                                                           Foreground="{ThemeResource CoffeeTextSecondaryBrush}">
                                                    <Run x:Uid="LineTotalPrefix" />
                                                    <Run Text="{Binding LineTotalFormatted}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Quantity Controls -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <Button x:Uid="IncreaseQuantityButton"
                                                        Content="+"
                                                        Width="34"
                                                        Height="34"
                                                        Background="{ThemeResource CoffeePrimaryBrush}"
                                                        Foreground="{ThemeResource CoffeeOnPrimaryBrush}"
                                                        CornerRadius="10"
                                                        FontSize="18"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding DataContext.IncrementItem, ElementName=PageRoot}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock Text="{Binding Quantity}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{ThemeResource CoffeeTextPrimaryBrush}"
                                                           HorizontalAlignment="Center" />
                                                <Button x:Uid="DecreaseQuantityButton"
                                                        Content="-"
                                                        Width="34"
                                                        Height="34"
                                                        Background="{ThemeResource CoffeeChipBackgroundBrush}"
                                                        Foreground="{ThemeResource CoffeePrimaryBrush}"
                                                        CornerRadius="10"
                                                        FontSize="18"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding DataContext.DecrementItem, ElementName=PageRoot}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- Order Summary + Place Order -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CoffeeSurfaceBrush}"
                        CornerRadius="20,20,0,0"
                        Padding="20,20,20,24"
                        BorderBrush="{ThemeResource CoffeeSubtleOverlayBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Spacing="0">

                        <!-- Order Confirmed Banner -->
                        <Border Visibility="{Binding IsOrderPlaced}"
                                Background="{ThemeResource CoffeeSuccessBgBrush}"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="&#x2713;"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource CoffeeSuccessBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Uid="OrderConfirmedMessage"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource CoffeeSuccessBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Summary Title -->
                        <TextBlock x:Uid="OrderSummaryTitle"
                                   Style="{StaticResource CardTitleTextBlockStyle}"
                                   Margin="0,0,0,14" />

                        <!-- Subtotal Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="SubtotalLabel"
                                       FontSize="14"
                                       Foreground="{ThemeResource CoffeeTextSecondaryBrush}"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       Foreground="{ThemeResource CoffeeTextPrimaryBrush}"
                                       FontWeight="SemiBold">
                                <Run Text="$" />
                                <Run Text="{Binding Totals.SubtotalFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Tax Row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="TaxLabel"
                                       FontSize="14"
                                       Foreground="{ThemeResource CoffeeTextSecondaryBrush}"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       Foreground="{ThemeResource CoffeeTextPrimaryBrush}"
                                       FontWeight="SemiBold">
                                <Run Text="$" />
                                <Run Text="{Binding Totals.TaxFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Divider -->
                        <utu:Divider Margin="0,0,0,12" />

                        <!-- Total Row -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="TotalLabel"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource CoffeeTextPrimaryBrush}"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource CoffeePrimaryBrush}">
                                <Run Text="$" />
                                <Run Text="{Binding Totals.TotalFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Place Order Button -->
                        <Button x:Uid="PlaceOrderButton"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource CoffeePrimaryBrush}"
                                Foreground="{ThemeResource CoffeeOnPrimaryBrush}"
                                CornerRadius="12"
                                Padding="0,16"
                                FontSize="16"
                                FontWeight="Bold"
                                Command="{Binding PlaceOrder}" />

                    </StackPanel>
                </Border>

            </Grid>

        </Grid>
    </utu:SafeArea>
</Page>
