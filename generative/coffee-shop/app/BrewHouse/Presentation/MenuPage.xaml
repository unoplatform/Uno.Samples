<Page x:Class="BrewHouse.Presentation.MenuPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource CoffeeBackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource CoffeePrimaryBrush}"
                        Padding="20,20,20,16"
                        Spacing="2">
                <TextBlock x:Uid="Menu_PageTitle"
                           Style="{StaticResource HeroTitleTextBlockStyle}" />
                <TextBlock x:Uid="Menu_Subtitle"
                           FontSize="13"
                           Foreground="{ThemeResource CoffeeHeroSubtitleBrush}" />
            </StackPanel>

            <!-- Category Filters -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CoffeeSurfaceBrush}"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Uid="FilterAllButton"
                            Command="{Binding FilterAll}"
                            CornerRadius="16"
                            Padding="14,7"
                            FontSize="13"
                            FontWeight="SemiBold" />
                    <Button x:Uid="FilterHotButton"
                            Command="{Binding FilterHot}"
                            CornerRadius="16"
                            Padding="14,7"
                            FontSize="13"
                            FontWeight="SemiBold" />
                    <Button x:Uid="FilterColdButton"
                            Command="{Binding FilterCold}"
                            CornerRadius="16"
                            Padding="14,7"
                            FontSize="13"
                            FontWeight="SemiBold" />
                    <Button x:Uid="FilterPastriesButton"
                            Command="{Binding FilterPastries}"
                            CornerRadius="16"
                            Padding="14,7"
                            FontSize="13"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Product List -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectionMode="None"
                      Padding="16,4,16,16">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CoffeeSurfaceBrush}"
                                CornerRadius="16"
                                BorderBrush="{ThemeResource CoffeeSubtleOverlayBrush}"
                                BorderThickness="1"
                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <!-- Product Image -->
                                <Border Grid.Column="0"
                                        CornerRadius="16,0,0,16"
                                        Background="{ThemeResource CoffeeChipBackgroundBrush}">
                                    <Image Source="{Binding ImageUrl}"
                                           Width="100"
                                           Height="110"
                                           Stretch="UniformToFill" />
                                </Border>

                                <!-- Product Info -->
                                <StackPanel Grid.Column="1"
                                            Padding="14"
                                            Spacing="4"
                                            VerticalAlignment="Center">

                                    <!-- Special Badge -->
                                    <Border Background="{ThemeResource CoffeeChipBackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding IsSpecial}">
                                        <TextBlock x:Uid="TodaysSpecialBadge"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource CoffeeAccentBrush}" />
                                    </Border>

                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource ItemTitleTextBlockStyle}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource SmallCaptionTextBlockStyle}"
                                               TextWrapping="Wrap"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Stretch"
                                                Spacing="10"
                                                Margin="0,6,0,0">
                                        <TextBlock Style="{StaticResource PriceTextBlockStyle}"
                                                   VerticalAlignment="Center">
                                            <Run Text="$" /><Run Text="{Binding PriceFormatted}" />
                                        </TextBlock>

                                        <Button x:Uid="MenuAddToCartButton"
                                                Background="{ThemeResource CoffeePrimaryBrush}"
                                                Foreground="{ThemeResource CoffeeOnPrimaryBrush}"
                                                CornerRadius="12"
                                                Padding="12,7"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Command="{Binding DataContext.AddToCart, ElementName=PageRoot}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </utu:SafeArea>
</Page>
