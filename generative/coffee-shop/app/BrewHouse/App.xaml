<Application x:Class="BrewHouse.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utus:SimpleToolkitTheme xmlns:utus="using:Uno.Toolkit.UI.Simple" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Add resources here -->

      <!-- BrewHouse brand palette - theme-aware -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="CoffeePrimaryBrush" Color="#FF4A2810" />
          <SolidColorBrush x:Key="CoffeeAccentBrush" Color="#FF8C5A28" />
          <SolidColorBrush x:Key="CoffeeBackgroundBrush" Color="#FFFDF6EE" />
          <SolidColorBrush x:Key="CoffeeSurfaceBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CoffeeOnPrimaryBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CoffeeTextPrimaryBrush" Color="#FF2C1A0E" />
          <SolidColorBrush x:Key="CoffeeTextSecondaryBrush" Color="#FF8C7060" />
          <SolidColorBrush x:Key="CoffeeChipBackgroundBrush" Color="#FFF5EFE6" />
          <SolidColorBrush x:Key="CoffeeDividerBrush" Color="#FFE8DDD0" />
          <SolidColorBrush x:Key="CoffeeSubtleOverlayBrush" Color="#15000000" />
          <SolidColorBrush x:Key="CoffeeHeroSubtitleBrush" Color="#CCF5EFE6" />
          <SolidColorBrush x:Key="CoffeeSuccessBrush" Color="#FF2E7D32" />
          <SolidColorBrush x:Key="CoffeeSuccessBgBrush" Color="#FFE8F5E9" />
          <SolidColorBrush x:Key="StatusPreparingBrush" Color="#FFF57C00" />
          <SolidColorBrush x:Key="StatusPreparingBgBrush" Color="#FFFFF3E0" />
          <SolidColorBrush x:Key="StatusReadyBrush" Color="#FF2E7D32" />
          <SolidColorBrush x:Key="StatusReadyBgBrush" Color="#FFE8F5E9" />
          <SolidColorBrush x:Key="StatusCompletedBrush" Color="#FFE8DDD0" />
          <SolidColorBrush x:Key="StatusCompletedFgBrush" Color="#FF2C1A0E" />
          <!-- Chip lightweight styling -->
          <SolidColorBrush x:Key="ChipBackground" Color="#FFF5EFE6" />
          <SolidColorBrush x:Key="ChipForeground" Color="#FF4A2810" />
          <SolidColorBrush x:Key="ChipBorderBrush" Color="#FFE8DDD0" />
          <SolidColorBrush x:Key="ChipBackgroundChecked" Color="#FF4A2810" />
          <SolidColorBrush x:Key="ChipForegroundChecked" Color="#FFFFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="CoffeePrimaryBrush" Color="#FFD4A574" />
          <SolidColorBrush x:Key="CoffeeAccentBrush" Color="#FFD4A574" />
          <SolidColorBrush x:Key="CoffeeBackgroundBrush" Color="#FF1A120E" />
          <SolidColorBrush x:Key="CoffeeSurfaceBrush" Color="#FF2C2118" />
          <SolidColorBrush x:Key="CoffeeOnPrimaryBrush" Color="#FF1A120E" />
          <SolidColorBrush x:Key="CoffeeTextPrimaryBrush" Color="#FFFDF6EE" />
          <SolidColorBrush x:Key="CoffeeTextSecondaryBrush" Color="#FFB8A898" />
          <SolidColorBrush x:Key="CoffeeChipBackgroundBrush" Color="#FF3A2E24" />
          <SolidColorBrush x:Key="CoffeeDividerBrush" Color="#FF3A2E24" />
          <SolidColorBrush x:Key="CoffeeSubtleOverlayBrush" Color="#20FFFFFF" />
          <SolidColorBrush x:Key="CoffeeHeroSubtitleBrush" Color="#CCB8A898" />
          <SolidColorBrush x:Key="CoffeeSuccessBrush" Color="#FF66BB6A" />
          <SolidColorBrush x:Key="CoffeeSuccessBgBrush" Color="#FF1B3A1E" />
          <SolidColorBrush x:Key="StatusPreparingBrush" Color="#FFFFB74D" />
          <SolidColorBrush x:Key="StatusPreparingBgBrush" Color="#FF3A2810" />
          <SolidColorBrush x:Key="StatusReadyBrush" Color="#FF66BB6A" />
          <SolidColorBrush x:Key="StatusReadyBgBrush" Color="#FF1B3A1E" />
          <SolidColorBrush x:Key="StatusCompletedBrush" Color="#FF3A2E24" />
          <SolidColorBrush x:Key="StatusCompletedFgBrush" Color="#FFFDF6EE" />
          <!-- Chip lightweight styling -->
          <SolidColorBrush x:Key="ChipBackground" Color="#FF3A2E24" />
          <SolidColorBrush x:Key="ChipForeground" Color="#FFFDF6EE" />
          <SolidColorBrush x:Key="ChipBorderBrush" Color="#FF3A2E24" />
          <SolidColorBrush x:Key="ChipBackgroundChecked" Color="#FFD4A574" />
          <SolidColorBrush x:Key="ChipForegroundChecked" Color="#FF1A120E" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- Hero overlay gradient colors (theme-independent) -->
      <Color x:Key="CoffeeHeroOverlayStartColor">#00000000</Color>
      <Color x:Key="CoffeeHeroOverlayEndColor">#E5140800</Color>

      <!-- Typography styles -->
      <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextPrimaryBrush}" />
      </Style>
      <Style x:Key="HeroTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeOnPrimaryBrush}" />
      </Style>
      <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextPrimaryBrush}" />
      </Style>
      <Style x:Key="CardTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextPrimaryBrush}" />
      </Style>
      <Style x:Key="ItemTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextPrimaryBrush}" />
      </Style>
      <Style x:Key="ItemNameTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextPrimaryBrush}" />
      </Style>
      <Style x:Key="BodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextSecondaryBrush}" />
      </Style>
      <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextSecondaryBrush}" />
      </Style>
      <Style x:Key="SmallCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeTextSecondaryBrush}" />
      </Style>
      <Style x:Key="PriceTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource CoffeeAccentBrush}" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>

</Application>
