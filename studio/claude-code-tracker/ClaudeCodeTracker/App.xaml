<Application x:Class="ClaudeCodeTracker.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utus:SimpleToolkitTheme xmlns:utus="using:Uno.Toolkit.UI.Simple" ColorOverrideSource="ms-appx:///ThemeColors.xaml"><utus:SimpleToolkitTheme.FontOverrideDictionary><ResourceDictionary><x:Double x:Key="DisplayLargeFontSize">52</x:Double><x:Double x:Key="DisplaySmallFontSize">34</x:Double><x:Double x:Key="HeadlineLargeFontSize">28</x:Double><FontFamily x:Key="TitleLargeFontFamily">Segoe UI Variable Display, Inter, system-ui</FontFamily><FontWeight x:Key="TitleLargeFontWeight">600</FontWeight><FontWeight x:Key="TitleMediumFontWeight">600</FontWeight><FontFamily x:Key="BodySmallFontFamily">Cascadia Code, JetBrains Mono, Consolas, monospace</FontFamily><FontFamily x:Key="LabelSmallFontFamily">Cascadia Code, JetBrains Mono, Consolas, monospace</FontFamily><x:Double x:Key="LabelSmallFontSize">11</x:Double><FontWeight x:Key="LabelMediumFontWeight">500</FontWeight></ResourceDictionary></utus:SimpleToolkitTheme.FontOverrideDictionary></utus:SimpleToolkitTheme>
      </ResourceDictionary.MergedDictionaries><CornerRadius x:Key="ControlCornerRadiusSmall">6</CornerRadius><CornerRadius x:Key="ControlCornerRadius">12</CornerRadius><CornerRadius x:Key="OverlayCornerRadius">20</CornerRadius><SolidColorBrush x:Key="App.PageBackground.Background" Color="{ThemeResource BackgroundBrush}" /><SolidColorBrush x:Key="App.PageBackground.Foreground" Color="{ThemeResource OnBackgroundBrush}" /><SolidColorBrush x:Key="App.CardBackground.Background" Color="{ThemeResource SurfaceBrush}" /><SolidColorBrush x:Key="App.CardBackground.Foreground" Color="{ThemeResource OnSurfaceBrush}" /><SolidColorBrush x:Key="App.NestedSurface.Background" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.NestedSurface.Foreground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.TabBar.Background" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.TabBar.Foreground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.TabBar.SelectionIndicator" Color="{ThemeResource PrimaryBrush}" /><SolidColorBrush x:Key="App.NavigationView.SidebarBackground" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.NavigationView.SidebarForeground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Accent.Indicator" Color="{ThemeResource PrimaryBrush}" /><SolidColorBrush x:Key="App.Badge.Positive" Color="{ThemeResource SecondaryContainerBrush}" /><SolidColorBrush x:Key="App.Badge.Positive.Foreground" Color="{ThemeResource OnSecondaryContainerBrush}" /><SolidColorBrush x:Key="App.Badge.Negative" Color="{ThemeResource ErrorBrush}" /><SolidColorBrush x:Key="App.Badge.Negative.Foreground" Color="{ThemeResource OnErrorBrush}" /><SolidColorBrush x:Key="App.Badge.Neutral" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Badge.Neutral.Foreground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Text.High" Color="{ThemeResource OnSurfaceBrush}" /><SolidColorBrush x:Key="App.Text.Medium" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Text.Low" Color="{ThemeResource OutlineBrush}" /><SolidColorBrush x:Key="App.Text.Disabled" Color="{ThemeResource OutlineVariantBrush}" />

      <!-- Add resources here -->

    </ResourceDictionary>
  </Application.Resources>

</Application>
