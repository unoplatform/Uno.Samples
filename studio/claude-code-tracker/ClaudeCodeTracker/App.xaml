<Application x:Class="ClaudeCodeTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utus="using:Uno.Toolkit.UI.Simple">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Load WinUI resources -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <!-- Simple theme: palette comes from ThemeColors.xaml; typography tuned below -->
                <utus:SimpleToolkitTheme ColorOverrideSource="ms-appx:///ThemeColors.xaml">
                    <utus:SimpleToolkitTheme.FontOverrideDictionary>
                        <ResourceDictionary>
                            <x:Double x:Key="DisplayLargeFontSize">52</x:Double>
                            <x:Double x:Key="DisplaySmallFontSize">34</x:Double>
                            <x:Double x:Key="HeadlineLargeFontSize">28</x:Double>
                            <FontFamily x:Key="TitleLargeFontFamily">Segoe UI Variable Display, Inter, system-ui</FontFamily>
                            <FontWeight x:Key="TitleLargeFontWeight">600</FontWeight>
                            <FontWeight x:Key="TitleMediumFontWeight">600</FontWeight>
                            <FontFamily x:Key="BodySmallFontFamily">Cascadia Code, JetBrains Mono, Consolas, monospace</FontFamily>
                            <FontFamily x:Key="LabelSmallFontFamily">Cascadia Code, JetBrains Mono, Consolas, monospace</FontFamily>
                            <x:Double x:Key="LabelSmallFontSize">11</x:Double>
                            <FontWeight x:Key="LabelMediumFontWeight">500</FontWeight>
                        </ResourceDictionary>
                    </utus:SimpleToolkitTheme.FontOverrideDictionary>
                </utus:SimpleToolkitTheme>
            </ResourceDictionary.MergedDictionaries>

            <!-- Slightly rounder corners than the Simple defaults, app-wide -->
            <CornerRadius x:Key="ControlCornerRadiusSmall">6</CornerRadius>
            <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">20</CornerRadius>

        </ResourceDictionary>
    </Application.Resources>

</Application>
