<Page x:Class="ClaudeCodeTracker.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="Root">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Padding="20,16,20,24">

                <!-- Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Style="{StaticResource HeadlineMedium}"
                                   Foreground="{ThemeResource OnBackgroundBrush}"
                                   Text="Claude Code Tracker" />
                        <TextBlock Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   Text="{Binding PeriodLabel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   Text="{Binding ResetWindowLabel}" />
                        <TextBlock Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource PrimaryBrush}"
                                   Text="{Binding ResetCountdown}" />
                    </StackPanel>
                </Grid>

                <!-- Budget progress card -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Style="{StaticResource LabelMedium}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   Text="Monthly Budget" />
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Style="{StaticResource TitleLarge}"
                                                       Foreground="{ThemeResource PrimaryBrush}">
                                                <Run Text="$" /><Run Text="{Binding TotalCostUsd}" />
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource BodyMedium}"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                <Run Text="/ $" /><Run Text="{Binding BudgetLimitUsd}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Style="{StaticResource TitleMedium}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource OnSurfaceBrush}">
                                            <Run Text="{Binding BudgetUsedPercent}" /><Run Text="%" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   Text="used" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding BudgetUsedPercent}"
                                             Maximum="100"
                                             HorizontalAlignment="Stretch"
                                             Height="8" />
                                <!-- vs last month indicator -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE74A;"
                                              FontSize="11"
                                              Foreground="{ThemeResource ErrorBrush}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource ErrorBrush}">
                                        <Run Text="+"/><Run Text="{Binding BudgetVsLastMonth}" /><Run Text="% vs last month" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- KPI stat row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total tokens -->
                    <utu:CardContentControl Grid.Column="0"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE9D9;"
                                              FontSize="18"
                                              Foreground="{ThemeResource SecondaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding TotalTokens}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Total Tokens" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Sessions -->
                    <utu:CardContentControl Grid.Column="2"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE8BD;"
                                              FontSize="18"
                                              Foreground="{ThemeResource TertiaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding TotalSessions}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Sessions" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Active days -->
                    <utu:CardContentControl Grid.Column="4"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE787;"
                                              FontSize="18"
                                              Foreground="{ThemeResource PrimaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding ActiveDays}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Active Days" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                </Grid>

                <!-- Model breakdown -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <TextBlock Style="{StaticResource TitleSmall}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           Text="Model Usage" />
                                <ItemsRepeater ItemsSource="{Binding ModelBreakdown}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="10" Orientation="Vertical" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Style="{StaticResource LabelMedium}"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               Text="{Binding ModelDisplayName}"
                                                               Width="160" />
                                                    <TextBlock Grid.Column="2"
                                                               Style="{StaticResource LabelSmall}"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                        <Run Text="$" /><Run Text="{Binding TotalCostUsd}" />
                                                    </TextBlock>
                                                </Grid>
                                                <ProgressBar Value="{Binding SharePercent}"
                                                             Maximum="100"
                                                             HorizontalAlignment="Stretch"
                                                             Height="6" />
                                                <TextBlock Style="{StaticResource LabelSmall}"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                    <Run Text="{Binding SessionCount}" /><Run Text=" sessions · " /><Run Text="{Binding SharePercent}" /><Run Text="% of tokens" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Recent sessions -->
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource TitleSmall}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               Text="Recent Sessions" />
                    <ItemsRepeater ItemsSource="{Binding RecentSessions}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Content="{Binding}"
                                                        Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch">
                                    <utu:CardContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="3">
                                                    <TextBlock Style="{StaticResource LabelMedium}"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               Text="{Binding ProjectName}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource SecondaryBrush}"
                                                                   Text="{Binding ModelDisplayName}" />
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                                   Text="&#xB7;" />
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                            <Run Text="{Binding DurationMinutes}" /><Run Text=" min" />
                                                        </TextBlock>
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                                   Text="&#xB7;" />
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                            <Run Text="{Binding MessageCount}" /><Run Text=" msgs" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Style="{StaticResource LabelMedium}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{ThemeResource PrimaryBrush}">
                                                        <Run Text="$" /><Run Text="{Binding CostUsd}" />
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource LabelSmall}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                        <Run Text="{Binding InputTokens}" /><Run Text=" in" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </utu:CardContentControl.ContentTemplate>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
