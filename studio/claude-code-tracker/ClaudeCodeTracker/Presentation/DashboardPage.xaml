<Page x:Class="ClaudeCodeTracker.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="Root" utu:SafeArea.Insets="Top">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20"
                        Padding="20,16,20,24"
                        MaxWidth="1100"
                        HorizontalAlignment="Stretch">

                <!-- Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock
                                   Style="{StaticResource TitleLarge}"
                                   Foreground="{ThemeResource OnBackgroundBrush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Left"
                                   Text="Claude Code Tracker" />
                        <TextBlock Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   Text="{Binding PeriodLabel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="2"
                                Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}">
                        <TextBlock Style="{StaticResource LabelSmall}"
                                   HorizontalAlignment="Right"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   Text="{Binding ResetWindowLabel}" />
                        <TextBlock Style="{StaticResource LabelSmall}"
                                   HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryBrush}"
                                   Text="{Binding ResetCountdown}" />
                    </StackPanel>
                </Grid>

                <!-- Budget progress card -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock
                                                   Style="{StaticResource LabelMedium}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   Text="Monthly Budget" />
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Style="{StaticResource TitleLarge}"
                                                       Foreground="{ThemeResource PrimaryBrush}"
                                                       Text="{Binding TotalCostDisplay}" />
                                            <TextBlock Style="{StaticResource BodyMedium}"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                <Run Text="/ " /><Run Text="{Binding BudgetLimitDisplay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Style="{StaticResource TitleMedium}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   Text="{Binding BudgetUsedDisplay}" />
                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   Text="used" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding BudgetUsedPercent}"
                                             Maximum="100"
                                             HorizontalAlignment="Stretch"
                                             Height="8" />
                                <!-- vs last month indicator: two {ThemeResource}-tinted variants
                                     toggled by the trend flag so the colour re-themes on a theme
                                     switch (up = over last month/Error, down = under/Secondary) -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="{Binding TrendGlyph}"
                                              FontSize="11"
                                              Foreground="{ThemeResource ErrorBrush}"
                                              Visibility="{Binding TrendUpVisibility}" />
                                    <FontIcon Glyph="{Binding TrendGlyph}"
                                              FontSize="11"
                                              Foreground="{ThemeResource SecondaryBrush}"
                                              Visibility="{Binding TrendDownVisibility}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource ErrorBrush}"
                                               Text="{Binding TrendDeltaDisplay}"
                                               Visibility="{Binding TrendUpVisibility}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource SecondaryBrush}"
                                               Text="{Binding TrendDeltaDisplay}"
                                               Visibility="{Binding TrendDownVisibility}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- KPI stat row: 4-across on wide, 2x2 on narrow -->
                <Grid ColumnSpacing="8" RowSpacing="{utu:Responsive Narrow=8, Wide=0}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total tokens -->
                    <utu:CardContentControl Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE9D9;"
                                              FontSize="18"
                                              HorizontalAlignment="Left"
                                              Foreground="{ThemeResource SecondaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding TotalTokensDisplay}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Total Tokens" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Sessions -->
                    <utu:CardContentControl Grid.Row="0"
                                            Grid.Column="{utu:Responsive Narrow=2, Wide=1}"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE8BD;"
                                              FontSize="18"
                                              HorizontalAlignment="Left"
                                              Foreground="{ThemeResource TertiaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding TotalSessionsDisplay}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Sessions" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Active days -->
                    <utu:CardContentControl Grid.Row="{utu:Responsive Narrow=1, Wide=0}"
                                            Grid.Column="{utu:Responsive Narrow=0, Wide=2}"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE787;"
                                              FontSize="18"
                                              HorizontalAlignment="Left"
                                              Foreground="{ThemeResource PrimaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding ActiveDaysDisplay}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Active Days" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Avg cost / session -->
                    <utu:CardContentControl Grid.Row="{utu:Responsive Narrow=1, Wide=0}"
                                            Grid.Column="{utu:Responsive Narrow=2, Wide=3}"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <FontIcon Glyph="&#xE8EF;"
                                              FontSize="18"
                                              HorizontalAlignment="Left"
                                              Foreground="{ThemeResource SecondaryBrush}" />
                                    <TextBlock Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="{Binding AvgCostDisplay}" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Avg / Session" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                </Grid>

                <!-- Model breakdown -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <TextBlock
                                           Style="{StaticResource TitleSmall}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           Text="Model Usage" />
                                <ItemsRepeater ItemsSource="{Binding ModelBreakdown}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="10" Orientation="Vertical" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Style="{StaticResource LabelMedium}"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               Text="{Binding ModelDisplayName}"
                                                               Width="160" />
                                                    <TextBlock Grid.Column="2"
                                                               Style="{StaticResource LabelSmall}"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                               Text="{Binding TotalCostDisplay}" />
                                                </Grid>
                                                <ProgressBar Value="{Binding SharePercent}"
                                                             Maximum="100"
                                                             HorizontalAlignment="Stretch"
                                                             Height="6" />
                                                <TextBlock Style="{StaticResource LabelSmall}"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                    <Run Text="{Binding SessionCount}" /><Run Text=" sessions · " /><Run Text="{Binding SharePercentDisplay}" /><Run Text="% of tokens" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Recent sessions -->
                <StackPanel Spacing="8">
                    <TextBlock
                               Style="{StaticResource TitleSmall}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               Text="Recent Sessions" />
                    <ItemsRepeater ItemsSource="{Binding RecentSessions}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Content="{Binding}"
                                                        Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        IsClickable="False"
                                                        HorizontalAlignment="Stretch">
                                    <utu:CardContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="3">
                                                    <TextBlock Style="{StaticResource LabelMedium}"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding ProjectName}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource SecondaryBrush}"
                                                                   Text="{Binding ModelDisplayName}" />
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                                   Text="&#xB7;" />
                                                        <TextBlock Style="{StaticResource LabelSmall}"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                            <Run Text="{Binding DurationMinutes}" /><Run Text=" min" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Style="{StaticResource LabelMedium}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{ThemeResource PrimaryBrush}"
                                                               Text="{Binding CostDisplay}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                               Text="{Binding StartedAtDisplay}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </utu:CardContentControl.ContentTemplate>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
