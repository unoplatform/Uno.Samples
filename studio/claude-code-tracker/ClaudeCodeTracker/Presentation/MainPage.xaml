<Page x:Class="ClaudeCodeTracker.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <!--
        Navigation shell. Owns the chrome once for the whole app: a NavigationView pane on wide
        layouts and a bottom TabBar on narrow ones. Responsive switching is driven by the Toolkit
        {utu:Responsive} extension on each property (never AdaptiveTrigger/VisualState) so it
        applies reliably to this navigation-injected page and stays consistent with the content
        pages' Narrow/Wide breakpoints. The content region is left empty — Uno.Extensions
        Navigation injects the active route (Dashboard / Sessions / Usage / Charts) into it.
    -->
    <Grid uen:Region.Attached="True">
        <!--
            Responsive shell pane: an expanded, labeled NavigationView pane on wide, hidden in
            favor of the bottom TabBar on narrow — switched by {utu:Responsive} against the
            app-wide DefaultResponsiveLayout breakpoint declared in App.xaml. That resource is
            required for the extension to resolve correctly (including in Studio Web / Hot Design);
            Wide=Left (not Auto) keeps the pane expanded with labels rather than dropping to the
            icon-only compact band on mid-width desktops.
        -->
        <NavigationView x:Name="NavView"
                        uen:Region.Attached="True"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="{utu:Responsive Narrow=LeftMinimal, Wide=Left}"
                        IsPaneToggleButtonVisible="{utu:Responsive Narrow=False, Wide=True}"
                        IsPaneOpen="{utu:Responsive Narrow=False, Wide=True}">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="Dashboard_NavItem" uen:Region.Name="Dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Sessions_NavItem" uen:Region.Name="Sessions" Content="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Usage_NavItem" uen:Region.Name="Usage" Content="Usage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="Charts_NavItem" uen:Region.Name="Charts" Content="Charts">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Shared content area: Navigation injects the active page here -->
                    <Grid Grid.Row="0"
                          uen:Region.Attached="True"
                          uen:Region.Navigator="Visibility" />

                    <!-- Bottom TabBar: shown on narrow, hidden on wide -->
                    <utu:TabBar x:Name="BottomTabs"
                                Grid.Row="1"
                                uen:Region.Attached="True"
                                Style="{StaticResource BottomTabBarStyle}"
                                Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}">
                        <utu:TabBarItem x:Uid="Dashboard_NavItem" uen:Region.Name="Dashboard" Content="Dashboard">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE80F;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                        <utu:TabBarItem x:Uid="Sessions_NavItem" uen:Region.Name="Sessions" Content="Sessions">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE8FD;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                        <utu:TabBarItem x:Uid="Usage_NavItem" uen:Region.Name="Usage" Content="Usage">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE9D2;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                        <utu:TabBarItem x:Uid="Charts_NavItem" uen:Region.Name="Charts" Content="Charts">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE9D9;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                    </utu:TabBar>
                </Grid>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
