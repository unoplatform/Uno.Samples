<Page x:Class="ClaudeCodeTracker.Presentation.UsagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="Root" utu:SafeArea.Insets="Top">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20"
                        Padding="20,16,20,24"
                        MaxWidth="1100"
                        HorizontalAlignment="Stretch">

                <!-- Header -->
                <StackPanel Spacing="2">
                    <TextBlock
                               Style="{StaticResource TitleLarge}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               Text="Usage &amp; Limits" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                            <Run Text="Plan: " /><Run Text="{Binding CurrentPlan}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="&#xB7;" />
                        <TextBlock Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding PlanDescription}" />
                    </StackPanel>
                </StackPanel>

                <!-- Cost summary row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <utu:CardContentControl Grid.Column="0" Style="{StaticResource FilledCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="Month-to-date" />
                                    <TextBlock Style="{StaticResource TitleMedium}" Foreground="{ThemeResource PrimaryBrush}" Text="{Binding TotalCostDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                    <utu:CardContentControl Grid.Column="1" Style="{StaticResource FilledCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="Daily avg" />
                                    <TextBlock Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="{Binding DailyCostAvgDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                    <utu:CardContentControl Grid.Column="2" Style="{StaticResource FilledCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Padding="12,10" Spacing="4">
                                    <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="Projected" />
                                    <TextBlock Style="{StaticResource TitleMedium}" Foreground="{ThemeResource TertiaryBrush}" Text="{Binding ProjectedMonthlyDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                </Grid>

                <!-- Token breakdown -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="14">
                                <TextBlock Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Token Breakdown" />

                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Input" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                            <Run Text="{Binding Tokens.InputTokensDisplay}" /><Run Text=" tokens · " /><Run Text="{Binding Tokens.InputPercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Tokens.InputPercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Output" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                            <Run Text="{Binding Tokens.OutputTokensDisplay}" /><Run Text=" tokens · " /><Run Text="{Binding Tokens.OutputPercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Tokens.OutputPercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Cache Read" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                            <Run Text="{Binding Tokens.CacheReadTokensDisplay}" /><Run Text=" tokens · " /><Run Text="{Binding Tokens.CacheReadPercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Tokens.CacheReadPercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Cache Write" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                            <Run Text="{Binding Tokens.CacheWriteTokensDisplay}" /><Run Text=" tokens · " /><Run Text="{Binding Tokens.CacheWritePercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Tokens.CacheWritePercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Rate limits -->
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" Text="Rate Limits" />
                    <ItemsRepeater ItemsSource="{Binding RateLimits}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Content="{Binding}" Style="{StaticResource ElevatedCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                                    <utu:CardContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="14,12" Spacing="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <TextBlock Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="{Binding LimitType}" />
                                                        <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding Description}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="1">
                                                        <TextBlock Style="{StaticResource LabelMedium}" HorizontalAlignment="Right" Foreground="{ThemeResource OnSurfaceBrush}">
                                                            <Run Text="{Binding UsedPercent}" /><Run Text="%" />
                                                        </TextBlock>
                                                        <TextBlock Style="{StaticResource LabelSmall}" HorizontalAlignment="Right" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding ResetIn}" />
                                                    </StackPanel>
                                                </Grid>
                                                <ProgressBar Value="{Binding UsedPercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </utu:CardContentControl.ContentTemplate>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Per-model usage & cost -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <TextBlock Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Model Usage &amp; Cost" />
                                <ItemsRepeater ItemsSource="{Binding ModelBreakdown}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="10" Orientation="Vertical" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" Text="{Binding ModelDisplayName}" Width="160" />
                                                    <TextBlock Grid.Column="2" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding TotalCostDisplay}" />
                                                </Grid>
                                                <ProgressBar Value="{Binding SharePercent}" Maximum="100" HorizontalAlignment="Stretch" Height="6" />
                                                <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                    <Run Text="{Binding SessionCount}" /><Run Text=" sessions · " /><Run Text="{Binding SharePercentDisplay}" /><Run Text="% of tokens" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Model pricing reference -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" IsClickable="False" HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <TextBlock Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" Text="Model Pricing Reference" />
                                <StackPanel Spacing="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="Model" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" Text="Input/1M" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" Text="Output/1M" />
                                    </Grid>
                                    <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" Margin="0,4" />
                                </StackPanel>
                                <ItemsRepeater ItemsSource="{Binding ModelPricing}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="10" Orientation="Vertical" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" Text="{Binding DisplayName}" />
                                                    <TextBlock Grid.Column="1" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource PrimaryBrush}" HorizontalAlignment="Right" Text="{Binding InputPriceDisplay}" />
                                                    <TextBlock Grid.Column="2" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource SecondaryBrush}" HorizontalAlignment="Right" Text="{Binding OutputPriceDisplay}" />
                                                </Grid>
                                                <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                    <Run Text="Cache " /><Run Text="{Binding CacheReadPriceDisplay}" /><Run Text=" read · " /><Run Text="{Binding CacheWritePriceDisplay}" /><Run Text=" write / 1M" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
