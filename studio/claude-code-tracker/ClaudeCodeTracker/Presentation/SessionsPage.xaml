<Page x:Class="ClaudeCodeTracker.Presentation.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="Root" utu:SafeArea.Insets="Top,SoftInput">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title, search, model filter chips -->
        <StackPanel Grid.Row="0"
                    Padding="20,16,20,12"
                    Spacing="12"
                    Background="{ThemeResource SurfaceVariantBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock
                               Style="{StaticResource TitleLarge}"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               Text="Sessions" />
                    <TextBlock Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               Text="{Binding TotalCountDisplay}" />
                </StackPanel>
                <FontIcon Grid.Column="1"
                          Glyph="&#xE721;"
                          FontSize="20"
                          VerticalAlignment="Center"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          AutomationProperties.AccessibilityView="Raw" />
            </Grid>

            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search sessions by name…"
                     HorizontalAlignment="Stretch"
                     TextChanged="SearchBox_TextChanged" />

            <utu:ChipGroup x:Name="ModelFilter"
                           SelectionMode="Single"
                           ItemsSource="{Binding FilterOptions}"
                           Style="{StaticResource FilterChipGroupStyle}"
                           ItemChecked="ModelFilter_ItemChecked" />
        </StackPanel>

        <!-- Session list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="SessionList" Margin="16,12,16,24">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="8" Orientation="Vertical" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <utu:CardContentControl Content="{Binding}"
                                                Style="{StaticResource ElevatedCardContentControlStyle}"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="Session entry"
                                                uen:Navigation.Request="SessionDetail"
                                                uen:Navigation.Data="{Binding}">
                            <utu:CardContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Grid Padding="14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock Style="{StaticResource LabelMedium}"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding ProjectName}" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Background="{ThemeResource SecondaryContainerBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock Style="{StaticResource LabelSmall}"
                                                               Foreground="{ThemeResource OnSecondaryContainerBrush}"
                                                               Text="{Binding ModelDisplayName}" />
                                                </Border>
                                                <TextBlock Style="{StaticResource LabelSmall}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                           Text="&#xB7;" />
                                                <TextBlock Style="{StaticResource LabelSmall}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                    <Run Text="{Binding DurationMinutes}" /><Run Text=" min" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Style="{StaticResource LabelMedium}"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{ThemeResource PrimaryBrush}"
                                                       Text="{Binding CostDisplay}" />
                                            <TextBlock Style="{StaticResource LabelSmall}"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       Text="{Binding StartedAtDisplay}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </utu:CardContentControl.ContentTemplate>
                        </utu:CardContentControl>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Empty state when search/filter excludes every session -->
        <TextBlock x:Name="EmptyState"
                   Grid.Row="1"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center"
                   Margin="0,48,0,0"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   Style="{StaticResource BodyMedium}"
                   Text="No sessions match your search" />
    </Grid>
</Page>
