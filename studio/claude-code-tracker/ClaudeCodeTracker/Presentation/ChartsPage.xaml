<Page x:Class="ClaudeCodeTracker.Presentation.ChartsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      xmlns:conv="using:ClaudeCodeTracker.Converters"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush" />
    </Page.Resources>

    <Grid x:Name="Root" utu:SafeArea.Insets="Top">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20"
                        Padding="20,16,20,24"
                        MaxWidth="1100"
                        HorizontalAlignment="Stretch">

                <!-- Header -->
                <StackPanel Spacing="2">
                    <TextBlock
                               Style="{StaticResource TitleLarge}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               Text="Charts" />
                    <TextBlock Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               Text="{Binding PeriodLabel}" />
                </StackPanel>

                <!-- Daily cost line chart -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                               Style="{StaticResource TitleSmall}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="Daily Cost Trend" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="USD spent per day over the last 14 days" />
                                </StackPanel>
                                <Grid Height="200">
                                    <lvc:CartesianChart Series="{Binding DailyCostSeries}"
                                                        XAxes="{Binding DailyCostXAxes}"
                                                        YAxes="{Binding DailyCostYAxes}"
                                                        LegendPosition="Hidden"
                                                        AutomationProperties.Name="Daily cost trend chart" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Weekly sessions bar chart -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <utu:CardContentControl.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Padding="16" Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                               Style="{StaticResource TitleSmall}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="Sessions Per Day" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Number of Claude Code sessions per day this week" />
                                </StackPanel>
                                <Grid Height="180">
                                    <lvc:CartesianChart Series="{Binding WeeklySessionsSeries}"
                                                        XAxes="{Binding WeeklySessionsXAxes}"
                                                        YAxes="{Binding WeeklySessionsYAxes}"
                                                        LegendPosition="Hidden"
                                                        AutomationProperties.Name="Sessions per day chart" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </utu:CardContentControl.ContentTemplate>
                </utu:CardContentControl>

                <!-- Donut charts row: two-up on Wide, stacked on Narrow -->
                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Token type donut -->
                    <utu:CardContentControl Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Margin="16" Spacing="2">
                                    <TextBlock
                                               Style="{StaticResource TitleSmall}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="Token Types" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Breakdown of token usage by type" />
                                    <!-- Fixed height so both donuts draw identically; legend is custom below -->
                                    <lvc:PieChart Series="{Binding TokenTypeSeries}"
                                                  LegendPosition="Hidden"
                                                  InitialRotation="-90"
                                                  Height="200"
                                                  Margin="0,8,0,0"
                                                  AutomationProperties.Name="Token type breakdown chart" />
                                    <ItemsRepeater ItemsSource="{Binding TokenTypeLegend}" Margin="0,12,0,0">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="130" MinColumnSpacing="8" MinRowSpacing="6" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{Binding Swatch, Converter={StaticResource ColorToBrush}}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}" VerticalAlignment="Center" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding Label}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}" VerticalAlignment="Center" Foreground="{ThemeResource OnSurfaceBrush}" Text="{Binding ValueDisplay}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>

                    <!-- Model share donut -->
                    <utu:CardContentControl Grid.Row="{utu:Responsive Narrow=1, Wide=0}"
                                            Grid.Column="{utu:Responsive Narrow=0, Wide=1}"
                                            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                            Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Margin="16" Spacing="2">
                                    <TextBlock
                                               Style="{StaticResource TitleSmall}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Text="Model Share" />
                                    <TextBlock Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Text="Token share by Claude model" />
                                    <lvc:PieChart Series="{Binding ModelShareSeries}"
                                                  LegendPosition="Hidden"
                                                  InitialRotation="-90"
                                                  Height="200"
                                                  Margin="0,8,0,0"
                                                  AutomationProperties.Name="Model token share chart" />
                                    <ItemsRepeater ItemsSource="{Binding ModelShareLegend}" Margin="0,12,0,0">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="130" MinColumnSpacing="8" MinRowSpacing="6" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{Binding Swatch, Converter={StaticResource ColorToBrush}}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}" VerticalAlignment="Center" Foreground="{ThemeResource OnSurfaceVariantBrush}" Text="{Binding Label}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}" VerticalAlignment="Center" Foreground="{ThemeResource OnSurfaceBrush}" Text="{Binding ValueDisplay}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
