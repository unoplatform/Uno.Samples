<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Color x:Key="PrimaryColor">#1A6B72</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#C8EEF1</Color>
			<Color x:Key="OnPrimaryContainerColor">#001F24</Color>
			<Color x:Key="SecondaryColor">#A0724A</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#F5DEC8</Color>
			<Color x:Key="OnSecondaryContainerColor">#2B1500</Color>
			<Color x:Key="TertiaryColor">#C96B5A</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#FFD9D2</Color>
			<Color x:Key="OnTertiaryContainerColor">#3B0905</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<Color x:Key="SurfaceColor">#F5FAFB</Color>
			<Color x:Key="OnSurfaceColor">#161D1E</Color>
			<Color x:Key="SurfaceVariantColor">#DCE8EA</Color>
			<Color x:Key="OnSurfaceVariantColor">#3F5052</Color>
