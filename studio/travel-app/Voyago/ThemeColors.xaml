<?xml version="1.0" encoding="utf-8"?>
<!--
  Voyago palette — "dusk / twilight travel".
  Violet-indigo primary keyed to the brand mark's lilac gradient (#B685FF→#E7A3FF),
  a warm amber secondary for prices/CTAs, and a soft rose tertiary. Neutrals are tinted
  cool-violet. Light: white cards lift off a faintly-violet page. Default (dark): a deep
  dusk close to the #151515 icon tile with luminous lilac accents. Distinct per theme (lesson 25).
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Color x:Key="PrimaryColor">#6541C6</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#E7DDFF</Color>
			<Color x:Key="OnPrimaryContainerColor">#1F0364</Color>
			<Color x:Key="SecondaryColor">#8A5A12</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#FBE1B4</Color>
			<Color x:Key="OnSecondaryContainerColor">#2B1700</Color>
			<Color x:Key="TertiaryColor">#A8436A</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#FFD9E3</Color>
			<Color x:Key="OnTertiaryContainerColor">#3C0723</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<Color x:Key="ErrorContainerColor">#FFDAD6</Color>
			<Color x:Key="OnErrorContainerColor">#410002</Color>
			<Color x:Key="BackgroundColor">#F5F1FB</Color>
			<Color x:Key="OnBackgroundColor">#1B1725</Color>
			<Color x:Key="SurfaceColor">#FFFFFF</Color>
			<Color x:Key="OnSurfaceColor">#1B1725</Color>
			<Color x:Key="SurfaceVariantColor">#EBE4F5</Color>
			<Color x:Key="OnSurfaceVariantColor">#4A4458</Color>
			<Color x:Key="OutlineColor">#7A7488</Color>
			<Color x:Key="OutlineVariantColor">#CEC6DC</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<Color x:Key="PrimaryColor">#C9B0FF</Color>
			<Color x:Key="OnPrimaryColor">#33146F</Color>
			<Color x:Key="PrimaryContainerColor">#4B3391</Color>
			<Color x:Key="OnPrimaryContainerColor">#E9DDFF</Color>
			<Color x:Key="SecondaryColor">#EEC069</Color>
			<Color x:Key="OnSecondaryColor">#3F2E00</Color>
			<Color x:Key="SecondaryContainerColor">#5B4300</Color>
			<Color x:Key="OnSecondaryContainerColor">#FBE1B4</Color>
			<Color x:Key="TertiaryColor">#FFB1C9</Color>
			<Color x:Key="OnTertiaryColor">#5E1138</Color>
			<Color x:Key="TertiaryContainerColor">#7C2C4F</Color>
			<Color x:Key="OnTertiaryContainerColor">#FFD9E3</Color>
			<Color x:Key="ErrorColor">#FFB4AB</Color>
			<Color x:Key="OnErrorColor">#690005</Color>
			<Color x:Key="ErrorContainerColor">#93000A</Color>
			<Color x:Key="OnErrorContainerColor">#FFDAD6</Color>
			<Color x:Key="BackgroundColor">#131019</Color>
			<Color x:Key="OnBackgroundColor">#E9E0F3</Color>
			<Color x:Key="SurfaceColor">#1D1926</Color>
			<Color x:Key="OnSurfaceColor">#E9E0F3</Color>
			<Color x:Key="SurfaceVariantColor">#2A2438</Color>
			<Color x:Key="OnSurfaceVariantColor">#CBC2DC</Color>
			<Color x:Key="OutlineColor">#948CA6</Color>
			<Color x:Key="OutlineVariantColor">#453F54</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
