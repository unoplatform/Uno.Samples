			<Color x:Key="OnBackgroundColor">#161D1E</Color>
			<Color x:Key="OutlineColor">#6F8A8C</Color>
			<Color x:Key="OutlineVariantColor">#BED0D2</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<Color x:Key="PrimaryColor">#4ECBD4</Color>
			<Color x:Key="OnPrimaryColor">#003739</Color>
			<Color x:Key="PrimaryContainerColor">#004F56</Color>
			<Color x:Key="OnPrimaryContainerColor">#A2ECF0</Color>
