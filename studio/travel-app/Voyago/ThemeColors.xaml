			<Color x:Key="OnSurfaceColor">#CDE8EA</Color>
			<Color x:Key="SurfaceVariantColor">#1E3032</Color>
			<Color x:Key="OnSurfaceVariantColor">#9DBDBF</Color>
			<Color x:Key="BackgroundColor">#080F10</Color>
			<Color x:Key="OnBackgroundColor">#CDE8EA</Color>
			<Color x:Key="OutlineColor">#537678</Color>
			<Color x:Key="OutlineVariantColor">#2B4042</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
