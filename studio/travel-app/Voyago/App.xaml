<Application x:Class="Voyago.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple">

  <!-- Thin manifest: only merges, defines no keys of its own (lesson 56).
       Styles.xaml is merged LAST so its well-known token overrides
       (ControlCornerRadius*, OverlayCornerRadius) win over the theme defaults. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utus:SimpleToolkitTheme ColorOverrideSource="ms-appx:///ThemeColors.xaml">
          <utus:SimpleToolkitTheme.FontOverrideDictionary>
            <ResourceDictionary>
              <!-- Brand base face for all control text (Plus Jakarta Sans). Per-role weights
                   are applied via the Styles.xaml type ramp using static per-weight files. -->
              <FontFamily x:Key="SimpleFontFamily">ms-appx:///Assets/Fonts/PlusJakartaSans-Regular.ttf#Plus Jakarta Sans</FontFamily>
            </ResourceDictionary>
          </utus:SimpleToolkitTheme.FontOverrideDictionary>
        </utus:SimpleToolkitTheme>
        <ResourceDictionary Source="ms-appx:///ControlThemeOverrides.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
