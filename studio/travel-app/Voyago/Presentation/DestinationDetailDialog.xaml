<ContentDialog x:Class="Voyago.Presentation.DestinationDetailDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:local="using:Voyago.Presentation"
               xmlns:uen="using:Uno.Extensions.Navigation.UI"
               xmlns:utu="using:Uno.Toolkit.UI"
               FullSizeDesired="True">

    <!-- Strip the default ContentDialog chrome so it acts as a transparent, full-window host: the
         smoke layer dims the shell behind (true modal), and the card below defines the surface. On
         phones the card fills the window; on wide it's a centred two-column panel. -->
    <ContentDialog.Resources>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
        <Thickness x:Key="ContentDialogBorderWidth">0</Thickness>
        <x:Double x:Key="ContentDialogMinWidth">0</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">0</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">100000</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">100000</x:Double>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="Transparent" />
    </ContentDialog.Resources>

    <Border HorizontalAlignment="{utu:Responsive Narrow=Stretch, Wide=Center}"
            VerticalAlignment="{utu:Responsive Narrow=Stretch, Wide=Center}"
            MaxWidth="{utu:Responsive Narrow=100000, Wide=1040}"
            MaxHeight="{utu:Responsive Narrow=100000, Wide=560}"
            Background="{ThemeResource BackgroundBrush}"
            CornerRadius="{utu:Responsive Narrow=0, Wide=24}">
        <Grid>
            <!-- Phone / narrow: hero on top, details below, single scrolling column -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}">
                <StackPanel>
                    <Border Height="320">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                        </Border.Background>
                        <Grid>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0.35" EndPoint="0.5,1">
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#B3000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <StackPanel VerticalAlignment="Bottom" Padding="24,0,24,24" Spacing="6">
                                <TextBlock Text="{Binding Name}" Style="{StaticResource DisplayMedium}" Foreground="White" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                        <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=location}" Fill="White" Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Country}" Style="{StaticResource BodyLarge}" Foreground="#E6FFFFFF" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <local:DestinationInfoPanel />
                </StackPanel>
            </ScrollViewer>

            <!-- Wide: hero fills the left column, details scroll on the right -->
            <Grid Width="1040" Height="560"
                  Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="440" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="24,0,0,24">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                    </Border.Background>
                    <Grid>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0.5,0.4" EndPoint="0.5,1">
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#B3000000" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel VerticalAlignment="Bottom" Padding="24,0,24,28" Spacing="6">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource DisplayMedium}" Foreground="White" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=location}" Fill="White" Stretch="Uniform" />
                                </Viewbox>
                                <TextBlock Text="{Binding Country}" Style="{StaticResource BodyLarge}" Foreground="#E6FFFFFF" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalAlignment="Center">
                    <local:DestinationInfoPanel />
                </ScrollViewer>
            </Grid>

            <!-- Close: navigates back, which dismisses the dialog. -->
            <Grid utu:SafeArea.Insets="Top" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="12,12,0,0">
                <Button Style="{StaticResource IconButtonStyle}"
                        Background="#59000000"
                        Foreground="White"
                        uen:Navigation.Request="-"
                        AutomationProperties.Name="Back">
                    <Viewbox Width="18" Height="18">
                        <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=arrow_left}" Fill="White" Stretch="Uniform" />
                    </Viewbox>
                </Button>
            </Grid>
        </Grid>
    </Border>
</ContentDialog>
