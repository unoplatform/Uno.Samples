<Page x:Class="Voyago.Presentation.DestinationDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <!-- Detail reads as a centred column on desktop; full-bleed hero on phones -->
            <Grid MaxWidth="720" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Hero: full-bleed image with a bottom scrim and the destination name overlaid -->
                <Grid Grid.Row="0" Height="{utu:Responsive Narrow=320, Wide=400}">
                    <Border>
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0.5,0.35" EndPoint="0.5,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#B3000000" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <StackPanel VerticalAlignment="Bottom" Padding="24,0,24,24" Spacing="6">
                        <TextBlock Text="{Binding Name}" Style="{StaticResource DisplayMedium}" Foreground="White" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=location}" Fill="White" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="{Binding Country}" Style="{StaticResource BodyLarge}" Foreground="#E6FFFFFF" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Content -->
                <StackPanel Grid.Row="1" Padding="24,22,24,32" Spacing="22">

                    <!-- Rating -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                            <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource SecondaryBrush}" Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="{Binding Rating}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReviewsText}" Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding Tagline}" Style="{StaticResource BodyLarge}" Foreground="{ThemeResource OnBackgroundBrush}" TextWrapping="Wrap" />

                    <!-- Highlights -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="WHY YOU'LL LOVE IT" Style="{StaticResource SectionLabel}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="12,14">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <Viewbox Width="22" Height="22"><Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" /></Viewbox>
                                    <TextBlock Text="Top rated" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="12,14">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <Viewbox Width="22" Height="22"><Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=calendar}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" /></Viewbox>
                                    <TextBlock Text="Flexible dates" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="12,14">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <Viewbox Width="22" Height="22"><Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=compass}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" /></Viewbox>
                                    <TextBlock Text="Guided tours" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource HairlineBrush}" />

                    <!-- Price + book CTA -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Starting from" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            <TextBlock Text="{Binding PriceFrom}" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Book this trip"
                                Command="{Binding Book}"
                                AutomationProperties.Name="Book this trip"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsBooked, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        <Border Grid.Column="1"
                                Background="{ThemeResource PrimaryContainerBrush}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                Padding="18,12"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsBooked, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Viewbox Width="18" Height="18" VerticalAlignment="Center"><Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=heart_filled}" Fill="{ThemeResource OnPrimaryContainerBrush}" Stretch="Uniform" /></Viewbox>
                                <TextBlock Text="Booked" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnPrimaryContainerBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Fixed back button, clear of the notch (SafeArea top). Dark scrim circle for contrast. -->
        <Grid utu:SafeArea.Insets="Top" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="12,12,0,0">
            <Button Style="{StaticResource IconButtonStyle}"
                    Background="#59000000"
                    Foreground="White"
                    uen:Navigation.Request="-"
                    AutomationProperties.Name="Back">
                <PathIcon Data="{Binding Converter={StaticResource Icon}, ConverterParameter=arrow_left}" />
            </Button>
        </Grid>
    </Grid>
</Page>
