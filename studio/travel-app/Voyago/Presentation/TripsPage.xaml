<Page x:Class="Voyago.Presentation.TripsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource SurfaceBrush}" Padding="20,14" utu:SafeArea.Insets="Top">
            <TextBlock Text="My trips" Style="{StaticResource TitleLarge}" Foreground="{ThemeResource OnSurfaceBrush}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Padding="16,20,16,26" MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Stretch">

                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Viewbox Width="17" Height="17" VerticalAlignment="Center">
                            <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=calendar}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="Upcoming" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsRepeater ItemsSource="{Binding UpcomingTrips}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" HorizontalAlignment="Stretch" IsClickable="False">
                                    <Grid Height="108">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Padding="14,12" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Destination}" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnSurfaceBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                                    <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=location}" Fill="{ThemeResource OnSurfaceVariantBrush}" Stretch="Uniform" />
                                                </Viewbox>
                                                <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <Run Text="·" />
                                                    <Run Text="{Binding DepartureDate}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <ContentControl Content="{Binding Status}"
                                                            ContentTemplateSelector="{StaticResource TripStatusSelector}"
                                                            IsTabStop="False"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Spacing="12" Margin="0,28,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Viewbox Width="17" Height="17" VerticalAlignment="Center">
                            <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=history}" Fill="{ThemeResource OnSurfaceVariantBrush}" Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="Past trips" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsRepeater ItemsSource="{Binding PastTrips}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" HorizontalAlignment="Stretch" IsClickable="False">
                                    <Grid Height="86">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Padding="14,10" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Destination}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" />
                                            <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OutlineBrush}" Margin="0,2,0,0">
                                                <Run Text="Ref:" />
                                                <Run Text="{Binding BookingRef}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
