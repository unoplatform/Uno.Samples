<Page x:Class="Voyago.Presentation.FavoritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Background="{ThemeResource SurfaceBrush}"
              Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Favorites"
                       Style="{StaticResource TitleLarge}"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <!-- Count badge -->
            <Border Grid.Column="1"
                    Background="{ThemeResource PrimaryBrush}"
                    CornerRadius="12"
                    Padding="10,4"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding TotalFavorites}"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnPrimaryBrush}" />
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16,20,16,24" Spacing="16" MaxWidth="900" HorizontalAlignment="Center">

                <TextBlock Text="Your saved destinations"
                           Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />

                <!--
                    MinWidth matches UniformGridLayout.MinItemWidth so the repeater is never measured below one
                    item width; otherwise UniformGridLayout computes itemsPerLine = 0 and throws DivideByZeroException.
                -->
                <ItemsRepeater ItemsSource="{Binding SavedDestinations}" MinWidth="150">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="150"
                                           MinItemHeight="220"
                                           MinColumnSpacing="12"
                                           MinRowSpacing="12"
                                           MaximumRowsOrColumns="2"
                                           Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    IsClickable="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="130" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Photo with heart overlay -->
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}"
                                               Stretch="UniformToFill" />
                                        <!-- Heart badge top-right -->
                                        <Border Background="{ThemeResource SurfaceBrush}"
                                                CornerRadius="14"
                                                Width="28"
                                                Height="28"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,8,8,0">
                                            <FontIcon Glyph="&#xEB51;"
                                                      FontSize="13"
                                                      Foreground="{ThemeResource PrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <!-- Details -->
                                    <StackPanel Grid.Row="1"
                                                Padding="10,8,10,12"
                                                Spacing="3">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource TitleSmall}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Country}"
                                                   Style="{StaticResource BodySmall}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        <!-- Rating row -->
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                            <FontIcon Glyph="&#xE734;"
                                                      FontSize="11"
                                                      Foreground="{ThemeResource TertiaryBrush}" />
                                            <TextBlock Text="{Binding Rating}"
                                                       Style="{StaticResource LabelSmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding PriceFrom}"
                                                   Style="{StaticResource LabelSmall}"
                                                   Foreground="{ThemeResource PrimaryBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
