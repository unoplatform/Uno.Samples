<Page x:Class="Voyago.Presentation.FavoritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Voyago.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with saved-count badge -->
        <Grid Grid.Row="0" Background="{ThemeResource SurfaceBrush}" Padding="20,14" utu:SafeArea.Insets="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Favorites" Style="{StaticResource TitleLarge}" Foreground="{ThemeResource OnSurfaceBrush}" VerticalAlignment="Center" />
            <Border Grid.Column="1" Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="{StaticResource PillCornerRadius}" Padding="10,4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                        <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=heart_filled}" Fill="{ThemeResource OnPrimaryContainerBrush}" Stretch="Uniform" />
                    </Viewbox>
                    <TextBlock Text="{Binding TotalFavorites}" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnPrimaryContainerBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16,20,16,26" Spacing="14" MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Stretch" local:Motion.Stagger="True">

                <TextBlock Text="Your saved destinations" Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />

                <ItemsRepeater ItemsSource="{Binding SavedDestinations}" MinWidth="164">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="164" MinItemHeight="228" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                    HorizontalAlignment="Stretch" IsClickable="True"
                                                    uen:Navigation.Request="DestinationDetail"
                                                    uen:Navigation.Data="{Binding}"
                                                    AutomationProperties.Name="{Binding Name}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="138" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Border Background="{ThemeResource SurfaceBrush}" CornerRadius="15" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                                            <Viewbox Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=heart_filled}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" />
                                            </Viewbox>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Padding="12,9,12,11" Spacing="3">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                        <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,2,0,0">
                                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource SecondaryBrush}" Stretch="Uniform" />
                                            </Viewbox>
                                            <TextBlock Text="{Binding Rating}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding PriceFrom}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource SecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
