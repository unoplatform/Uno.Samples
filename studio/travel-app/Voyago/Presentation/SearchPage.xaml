<Page x:Class="Voyago.Presentation.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Voyago.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource SurfaceBrush}" Padding="20,14" utu:SafeArea.Insets="Top">
            <TextBlock Text="Search" Style="{StaticResource TitleLarge}" Foreground="{ThemeResource OnSurfaceBrush}"
                       MaxWidth="{StaticResource ContentMaxWidthWide}" HorizontalAlignment="Stretch" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" MaxWidth="{StaticResource ContentMaxWidthWide}" HorizontalAlignment="Stretch" local:Motion.Stagger="True">

                <StackPanel Padding="16,20,16,0" Spacing="18">
                    <!-- Search entry (visual affordance for the mock) -->
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="{StaticResource ControlCornerRadius}">
                        <Grid Padding="16,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=search}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="{Binding SearchPlaceholder}" Style="{StaticResource BodyLarge}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Popular searches" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled">
                            <ItemsRepeater ItemsSource="{Binding PopularSearches}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="{StaticResource PillCornerRadius}" Padding="14,7">
                                            <TextBlock Text="{Binding}" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>

                <StackPanel Padding="16,24,16,0" Spacing="12">
                    <TextBlock Text="Popular destinations" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding PopularDestinations}" MinWidth="164">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="{utu:Responsive Narrow=164, Wide=240}" MinItemHeight="228" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" IsClickable="True"
                                                        uen:Navigation.Request="DestinationDetail"
                                                        uen:Navigation.Data="{Binding}"
                                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="138" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Row="1" Padding="12,9,12,11" Spacing="3">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                            <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,2,0,0">
                                                <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                                    <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource SecondaryBrush}" Stretch="Uniform" />
                                                </Viewbox>
                                                <TextBlock Text="{Binding Rating}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Padding="16,24,16,26" Spacing="12">
                    <TextBlock Text="Browse by style" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding ExploreCategories}">
                        <ItemsRepeater.Layout>
                            <!-- One column on phones (720 > phone width), two per row on wide displays -->
                            <UniformGridLayout MinItemWidth="720" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        Height="{utu:Responsive Narrow=96, Wide=160}"
                                                        HorizontalAlignment="Stretch"
                                                        IsClickable="True"
                                                        uen:Navigation.Request="DestinationDetail"
                                                        uen:Navigation.Data="{Binding Featured}"
                                                        AutomationProperties.Name="{Binding Label}">
                                    <Grid>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <!-- Bottom-anchored scrim (matches the app's other image overlays) so the
                                             label + wrapping description stay legible over bright photos. -->
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#26000000" Offset="0" />
                                                    <GradientStop Color="#D9000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Bottom" Padding="16,0,16,12" Spacing="2">
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource TitleMedium}" Foreground="White" />
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource BodySmall}" Foreground="#E6FFFFFF" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
