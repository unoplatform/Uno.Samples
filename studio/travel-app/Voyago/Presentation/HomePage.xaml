<Page x:Class="Voyago.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Voyago.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{ThemeResource SurfaceBrush}" Padding="16,12" utu:SafeArea.Insets="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{ThemeResource PrimaryBrush}">
                <TextBlock Text="{Binding UserInitials}" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Grid.Column="1" Text="Voyago" FontWeight="Bold" FontSize="22" Foreground="{ThemeResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" CharacterSpacing="20" />
            <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Notifications">
                <PathIcon Data="{Binding Converter={StaticResource Icon}, ConverterParameter=alert}" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Stretch" Spacing="0" local:Motion.Stagger="True">

                <!-- Greeting + search entry -->
                <StackPanel Padding="16,24,16,0" Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="WELCOME BACK" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding GreetingText}" Style="{StaticResource HeadlineMedium}" Foreground="{ThemeResource OnBackgroundBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" HorizontalAlignment="Stretch"
                                            IsClickable="True" uen:Navigation.Request="Search"
                                            AutomationProperties.Name="Search destinations, flights and hotels">
                        <Grid Padding="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=search}" Fill="{ThemeResource OnSurfaceVariantBrush}" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Search destinations, flights, hotels..." Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </utu:CardContentControl>
                </StackPanel>

                <!-- Hero carousel (coffee-shop pattern): retemplated FlipView with NO built-in
                     flippers, custom fixed-size prev/next buttons that scroll the ScrollingHost, and
                     a display-only pager. Full-bleed on phones; an inset rounded banner on desktop. -->
                <Grid Height="{utu:Responsive Narrow=320, Wide=400}"
                      Margin="{utu:Responsive Narrow='0,24,0,0', Wide='16,24,16,0'}">
                    <FlipView x:Name="Hero"
                              Style="{StaticResource HeroFlipViewStyle}"
                              ItemsSource="{Binding HeroDestinations}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              CornerRadius="{utu:Responsive Narrow=0, Wide=18}"
                              SelectionChanged="OnHeroSelectionChanged"
                              AutomationProperties.Name="Featured destinations carousel">
                        <FlipView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Border>
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <!-- 3-stop scrim keeps the white caption legible over any photo -->
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#40000000" Offset="0.45" />
                                                <GradientStop Color="#E6000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel VerticalAlignment="Bottom" Padding="24,0,24,30" Spacing="6">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource DisplayMedium}" Foreground="White" />
                                        <TextBlock Text="{Binding Tagline}" Style="{StaticResource BodyMedium}" Foreground="#E6FFFFFF" TextWrapping="Wrap" />
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Content="Explore"
                                                Padding="20,10"
                                                FontSize="14"
                                                HorizontalAlignment="Left"
                                                Margin="0,8,0,0"
                                                uen:Navigation.Request="DestinationDetail"
                                                uen:Navigation.Data="{Binding}"
                                                AutomationProperties.Name="{Binding Name}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </FlipView.ItemTemplate>
                    </FlipView>

                    <!-- Display-only position indicator: never clickable, so it can't fall out of sync
                         (lesson 49). RequestedTheme=Dark gives pips that read on the scrim. -->
                    <PipsPager x:Name="HeroPager"
                               NumberOfPages="{Binding HeroCount}"
                               IsHitTestVisible="False"
                               RequestedTheme="Dark"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,10" />

                    <!-- Custom, fixed-size flippers — the ONLY paging buttons (the template has none),
                         so they render identically on every form factor. They page by scrolling the
                         FlipView's ScrollingHost (reliable on Skia; keeps the pager in sync). -->
                    <Button x:Name="HeroPrev"
                            Style="{StaticResource HeroNavButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="12,0,0,0"
                            Click="HeroPrev_Click"
                            AutomationProperties.Name="Previous destination">
                        <Path Data="M15.5303 4.21967C15.8232 4.51256 15.8232 4.98744 15.5303 5.28033L8.81066 12L15.5303 18.7197C15.8232 19.0126 15.8232 19.4874 15.5303 19.7803C15.2374 20.0732 14.7626 20.0732 14.4697 19.7803L7.21967 12.5303C6.92678 12.2374 6.92678 11.7626 7.21967 11.4697L14.4697 4.21967C14.7626 3.92678 15.2374 3.92678 15.5303 4.21967Z"
                              Fill="#FFFFFF" Stretch="Uniform" Width="15" Height="15"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="HeroNext"
                            Style="{StaticResource HeroNavButtonStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,0,12,0"
                            Click="HeroNext_Click"
                            AutomationProperties.Name="Next destination">
                        <Path Data="M8.46967 4.21967C8.76256 3.92678 9.23744 3.92678 9.53033 4.21967L16.7803 11.4697C17.0732 11.7626 17.0732 12.2374 16.7803 12.5303L9.53033 19.7803C9.23744 20.0732 8.76256 20.0732 8.46967 19.7803C8.17678 19.4874 8.17678 19.0126 8.46967 18.7197L15.1893 12L8.46967 5.28033C8.17678 4.98744 8.17678 4.51256 8.46967 4.21967Z"
                              Fill="#FFFFFF" Stretch="Uniform" Width="15" Height="15"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>

                <!-- Quick actions -->
                <StackPanel Padding="16,24,16,0" Spacing="12">
                    <TextBlock Text="Plan your trip" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding QuickActions}" MinWidth="88">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="88" MinItemHeight="88" MinColumnSpacing="12" MinRowSpacing="12" MaximumRowsOrColumns="6" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" IsClickable="True"
                                                        uen:Navigation.Request="Search"
                                                        AutomationProperties.Name="{Binding Label}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7" Padding="8,12">
                                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                            <Path Data="{Binding Label, Converter={StaticResource Icon}}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                                    </StackPanel>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Recommended — a 2-up grid of destination cards (same aligned UniformGridLayout
                     pattern as the categories below; a horizontal ScrollViewer offsets its content
                     left of the title on this stack, so a grid keeps the section edge-aligned). Each
                     card's image row has a fixed height, so cells never collapse. -->
                <StackPanel Padding="16,24,16,0" Spacing="12">
                    <TextBlock Text="Recommended for you" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding RecommendedTrips}" MinWidth="164">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="164" MinItemHeight="196" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" IsClickable="True"
                                                        uen:Navigation.Request="DestinationDetail"
                                                        uen:Navigation.Data="{Binding}"
                                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="118" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Row="1" Padding="12,10,12,12" Spacing="3">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                            <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0" VerticalAlignment="Center">
                                                <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                                    <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource SecondaryBrush}" Stretch="Uniform" />
                                                </Viewbox>
                                                <TextBlock Text="{Binding Rating}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding PriceFrom}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource SecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Explore categories: a 2-up grid of fixed-height image tiles (each tile carries an
                     explicit Height so it never collapses — an ImageBrush background contributes no
                     measured height on its own, unlike the fixed image rows on the cards above). -->
                <StackPanel Padding="16,24,16,24" Spacing="12">
                    <TextBlock Text="Explore by style" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding ExploreCategories}" MinWidth="150">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="150" MinItemHeight="132" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        Height="132"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        IsClickable="True"
                                                        uen:Navigation.Request="Search"
                                                        AutomationProperties.Name="{Binding Label}">
                                    <Grid>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0.1" EndPoint="0.5,1">
                                                    <GradientStop Color="#1A000000" Offset="0" />
                                                    <GradientStop Color="#CC000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource TitleSmall}" Foreground="White" VerticalAlignment="Bottom" Padding="14,0,14,12" TextWrapping="Wrap" />
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
