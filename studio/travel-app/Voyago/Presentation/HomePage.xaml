<Page x:Class="Voyago.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Voyago.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{ThemeResource SurfaceBrush}" Padding="16,12" utu:SafeArea.Insets="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{ThemeResource PrimaryBrush}">
                <TextBlock Text="{Binding UserInitials}" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Grid.Column="1" Text="Voyago" FontFamily="{StaticResource DisplaySemiBoldFontFamily}" FontSize="22" Foreground="{ThemeResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Notifications">
                <PathIcon Data="{Binding Converter={StaticResource Icon}, ConverterParameter=alert}" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Stretch" Spacing="0" local:Motion.Stagger="True">

                <!-- Greeting + search entry -->
                <StackPanel Padding="16,22,16,0" Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="WELCOME BACK" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding GreetingText}" Style="{StaticResource HeadlineMedium}" Foreground="{ThemeResource OnBackgroundBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" HorizontalAlignment="Stretch"
                                            IsClickable="True" uen:Navigation.Request="Search"
                                            AutomationProperties.Name="Search destinations, flights and hotels">
                        <Grid Padding="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=search}" Fill="{ThemeResource OnSurfaceVariantBrush}" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Search destinations, flights, hotels..." Style="{StaticResource BodyMedium}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </utu:CardContentControl>
                </StackPanel>

                <!-- Hero carousel + synced pager -->
                <StackPanel Padding="16,22,16,0" Spacing="10">
                    <FlipView x:Name="Hero"
                              ItemsSource="{Binding HeroDestinations}"
                              Height="{utu:Responsive Narrow=300, Wide=380}"
                              Background="Transparent"
                              SelectionChanged="OnHeroSelectionChanged">
                        <FlipView.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                        IsClickable="True"
                                                        uen:Navigation.Request="DestinationDetail"
                                                        uen:Navigation.Data="{Binding}"
                                                        AutomationProperties.Name="{Binding Name}">
                                    <Grid>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0.35" EndPoint="0.5,1">
                                                    <GradientStop Color="#00000000" Offset="0" />
                                                    <GradientStop Color="#B3000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Bottom" Padding="22,0,22,22" Spacing="4">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource DisplayMedium}" Foreground="White" />
                                            <TextBlock Text="{Binding Tagline}" Style="{StaticResource BodyMedium}" Foreground="#E6FFFFFF" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PriceFrom}" Style="{StaticResource LabelMedium}" Foreground="White" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </FlipView.ItemTemplate>
                    </FlipView>
                    <!-- Display-only position indicator: never clickable, so it can't fall out of sync (lesson 49) -->
                    <PipsPager x:Name="HeroPager"
                               NumberOfPages="{Binding HeroCount}"
                               IsHitTestVisible="False"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Quick actions -->
                <StackPanel Padding="16,24,16,0" Spacing="12">
                    <TextBlock Text="Plan your trip" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding QuickActions}" MinWidth="88">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="88" MinItemHeight="88" MinColumnSpacing="12" MinRowSpacing="12" MaximumRowsOrColumns="6" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" IsClickable="True"
                                                        uen:Navigation.Request="Search"
                                                        AutomationProperties.Name="{Binding Label}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7" Padding="8,12">
                                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                            <Path Data="{Binding Label, Converter={StaticResource Icon}}" Fill="{ThemeResource PrimaryBrush}" Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                                    </StackPanel>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Recommended -->
                <StackPanel Padding="0,26,0,0" Spacing="12">
                    <TextBlock Text="Recommended for you" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" Margin="16,0" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled">
                        <ItemsRepeater ItemsSource="{Binding RecommendedTrips}" Margin="16,0,16,4">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                            Width="190" IsClickable="True"
                                                            uen:Navigation.Request="DestinationDetail"
                                                            uen:Navigation.Data="{Binding}"
                                                            AutomationProperties.Name="{Binding Name}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="122" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <StackPanel Grid.Row="1" Padding="12,10,12,12" Spacing="3">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                <TextBlock Text="{Binding Country}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0" VerticalAlignment="Center">
                                                    <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                                        <Path Data="{Binding Converter={StaticResource Icon}, ConverterParameter=star_filled}" Fill="{ThemeResource SecondaryBrush}" Stretch="Uniform" />
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding Rating}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding PriceFrom}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource PrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </utu:CardContentControl>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Explore categories -->
                <StackPanel Padding="16,26,16,26" Spacing="12">
                    <TextBlock Text="Explore by style" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ItemsRepeater ItemsSource="{Binding ExploreCategories}" MinWidth="168">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="168" MinItemHeight="116" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                                        HorizontalAlignment="Stretch" IsClickable="True"
                                                        uen:Navigation.Request="Search"
                                                        AutomationProperties.Name="{Binding Label}">
                                    <Grid>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0.15" EndPoint="0.5,1">
                                                    <GradientStop Color="#26000000" Offset="0" />
                                                    <GradientStop Color="#BF000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource TitleSmall}" Foreground="White" VerticalAlignment="Bottom" Padding="14,0,14,12" TextWrapping="Wrap" />
                                    </Grid>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
