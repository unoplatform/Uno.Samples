<UserControl x:Class="Voyago.Presentation.Shell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Voyago.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:utu="using:Uno.Toolkit.UI"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="400">
  <Border Background="{ThemeResource BackgroundBrush}">
    <!--
      The shell's content host is an ExtendedSplashScreen: it keeps the native (Resizetizer)
      splash on screen, overlaid with the loading content below, until the app reports ready
      (see Shell.xaml.cs). Navigation injects the active page (Main) as its Content and the splash
      reveals it once loading completes. Navigation regions live on MainPage, never on the splash.
    -->
    <utu:ExtendedSplashScreen x:Name="ShellContent"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch">
      <utu:ExtendedSplashScreen.LoadingContent>
        <!-- Mirrors the native splash: the Voyago suitcase mark on #151515, drawn with native
             shapes (Paths + a LinearGradientBrush — never an SVG <Image>, which can render as a
             black tile). The gradient hex matches the icon/splash SVGs because this mark paints
             before the resource system is up, so it can't use a ThemeResource (lesson 59). -->
        <Grid Background="#151515">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Viewbox Grid.Row="1"
                   Width="132"
                   Height="132"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <Canvas Width="240" Height="240">
              <Path Data="F1 M130 30C146.569 30 160 43.4315 160 60V66.7695C174.306 69.9621 185 82.7315 185 98V164C185 178.911 174.802 191.437 161 194.989V201C161 205.971 156.971 210 152 210C147.029 210 143 205.971 143 201V196H97V201C97 205.971 92.9706 210 88 210C83.0294 210 79 205.971 79 201V194.989C65.4542 191.503 55.3794 179.372 55.0107 164.826L55 164V98C55 82.7315 65.6938 69.9621 80 66.7695V60C80 43.4315 93.4315 30 110 30H130ZM87 82C78.1634 82 71 89.1634 71 98V164C71 172.837 78.1634 180 87 180H153C161.837 180 169 172.837 169 164V98C169 89.1634 161.837 82 153 82H87ZM110 46C102.268 46 96 52.268 96 60V66H144V60C144 52.268 137.732 46 130 46H110Z">
                <Path.Fill>
                  <LinearGradientBrush StartPoint="0.77,0.87" EndPoint="0.07,0.32">
                    <GradientStop Offset="0" Color="#B685FF" />
                    <GradientStop Offset="1" Color="#E7A3FF" />
                  </LinearGradientBrush>
                </Path.Fill>
              </Path>
              <Path Data="F1 M149.079 95.9776C152.096 95.1157 154.886 97.9056 154.024 100.923L141.611 144.367C140.472 148.354 137.355 151.47 133.369 152.609L89.9243 165.022C86.9071 165.884 84.1171 163.094 84.979 160.077L97.3921 116.633C98.5311 112.646 101.648 109.53 105.634 108.391L149.079 95.9776ZM119.501 118.333C116.122 118.333 113.249 119.516 110.883 121.882C108.518 124.248 107.334 127.12 107.334 130.5C107.334 133.88 108.518 136.752 110.883 139.118C113.249 141.484 116.122 142.667 119.501 142.667C122.881 142.667 125.754 141.484 128.12 139.118C130.485 136.752 131.668 133.88 131.668 130.5C131.668 127.12 130.485 124.248 128.12 121.882C125.754 119.516 122.881 118.333 119.501 118.333Z"
                    Fill="White" />
            </Canvas>
          </Viewbox>
          <TextBlock Grid.Row="2"
                     Text="Voyago"
                     FontFamily="ms-appx:///Assets/Fonts/Fraunces-DisplaySemiBold.ttf#Fraunces Display SemiBold"
                     FontSize="30"
                     CharacterSpacing="40"
                     Foreground="White"
                     Margin="0,20,0,0"
                     HorizontalAlignment="Center" />
          <ProgressRing Grid.Row="3"
                        IsActive="True"
                        Width="42"
                        Height="42"
                        Margin="0,36,0,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Foreground="#C9B0FF" />
        </Grid>
      </utu:ExtendedSplashScreen.LoadingContent>
    </utu:ExtendedSplashScreen>
  </Border>
</UserControl>
