<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Lightweight-styling overrides for built-in controls, per theme (lessons 6b / 51). -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- The default NavigationView indicator is system-accent blue and stretches as it
           travels between items; recolour it to the brand violet so it harmonises (lesson 51). -->
      <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#6541C6" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#C9B0FF" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
