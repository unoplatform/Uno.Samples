<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-android;net10.0-ios;net10.0-browserwasm;net10.0-desktop</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>Voyago</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>com.companyname.travelapp</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>Voyago</ApplicationPublisher>
    <!-- Package Description -->
    <Description>Voyago powered by Uno Platform.</Description>

    <!-- Branded app icon + splash (Uno.Resizetizer): one source drives every platform -->
    <UnoIconForegroundFile>Assets/Icons/icon_foreground.svg</UnoIconForegroundFile>
    <UnoIconBackgroundColor>#151515</UnoIconBackgroundColor>
    <UnoSplashScreenFile>Assets/Splash/splash_screen.svg</UnoSplashScreenFile>
    <UnoSplashScreenColor>#151515</UnoSplashScreenColor>

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <UnoFeatures>
      SimpleTheme;
      Hosting;
      Toolkit;
      Logging;
      MVUX;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      SkiaRenderer;
    </UnoFeatures>
  </PropertyGroup>

  <ItemGroup>
    <!-- Bundled brand type (SIL OFL): Plus Jakarta Sans (UI/body) + Fraunces (serif display).
         The SDK does not auto-glob .ttf, so each weight is included explicitly as Content. -->
    <Content Include="Assets/Fonts/*.ttf" />
    <!-- Bundled destination/category photos (freely-licensed, Wikimedia Commons), referenced via
         ms-appx:///Assets/Photos/*.jpg. Local assets load reliably on every head (unlike some remote
         hosts that require a User-Agent on the Skia renderer) and always match their labels. -->
    <Content Include="Assets/Photos/*.jpg" />
  </ItemGroup>

</Project>
