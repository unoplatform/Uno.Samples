<Page x:Class="UnoCRM.LeadsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      x:Uid="LeadsPage"
      Background="{StaticResource DashboardPageBackgroundBrush}">
  <Grid Background="{StaticResource DashboardPageBackgroundBrush}">
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <VisualState x:Name="MobileState" />
        <VisualState x:Name="DesktopState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="900" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopRoot.Visibility" Value="Visible" />
            <Setter Target="MobileRoot.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid x:Name="DesktopRoot" Visibility="Collapsed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="204" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{StaticResource DashboardSurfaceBrush}"
              BorderBrush="{StaticResource DashboardBorderBrush}"
              BorderThickness="0,0,1,0">
        <Grid Padding="20,24,20,24">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Spacing="18">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Width="28"
                      Height="28"
                      CornerRadius="8"
                      Background="{StaticResource DashboardAccentBrush}" />
              <TextBlock Text="Uno CRM"
                         VerticalAlignment="Center"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
            </StackPanel>

            <TextBlock Text="MENU"
                       Style="{StaticResource DashboardSectionLabelStyle}"
                       Margin="0,4,0,0" />

            <StackPanel Spacing="8">
              <Button Click="NavigateToDashboard_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE80F;"
                              FontSize="16"
                              Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Dashboard"
                               Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>

              <Button Click="NavigateToPipeline_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE8C8;"
                              FontSize="16"
                              Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Pipeline"
                               Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>

              <Border Style="{StaticResource DashboardSidebarItemBorderStyle}"
                      Background="{StaticResource DashboardAccentSoftBrush}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <FontIcon Glyph="&#xE716;"
                            FontSize="16"
                            Foreground="{StaticResource DashboardAccentBrush}" />
                  <TextBlock Text="Leads"
                             Foreground="{StaticResource DashboardAccentBrush}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </StackPanel>
              </Border>

              <Button Click="NavigateToContacts_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE77B;"
                              FontSize="16"
                              Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Contacts"
                               Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="12"
                      VerticalAlignment="Bottom">
            <Border Width="32"
                    Height="32"
                    CornerRadius="16"
                    Background="{StaticResource DashboardAccentBrush}" />
            <StackPanel>
              <TextBlock Text="Alex Morgan"
                         Style="{StaticResource DashboardBodyTextStyle}" />
              <TextBlock Text="Sales Manager"
                         Style="{StaticResource DashboardSubtleTextStyle}"
                         FontSize="12" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Grid Padding="28,22,28,28"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
              <TextBlock Text="Leads Intelligence"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="30" />
              <TextBlock Text="Track acquisition momentum, source quality, and stage progression in real time"
                         Style="{StaticResource DashboardSubtleTextStyle}"
                         MaxWidth="620" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
              <Grid Width="260"
                    VerticalAlignment="Center">
                <TextBox x:Uid="LeadsPage.DesktopSearch"
                         AutomationProperties.Name="Search leads"
                         PlaceholderText="Search leads"
                         Style="{StaticResource DashboardSearchBoxStyle}"
                         Padding="36,10,14,10" />
                <FontIcon Glyph="&#xE721;"
                          FontSize="14"
                          Foreground="{StaticResource DashboardMutedTextBrush}"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left" />
              </Grid>

              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <FontIcon Glyph="&#xE7ED;"
                          FontSize="15"
                          Foreground="{StaticResource DashboardMutedTextBrush}" />
              </Button>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16">
              <StackPanel Spacing="8">
                <TextBlock Text="NEW LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding NewLeadsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16">
              <StackPanel Spacing="8">
                <TextBlock Text="QUALIFICATION RATE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding QualificationRateText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16">
              <StackPanel Spacing="8">
                <TextBlock Text="PIPELINE VALUE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding PipelineValueText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16">
              <StackPanel Spacing="8">
                <TextBlock Text="AVG DEAL SIZE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding AverageDealSizeText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="2"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.35*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Lead Acquisition Trend"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:CartesianChart Height="280"
                                    Series="{Binding LeadTrendSeries}"
                                    XAxes="{Binding MonthXAxis}"
                                    YAxes="{Binding CountYAxis}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Lead Stage Distribution"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:PieChart Height="280"
                              Series="{Binding StageDistributionSeries}"
                              LegendPosition="Right"
                              InitialRotation="-90" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="3"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.15*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Leads by Source"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:CartesianChart Height="260"
                                    Series="{Binding LeadsBySourceSeries}"
                                    XAxes="{Binding SourceXAxis}"
                                    YAxes="{Binding SourceYAxis}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Top Open Leads"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />

                <Border BorderBrush="{StaticResource DashboardBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Northwind Analytics"
                               Style="{StaticResource DashboardBodyTextStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="$132,000"
                               Style="{StaticResource DashboardBodyTextStyle}"
                               Foreground="{StaticResource DashboardAccentBrush}" />
                  </Grid>
                </Border>

                <Border BorderBrush="{StaticResource DashboardBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Vertex Finance Group"
                               Style="{StaticResource DashboardBodyTextStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="$108,500"
                               Style="{StaticResource DashboardBodyTextStyle}"
                               Foreground="{StaticResource DashboardAccentBrush}" />
                  </Grid>
                </Border>

                <Border BorderBrush="{StaticResource DashboardBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Crestline Robotics"
                               Style="{StaticResource DashboardBodyTextStyle}" />
                    <TextBlock Grid.Column="1"
                               Text="$89,900"
                               Style="{StaticResource DashboardBodyTextStyle}"
                               Foreground="{StaticResource DashboardAccentBrush}" />
                  </Grid>
                </Border>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Clearwater Retail"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <TextBlock Grid.Column="1"
                             Text="$67,400"
                             Style="{StaticResource DashboardBodyTextStyle}"
                             Foreground="{StaticResource DashboardAccentBrush}" />
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>

    <Grid x:Name="MobileRoot" Visibility="Visible">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20,16,20,130"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock Text="Leads"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="32" />
              <TextBlock Text="Realtime lead analytics"
                         Style="{StaticResource DashboardSubtleTextStyle}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource DashboardIconButtonStyle}">
              <FontIcon Glyph="&#xE7ED;"
                        FontSize="15"
                        Foreground="{StaticResource DashboardMutedTextBrush}" />
            </Button>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="12"
                RowSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14">
              <StackPanel Spacing="6">
                <TextBlock Text="NEW LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding NewLeadsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="24" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14">
              <StackPanel Spacing="6">
                <TextBlock Text="QUALIFIED"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding QualificationRateText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="24" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Monthly Lead Flow"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:CartesianChart Height="230"
                                  Series="{Binding LeadTrendSeries}"
                                  XAxes="{Binding MonthXAxis}"
                                  YAxes="{Binding CountYAxis}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="3"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Lead Mix by Stage"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:PieChart Height="240"
                            Series="{Binding StageDistributionSeries}"
                            LegendPosition="Bottom"
                            InitialRotation="-90" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Top Sources"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:CartesianChart Height="230"
                                  Series="{Binding LeadsBySourceSeries}"
                                  XAxes="{Binding SourceXAxis}"
                                  YAxes="{Binding SourceYAxis}" />
            </StackPanel>
          </Border>
        </Grid>
      </ScrollViewer>

      <Border VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="16,0,16,18"
              Padding="10"
              MinWidth="320"
              MaxWidth="560"
              CornerRadius="34"
              Background="{StaticResource DashboardSurfaceBrush}"
              BorderBrush="{StaticResource DashboardBorderBrush}"
              BorderThickness="1">
        <Grid ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  Click="NavigateToDashboard_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE80F;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="HOME"
                         HorizontalAlignment="Center"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>

          <Button Grid.Column="1"
                  Click="NavigateToPipeline_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE9D2;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="PIPELINE"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>

          <Border Grid.Column="2"
                  Background="{StaticResource DashboardAccentBrush}"
                  CornerRadius="28"
                  Padding="20,14">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE716;"
                        FontSize="20"
                        Foreground="White" />
              <TextBlock Text="LEADS"
                         HorizontalAlignment="Center"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Border>

          <Button Grid.Column="3"
                  Click="NavigateToContacts_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE77B;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="CONTACTS"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>
