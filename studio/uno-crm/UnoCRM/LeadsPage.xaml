<Page x:Class="UnoCRM.LeadsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      xmlns:utu="using:Uno.Toolkit.UI"
      x:Uid="LeadsPage"
      Background="{ThemeResource DashboardPageBackgroundBrush}">
  <Page.Resources>
    <!-- A "Top Open Leads" row, bound to the highest-value open deals in the shared dataset. -->
    <DataTemplate x:Key="TopLeadTemplate">
      <Border BorderBrush="{ThemeResource DashboardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding Company}" Style="{StaticResource DashboardBodyTextStyle}" />
          <TextBlock Grid.Column="1" Text="{Binding AmountDisplay}"
                     Style="{StaticResource DashboardBodyTextStyle}"
                     Foreground="{ThemeResource DashboardAccentBrush}" />
        </Grid>
      </Border>
    </DataTemplate>
  </Page.Resources>
  <Grid Background="{ThemeResource DashboardPageBackgroundBrush}">
    <Grid x:Name="DesktopRoot" Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Grid Padding="28,22,28,28"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
              <TextBlock Text="Leads Intelligence"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="26" />
              <TextBlock Text="Track acquisition momentum, source quality, and stage progression in real time"
                         Style="{StaticResource DashboardSubtleTextStyle}"
                         HorizontalAlignment="Left"
                         MaxWidth="620" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
              <Grid Width="260"
                    VerticalAlignment="Center">
                <TextBox x:Uid="LeadsPage.DesktopSearch"
                         AutomationProperties.Name="Search leads"
                         PlaceholderText="Search leads"
                         Style="{StaticResource DashboardSearchBoxStyle}"
                         Padding="36,10,14,10" />
                <FontIcon Glyph="&#xE721;"
                          FontSize="14"
                          Foreground="{ThemeResource DashboardMutedTextBrush}"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left" />
              </Grid>

              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <FontIcon Glyph="&#xE7ED;"
                          FontSize="15"
                          Foreground="{ThemeResource DashboardMutedTextBrush}" />
              </Button>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="112">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="NEW LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Grid.Row="2"
                           Text="{Binding NewLeadsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="112">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="QUALIFICATION RATE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Grid.Row="2"
                           Text="{Binding QualificationRateText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="112">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="PIPELINE VALUE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Grid.Row="2"
                           Text="{Binding PipelineValueText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </Grid>
            </Border>

            <Border Grid.Column="3"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="112">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="AVG DEAL SIZE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Grid.Row="2"
                           Text="{Binding AverageDealSizeText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="28" />
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="2"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.35*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Lead Acquisition Trend"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:CartesianChart Height="280"
                                    Series="{Binding LeadTrendSeries}"
                                    XAxes="{Binding MonthXAxis}"
                                    YAxes="{Binding CountYAxis}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Lead Stage Distribution"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:PieChart Height="280"
                              Series="{Binding StageDistributionSeries}"
                              LegendPosition="Bottom"
                              InitialRotation="-90" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="3"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.35*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Leads by Source"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />
                <lvc:CartesianChart Height="260"
                                    Series="{Binding LeadsBySourceSeries}"
                                    XAxes="{Binding SourceXAxis}"
                                    YAxes="{Binding SourceYAxis}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,14,18,16">
              <StackPanel Spacing="12">
                <TextBlock Text="Top Open Leads"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />

                <ItemsControl ItemsSource="{Binding TopOpenLeads}"
                              ItemTemplate="{StaticResource TopLeadTemplate}" />
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>

    <Grid x:Name="MobileRoot" Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}" utu:SafeArea.Insets="Top,Bottom">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20,16,20,130"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock Text="Leads"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="32" />
              <TextBlock Text="Realtime lead analytics"
                         Style="{StaticResource DashboardSubtleTextStyle}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource DashboardIconButtonStyle}">
              <FontIcon Glyph="&#xE7ED;"
                        FontSize="15"
                        Foreground="{ThemeResource DashboardMutedTextBrush}" />
            </Button>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="12"
                RowSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14">
              <StackPanel Spacing="6">
                <TextBlock Text="NEW LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding NewLeadsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="24" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14">
              <StackPanel Spacing="6">
                <TextBlock Text="QUALIFIED"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding QualificationRateText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="24" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Monthly Lead Flow"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:CartesianChart Height="230"
                                  Series="{Binding LeadTrendSeries}"
                                  XAxes="{Binding MonthXAxis}"
                                  YAxes="{Binding CountYAxis}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="3"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Lead Mix by Stage"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:PieChart Height="240"
                            Series="{Binding StageDistributionSeries}"
                            LegendPosition="Bottom"
                            InitialRotation="-90" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="16,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Top Sources"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <lvc:CartesianChart Height="230"
                                  Series="{Binding LeadsBySourceSeries}"
                                  XAxes="{Binding SourceXAxis}"
                                  YAxes="{Binding SourceYAxis}" />
            </StackPanel>
          </Border>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
