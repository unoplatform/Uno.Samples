<Page x:Class="UnoCRM.ContactsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:maps="clr-namespace:Mapsui.UI.WinUI;assembly=Mapsui.UI.Uno.WinUI"
      x:Uid="ContactsPage"
      Background="{StaticResource DashboardPageBackgroundBrush}">
  <Grid Background="{StaticResource DashboardPageBackgroundBrush}">
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <VisualState x:Name="MobileState" />
        <VisualState x:Name="DesktopState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="900" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopRoot.Visibility" Value="Visible" />
            <Setter Target="MobileRoot.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid x:Name="DesktopRoot" Visibility="Collapsed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="204" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{StaticResource DashboardSurfaceBrush}"
              BorderBrush="{StaticResource DashboardBorderBrush}"
              BorderThickness="0,0,1,0">
        <Grid Padding="20,24,20,24">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Spacing="18">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Width="28"
                      Height="28"
                      CornerRadius="8"
                      Background="{StaticResource DashboardAccentBrush}" />
              <TextBlock Text="Uno CRM"
                         VerticalAlignment="Center"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
            </StackPanel>

            <TextBlock Text="MENU"
                       Style="{StaticResource DashboardSectionLabelStyle}"
                       Margin="0,4,0,0" />

            <StackPanel Spacing="8">
              <Button Click="NavigateToDashboard_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Dashboard" Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>

              <Button Click="NavigateToPipeline_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE8C8;" FontSize="16" Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Pipeline" Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>

              <Button Click="NavigateToLeads_Click"
                      Style="{StaticResource DashboardNavButtonStyle}">
                <Border Style="{StaticResource DashboardSidebarItemBorderStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE716;" FontSize="16" Foreground="{StaticResource DashboardMutedTextBrush}" />
                    <TextBlock Text="Leads" Style="{StaticResource DashboardSubtleTextStyle}" />
                  </StackPanel>
                </Border>
              </Button>

              <Border Style="{StaticResource DashboardSidebarItemBorderStyle}"
                      Background="{StaticResource DashboardAccentSoftBrush}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="{StaticResource DashboardAccentBrush}" />
                  <TextBlock Text="Contacts"
                             Foreground="{StaticResource DashboardAccentBrush}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="12"
                      VerticalAlignment="Bottom">
            <Border Width="32"
                    Height="32"
                    CornerRadius="16"
                    Background="{StaticResource DashboardAccentBrush}" />
            <StackPanel>
              <TextBlock Text="Alex Morgan" Style="{StaticResource DashboardBodyTextStyle}" />
              <TextBlock Text="Sales Manager" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="12" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Column="1"
        Padding="28,22,28,28"
        RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock Text="Contacts Atlas"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="30" />
              <TextBlock Text="Discover and segment contacts by geography, region, and segment"
                         Style="{StaticResource DashboardSubtleTextStyle}"
                         MaxWidth="620" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
              <Button Style="{StaticResource DashboardPrimaryButtonStyle}"
                      Click="ResetMap_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <FontIcon Glyph="&#xE81E;" FontSize="12" Foreground="White" />
                  <TextBlock Text="Reset View" Foreground="White" FontSize="14" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
              <TextBox x:Name="DesktopSearchBox"
                       PlaceholderText="Search contacts, company, city"
                       Style="{StaticResource DashboardSearchBoxStyle}"
                       Padding="36,10,14,10"
                       TextChanged="SearchContacts_TextChanged" />
              <FontIcon Glyph="&#xE721;"
                        FontSize="14"
                        Foreground="{StaticResource DashboardMutedTextBrush}"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left" />
            </Grid>

            <ComboBox x:Name="DesktopRegionFilter"
                      Grid.Column="1"
                      SelectedIndex="0"
                      SelectionChanged="RegionFilter_SelectionChanged">
              <ComboBoxItem Content="All Regions" />
              <ComboBoxItem Content="North America" />
              <ComboBoxItem Content="Europe" />
              <ComboBoxItem Content="APAC" />
              <ComboBoxItem Content="LATAM" />
            </ComboBox>

            <ComboBox x:Name="DesktopSegmentFilter"
                      Grid.Column="2"
                      SelectedIndex="0"
                      SelectionChanged="SegmentFilter_SelectionChanged">
              <ComboBoxItem Content="All Segments" />
              <ComboBoxItem Content="Enterprise" />
              <ComboBoxItem Content="Mid-Market" />
              <ComboBoxItem Content="SMB" />
            </ComboBox>
          </Grid>

          <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.35*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14,16,16"
                    MinHeight="560">
              <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Live Contact Geography"
                             Style="{StaticResource DashboardBodyTextStyle}"
                             FontFamily="Georgia"
                             FontSize="22" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding TotalFilteredLabel}"
                             Style="{StaticResource DashboardSubtleTextStyle}"
                             Margin="12,2,0,0" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding RegionsLabel}"
                             Style="{StaticResource DashboardSubtleTextStyle}"
                             Margin="12,2,0,0" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding SegmentsLabel}"
                             Style="{StaticResource DashboardSubtleTextStyle}"
                             Margin="12,2,0,0" />
                </Grid>

                <maps:MapControl x:Name="DesktopMapControl"
                                 Grid.Row="1"
                                 MinHeight="460"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
              </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="16,14,16,16"
                    MinHeight="560">
              <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Filtered Contacts"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />

                <ListView Grid.Row="1"
                          ItemsSource="{Binding FilteredContacts}"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionMode="None">
                  <ListView.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource DashboardKanbanCardStyle}"
                              Margin="0,0,0,10">
                        <StackPanel Spacing="6">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource DashboardBodyTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Segment}"
                                       Style="{StaticResource DashboardMicroTextStyle}" />
                          </Grid>
                          <TextBlock Text="{Binding Company}"
                                     Style="{StaticResource DashboardSubtleTextStyle}" />
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding City}"
                                       Style="{StaticResource DashboardSubtleTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Region}"
                                       Foreground="{StaticResource DashboardAccentBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListView.ItemTemplate>
                </ListView>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Grid>

    <Grid x:Name="MobileRoot" Visibility="Visible">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20,16,20,130"
              RowSpacing="14">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Spacing="6">
            <TextBlock Text="Contacts"
                       Style="{StaticResource DashboardCardTitleStyle}"
                       FontSize="32" />
            <TextBlock Text="Map-driven contact discovery"
                       Style="{StaticResource DashboardSubtleTextStyle}" />
          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="10">
            <Grid>
              <TextBox x:Name="MobileSearchBox"
                       PlaceholderText="Search contacts"
                       Style="{StaticResource DashboardSearchBoxStyle}"
                       Padding="36,10,14,10"
                       TextChanged="SearchContacts_TextChanged" />
              <FontIcon Glyph="&#xE721;"
                        FontSize="14"
                        Foreground="{StaticResource DashboardMutedTextBrush}"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left" />
            </Grid>
            <Grid ColumnSpacing="10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <ComboBox x:Name="MobileRegionFilter"
                        Grid.Column="0"
                        SelectedIndex="0"
                        SelectionChanged="RegionFilter_SelectionChanged">
                <ComboBoxItem Content="All Regions" />
                <ComboBoxItem Content="North America" />
                <ComboBoxItem Content="Europe" />
                <ComboBoxItem Content="APAC" />
                <ComboBoxItem Content="LATAM" />
              </ComboBox>

              <ComboBox x:Name="MobileSegmentFilter"
                        Grid.Column="1"
                        SelectedIndex="0"
                        SelectionChanged="SegmentFilter_SelectionChanged">
                <ComboBoxItem Content="All Segments" />
                <ComboBoxItem Content="Enterprise" />
                <ComboBoxItem Content="Mid-Market" />
                <ComboBoxItem Content="SMB" />
              </ComboBox>
            </Grid>
          </StackPanel>

          <Border Grid.Row="2"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="14,12,14,14">
            <StackPanel Spacing="10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Contact Geography"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="20" />
                <Button Grid.Column="1"
                        Click="ResetMap_Click"
                        Style="{StaticResource DashboardFilterButtonStyle}">
                  <TextBlock Text="Reset" FontSize="12" />
                </Button>
              </Grid>
              <maps:MapControl x:Name="MobileMapControl"
                               Height="300" />
            </StackPanel>
          </Border>

          <Border Grid.Row="3"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="14,12,14,14">
            <StackPanel Spacing="10">
              <TextBlock Text="Contacts"
                         Style="{StaticResource DashboardBodyTextStyle}"
                         FontFamily="Georgia"
                         FontSize="20" />
              <ListView ItemsSource="{Binding FilteredContacts}"
                        BorderThickness="0"
                        Background="Transparent"
                        SelectionMode="None"
                        MaxHeight="360">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource DashboardKanbanCardStyle}"
                            Margin="0,0,0,10">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Name}" Style="{StaticResource DashboardBodyTextStyle}" />
                        <TextBlock Text="{Binding Company}" Style="{StaticResource DashboardSubtleTextStyle}" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding City}" Style="{StaticResource DashboardSubtleTextStyle}" />
                          <TextBlock Grid.Column="1" Text="{Binding Region}" Foreground="{StaticResource DashboardAccentBrush}" FontSize="12" />
                        </Grid>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </Border>
        </Grid>
      </ScrollViewer>

      <Border VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="16,0,16,18"
              Padding="10"
              MinWidth="320"
              MaxWidth="560"
              CornerRadius="34"
              Background="{StaticResource DashboardSurfaceBrush}"
              BorderBrush="{StaticResource DashboardBorderBrush}"
              BorderThickness="1">
        <Grid ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  Click="NavigateToDashboard_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
              <FontIcon Glyph="&#xE80F;" FontSize="20" Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="HOME" Foreground="{StaticResource DashboardSubtleTextBrush}" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Grid.Column="1"
                  Click="NavigateToPipeline_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
              <FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="PIPELINE" Foreground="{StaticResource DashboardSubtleTextBrush}" FontSize="12" />
            </StackPanel>
          </Button>

          <Button Grid.Column="2"
                  Click="NavigateToLeads_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
              <FontIcon Glyph="&#xE716;" FontSize="20" Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="LEADS" Foreground="{StaticResource DashboardSubtleTextBrush}" FontSize="12" />
            </StackPanel>
          </Button>

          <Border Grid.Column="3"
                  Background="{StaticResource DashboardAccentBrush}"
                  CornerRadius="28"
                  Padding="20,14">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
              <FontIcon Glyph="&#xE77B;" FontSize="20" Foreground="White" />
              <TextBlock Text="CONTACTS"
                         HorizontalAlignment="Center"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>
