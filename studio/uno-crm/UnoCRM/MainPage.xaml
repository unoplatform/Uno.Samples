<Page x:Class="UnoCRM.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource DashboardPageBackgroundBrush}">

  <!--
    Navigation shell. Owns the chrome once for the whole app: a NavigationView pane on
    wide layouts and a bottom TabBar on narrow ones. Responsive switching is driven by the
    Toolkit {utu:Responsive} extension on each property (not AdaptiveTrigger/VisualState) so
    it applies reliably to this navigation-injected page and matches the content pages'
    Narrow/Wide breakpoints. The content region below is left empty - Uno.Extensions
    Navigation injects the active route (Dashboard / Pipeline / Leads / Contacts) into it.
  -->
  <Grid x:Name="RootShellGrid" uen:Region.Attached="True">

    <!-- NavigationView: sidebar pane on Wide; collapsed (TabBar takes over) on Narrow -->
    <NavigationView x:Name="NavView"
                    uen:Region.Attached="True"
                    IsSettingsVisible="False"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="{utu:Responsive Narrow=LeftMinimal, Wide=Auto}"
                    IsPaneToggleButtonVisible="{utu:Responsive Narrow=False, Wide=True}"
                    IsPaneOpen="{utu:Responsive Narrow=False, Wide=True}">
      <NavigationView.MenuItems>
        <NavigationViewItem uen:Region.Name="Dashboard" Content="Dashboard">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE80F;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem uen:Region.Name="Pipeline" Content="Pipeline">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8C8;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem uen:Region.Name="Leads" Content="Leads">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE716;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem uen:Region.Name="Contacts" Content="Contacts">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE77B;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <NavigationView.Content>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Shared content area - navigation framework injects the active page here -->
          <Grid Grid.Row="0"
                uen:Region.Attached="True"
                uen:Region.Navigator="Visibility" />

          <!-- Bottom TabBar: shown on Narrow, hidden once the pane appears on Wide -->
          <utu:TabBar x:Name="BottomTabs"
                      Grid.Row="1"
                      uen:Region.Attached="True"
                      Style="{StaticResource BottomTabBarStyle}"
                      Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}">
            <utu:TabBarItem uen:Region.Name="Dashboard" Content="Dashboard">
              <utu:TabBarItem.Icon>
                <FontIcon Glyph="&#xE80F;" />
              </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Pipeline" Content="Pipeline">
              <utu:TabBarItem.Icon>
                <FontIcon Glyph="&#xE8C8;" />
              </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Leads" Content="Leads">
              <utu:TabBarItem.Icon>
                <FontIcon Glyph="&#xE716;" />
              </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem uen:Region.Name="Contacts" Content="Contacts">
              <utu:TabBarItem.Icon>
                <FontIcon Glyph="&#xE77B;" />
              </utu:TabBarItem.Icon>
            </utu:TabBarItem>
          </utu:TabBar>
        </Grid>
      </NavigationView.Content>
    </NavigationView>
  </Grid>
</Page>
