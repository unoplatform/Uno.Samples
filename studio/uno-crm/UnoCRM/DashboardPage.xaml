<Page x:Class="UnoCRM.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoCRM"
      xmlns:utu="using:Uno.Toolkit.UI"
      x:Uid="MainPage"
      Background="{ThemeResource DashboardPageBackgroundBrush}">
  <Page.Resources>
    <!-- Recent-activity rows, bound to CrmData.Dashboard.Activities. The dot/icon colors come
         from each item's palette keys via the shared ResourceKeyToBrush converter. -->
    <DataTemplate x:Key="DesktopActivityTemplate">
      <Border BorderBrush="{ThemeResource DashboardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,14">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Title}" Style="{StaticResource DashboardBodyTextStyle}" />
            <TextBlock Text="{Binding Detail}" Style="{StaticResource DashboardSubtleTextStyle}" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding TimeAgo}"
                     Style="{StaticResource DashboardSubtleTextStyle}" FontSize="12" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="MobileActivityTemplate">
      <Border BorderBrush="{ThemeResource DashboardBorderBrush}" BorderThickness="0,0,0,1" Padding="16,16">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Spacing="4" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}" Style="{StaticResource DashboardBodyTextStyle}"
                       FontFamily="Georgia" FontSize="18" FontWeight="Light" />
            <TextBlock Text="{Binding Detail}" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="16" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding TimeAgo}"
                     Style="{StaticResource DashboardSubtleTextStyle}" FontSize="14" VerticalAlignment="Center" />
        </Grid>
      </Border>
    </DataTemplate>
  </Page.Resources>
  <Grid Background="{ThemeResource DashboardPageBackgroundBrush}">
    <Grid x:Name="DesktopRoot" Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
          <Grid Padding="28,34,28,28"
              RowSpacing="28">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Dashboard"
                       Style="{StaticResource DashboardCardTitleStyle}"
                       FontSize="28"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
              <Grid Width="280"
                    VerticalAlignment="Center">
                <TextBox x:Uid="MainPage.DesktopSearch"
                         AutomationProperties.Name="Search leads and deals"
                         PlaceholderText="Search leads, deals..."
                         Style="{StaticResource DashboardSearchBoxStyle}"
                         Padding="36,10,14,10" />
                <FontIcon Glyph="&#xE721;"
                          FontSize="14"
                          Foreground="{ThemeResource DashboardMutedTextBrush}"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left" />
              </Grid>

              <Button x:Uid="MainPage.DesktopNotifications"
                      AutomationProperties.Name="Notifications"
                      Width="42"
                      Height="42"
                      Background="{ThemeResource DashboardSurfaceBrush}"
                      BorderBrush="{ThemeResource DashboardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="12">
                <FontIcon Glyph="&#xE7ED;"
                          FontSize="15"
                          Foreground="{ThemeResource DashboardPrimaryTextBrush}" />
              </Button>

              <Border Width="32"
                      Height="32"
                      CornerRadius="16"
                      Background="{ThemeResource DashboardAccentBrush}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="132">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="TOTAL LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <StackPanel Grid.Row="2" Spacing="2">
                  <TextBlock Text="{Binding TotalLeadsText}"
                             Style="{StaticResource DashboardMetricValueStyle}"
                             FontSize="30" />
                  <TextBlock Text="{Binding TotalLeadsDelta}"
                             Foreground="{ThemeResource DashboardAccentBrush}"
                             FontSize="13" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="132">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="ACTIVE DEALS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <StackPanel Grid.Row="2" Spacing="2">
                  <TextBlock Text="{Binding ActiveDealsText}"
                             Style="{StaticResource DashboardMetricValueStyle}"
                             FontSize="30" />
                  <TextBlock Text="{Binding ActiveDealsDelta}"
                             Foreground="{ThemeResource DashboardAccentBrush}"
                             FontSize="13" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="132">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="REVENUE THIS MONTH"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <StackPanel Grid.Row="2" Spacing="2">
                  <TextBlock Text="{Binding RevenueText}"
                             Style="{StaticResource DashboardMetricValueStyle}"
                             FontSize="30" />
                  <TextBlock Text="{Binding RevenueDelta}"
                             Foreground="{ThemeResource DashboardAccentBrush}"
                             FontSize="13" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="3"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,16"
                    MinHeight="132">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="CONVERSION RATE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <StackPanel Grid.Row="2" Spacing="2">
                  <TextBlock Text="{Binding ConversionRateText}"
                             Style="{StaticResource DashboardMetricValueStyle}"
                             FontSize="30" />
                  <TextBlock Text="{Binding ConversionRateDelta}"
                             Foreground="{ThemeResource DashboardAccentBrush}"
                             FontSize="13" />
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="2"
                ColumnSpacing="18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.05*" />
              <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,14,20,18"
                    MinHeight="520">
              <StackPanel Spacing="24">
                <TextBlock Text="Pipeline Summary"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />

                <StackPanel Spacing="14">
                  <StackPanel Spacing="8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="New Lead"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Funnel[0].Count}"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                    </Grid>
                    <Grid Height="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Funnel[0].FillColumn}" />
                        <ColumnDefinition Width="{Binding Funnel[0].RemainderColumn}" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.ColumnSpan="2"
                              Background="{ThemeResource DashboardBorderBrush}"
                              CornerRadius="4" />
                      <Border Background="{ThemeResource DashboardBlueBrush}"
                              CornerRadius="4" />
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Qualified"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Funnel[1].Count}"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                    </Grid>
                    <Grid Height="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Funnel[1].FillColumn}" />
                        <ColumnDefinition Width="{Binding Funnel[1].RemainderColumn}" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.ColumnSpan="2"
                              Background="{ThemeResource DashboardBorderBrush}"
                              CornerRadius="4" />
                      <Border Background="{ThemeResource DashboardPurpleBrush}"
                              CornerRadius="4" />
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Proposal"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Funnel[2].Count}"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                    </Grid>
                    <Grid Height="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Funnel[2].FillColumn}" />
                        <ColumnDefinition Width="{Binding Funnel[2].RemainderColumn}" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.ColumnSpan="2"
                              Background="{ThemeResource DashboardBorderBrush}"
                              CornerRadius="4" />
                      <Border Background="{ThemeResource DashboardAmberBrush}"
                              CornerRadius="4" />
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Negotiation"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Funnel[3].Count}"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                    </Grid>
                    <Grid Height="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Funnel[3].FillColumn}" />
                        <ColumnDefinition Width="{Binding Funnel[3].RemainderColumn}" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.ColumnSpan="2"
                              Background="{ThemeResource DashboardBorderBrush}"
                              CornerRadius="4" />
                      <Border Background="{ThemeResource DashboardRedBrush}"
                              CornerRadius="4" />
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Closed Won"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Funnel[4].Count}"
                                 Style="{StaticResource DashboardBodyTextStyle}" />
                    </Grid>
                    <Grid Height="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Funnel[4].FillColumn}" />
                        <ColumnDefinition Width="{Binding Funnel[4].RemainderColumn}" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.ColumnSpan="2"
                              Background="{ThemeResource DashboardBorderBrush}"
                              CornerRadius="4" />
                      <Border Background="{ThemeResource DashboardGreenBrush}"
                              CornerRadius="4" />
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="20,14,20,18"
                    MinHeight="520">
              <StackPanel Spacing="14">
                <TextBlock Text="Recent Activity"
                           Style="{StaticResource DashboardBodyTextStyle}"
                           FontFamily="Georgia"
                           FontSize="22" />

                <ItemsControl ItemsSource="{Binding Activities}"
                              ItemTemplate="{StaticResource DesktopActivityTemplate}" />
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>

    <Grid x:Name="MobileRoot"
          Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}"
          utu:SafeArea.Insets="Top,Bottom">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20,16,20,130"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
              <TextBlock Text="Good morning, Alex"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="32" />
              <TextBlock Text="Here's your sales overview"
                         Style="{StaticResource DashboardSubtleTextStyle}" />
            </StackPanel>

            <Button Grid.Column="1"
                    x:Uid="MainPage.MobileNotifications"
                    AutomationProperties.Name="Notifications"
                    VerticalAlignment="Top"
                    Style="{StaticResource DashboardIconButtonStyle}">
              <FontIcon Glyph="&#xE7ED;"
                        FontSize="15"
                        Foreground="{ThemeResource DashboardMutedTextBrush}" />
            </Button>
          </Grid>

          <Grid Grid.Row="1"
                ColumnSpacing="16"
                RowSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,18,18,20"
                    MinHeight="160">
              <StackPanel Spacing="10">
                <TextBlock Text="TOTAL LEADS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding TotalLeadsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="48" />
                <TextBlock Text="{Binding TotalLeadsDelta}"
                           Foreground="{ThemeResource DashboardAccentBrush}"
                           FontSize="16" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,18,18,20"
                    MinHeight="160">
              <StackPanel Spacing="10">
                <TextBlock Text="ACTIVE DEALS"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding ActiveDealsText}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="48" />
                <TextBlock Text="{Binding ActiveDealsDelta}"
                           Foreground="{ThemeResource DashboardAccentBrush}"
                           FontSize="16" />
              </StackPanel>
            </Border>
          </Grid>

          <StackPanel Grid.Row="2"
                      Spacing="14">
            <TextBlock Text="PIPELINE SUMMARY"
                       Style="{StaticResource DashboardSectionLabelStyle}" />

            <Border Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="18,18,18,20">
              <StackPanel Spacing="18">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="New"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <Grid Grid.Column="1"
                        Height="10"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Funnel[0].FillColumn}" />
                      <ColumnDefinition Width="{Binding Funnel[0].RemainderColumn}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{ThemeResource DashboardBorderBrush}"
                            CornerRadius="5" />
                    <Border Background="{ThemeResource DashboardBlueBrush}"
                            CornerRadius="5" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Funnel[0].Count}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Qualified"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <Grid Grid.Column="1"
                        Height="10"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Funnel[1].FillColumn}" />
                      <ColumnDefinition Width="{Binding Funnel[1].RemainderColumn}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{ThemeResource DashboardBorderBrush}"
                            CornerRadius="5" />
                    <Border Background="{ThemeResource DashboardPurpleBrush}"
                            CornerRadius="5" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Funnel[1].Count}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Proposal"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <Grid Grid.Column="1"
                        Height="10"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Funnel[2].FillColumn}" />
                      <ColumnDefinition Width="{Binding Funnel[2].RemainderColumn}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{ThemeResource DashboardBorderBrush}"
                            CornerRadius="5" />
                    <Border Background="{ThemeResource DashboardAmberBrush}"
                            CornerRadius="5" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Funnel[2].Count}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Negotiation"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <Grid Grid.Column="1"
                        Height="10"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Funnel[3].FillColumn}" />
                      <ColumnDefinition Width="{Binding Funnel[3].RemainderColumn}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{ThemeResource DashboardBorderBrush}"
                            CornerRadius="5" />
                    <Border Background="{ThemeResource DashboardRedBrush}"
                            CornerRadius="5" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Funnel[3].Count}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Won"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                  <Grid Grid.Column="1"
                        Height="10"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Funnel[4].FillColumn}" />
                      <ColumnDefinition Width="{Binding Funnel[4].RemainderColumn}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{ThemeResource DashboardBorderBrush}"
                            CornerRadius="5" />
                    <Border Background="{ThemeResource DashboardGreenBrush}"
                            CornerRadius="5" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Funnel[4].Count}"
                             Style="{StaticResource DashboardBodyTextStyle}" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Row="3"
                      Spacing="14">
            <TextBlock Text="RECENT ACTIVITY"
                       Style="{StaticResource DashboardSectionLabelStyle}" />

            <Border Style="{StaticResource DashboardPanelBorderStyle}"
                    Padding="0,6,0,6">
              <ItemsControl ItemsSource="{Binding Activities}"
                            ItemTemplate="{StaticResource MobileActivityTemplate}" />
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
