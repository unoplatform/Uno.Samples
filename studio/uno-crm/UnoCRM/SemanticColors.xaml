<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Semantic role palette consumed by SimpleToolkitTheme (App.xaml ColorOverrideSource). SimpleTheme
    turns these into the built-in control brushes (PrimaryBrush, SurfaceBrush, ...), so the framework
    controls the app doesn't explicitly style (NavigationView pane + selection pill, TabBar,
    ProgressRing, ScrollBar) pick up the CRM identity instead of the Simple/system defaults.

    The CRM brand is a teal primary over neutral surfaces, with a blue secondary and amber tertiary.
    The app's own styled surfaces use the Dashboard* palette in ThemeColors.xaml; these mirror the
    same colors onto the standard role names.
  -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#0D6E6E</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#E8F4F3</Color>
      <Color x:Key="OnPrimaryContainerColor">#06403E</Color>
      <Color x:Key="SecondaryColor">#3B82F6</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#EFF4FF</Color>
      <Color x:Key="OnSecondaryContainerColor">#0A2A5E</Color>
      <Color x:Key="TertiaryColor">#F59E0B</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#FFF5E7</Color>
      <Color x:Key="OnTertiaryContainerColor">#3A2400</Color>
      <Color x:Key="ErrorColor">#EF4444</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#F0F0F0</Color>
      <Color x:Key="OnSurfaceVariantColor">#666666</Color>
      <Color x:Key="BackgroundColor">#FAFAFA</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="OutlineColor">#CBCBCB</Color>
      <Color x:Key="OutlineVariantColor">#E5E5E5</Color>
    </ResourceDictionary>

    <ResourceDictionary x:Key="Default">
      <Color x:Key="PrimaryColor">#1FA39E</Color>
      <Color x:Key="OnPrimaryColor">#06201F</Color>
      <Color x:Key="PrimaryContainerColor">#123230</Color>
      <Color x:Key="OnPrimaryContainerColor">#A9E9E5</Color>
      <Color x:Key="SecondaryColor">#5B97F7</Color>
      <Color x:Key="OnSecondaryColor">#04204A</Color>
      <Color x:Key="SecondaryContainerColor">#17263E</Color>
      <Color x:Key="OnSecondaryContainerColor">#CFE0FF</Color>
      <Color x:Key="TertiaryColor">#F6AE33</Color>
      <Color x:Key="OnTertiaryColor">#3A2400</Color>
      <Color x:Key="TertiaryContainerColor">#332915</Color>
      <Color x:Key="OnTertiaryContainerColor">#FCE8C8</Color>
      <Color x:Key="ErrorColor">#F26B6B</Color>
      <Color x:Key="OnErrorColor">#3A0A0A</Color>
      <Color x:Key="SurfaceColor">#181E20</Color>
      <Color x:Key="OnSurfaceColor">#ECF1F2</Color>
      <Color x:Key="SurfaceVariantColor">#222A2C</Color>
      <Color x:Key="OnSurfaceVariantColor">#9AA4A9</Color>
      <Color x:Key="BackgroundColor">#0E1213</Color>
      <Color x:Key="OnBackgroundColor">#ECF1F2</Color>
      <Color x:Key="OutlineColor">#3A4448</Color>
      <Color x:Key="OutlineVariantColor">#2B3336</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
