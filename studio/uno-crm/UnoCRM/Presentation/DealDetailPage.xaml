<Page x:Class="UnoCRM.Presentation.DealDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource DashboardPageBackgroundBrush}">

  <Grid Background="{ThemeResource DashboardPageBackgroundBrush}"
        utu:SafeArea.Insets="Top,Bottom">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <Grid Padding="{utu:Responsive Narrow='20,16,20,32', Wide='28,24,28,28'}"
            HorizontalAlignment="Stretch">
        <Grid MaxWidth="720"
              HorizontalAlignment="Stretch"
              RowSpacing="20">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Header: back button + breadcrumb -->
          <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button uen:Navigation.Request="-"
                    AutomationProperties.Name="Back"
                    Style="{StaticResource DashboardIconButtonStyle}">
              <PathIcon Data="F1 M15.5303 4.21967C15.8232 4.51256 15.8232 4.98744 15.5303 5.28033L8.81066 12L15.5303 18.7197C15.8232 19.0126 15.8232 19.4874 15.5303 19.7803C15.2374 20.0732 14.7626 20.0732 14.4697 19.7803L7.21967 12.5303C6.92678 12.2374 6.92678 11.7626 7.21967 11.4697L14.4697 4.21967C14.7626 3.92678 15.2374 3.92678 15.5303 4.21967Z"
                      Foreground="{ThemeResource DashboardPrimaryTextBrush}" />
            </Button>
            <TextBlock Text="Deal Details"
                       Style="{StaticResource DashboardSectionLabelStyle}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Headline card: company, stage pill, amount -->
          <Border Grid.Row="1"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="28,26">
            <StackPanel Spacing="16">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Deal.Company}"
                           Style="{StaticResource DashboardCardTitleStyle}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        CornerRadius="{StaticResource RadiusMd}"
                        Padding="12,6"
                        Background="{ThemeResource DashboardAccentSoftBrush}">
                  <TextBlock Text="{Binding Deal.StageDisplay}"
                             Foreground="{ThemeResource DashboardAccentBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Border>
              </Grid>

              <StackPanel Spacing="2">
                <TextBlock Text="DEAL VALUE"
                           Style="{StaticResource DashboardSectionLabelStyle}" />
                <TextBlock Text="{Binding Deal.AmountDisplay}"
                           Style="{StaticResource DashboardMetricValueStyle}"
                           FontSize="44" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Facts grid -->
          <Border Grid.Row="2"
                  Style="{StaticResource DashboardPanelBorderStyle}"
                  Padding="28,24">
            <StackPanel Spacing="18">
              <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                  <TextBlock Text="OWNER" Style="{StaticResource DashboardSectionLabelStyle}" />
                  <TextBlock Text="{Binding Deal.Owner}" Style="{StaticResource DashboardBodyTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="LEAD SOURCE" Style="{StaticResource DashboardSectionLabelStyle}" />
                  <TextBlock Text="{Binding Deal.Source}" Style="{StaticResource DashboardBodyTextStyle}" />
                </StackPanel>
              </Grid>

              <Border Height="1" Background="{ThemeResource DashboardDividerBrush}" />

              <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                  <TextBlock Text="HEALTH" Style="{StaticResource DashboardSectionLabelStyle}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                             Fill="{Binding Deal.AccentKey, Converter={StaticResource ResourceKeyToBrush}}" />
                    <TextBlock Text="{Binding Deal.HealthDisplay}"
                               Style="{StaticResource DashboardBodyTextStyle}"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="AGE IN STAGE" Style="{StaticResource DashboardSectionLabelStyle}" />
                  <TextBlock Text="{Binding Deal.MetaDisplay}" Style="{StaticResource DashboardBodyTextStyle}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
