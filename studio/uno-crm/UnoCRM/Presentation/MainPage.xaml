<Page x:Class="UnoCRM.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource DashboardPageBackgroundBrush}">

  <!--
    Navigation shell. Owns the chrome once for the whole app: a NavigationView pane on
    wide layouts and a bottom TabBar on narrow ones. Responsive switching is driven by the
    Toolkit {utu:Responsive} extension on each property (not AdaptiveTrigger/VisualState) so
    it applies reliably to this navigation-injected page and matches the content pages'
    Narrow/Wide breakpoints. The content region below is left empty - Uno.Extensions
    Navigation injects the active route (Dashboard / Pipeline / Leads / Contacts) into it.
    Icons are PathIcon vector geometry (Fluent UI System Icons, 24x24 regular) rather than
    FontIcon glyphs, so they render in Studio / Hot Design where Segoe Fluent Icons is absent.
  -->
  <Grid x:Name="RootShellGrid" uen:Region.Attached="True">

    <!-- NavigationView: sidebar pane on Wide; collapsed (TabBar takes over) on Narrow -->
    <NavigationView x:Name="NavView"
                    uen:Region.Attached="True"
                    IsSettingsVisible="False"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="{utu:Responsive Narrow=LeftMinimal, Wide=Auto}"
                    IsPaneToggleButtonVisible="{utu:Responsive Narrow=False, Wide=True}"
                    IsPaneOpen="{utu:Responsive Narrow=False, Wide=True}">
