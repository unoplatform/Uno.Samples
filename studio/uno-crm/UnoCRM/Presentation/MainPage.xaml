      <NavigationView.Content>
        <!--
          Single cell so the floating TabBar OVERLAYS the content (last in z-order) rather than
          reserving its own row. Content fills the full height and scrolls behind the translucent
          Liquid-Glass bar (HIG peek-through); each content page's Narrow root already carries a
          bottom Padding + SafeArea inset so its last item clears the floating bar.
        -->
        <Grid>
          <!-- Shared content area - navigation framework injects the active page here -->
          <Grid uen:Region.Attached="True"
                uen:Region.Navigator="Visibility" />

          <!-- Bottom floating TabBar: overlays content on Narrow, hidden once the pane appears on Wide -->
          <utu:TabBar x:Name="BottomTabs"
