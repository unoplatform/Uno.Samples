<Page x:Class="UnoCRM.Presentation.PipelinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:UnoCRM.Controls"
      Background="{ThemeResource DashboardPageBackgroundBrush}">
  <Page.Resources>
    <!-- One deal tile, bound to a Deal from the shared dataset. Reused by every stage column
         (desktop) and by the stacked stage list (mobile). -->
    <DataTemplate x:Key="DealCardTemplate">
      <!-- The whole card is a real Button (accessible + tactile press) that opens the deal detail
           via the navigation-data route. -->
      <Button Style="{StaticResource ClickableCardButtonStyle}"
              uen:Navigation.Request="DealDetail"
              uen:Navigation.Data="{Binding}"
              AutomationProperties.Name="{Binding Company}">
        <controls:PipelineCard Company="{Binding Company}"
                               Amount="{Binding AmountDisplay}"
                               Owner="{Binding Owner}"
                               Meta="{Binding MetaDisplay}"
                               IsWon="{Binding IsWon}"
                               Accent="{Binding AccentKey, Converter={StaticResource ResourceKeyToBrush}}"
                               MetaBrush="{Binding MetaKey, Converter={StaticResource ResourceKeyToBrush}}" />
      </Button>
    </DataTemplate>

    <ItemsPanelTemplate x:Key="DealStackPanel">
      <StackPanel Spacing="12" />
    </ItemsPanelTemplate>

    <!-- A full mobile stage section: colored header with live count, then its deal cards. -->
    <DataTemplate x:Key="MobileStageTemplate">
      <StackPanel Spacing="12" Margin="0,0,0,6">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                   Fill="{Binding AccentKey, Converter={StaticResource ResourceKeyToBrush}}" />
          <TextBlock Text="{Binding Name}" Style="{StaticResource DashboardSectionLabelStyle}" VerticalAlignment="Center" />
          <Border CornerRadius="8" Padding="6,1" VerticalAlignment="Center"
                  Background="{Binding SoftKey, Converter={StaticResource ResourceKeyToBrush}}">
            <TextBlock Text="{Binding Count}" FontSize="11"
                       Foreground="{Binding AccentKey, Converter={StaticResource ResourceKeyToBrush}}" />
          </Border>
        </StackPanel>
        <ItemsControl ItemsSource="{Binding Deals}"
                      ItemTemplate="{StaticResource DealCardTemplate}"
                      ItemsPanel="{StaticResource DealStackPanel}" />
      </StackPanel>
    </DataTemplate>
  </Page.Resources>
  <Grid Background="{ThemeResource DashboardPageBackgroundBrush}">
    <Grid x:Name="DesktopRoot" Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
          <Grid Padding="28,20,28,28"
          RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
              <TextBlock Text="Sales Pipeline"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="30" />
              <TextBlock Text="Manage and track your deals across stages"
                         Style="{StaticResource DashboardSubtleTextStyle}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <Viewbox Width="16" Height="16">
                  <Path Data="F1 M16.1017 17.1624C14.717 18.3101 12.9391 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11C19 12.9391 18.3101 14.717 17.1624 16.1018L21.7803 20.7197C22.0732 21.0126 22.0732 21.4874 21.7803 21.7803C21.4874 22.0732 21.0125 22.0732 20.7196 21.7803L16.1017 17.1624ZM17.5 11C17.5 7.41015 14.5899 4.5 11 4.5C7.41015 4.5 4.5 7.41015 4.5 11C4.5 14.5899 7.41015 17.5 11 17.5C14.5899 17.5 17.5 14.5899 17.5 11Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </Button>
              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <Viewbox Width="17" Height="17">
                  <Path Data="F1 M12 2.00098C16.0041 2.00098 19.25 5.24691 19.25 9.25098C19.25 11.347 18.3493 13.2707 16.5869 14.9929C16.51 15.0681 16.4504 15.1586 16.4118 15.2582L16.3804 15.3605L15.2493 20.2561C15.0266 21.22 14.2035 21.9183 13.2302 21.993L13.057 21.9996H10.9433C9.95374 21.9996 9.08791 21.3545 8.79629 20.4228L8.75088 20.2555L7.62132 15.3607C7.58904 15.2208 7.51728 15.0931 7.41456 14.9928C5.73515 13.3526 4.83778 11.5297 4.75613 9.54923L4.75 9.25098L4.75388 9.01166C4.88014 5.11837 8.07601 2.00098 12 2.00098ZM14.115 18.499H9.884L10.2125 19.9182C10.2831 20.2245 10.5357 20.4504 10.8401 20.4925L10.9433 20.4996H13.057C13.3713 20.4996 13.6481 20.3044 13.7577 20.0174L13.7878 19.9184L14.115 18.499ZM12 3.50098C8.89821 3.50098 6.37006 5.95699 6.25415 9.03042L6.25 9.25098L6.25672 9.52799C6.33286 11.0913 7.05722 12.5471 8.46262 13.9197C8.72675 14.1777 8.92265 14.496 9.03422 14.846L9.08291 15.0235L9.538 16.999H14.461L14.9189 15.0228C15.0019 14.6634 15.1718 14.3309 15.4124 14.0539L15.5386 13.9201C16.9432 12.5475 17.6672 11.0916 17.7433 9.52803L17.75 9.25098L17.7458 9.03042C17.6299 5.95699 15.1018 3.50098 12 3.50098Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </Button>
              <Button Style="{StaticResource DashboardPrimaryButtonStyle}"
                      MinWidth="92">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8">
                  <Viewbox Width="13" Height="13">
                    <Path Data="F1 M11.25 4.75 H12.75 V11.25 H19.25 V12.75 H12.75 V19.25 H11.25 V12.75 H4.75 V11.25 H11.25 Z"
                          Stretch="Uniform"
                          Fill="White" />
                  </Viewbox>
                  <TextBlock Text="Add Deal"
                             Foreground="White"
                             FontSize="14" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>

          <StackPanel Grid.Row="1"
                      Orientation="Horizontal"
                      Spacing="12">
            <Button Style="{StaticResource DashboardFilterButtonStyle}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="All Pipelines"
                           FontSize="13"
                           Foreground="{ThemeResource DashboardPrimaryTextBrush}" />
                <Viewbox Width="12" Height="12">
                  <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource DashboardFilterButtonStyle}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="This Quarter"
                           FontSize="13"
                           Foreground="{ThemeResource DashboardPrimaryTextBrush}" />
                <Viewbox Width="12" Height="12">
                  <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource DashboardFilterButtonStyle}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="All Reps"
                           FontSize="13"
                           Foreground="{ThemeResource DashboardPrimaryTextBrush}" />
                <Viewbox Width="12" Height="12">
                  <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Kanban board: each column is a stage from the shared dataset; the count badge and
               the cards are bound, so they always agree with the Dashboard and Leads pages. -->
          <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="{ThemeResource DashboardBlueBrush}" Margin="0,5,0,0" />
                <TextBlock Text="NEW LEAD" Style="{StaticResource DashboardSectionLabelStyle}" />
                <Border Background="{ThemeResource DashboardBlueSoftBrush}" CornerRadius="8" Padding="6,1">
                  <TextBlock Text="{Binding NewLead.Count}" Foreground="{ThemeResource DashboardBlueBrush}" FontSize="11" />
                </Border>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding NewLead.Deals}"
                            ItemTemplate="{StaticResource DealCardTemplate}"
                            ItemsPanel="{StaticResource DealStackPanel}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="{ThemeResource DashboardPurpleBrush}" Margin="0,5,0,0" />
                <TextBlock Text="QUALIFIED" Style="{StaticResource DashboardSectionLabelStyle}" />
                <Border Background="{ThemeResource DashboardPurpleSoftBrush}" CornerRadius="8" Padding="6,1">
                  <TextBlock Text="{Binding Qualified.Count}" Foreground="{ThemeResource DashboardPurpleBrush}" FontSize="11" />
                </Border>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding Qualified.Deals}"
                            ItemTemplate="{StaticResource DealCardTemplate}"
                            ItemsPanel="{StaticResource DealStackPanel}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="{ThemeResource DashboardAmberBrush}" Margin="0,5,0,0" />
                <TextBlock Text="PROPOSAL" Style="{StaticResource DashboardSectionLabelStyle}" />
                <Border Background="{ThemeResource DashboardAmberSoftBrush}" CornerRadius="8" Padding="6,1">
                  <TextBlock Text="{Binding Proposal.Count}" Foreground="{ThemeResource DashboardAmberBrush}" FontSize="11" />
                </Border>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding Proposal.Deals}"
                            ItemTemplate="{StaticResource DealCardTemplate}"
                            ItemsPanel="{StaticResource DealStackPanel}" />
            </StackPanel>

            <StackPanel Grid.Column="3" Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="{ThemeResource DashboardRedBrush}" Margin="0,5,0,0" />
                <TextBlock Text="NEGOTIATION" Style="{StaticResource DashboardSectionLabelStyle}" />
                <Border Background="{ThemeResource DashboardRedSoftBrush}" CornerRadius="8" Padding="6,1">
                  <TextBlock Text="{Binding Negotiation.Count}" Foreground="{ThemeResource DashboardRedBrush}" FontSize="11" />
                </Border>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding Negotiation.Deals}"
                            ItemTemplate="{StaticResource DealCardTemplate}"
                            ItemsPanel="{StaticResource DealStackPanel}" />
            </StackPanel>

            <StackPanel Grid.Column="4" Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="{ThemeResource DashboardGreenBrush}" Margin="0,5,0,0" />
                <TextBlock Text="CLOSED WON" Style="{StaticResource DashboardSectionLabelStyle}" />
                <Border Background="{ThemeResource DashboardGreenSoftBrush}" CornerRadius="8" Padding="6,1">
                  <TextBlock Text="{Binding ClosedWon.Count}" Foreground="{ThemeResource DashboardGreenBrush}" FontSize="11" />
                </Border>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding ClosedWon.Deals}"
                            ItemTemplate="{StaticResource DealCardTemplate}"
                            ItemsPanel="{StaticResource DealStackPanel}" />
            </StackPanel>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>

    <Grid x:Name="MobileRoot" Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}" utu:SafeArea.Insets="Top,Bottom">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20,16,20,130"
              RowSpacing="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock Text="Sales Pipeline"
                         Style="{StaticResource DashboardCardTitleStyle}"
                         FontSize="32" />
              <TextBlock Text="Manage and track your deals across stages"
                         Style="{StaticResource DashboardSubtleTextStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Top">
              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <Viewbox Width="16" Height="16">
                  <Path Data="F1 M16.1017 17.1624C14.717 18.3101 12.9391 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11C19 12.9391 18.3101 14.717 17.1624 16.1018L21.7803 20.7197C22.0732 21.0126 22.0732 21.4874 21.7803 21.7803C21.4874 22.0732 21.0125 22.0732 20.7196 21.7803L16.1017 17.1624ZM17.5 11C17.5 7.41015 14.5899 4.5 11 4.5C7.41015 4.5 4.5 7.41015 4.5 11C4.5 14.5899 7.41015 17.5 11 17.5C14.5899 17.5 17.5 14.5899 17.5 11Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </Button>
              <Button Style="{StaticResource DashboardIconButtonStyle}">
                <Viewbox Width="17" Height="17">
                  <Path Data="F1 M12 2.00098C16.0041 2.00098 19.25 5.24691 19.25 9.25098C19.25 11.347 18.3493 13.2707 16.5869 14.9929C16.51 15.0681 16.4504 15.1586 16.4118 15.2582L16.3804 15.3605L15.2493 20.2561C15.0266 21.22 14.2035 21.9183 13.2302 21.993L13.057 21.9996H10.9433C9.95374 21.9996 9.08791 21.3545 8.79629 20.4228L8.75088 20.2555L7.62132 15.3607C7.58904 15.2208 7.51728 15.0931 7.41456 14.9928C5.73515 13.3526 4.83778 11.5297 4.75613 9.54923L4.75 9.25098L4.75388 9.01166C4.88014 5.11837 8.07601 2.00098 12 2.00098ZM14.115 18.499H9.884L10.2125 19.9182C10.2831 20.2245 10.5357 20.4504 10.8401 20.4925L10.9433 20.4996H13.057C13.3713 20.4996 13.6481 20.3044 13.7577 20.0174L13.7878 19.9184L14.115 18.499ZM12 3.50098C8.89821 3.50098 6.37006 5.95699 6.25415 9.03042L6.25 9.25098L6.25672 9.52799C6.33286 11.0913 7.05722 12.5471 8.46262 13.9197C8.72675 14.1777 8.92265 14.496 9.03422 14.846L9.08291 15.0235L9.538 16.999H14.461L14.9189 15.0228C15.0019 14.6634 15.1718 14.3309 15.4124 14.0539L15.5386 13.9201C16.9432 12.5475 17.6672 11.0916 17.7433 9.52803L17.75 9.25098L17.7458 9.03042C17.6299 5.95699 15.1018 3.50098 12 3.50098Z"
                        Stretch="Uniform"
                        Fill="{ThemeResource DashboardMutedTextBrush}" />
                </Viewbox>
              </Button>
            </StackPanel>
          </Grid>

          <Button Grid.Row="1"
                  Style="{StaticResource DashboardPrimaryButtonStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
              <Viewbox Width="13" Height="13">
                <Path Data="F1 M11.25 4.75 H12.75 V11.25 H19.25 V12.75 H12.75 V19.25 H11.25 V12.75 H4.75 V11.25 H11.25 Z"
                      Stretch="Uniform"
                      Fill="White" />
              </Viewbox>
              <TextBlock Text="Add Deal"
                         Foreground="White"
                         FontSize="14" />
            </StackPanel>
          </Button>

          <ScrollViewer Grid.Row="2"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="All Pipelines" FontSize="13" />
                  <Viewbox Width="12" Height="12">
                    <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                          Stretch="Uniform"
                          Fill="{ThemeResource DashboardMutedTextBrush}" />
                  </Viewbox>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="This Quarter" FontSize="13" />
                  <Viewbox Width="12" Height="12">
                    <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                          Stretch="Uniform"
                          Fill="{ThemeResource DashboardMutedTextBrush}" />
                  </Viewbox>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="All Reps" FontSize="13" />
                  <Viewbox Width="12" Height="12">
                    <Path Data="F1 M4.21967 8.46967C4.51256 8.17678 4.98744 8.17678 5.28033 8.46967L12 15.1893L18.7197 8.46967C19.0126 8.17678 19.4874 8.17678 19.7803 8.46967C20.0732 8.76256 20.0732 9.23744 19.7803 9.53033L12.5303 16.7803C12.2374 17.0732 11.7626 17.0732 11.4697 16.7803L4.21967 9.53033C3.92678 9.23744 3.92678 8.76256 4.21967 8.46967Z"
                          Stretch="Uniform"
                          Fill="{ThemeResource DashboardMutedTextBrush}" />
                  </Viewbox>
                </StackPanel>
              </Button>
            </StackPanel>
          </ScrollViewer>

          <!-- All stages, stacked, bound to the same dataset the desktop board uses. -->
          <ItemsControl Grid.Row="3"
                        ItemsSource="{Binding Stages}"
                        ItemTemplate="{StaticResource MobileStageTemplate}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="18" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
