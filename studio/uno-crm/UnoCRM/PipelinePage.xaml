          <Button Grid.Row="1"
                  Style="{StaticResource DashboardPrimaryButtonStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE710;"
                        FontSize="12"
                        Foreground="White" />
              <TextBlock Text="Add Deal"
                         Foreground="White"
                         FontSize="14" />
            </StackPanel>
          </Button>

          <ScrollViewer Grid.Row="2"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="All Pipelines" FontSize="13" />
                  <FontIcon Glyph="&#xE70D;" FontSize="10" Foreground="{StaticResource DashboardMutedTextBrush}" />
                </StackPanel>
              </Button>
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="This Quarter" FontSize="13" />
                  <FontIcon Glyph="&#xE70D;" FontSize="10" Foreground="{StaticResource DashboardMutedTextBrush}" />
                </StackPanel>
              </Button>
              <Button Style="{StaticResource DashboardFilterButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="All Reps" FontSize="13" />
                  <FontIcon Glyph="&#xE70D;" FontSize="10" Foreground="{StaticResource DashboardMutedTextBrush}" />
                </StackPanel>
              </Button>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="3" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="10" Height="10" Fill="{StaticResource DashboardBlueBrush}" Margin="0,5,0,0" />
              <TextBlock Text="NEW LEAD" Style="{StaticResource DashboardSectionLabelStyle}" />
              <Border Background="{StaticResource DashboardBlueSoftBrush}" CornerRadius="8" Padding="6,1">
                <TextBlock Text="4" Foreground="{StaticResource DashboardBlueBrush}" FontSize="11" />
              </Border>
            </StackPanel>
            <Border Style="{StaticResource DashboardKanbanCardStyle}">
              <StackPanel Spacing="8">
                <TextBlock Text="Acme Corp" FontFamily="Georgia" FontSize="17" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <TextBlock Text="$45,000" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <Grid>
                  <TextBlock Text="Sarah Chen" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="13" />
                  <TextBlock HorizontalAlignment="Right" Text="2d" Style="{StaticResource DashboardMicroTextStyle}" FontSize="11" />
                </Grid>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardKanbanCardStyle}">
              <StackPanel Spacing="8">
                <TextBlock Text="TechVision Inc" FontFamily="Georgia" FontSize="17" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <TextBlock Text="$28,500" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <Grid>
                  <TextBlock Text="Mike Johnson" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="13" />
                  <TextBlock HorizontalAlignment="Right" Text="5d" Style="{StaticResource DashboardMicroTextStyle}" FontSize="11" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Row="4" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="10" Height="10" Fill="{StaticResource DashboardPurpleBrush}" Margin="0,5,0,0" />
              <TextBlock Text="QUALIFIED" Style="{StaticResource DashboardSectionLabelStyle}" />
              <Border Background="{StaticResource DashboardPurpleSoftBrush}" CornerRadius="8" Padding="6,1">
                <TextBlock Text="3" Foreground="{StaticResource DashboardPurpleBrush}" FontSize="11" />
              </Border>
            </StackPanel>
            <Border Style="{StaticResource DashboardKanbanCardStyle}">
              <StackPanel Spacing="8">
                <TextBlock Text="NovaTech" FontFamily="Georgia" FontSize="17" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <TextBlock Text="$89,000" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <Grid>
                  <TextBlock Text="David Kim" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="13" />
                  <TextBlock HorizontalAlignment="Right" Text="8d" Style="{StaticResource DashboardMicroTextStyle}" FontSize="11" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Row="5" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="10" Height="10" Fill="{StaticResource DashboardAmberBrush}" Margin="0,5,0,0" />
              <TextBlock Text="PROPOSAL" Style="{StaticResource DashboardSectionLabelStyle}" />
              <Border Background="{StaticResource DashboardAmberSoftBrush}" CornerRadius="8" Padding="6,1">
                <TextBlock Text="3" Foreground="{StaticResource DashboardAmberBrush}" FontSize="11" />
              </Border>
            </StackPanel>
            <Border Style="{StaticResource DashboardKanbanCardStyle}">
              <StackPanel Spacing="8">
                <TextBlock Text="Meridian Health" FontFamily="Georgia" FontSize="17" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <TextBlock Text="$124,000" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <Grid>
                  <TextBlock Text="Rachel Adams" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="13" />
                  <TextBlock HorizontalAlignment="Right" Text="15d" Style="{StaticResource DashboardMicroTextStyle}" FontSize="11" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Row="6" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="10" Height="10" Fill="{StaticResource DashboardGreenBrush}" Margin="0,5,0,0" />
              <TextBlock Text="CLOSED WON" Style="{StaticResource DashboardSectionLabelStyle}" />
              <Border Background="{StaticResource DashboardGreenSoftBrush}" CornerRadius="8" Padding="6,1">
                <TextBlock Text="3" Foreground="{StaticResource DashboardGreenBrush}" FontSize="11" />
              </Border>
            </StackPanel>
            <Border Style="{StaticResource DashboardKanbanCardStyle}">
              <StackPanel Spacing="8">
                <Grid>
                  <TextBlock Text="Summit Retail" FontFamily="Georgia" FontSize="17" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                  <FontIcon HorizontalAlignment="Right" Glyph="&#xE73E;" FontSize="12" Foreground="{StaticResource DashboardGreenBrush}" Margin="0,2,0,0" />
                </Grid>
                <TextBlock Text="$156,000" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource DashboardPrimaryTextBrush}" />
                <Grid>
                  <TextBlock Text="Paul Martinez" Style="{StaticResource DashboardSubtleTextStyle}" FontSize="13" />
                  <TextBlock HorizontalAlignment="Right" Text="Won" Foreground="{StaticResource DashboardGreenBrush}" FontSize="11" FontWeight="SemiBold" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>

      <Border VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="16,0,16,18"
              Padding="10"
              MinWidth="320"
              MaxWidth="560"
              CornerRadius="34"
              Background="{StaticResource DashboardSurfaceBrush}"
              BorderBrush="{StaticResource DashboardBorderBrush}"
              BorderThickness="1">
        <Grid ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  Click="NavigateToDashboard_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE80F;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="HOME"
                         HorizontalAlignment="Center"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>

          <Border Grid.Column="1"
                  Background="{StaticResource DashboardAccentBrush}"
                  CornerRadius="28"
                  Padding="20,14">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE9D2;"
                        FontSize="20"
                        Foreground="White" />
              <TextBlock Text="PIPELINE"
                         HorizontalAlignment="Center"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Border>

          <Button Grid.Column="2"
                  Click="NavigateToLeads_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE716;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="LEADS"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>

          <Button Grid.Column="3"
                  Click="NavigateToContacts_Click"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="&#xE77B;"
                        FontSize="20"
                        Foreground="{StaticResource DashboardSubtleTextBrush}" />
              <TextBlock Text="CONTACTS"
                         Foreground="{StaticResource DashboardSubtleTextBrush}"
                         FontSize="12" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>