<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Theme-aware CRM palette. "Light" is used in OS/app light mode, "Default" in dark mode.
    Each dictionary is self-contained: the colors are declared first, then the brushes reference
    those colors so the whole palette swaps with the system theme. The app does not set
    RequestedTheme, so it follows the OS theme automatically.

    The keys are intentionally domain-named (Dashboard*) rather than semantic role names: they are
    consumed only by this app's own styles and pages, never by built-in control templates, so a
    self-documenting dashboard vocabulary is clearer than Primary/OnSurface here.

    Chart1..Chart5 are a dedicated *categorical* chart palette (teal / violet / amber / red /
    green), spread ~72 degrees apart in hue so adjacent pie/donut segments and legend swatches read
    as distinct. The brand teal is Chart1 so the accent stays present in the charts. Single-series
    charts (the lead-trend line, the source bar) keep the semantic accent/blue instead.
  -->
  <ResourceDictionary.ThemeDictionaries>

    <!-- LIGHT THEME -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="DashboardPageBackgroundColor">#FFFAFAFA</Color>
      <Color x:Key="DashboardSurfaceColor">#FFFFFFFF</Color>
      <Color x:Key="DashboardMutedSurfaceColor">#FFF8F8F8</Color>
      <Color x:Key="DashboardControlColor">#FFF0F0F0</Color>
      <Color x:Key="DashboardBorderColor">#FFE5E5E5</Color>
      <Color x:Key="DashboardDividerColor">#FFF0F0F0</Color>
      <Color x:Key="DashboardMutedTextColor">#FFAAAAAA</Color>
      <Color x:Key="DashboardSubtleTextColor">#FF8A8A8A</Color>
      <Color x:Key="DashboardDisabledTextColor">#FFBBBBBB</Color>
      <Color x:Key="DashboardPrimaryTextColor">#FF1A1A1A</Color>
      <Color x:Key="DashboardAccentColor">#FF0D6E6E</Color>
      <Color x:Key="DashboardAccentSoftColor">#FFE8F4F3</Color>
      <Color x:Key="DashboardBlueColor">#FF3B82F6</Color>
      <Color x:Key="DashboardPurpleColor">#FF8B5CF6</Color>
      <Color x:Key="DashboardAmberColor">#FFF59E0B</Color>
      <Color x:Key="DashboardRedColor">#FFEF4444</Color>
      <Color x:Key="DashboardGreenColor">#FF10B981</Color>
      <Color x:Key="DashboardLostColor">#FF6B7280</Color>
      <Color x:Key="DashboardActivityOrangeColor">#FFE07B54</Color>
      <Color x:Key="DashboardActivitySoftColor">#FFFFF2EC</Color>
      <Color x:Key="DashboardBlueSoftColor">#FFEFF4FF</Color>
      <Color x:Key="DashboardPurpleSoftColor">#FFF5F0FF</Color>
      <Color x:Key="DashboardAmberSoftColor">#FFFFF5E7</Color>
      <Color x:Key="DashboardRedSoftColor">#FFFFEFEF</Color>
      <Color x:Key="DashboardGreenSoftColor">#FFEFFBF6</Color>

      <!-- Dedicated categorical chart palette -->
      <Color x:Key="Chart1Color">#FF0D6E6E</Color>
      <Color x:Key="Chart2Color">#FF8B5CF6</Color>
      <Color x:Key="Chart3Color">#FFF59E0B</Color>
      <Color x:Key="Chart4Color">#FFEF4444</Color>
      <Color x:Key="Chart5Color">#FF10B981</Color>

      <SolidColorBrush x:Key="DashboardPageBackgroundBrush" Color="{StaticResource DashboardPageBackgroundColor}" />
      <SolidColorBrush x:Key="DashboardSurfaceBrush" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="DashboardMutedSurfaceBrush" Color="{StaticResource DashboardMutedSurfaceColor}" />
      <SolidColorBrush x:Key="DashboardControlBrush" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="DashboardBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="DashboardDividerBrush" Color="{StaticResource DashboardDividerColor}" />
      <SolidColorBrush x:Key="DashboardMutedTextBrush" Color="{StaticResource DashboardMutedTextColor}" />
      <SolidColorBrush x:Key="DashboardSubtleTextBrush" Color="{StaticResource DashboardSubtleTextColor}" />
      <SolidColorBrush x:Key="DashboardDisabledTextBrush" Color="{StaticResource DashboardDisabledTextColor}" />
      <SolidColorBrush x:Key="DashboardPrimaryTextBrush" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="DashboardAccentBrush" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="DashboardAccentSoftBrush" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="DashboardBlueBrush" Color="{StaticResource DashboardBlueColor}" />
      <SolidColorBrush x:Key="DashboardPurpleBrush" Color="{StaticResource DashboardPurpleColor}" />
      <SolidColorBrush x:Key="DashboardAmberBrush" Color="{StaticResource DashboardAmberColor}" />
      <SolidColorBrush x:Key="DashboardRedBrush" Color="{StaticResource DashboardRedColor}" />
      <SolidColorBrush x:Key="DashboardGreenBrush" Color="{StaticResource DashboardGreenColor}" />
      <SolidColorBrush x:Key="DashboardLostBrush" Color="{StaticResource DashboardLostColor}" />
      <SolidColorBrush x:Key="DashboardActivityOrangeBrush" Color="{StaticResource DashboardActivityOrangeColor}" />
      <SolidColorBrush x:Key="DashboardActivitySoftBrush" Color="{StaticResource DashboardActivitySoftColor}" />
      <SolidColorBrush x:Key="DashboardBlueSoftBrush" Color="{StaticResource DashboardBlueSoftColor}" />
      <SolidColorBrush x:Key="DashboardPurpleSoftBrush" Color="{StaticResource DashboardPurpleSoftColor}" />
      <SolidColorBrush x:Key="DashboardAmberSoftBrush" Color="{StaticResource DashboardAmberSoftColor}" />
      <SolidColorBrush x:Key="DashboardRedSoftBrush" Color="{StaticResource DashboardRedSoftColor}" />
      <SolidColorBrush x:Key="DashboardGreenSoftBrush" Color="{StaticResource DashboardGreenSoftColor}" />

      <!-- ComboBox lightweight styling: align the closed box, chevron, drop-down and items with the dashboard palette. -->
      <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundUnfocused" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{StaticResource DashboardMutedTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPointerOver" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPressed" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{StaticResource DashboardAccentColor}" />
    </ResourceDictionary>

    <!-- DARK THEME ("Default" maps to the OS dark mode) -->
    <ResourceDictionary x:Key="Default">
      <Color x:Key="DashboardPageBackgroundColor">#FF0E1213</Color>
      <Color x:Key="DashboardSurfaceColor">#FF181E20</Color>
      <Color x:Key="DashboardMutedSurfaceColor">#FF13191A</Color>
      <Color x:Key="DashboardControlColor">#FF222A2C</Color>
      <Color x:Key="DashboardBorderColor">#FF2B3336</Color>
      <Color x:Key="DashboardDividerColor">#FF232A2C</Color>
      <Color x:Key="DashboardMutedTextColor">#FF7E888D</Color>
      <Color x:Key="DashboardSubtleTextColor">#FF9AA4A9</Color>
      <Color x:Key="DashboardDisabledTextColor">#FF565E62</Color>
      <Color x:Key="DashboardPrimaryTextColor">#FFECF1F2</Color>
      <Color x:Key="DashboardAccentColor">#FF1FA39E</Color>
      <Color x:Key="DashboardAccentSoftColor">#FF123230</Color>
      <Color x:Key="DashboardBlueColor">#FF5B97F7</Color>
      <Color x:Key="DashboardPurpleColor">#FFA482F8</Color>
      <Color x:Key="DashboardAmberColor">#FFF6AE33</Color>
      <Color x:Key="DashboardRedColor">#FFF26B6B</Color>
      <Color x:Key="DashboardGreenColor">#FF2DD0A0</Color>
      <Color x:Key="DashboardLostColor">#FF8B939E</Color>
      <Color x:Key="DashboardActivityOrangeColor">#FFE89070</Color>
      <Color x:Key="DashboardActivitySoftColor">#FF33241D</Color>
      <Color x:Key="DashboardBlueSoftColor">#FF17263E</Color>
      <Color x:Key="DashboardPurpleSoftColor">#FF241D3A</Color>
      <Color x:Key="DashboardAmberSoftColor">#FF332915</Color>
      <Color x:Key="DashboardRedSoftColor">#FF3A2122</Color>
      <Color x:Key="DashboardGreenSoftColor">#FF123026</Color>

      <!-- Dedicated categorical chart palette -->
      <Color x:Key="Chart1Color">#FF1FA39E</Color>
      <Color x:Key="Chart2Color">#FFA482F8</Color>
      <Color x:Key="Chart3Color">#FFF6AE33</Color>
      <Color x:Key="Chart4Color">#FFF26B6B</Color>
      <Color x:Key="Chart5Color">#FF2DD0A0</Color>

      <SolidColorBrush x:Key="DashboardPageBackgroundBrush" Color="{StaticResource DashboardPageBackgroundColor}" />
      <SolidColorBrush x:Key="DashboardSurfaceBrush" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="DashboardMutedSurfaceBrush" Color="{StaticResource DashboardMutedSurfaceColor}" />
      <SolidColorBrush x:Key="DashboardControlBrush" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="DashboardBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="DashboardDividerBrush" Color="{StaticResource DashboardDividerColor}" />
      <SolidColorBrush x:Key="DashboardMutedTextBrush" Color="{StaticResource DashboardMutedTextColor}" />
      <SolidColorBrush x:Key="DashboardSubtleTextBrush" Color="{StaticResource DashboardSubtleTextColor}" />
      <SolidColorBrush x:Key="DashboardDisabledTextBrush" Color="{StaticResource DashboardDisabledTextColor}" />
      <SolidColorBrush x:Key="DashboardPrimaryTextBrush" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="DashboardAccentBrush" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="DashboardAccentSoftBrush" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="DashboardBlueBrush" Color="{StaticResource DashboardBlueColor}" />
      <SolidColorBrush x:Key="DashboardPurpleBrush" Color="{StaticResource DashboardPurpleColor}" />
      <SolidColorBrush x:Key="DashboardAmberBrush" Color="{StaticResource DashboardAmberColor}" />
      <SolidColorBrush x:Key="DashboardRedBrush" Color="{StaticResource DashboardRedColor}" />
      <SolidColorBrush x:Key="DashboardGreenBrush" Color="{StaticResource DashboardGreenColor}" />
      <SolidColorBrush x:Key="DashboardLostBrush" Color="{StaticResource DashboardLostColor}" />
      <SolidColorBrush x:Key="DashboardActivityOrangeBrush" Color="{StaticResource DashboardActivityOrangeColor}" />
      <SolidColorBrush x:Key="DashboardActivitySoftBrush" Color="{StaticResource DashboardActivitySoftColor}" />
      <SolidColorBrush x:Key="DashboardBlueSoftBrush" Color="{StaticResource DashboardBlueSoftColor}" />
      <SolidColorBrush x:Key="DashboardPurpleSoftBrush" Color="{StaticResource DashboardPurpleSoftColor}" />
      <SolidColorBrush x:Key="DashboardAmberSoftBrush" Color="{StaticResource DashboardAmberSoftColor}" />
      <SolidColorBrush x:Key="DashboardRedSoftBrush" Color="{StaticResource DashboardRedSoftColor}" />
      <SolidColorBrush x:Key="DashboardGreenSoftBrush" Color="{StaticResource DashboardGreenSoftColor}" />

      <!-- ComboBox lightweight styling: align the closed box, chevron, drop-down and items with the dashboard palette. -->
      <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxBackgroundUnfocused" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="{StaticResource DashboardAccentColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{StaticResource DashboardMutedTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPointerOver" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPressed" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource DashboardSurfaceColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource DashboardBorderColor}" />
      <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{StaticResource DashboardPrimaryTextColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="{StaticResource DashboardControlColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="{StaticResource DashboardAccentSoftColor}" />
      <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{StaticResource DashboardAccentColor}" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
