<UserControl x:Class="UnoCRM.Controls.BottomNavBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Bottom">

  <UserControl.Resources>
    <!--
      Bottom-nav item button. A dedicated template so the press/hover feedback is a
      rounded, theme-aware highlight (DashboardControlBrush) instead of the default
      WinUI square gray "ButtonBackgroundPressed" rectangle.
    -->
    <Style x:Key="BottomNavItemStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="UseSystemFocusVisuals" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid x:Name="ContentRoot"
                  Background="{TemplateBinding Background}"
                  CornerRadius="24">
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal" />
                  <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                      <Setter Target="ContentRoot.Background" Value="{ThemeResource DashboardControlBrush}" />
                    </VisualState.Setters>
                  </VisualState>
                  <VisualState x:Name="Pressed">
                    <VisualState.Setters>
                      <Setter Target="ContentRoot.Background" Value="{ThemeResource DashboardControlBrush}" />
                    </VisualState.Setters>
                  </VisualState>
                  <VisualState x:Name="Disabled" />
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Padding="{TemplateBinding Padding}"
                                Content="{TemplateBinding Content}" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid>
    <!-- Active-tab indicator: only the active item shows the accent pill + white content. -->
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="ActiveTabStates">
        <VisualState x:Name="Home">
          <VisualState.Setters>
            <Setter Target="HomePill.Background" Value="{ThemeResource DashboardAccentBrush}" />
            <Setter Target="HomeIcon.Foreground" Value="White" />
            <Setter Target="HomeLabel.Foreground" Value="White" />
            <Setter Target="HomeLabel.FontWeight" Value="SemiBold" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="Pipeline">
          <VisualState.Setters>
            <Setter Target="PipelinePill.Background" Value="{ThemeResource DashboardAccentBrush}" />
            <Setter Target="PipelineIcon.Foreground" Value="White" />
            <Setter Target="PipelineLabel.Foreground" Value="White" />
            <Setter Target="PipelineLabel.FontWeight" Value="SemiBold" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="Leads">
          <VisualState.Setters>
            <Setter Target="LeadsPill.Background" Value="{ThemeResource DashboardAccentBrush}" />
            <Setter Target="LeadsIcon.Foreground" Value="White" />
            <Setter Target="LeadsLabel.Foreground" Value="White" />
            <Setter Target="LeadsLabel.FontWeight" Value="SemiBold" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="Contacts">
          <VisualState.Setters>
            <Setter Target="ContactsPill.Background" Value="{ThemeResource DashboardAccentBrush}" />
            <Setter Target="ContactsIcon.Foreground" Value="White" />
            <Setter Target="ContactsLabel.Foreground" Value="White" />
            <Setter Target="ContactsLabel.FontWeight" Value="SemiBold" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Border x:Name="BarRoot"
            HorizontalAlignment="Center"
            Margin="16,0,16,18"
            Padding="10"
            MinWidth="320"
            MaxWidth="560"
            CornerRadius="34"
            Background="{ThemeResource DashboardSurfaceBrush}"
            BorderBrush="{ThemeResource DashboardBorderBrush}"
            BorderThickness="1">
      <Border.RenderTransform>
        <TranslateTransform x:Name="BarTransform" />
      </Border.RenderTransform>
      <Grid ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button x:Name="HomeButton"
                Grid.Column="0"
                Tag="Home"
                AutomationProperties.Name="Home"
                Click="OnTabClick"
                Style="{StaticResource BottomNavItemStyle}">
          <Border x:Name="HomePill"
                  CornerRadius="24"
                  Padding="4,10"
                  Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
              <FontIcon x:Name="HomeIcon"
                        Glyph="&#xE80F;"
                        FontSize="20"
                        Foreground="{ThemeResource DashboardSubtleTextBrush}" />
              <TextBlock x:Name="HomeLabel"
                         Text="HOME"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource DashboardSubtleTextBrush}"
                         FontSize="10"
                         CharacterSpacing="40" />
            </StackPanel>
          </Border>
        </Button>

        <Button x:Name="PipelineButton"
                Grid.Column="1"
                Tag="Pipeline"
                AutomationProperties.Name="Pipeline"
                Click="OnTabClick"
                Style="{StaticResource BottomNavItemStyle}">
          <Border x:Name="PipelinePill"
                  CornerRadius="24"
                  Padding="4,10"
                  Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
              <FontIcon x:Name="PipelineIcon"
                        Glyph="&#xE9D2;"
                        FontSize="20"
                        Foreground="{ThemeResource DashboardSubtleTextBrush}" />
              <TextBlock x:Name="PipelineLabel"
                         Text="PIPELINE"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource DashboardSubtleTextBrush}"
                         FontSize="10"
                         CharacterSpacing="40" />
            </StackPanel>
          </Border>
        </Button>

        <Button x:Name="LeadsButton"
                Grid.Column="2"
                Tag="Leads"
                AutomationProperties.Name="Leads"
                Click="OnTabClick"
                Style="{StaticResource BottomNavItemStyle}">
          <Border x:Name="LeadsPill"
                  CornerRadius="24"
                  Padding="4,10"
                  Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
              <FontIcon x:Name="LeadsIcon"
                        Glyph="&#xE716;"
                        FontSize="20"
                        Foreground="{ThemeResource DashboardSubtleTextBrush}" />
              <TextBlock x:Name="LeadsLabel"
                         Text="LEADS"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource DashboardSubtleTextBrush}"
                         FontSize="10"
                         CharacterSpacing="40" />
            </StackPanel>
          </Border>
        </Button>

        <Button x:Name="ContactsButton"
                Grid.Column="3"
                Tag="Contacts"
                AutomationProperties.Name="Contacts"
                Click="OnTabClick"
                Style="{StaticResource BottomNavItemStyle}">
          <Border x:Name="ContactsPill"
                  CornerRadius="24"
                  Padding="4,10"
                  Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
              <FontIcon x:Name="ContactsIcon"
                        Glyph="&#xE77B;"
                        FontSize="20"
                        Foreground="{ThemeResource DashboardSubtleTextBrush}" />
              <TextBlock x:Name="ContactsLabel"
                         Text="CONTACTS"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource DashboardSubtleTextBrush}"
                         FontSize="10"
                         CharacterSpacing="40" />
            </StackPanel>
          </Border>
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>
