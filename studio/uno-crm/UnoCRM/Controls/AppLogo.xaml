<UserControl x:Class="UnoCRM.Controls.AppLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    The CRM brand mark drawn with native XAML shapes (not an SVG <Image>): the bar-chart
    glyph on its dark #151515 tile. Rendering the gradient bars as Rectangles avoids any
    runtime SVG/gradient rendering gaps that left the image showing as a solid black tile.
    The 240x240 Canvas mirrors the source icon coordinates; the Viewbox scales it to fit.
  -->
  <Border CornerRadius="8" Background="#151515">
    <Viewbox Stretch="Uniform">
      <Canvas Width="240" Height="240">
        <Canvas.Resources>
          <LinearGradientBrush x:Key="BarBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Offset="0" Color="#18E1C6" />
            <GradientStop Offset="1" Color="#2EB9FF" />
          </LinearGradientBrush>
        </Canvas.Resources>
        <Rectangle Canvas.Left="130" Canvas.Top="30" Width="80" Height="180" RadiusX="16" RadiusY="16" Fill="{StaticResource BarBrush}" />
        <Rectangle Canvas.Left="80.19" Canvas.Top="90" Width="80" Height="120" RadiusX="16" RadiusY="16" Fill="{StaticResource BarBrush}" />
        <Rectangle Canvas.Left="30" Canvas.Top="150" Width="80" Height="60" RadiusX="16" RadiusY="16" Fill="{StaticResource BarBrush}" />
      </Canvas>
    </Viewbox>
  </Border>
</UserControl>
