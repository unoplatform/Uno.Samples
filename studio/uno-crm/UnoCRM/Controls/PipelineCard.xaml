<UserControl x:Class="UnoCRM.Controls.PipelineCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch">
  <!--
    A single deal tile for the Sales Pipeline board. Every card is the same
    height (the title region reserves two lines) and the status indicator lives
    in its own right-hand column so it is always pinned top-right and never
    overlaps a long, wrapping company name.
  -->
  <Border Style="{StaticResource DashboardKanbanCardStyle}">
    <StackPanel Spacing="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{x:Bind Company, Mode=OneWay}"
                   Foreground="{ThemeResource DashboardPrimaryTextBrush}"
                   FontWeight="Medium"
                   FontSize="16"
                   TextWrapping="Wrap"
                   MaxLines="2"
                   Height="46"
                   VerticalAlignment="Top" />

        <Ellipse Grid.Column="1"
                 Width="8"
                 Height="8"
                 VerticalAlignment="Top"
                 Margin="8,7,0,0"
                 Fill="{x:Bind Accent, Mode=OneWay}"
                 Visibility="{x:Bind DotVisibility(IsWon), Mode=OneWay}" />

        <Viewbox Grid.Column="1"
                 Width="14"
                 Height="14"
                 VerticalAlignment="Top"
                 Margin="8,5,0,0"
                 Visibility="{x:Bind CheckVisibility(IsWon), Mode=OneWay}">
          <Path Data="F1 M4.53033 12.9697C4.23744 12.6768 3.76256 12.6768 3.46967 12.9697C3.17678 13.2626 3.17678 13.7374 3.46967 14.0303L7.96967 18.5303C8.26256 18.8232 8.73744 18.8232 9.03033 18.5303L20.0303 7.53033C20.3232 7.23744 20.3232 6.76256 20.0303 6.46967C19.7374 6.17678 19.2626 6.17678 18.9697 6.46967L8.5 16.9393L4.53033 12.9697Z"
                Stretch="Uniform"
                Fill="{x:Bind Accent, Mode=OneWay}" />
        </Viewbox>
      </Grid>

      <TextBlock Text="{x:Bind Amount, Mode=OneWay}"
                 Foreground="{ThemeResource DashboardPrimaryTextBrush}"
                 FontSize="20"
                 FontWeight="SemiBold" />

      <Grid>
        <TextBlock Text="{x:Bind Owner, Mode=OneWay}"
                   Foreground="{ThemeResource DashboardMutedTextBrush}"
                   FontSize="13" />
        <TextBlock HorizontalAlignment="Right"
                   Text="{x:Bind Meta, Mode=OneWay}"
                   Foreground="{x:Bind MetaBrush, Mode=OneWay}"
                   FontSize="11"
                   FontWeight="{x:Bind MetaWeight(IsWon), Mode=OneWay}" />
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
