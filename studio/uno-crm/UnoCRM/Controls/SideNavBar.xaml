<UserControl x:Class="UnoCRM.Controls.SideNavBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:UnoCRM.Controls"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

  <!--
    Desktop navigation rail shared by the wide layout of every page. Set ActiveTab
    ("Dashboard" | "Pipeline" | "Leads" | "Contacts") to highlight the current page;
    the control navigates the hosting Frame on tap. Mirror of the mobile BottomNavBar.
  -->
  <Border Background="{ThemeResource DashboardSurfaceBrush}"
          BorderBrush="{ThemeResource DashboardBorderBrush}"
          BorderThickness="0,0,1,0">
    <Grid Padding="20,24,20,24">
      <!-- Active-tab indicator: only the active item shows the accent-soft pill + accent content. -->
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="ActiveTabStates">
          <VisualState x:Name="Dashboard">
            <VisualState.Setters>
              <Setter Target="DashboardPill.Background" Value="{ThemeResource DashboardAccentSoftBrush}" />
              <Setter Target="DashboardIcon.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
              <Setter Target="DashboardLabel.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Pipeline">
            <VisualState.Setters>
              <Setter Target="PipelinePill.Background" Value="{ThemeResource DashboardAccentSoftBrush}" />
              <Setter Target="PipelineIcon.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
              <Setter Target="PipelineLabel.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Leads">
            <VisualState.Setters>
              <Setter Target="LeadsPill.Background" Value="{ThemeResource DashboardAccentSoftBrush}" />
              <Setter Target="LeadsIcon.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
              <Setter Target="LeadsLabel.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="Contacts">
            <VisualState.Setters>
              <Setter Target="ContactsPill.Background" Value="{ThemeResource DashboardAccentSoftBrush}" />
              <Setter Target="ContactsIcon.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
              <Setter Target="ContactsLabel.Foreground" Value="{ThemeResource DashboardAccentBrush}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Spacing="30">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <controls:AppLogo Width="28" Height="28" />
          <TextBlock Text="Uno CRM"
                     VerticalAlignment="Center"
                     Style="{StaticResource DashboardBodyTextStyle}"
                     FontFamily="Georgia"
                     FontSize="20" />
        </StackPanel>

        <StackPanel Spacing="8">
          <Button x:Name="DashboardButton"
                  Tag="Dashboard"
                  AutomationProperties.Name="Dashboard"
                  Click="OnTabClick"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <Border x:Name="DashboardPill"
                    Style="{StaticResource DashboardSidebarItemBorderStyle}"
                    Background="Transparent">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="DashboardIcon"
                          Glyph="&#xE80F;"
                          FontSize="16"
                          Foreground="{ThemeResource DashboardMutedTextBrush}" />
                <TextBlock x:Name="DashboardLabel"
                           Text="Dashboard"
                           Style="{StaticResource DashboardSubtleTextStyle}" />
              </StackPanel>
            </Border>
          </Button>

          <Button x:Name="PipelineButton"
                  Tag="Pipeline"
                  AutomationProperties.Name="Pipeline"
                  Click="OnTabClick"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <Border x:Name="PipelinePill"
                    Style="{StaticResource DashboardSidebarItemBorderStyle}"
                    Background="Transparent">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="PipelineIcon"
                          Glyph="&#xE8C8;"
                          FontSize="16"
                          Foreground="{ThemeResource DashboardMutedTextBrush}" />
                <TextBlock x:Name="PipelineLabel"
                           Text="Pipeline"
                           Style="{StaticResource DashboardSubtleTextStyle}" />
              </StackPanel>
            </Border>
          </Button>

          <Button x:Name="LeadsButton"
                  Tag="Leads"
                  AutomationProperties.Name="Leads"
                  Click="OnTabClick"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <Border x:Name="LeadsPill"
                    Style="{StaticResource DashboardSidebarItemBorderStyle}"
                    Background="Transparent">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="LeadsIcon"
                          Glyph="&#xE716;"
                          FontSize="16"
                          Foreground="{ThemeResource DashboardMutedTextBrush}" />
                <TextBlock x:Name="LeadsLabel"
                           Text="Leads"
                           Style="{StaticResource DashboardSubtleTextStyle}" />
              </StackPanel>
            </Border>
          </Button>

          <Button x:Name="ContactsButton"
                  Tag="Contacts"
                  AutomationProperties.Name="Contacts"
                  Click="OnTabClick"
                  Style="{StaticResource DashboardNavButtonStyle}">
            <Border x:Name="ContactsPill"
                    Style="{StaticResource DashboardSidebarItemBorderStyle}"
                    Background="Transparent">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="ContactsIcon"
                          Glyph="&#xE77B;"
                          FontSize="16"
                          Foreground="{ThemeResource DashboardMutedTextBrush}" />
                <TextBlock x:Name="ContactsLabel"
                           Text="Contacts"
                           Style="{StaticResource DashboardSubtleTextStyle}" />
              </StackPanel>
            </Border>
          </Button>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  Spacing="12"
                  VerticalAlignment="Bottom">
        <Border Width="32"
                Height="32"
                CornerRadius="16"
                Background="{ThemeResource DashboardAccentBrush}" />
        <StackPanel>
          <TextBlock Text="Alex Morgan"
                     Style="{StaticResource DashboardBodyTextStyle}" />
          <TextBlock Text="Sales Manager"
                     Style="{StaticResource DashboardSubtleTextStyle}"
                     FontSize="12" />
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
