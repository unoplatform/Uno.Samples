<Application x:Class="UnoCRM.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    App.xaml is a thin manifest: it only merges the dedicated dictionaries. The
    theme-aware palette (colors, brushes, and the ComboBox lightweight-styling keys derived from it)
    lives in ThemeColors.xaml; the styling vocabulary (converters, tokens, the responsive
    breakpoint, and every named Style) lives in Styles.xaml, merged LAST so its keys win.
  -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Theme-aware CRM palette (light + dark) -->
        <ResourceDictionary Source="ms-appx:///ThemeColors.xaml" />
        <!-- App styling vocabulary -->
        <ResourceDictionary Source="ms-appx:///Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
