<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Uno.Sdk.Private">
  <PropertyGroup>
    <TargetFrameworks>net10.0-browserwasm;net10.0-desktop</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>BrewHouse</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>com.companyname.brewhouse</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>BrewHouse</ApplicationPublisher>
    <!-- Package Description -->
    <Description>BrewHouse powered by Uno Platform.</Description>

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <UnoFeatures>
      SimpleTheme;
      Hosting;
      Toolkit;
      Logging;
      MVUX;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      ThemeService;
      SkiaRenderer;
    </UnoFeatures>
  </PropertyGroup>

  <!--
    App icon + splash screen via Uno.Resizetizer (lesson 17). The orange coffee-bean
    foreground sits on the dark background colour; icon.svg supplies the solid background
    so transparent corners / the Android adaptive-icon background are filled.
  -->
  <PropertyGroup>
    <UnoIconForegroundFile>Assets/Icons/icon_foreground.svg</UnoIconForegroundFile>
    <UnoIconBackgroundColor>#151515</UnoIconBackgroundColor>
    <UnoSplashScreenFile>Assets/Splash/splash_screen.svg</UnoSplashScreenFile>
    <UnoSplashScreenColor>#151515</UnoSplashScreenColor>
  </PropertyGroup>

<ItemGroup><PackageReference Include="Uno.UI.HotDesign" VersionOverride="1.19.0-alc.129" /></ItemGroup></Project>
