<Application x:Class="BrewHouse.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple"
       xmlns:utu="using:Uno.Toolkit.UI"
       xmlns:presentation="using:BrewHouse.Presentation">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Warm BrewHouse palette (light + dark) layered onto the Simple theme -->
        <utus:SimpleToolkitTheme xmlns:utus="using:Uno.Toolkit.UI.Simple"
                                 ColorOverrideSource="ms-appx:///ThemeColors.xaml" />
        <!-- Merged last so its ThemeDictionaries win over the Simple theme: pins the wide
             NavigationView pane's selection indicator to the warm palette (the bottom TabBar
             deliberately uses the Simple defaults — see ControlThemeOverrides.xaml). -->
        <ResourceDictionary Source="ms-appx:///ControlThemeOverrides.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- App-specific brushes. Only genuinely theme-VARYING chrome lives in ThemeDictionaries;
           everything theme-invariant (header, status pills, the ready dot) sits at the root. -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <!-- Card separator: translucent black in light, translucent white in dark -->
          <SolidColorBrush x:Key="BrewCardBorderBrush" Color="#14000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
          <SolidColorBrush x:Key="BrewCardBorderBrush" Color="#24FFFFFF" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- Order-status pill containers: bright background + legible on-colour, read on light + dark -->
      <SolidColorBrush x:Key="BrewStatusReadyContainerBrush" Color="#3FB368" />
      <SolidColorBrush x:Key="BrewStatusReadyOnContainerBrush" Color="#0C3A1E" />
      <SolidColorBrush x:Key="BrewStatusPreparingContainerBrush" Color="#F0A23C" />
      <SolidColorBrush x:Key="BrewStatusPreparingOnContainerBrush" Color="#4A2A08" />
      <SolidColorBrush x:Key="BrewStatusCompletedContainerBrush" Color="#A99A88" />
      <SolidColorBrush x:Key="BrewStatusCompletedOnContainerBrush" Color="#33291F" />

      <!-- 'Ready' status dot (used by the Cart's ready note) -->
      <SolidColorBrush x:Key="BrewStatusReadyBrush" Color="#3FA34D" />

      <!-- Converter (content-free value transform; brush/visibility choices stay in XAML) -->
      <presentation:BoolToVisibilityConverter x:Key="BoolToVisibility" />

      <!-- Chrome-less, keyboard-focusable button: makes a card / chip / pill a real, accessible
           control (focus + Invoke automation peer) while the inner content defines the look. A
           foreground-neutral state layer (rounded to the button's CornerRadius) gives hover/pressed
           feedback; set CornerRadius on the button to match the content's rounding. -->
      <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Grid Background="Transparent">
                <VisualStateManager.VisualStateGroups>
                  <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                      <VisualState.Setters>
                        <Setter Target="FlatStateLayer.Opacity" Value="0.06" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                      <VisualState.Setters>
                        <Setter Target="FlatStateLayer.Opacity" Value="0.12" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                      <VisualState.Setters>
                        <Setter Target="FlatContent.Opacity" Value="0.4" />
                      </VisualState.Setters>
                    </VisualState>
                  </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <ContentPresenter x:Name="FlatContent"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Padding="{TemplateBinding Padding}"
                                  Background="Transparent" />
                <Border x:Name="FlatStateLayer"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Background="{ThemeResource OnSurfaceBrush}"
                        Opacity="0"
                        IsHitTestVisible="False" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Filled action button: one crisp rounded Border for the fill (no themed border to alias at
           small sizes), plus a foreground-coloured state layer for hover/pressed. The canonical button
           for every coloured action (Add, Place Order, +/-, etc.); callers override Background/Foreground
           for secondary/neutral variants. -->
      <Style x:Key="BrewButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Root"
                      Background="{TemplateBinding Background}"
                      CornerRadius="{TemplateBinding CornerRadius}"
                      RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                  <!-- Tactile press: firm 0.98 scale (not a collapse), per the design-polish house value -->
                  <ScaleTransform x:Name="RootScale" />
                </Border.RenderTransform>
                <VisualStateManager.VisualStateGroups>
                  <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                      <VisualState.Setters>
                        <Setter Target="StateLayer.Opacity" Value="0.10" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                      <VisualState.Setters>
                        <Setter Target="StateLayer.Opacity" Value="0.20" />
                        <Setter Target="RootScale.ScaleX" Value="0.98" />
                        <Setter Target="RootScale.ScaleY" Value="0.98" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                      <VisualState.Setters>
                        <Setter Target="Root.Opacity" Value="0.4" />
                      </VisualState.Setters>
                    </VisualState>
                  </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <Grid>
                  <Border x:Name="StateLayer"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Background="{TemplateBinding Foreground}"
                          Opacity="0"
                          IsHitTestVisible="False" />
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Padding="{TemplateBinding Padding}"
                                    Foreground="{TemplateBinding Foreground}"
                                    FontWeight="{TemplateBinding FontWeight}"
                                    FontSize="{TemplateBinding FontSize}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Rounder controls to match the card language -->
      <CornerRadius x:Key="ControlCornerRadiusSmall">8</CornerRadius>
      <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>
      <CornerRadius x:Key="OverlayCornerRadius">16</CornerRadius>

      <!-- Spacing scale (design-system tokens) so padding/margins come from one rhythm -->
      <x:Double x:Key="SpacingXS">4</x:Double>
      <x:Double x:Key="SpacingSM">8</x:Double>
      <x:Double x:Key="SpacingMD">12</x:Double>
      <x:Double x:Key="SpacingLG">16</x:Double>
      <x:Double x:Key="SpacingXL">24</x:Double>

      <!-- Consistent page header: identical position, background and type on every page so the title
           doesn't jump when navigating (a plain BackgroundBrush strip; page content scrolls below). -->
      <Thickness x:Key="PageHeaderPadding">20,20,20,12</Thickness>
      <Style x:Key="PageHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource BackgroundBrush}" />
        <Setter Property="Padding" Value="{StaticResource PageHeaderPadding}" />
      </Style>
      <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
      </Style>
      <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
        <Setter Property="Margin" Value="0,2,0,0" />
      </Style>

      <!-- Window-width breakpoint shared by the shell + page layouts: phone below 900px
           (bottom TabBar), desktop/web at or above (NavigationView pane) -->
      <utu:ResponsiveLayout x:Key="DefaultResponsiveLayout"
                            Narrow="0"
                            Wide="900" />

    </ResourceDictionary>
  </Application.Resources>

</Application>
