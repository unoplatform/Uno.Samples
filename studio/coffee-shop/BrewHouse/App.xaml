<Application x:Class="BrewHouse.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple"
       xmlns:utu="using:Uno.Toolkit.UI"
       xmlns:presentation="using:BrewHouse.Presentation">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Warm BrewHouse palette (light + dark) layered onto the Simple theme -->
        <utus:SimpleToolkitTheme xmlns:utus="using:Uno.Toolkit.UI.Simple"
                                 ColorOverrideSource="ms-appx:///ThemeColors.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- App-specific brushes that aren't part of the M3 palette -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <!-- A dark espresso banner that stays dark in both themes (light text reads on it) -->
          <SolidColorBrush x:Key="BrewHeaderBrush" Color="#3A2012" />
          <SolidColorBrush x:Key="BrewOnHeaderBrush" Color="#FBEFE2" />
          <!-- Card separators: translucent black in light, translucent white in dark -->
          <SolidColorBrush x:Key="BrewCardBorderBrush" Color="#14000000" />
          <!-- Order-status pill containers (theme-aware): coloured background + legible on-colour -->
          <SolidColorBrush x:Key="BrewStatusReadyContainerBrush" Color="#C6E6D0" />
          <SolidColorBrush x:Key="BrewStatusReadyOnContainerBrush" Color="#1A4D28" />
          <SolidColorBrush x:Key="BrewStatusPreparingContainerBrush" Color="#FFE5CC" />
          <SolidColorBrush x:Key="BrewStatusPreparingOnContainerBrush" Color="#8B4513" />
          <SolidColorBrush x:Key="BrewStatusCompletedContainerBrush" Color="#E8DFD7" />
          <SolidColorBrush x:Key="BrewStatusCompletedOnContainerBrush" Color="#4A3E36" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
          <SolidColorBrush x:Key="BrewHeaderBrush" Color="#3A2012" />
          <SolidColorBrush x:Key="BrewOnHeaderBrush" Color="#FBEFE2" />
          <SolidColorBrush x:Key="BrewCardBorderBrush" Color="#24FFFFFF" />
          <!-- Order-status pill containers (theme-aware): coloured background + legible on-colour -->
          <SolidColorBrush x:Key="BrewStatusReadyContainerBrush" Color="#2D5A3D" />
          <SolidColorBrush x:Key="BrewStatusReadyOnContainerBrush" Color="#E8F5EC" />
          <SolidColorBrush x:Key="BrewStatusPreparingContainerBrush" Color="#9B6B4D" />
          <SolidColorBrush x:Key="BrewStatusPreparingOnContainerBrush" Color="#FFE8D1" />
          <SolidColorBrush x:Key="BrewStatusCompletedContainerBrush" Color="#6B5F54" />
          <SolidColorBrush x:Key="BrewStatusCompletedOnContainerBrush" Color="#F0EAE3" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- Order-status indicator dots: semantic, theme-invariant (read on light + dark) -->
      <SolidColorBrush x:Key="BrewStatusReadyBrush" Color="#3FA34D" />
      <SolidColorBrush x:Key="BrewStatusPreparingBrush" Color="#D98A2B" />
      <SolidColorBrush x:Key="BrewStatusDoneBrush" Color="#9C8B7E" />

      <!-- Converter (content-free value transform; brush/visibility choices stay in XAML) -->
      <presentation:BoolToVisibilityConverter x:Key="BoolToVisibility" />

      <!-- Chrome-less, keyboard-focusable button: makes a card / chip / pill a real, accessible
           control (focus + Invoke automation peer) while the inner content defines the look. A
           foreground-neutral state layer (rounded to the button's CornerRadius) gives hover/pressed
           feedback; set CornerRadius on the button to match the content's rounding. -->
      <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Grid Background="Transparent">
                <VisualStateManager.VisualStateGroups>
                  <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                      <VisualState.Setters>
                        <Setter Target="FlatStateLayer.Opacity" Value="0.06" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                      <VisualState.Setters>
                        <Setter Target="FlatStateLayer.Opacity" Value="0.12" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                      <VisualState.Setters>
                        <Setter Target="FlatContent.Opacity" Value="0.4" />
                      </VisualState.Setters>
                    </VisualState>
                  </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <ContentPresenter x:Name="FlatContent"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Padding="{TemplateBinding Padding}"
                                  Background="Transparent" />
                <Border x:Name="FlatStateLayer"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Background="{ThemeResource OnSurfaceBrush}"
                        Opacity="0"
                        IsHitTestVisible="False" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Filled action button: one crisp rounded Border for the fill (no themed border to alias at
           small sizes), plus a foreground-coloured state layer for hover/pressed. The canonical button
           for every coloured action (Add, Place Order, +/-, etc.); callers override Background/Foreground
           for secondary/neutral variants. See specs/lessons.md lesson 42. -->
      <Style x:Key="BrewButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Root"
                      Background="{TemplateBinding Background}"
                      CornerRadius="{TemplateBinding CornerRadius}">
                <VisualStateManager.VisualStateGroups>
                  <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                      <VisualState.Setters>
                        <Setter Target="StateLayer.Opacity" Value="0.10" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                      <VisualState.Setters>
                        <Setter Target="StateLayer.Opacity" Value="0.20" />
                      </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                      <VisualState.Setters>
                        <Setter Target="Root.Opacity" Value="0.4" />
                      </VisualState.Setters>
                    </VisualState>
                  </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <Grid>
                  <Border x:Name="StateLayer"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Background="{TemplateBinding Foreground}"
                          Opacity="0"
                          IsHitTestVisible="False" />
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Padding="{TemplateBinding Padding}"
                                    Foreground="{TemplateBinding Foreground}"
                                    FontWeight="{TemplateBinding FontWeight}"
                                    FontSize="{TemplateBinding FontSize}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Rounder controls to match the card language -->
      <CornerRadius x:Key="ControlCornerRadiusSmall">8</CornerRadius>
      <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>
      <CornerRadius x:Key="OverlayCornerRadius">16</CornerRadius>

      <!-- Window-width breakpoint shared by the shell + page layouts: phone below 900px
           (bottom TabBar), desktop/web at or above (NavigationView pane) -->
      <utu:ResponsiveLayout x:Key="DefaultResponsiveLayout"
                            Narrow="0"
                            Wide="900" />

    </ResourceDictionary>
  </Application.Resources>

</Application>
