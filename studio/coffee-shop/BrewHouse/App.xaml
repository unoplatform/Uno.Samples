<Application x:Class="BrewHouse.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple">

  <!-- App.xaml is a thin manifest: it only merges the dedicated dictionaries, each with one
       concern. The visual vocabulary (styles, templates, brushes, tokens) lives in Styles.xaml;
       the palette in ThemeColors.xaml; built-in control key overrides in ControlThemeOverrides.xaml.
       See lesson 56. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Warm BrewHouse palette (light + dark) layered onto the Simple theme -->
        <utus:SimpleToolkitTheme ColorOverrideSource="ms-appx:///ThemeColors.xaml" />
        <!-- Merged after the Simple theme so its ThemeDictionaries win: pins the wide NavigationView
             pane's selection indicator to the warm palette (the bottom TabBar deliberately uses the
             Simple defaults — see ControlThemeOverrides.xaml). -->
        <ResourceDictionary Source="ms-appx:///ControlThemeOverrides.xaml" />
        <!-- App styling vocabulary. Merged LAST so its well-known-key overrides
             (ControlCornerRadius*, OverlayCornerRadius) beat the theme defaults. -->
        <ResourceDictionary Source="ms-appx:///Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
