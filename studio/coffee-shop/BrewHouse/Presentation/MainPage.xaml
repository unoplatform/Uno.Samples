<Page x:Class="BrewHouse.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <!--
      Navigation shell. Owns the chrome once for the whole app: a NavigationView pane on wide
      layouts (desktop / web) and a bottom TabBar on narrow ones (phone). Responsive switching is
      driven by the Toolkit {utu:Responsive} extension on each property (not AdaptiveTrigger /
      VisualState) so it applies reliably to this navigation-injected page. The content region is
      left empty - Uno.Extensions Navigation injects the active route (Home / Menu / Cart / Orders).

      The Cart count badges bind to the MainModel directly: the badge text to the CartItemCount feed
      value and its visibility to the CartHasItems bool (via BoolToVisibility) — so the
      badge appears only when the cart has items. The bindings reach the page VM via
      ElementName=RootShellGrid because a region-attached NavigationView/TabBar does not propagate
      the page DataContext to its item content.
    -->
    <Grid x:Name="RootShellGrid" uen:Region.Attached="True">

        <!-- NavigationView: sidebar pane on Wide; collapsed (TabBar takes over) on Narrow -->
        <NavigationView x:Name="NavView"
                        uen:Region.Attached="True"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="{utu:Responsive Narrow=LeftMinimal, Wide=Auto}"
                        IsPaneToggleButtonVisible="{utu:Responsive Narrow=False, Wide=True}"
                        IsPaneOpen="{utu:Responsive Narrow=False, Wide=True}">
            <NavigationView.MenuItems>
                <NavigationViewItem uen:Region.Name="Home" Content="Home">
                    <NavigationViewItem.Icon>
                        <PathIcon Data="F1 M10.5495 2.53189C11.3874 1.82531 12.6126 1.82531 13.4505 2.5319L20.2005 8.224C20.7074 8.65152 21 9.2809 21 9.94406L21 19.2539C21 20.2204 20.2165 21.0039 19.25 21.0039H15.75C14.7835 21.0039 14 20.2204 14 19.2539L14 14.2468C14 14.1088 13.8881 13.9968 13.75 13.9968H10.25C10.1119 13.9968 9.99999 14.1088 9.99999 14.2468L9.99999 19.2539C9.99999 20.2204 9.2165 21.0039 8.25 21.0039H4.75C3.7835 21.0039 3 20.2204 3 19.2539V9.94406C3 9.2809 3.29255 8.65152 3.79952 8.224L10.5495 2.53189ZM12.4835 3.6786C12.2042 3.44307 11.7958 3.44307 11.5165 3.6786L4.76651 9.37071C4.59752 9.51321 4.5 9.72301 4.5 9.94406L4.5 19.2539C4.5 19.392 4.61193 19.5039 4.75 19.5039H8.25C8.38807 19.5039 8.49999 19.392 8.49999 19.2539L8.49999 14.2468C8.49999 13.2803 9.2835 12.4968 10.25 12.4968H13.75C14.7165 12.4968 15.5 13.2803 15.5 14.2468L15.5 19.2539C15.5 19.392 15.6119 19.5039 15.75 19.5039H19.25C19.3881 19.5039 19.5 19.392 19.5 19.2539L19.5 9.94406C19.5 9.72301 19.4025 9.51321 19.2335 9.37071L12.4835 3.6786Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem uen:Region.Name="Menu" Content="Menu">
