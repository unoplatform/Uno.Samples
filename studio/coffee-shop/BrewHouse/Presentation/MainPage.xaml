<Page x:Class="BrewHouse.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <!--
      Navigation shell. Owns the chrome once for the whole app: a NavigationView pane on wide
      layouts (desktop / web) and a bottom TabBar on narrow ones (phone). Responsive switching is
      driven by the Toolkit {utu:Responsive} extension on each property (not AdaptiveTrigger /
      VisualState) so it applies reliably to this navigation-injected page. The content region is
      left empty - Uno.Extensions Navigation injects the active route (Home / Menu / Cart / Orders).

      The Cart count badges bind to the MainModel directly: the badge text to the CartItemCount feed
      value and its visibility to the CartHasItems bool (via BoolToVisibility, lesson 28) — so the
      badge appears only when the cart has items. The bindings reach the page VM via
      ElementName=RootShellGrid because a region-attached NavigationView/TabBar does not propagate
      the page DataContext to its item content (lesson 36).
    -->
    <Grid x:Name="RootShellGrid" uen:Region.Attached="True">

        <!-- NavigationView: sidebar pane on Wide; collapsed (TabBar takes over) on Narrow -->
        <NavigationView x:Name="NavView"
                        uen:Region.Attached="True"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="{utu:Responsive Narrow=LeftMinimal, Wide=Auto}"
                        IsPaneToggleButtonVisible="{utu:Responsive Narrow=False, Wide=True}"
                        IsPaneOpen="{utu:Responsive Narrow=False, Wide=True}">
            <!-- Light/dark toggle in the pane footer (desktop/web); phone follows the OS theme -->
            <NavigationView.PaneFooter>
                <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="14,12"
                        Margin="4,4,4,8"
                        AutomationProperties.Name="Toggle light or dark theme"
                        Click="OnToggleTheme">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE706;" FontSize="16" />
                        <TextBlock Text="Theme" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </NavigationView.PaneFooter>
            <NavigationView.MenuItems>
                <NavigationViewItem uen:Region.Name="Home" Content="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem uen:Region.Name="Menu" Content="Menu">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem uen:Region.Name="Cart">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BF;" />
                    </NavigationViewItem.Icon>
                    <!-- Label + live count badge; the badge shows only when the cart has items
                         (visibility = CartHasItems bool via BoolToVisibility, lesson 28) -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="Cart" VerticalAlignment="Center" />
                        <Border Background="{ThemeResource PrimaryBrush}"
                                CornerRadius="9"
                                MinWidth="18"
                                Height="18"
                                Padding="5,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding DataContext.CartHasItems, ElementName=RootShellGrid, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding DataContext.CartItemCount, ElementName=RootShellGrid}"
                                       Foreground="{ThemeResource OnPrimaryBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </NavigationViewItem>
                <NavigationViewItem uen:Region.Name="Orders" Content="Orders">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Shared content area - navigation framework injects the active page here -->
                    <Grid Grid.Row="0"
                          uen:Region.Attached="True"
                          uen:Region.Navigator="Visibility" />

                    <!-- Bottom TabBar: shown on Narrow, hidden once the pane appears on Wide -->
                    <utu:TabBar x:Name="BottomTabs"
                                Grid.Row="1"
                                uen:Region.Attached="True"
                                utu:SafeArea.Insets="Bottom"
                                Style="{StaticResource BottomTabBarStyle}"
                                Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}">
                        <utu:TabBarItem uen:Region.Name="Home" Content="Home">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE80F;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                        <utu:TabBarItem uen:Region.Name="Menu" Content="Menu">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE8FD;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                        <utu:TabBarItem uen:Region.Name="Cart">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE7BF;" />
                            </utu:TabBarItem.Icon>
                            <!-- Label + live count badge; the badge shows only when the cart has
                                 items (visibility = CartHasItems bool via BoolToVisibility, lesson 28) -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Cart" VerticalAlignment="Center" />
                                <Border Background="{ThemeResource PrimaryBrush}"
                                        CornerRadius="9"
                                        MinWidth="18"
                                        Height="18"
                                        Padding="5,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding DataContext.CartHasItems, ElementName=RootShellGrid, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding DataContext.CartItemCount, ElementName=RootShellGrid}"
                                               Foreground="{ThemeResource OnPrimaryBrush}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </utu:TabBarItem>
                        <utu:TabBarItem uen:Region.Name="Orders" Content="Orders">
                            <utu:TabBarItem.Icon>
                                <FontIcon Glyph="&#xE9D9;" />
                            </utu:TabBarItem.Icon>
                        </utu:TabBarItem>
                    </utu:TabBar>
                </Grid>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
