<Page x:Class="BrewHouse.Presentation.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <!-- Chip button with no default chrome: the inner pills define the look -->
        <Style x:Key="ChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bare container so list rows never flash the grey hover/selection rectangle -->
        <Style x:Key="CardListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <utu:SafeArea Insets="VisibleBounds">
        <Grid MaxWidth="720" HorizontalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource BrewHeaderBrush}"
                        Padding="20,20,20,16"
                        Spacing="2">
                <TextBlock Text="Our Menu"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{ThemeResource BrewOnHeaderBrush}" />
                <TextBlock Text="Find your perfect brew"
                           FontSize="13"
                           Foreground="{ThemeResource BrewOnHeaderBrush}"
                           Opacity="0.8" />
            </StackPanel>

            <!-- Category Chip Filter Bar -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled"
                          Background="{ThemeResource BackgroundBrush}"
                          Padding="0,12,0,12">
                <ItemsControl ItemsSource="{Binding Categories}"
                              Padding="16,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ChipButtonStyle}"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:ItemsControlBinding Path=DataContext.FilterByCategoryCommand}"
                                    CommandParameter="{Binding Id}">
                                <Grid>
                                    <!-- unselected pill -->
                                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                                            CornerRadius="18"
                                            Padding="16,8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                    </Border>
                                    <!-- selected pill overlays when this category is active -->
                                    <Border Background="{ThemeResource PrimaryBrush}"
                                            CornerRadius="18"
                                            Padding="16,8"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Product List -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectionMode="None"
                      ItemContainerStyle="{StaticResource CardListItemStyle}"
                      Padding="16,4,16,16">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="16"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <!-- Product Image -->
                                <Border Grid.Column="0"
                                        CornerRadius="16,0,0,16"
                                        Background="{ThemeResource SurfaceVariantBrush}">
                                    <Image Source="{Binding ImageUrl}"
                                           Width="100"
                                           Height="110"
                                           Stretch="UniformToFill" />
                                </Border>

                                <!-- Product Info -->
                                <StackPanel Grid.Column="1"
                                            Padding="14"
                                            Spacing="4"
                                            VerticalAlignment="Center">

                                    <!-- Special Badge -->
                                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                                            CornerRadius="6"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding IsSpecial, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Today's Special"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SecondaryBrush}" />
                                    </Border>

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               TextWrapping="Wrap"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Stretch"
                                                Spacing="10"
                                                Margin="0,6,0,0">
                                        <TextBlock FontSize="17"
                                                   FontWeight="Bold"
                                                   Foreground="{ThemeResource SecondaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="$" /><Run Text="{Binding Price}" />
                                        </TextBlock>

                                        <Button Content="+ Add to Cart"
                                                AutomationProperties.Name="Add to cart"
                                                Background="{ThemeResource PrimaryBrush}"
                                                Foreground="{ThemeResource OnPrimaryBrush}"
                                                CornerRadius="12"
                                                Padding="12,7"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Command="{utu:ItemsControlBinding Path=DataContext.AddToCartCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </utu:SafeArea>
</Page>
