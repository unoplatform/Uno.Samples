<Page x:Class="BrewHouse.Presentation.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:BrewHouse.Presentation.Controls"
      xmlns:mock="using:BrewHouse.Presentation.MockData"
      Background="{ThemeResource BrewCreamBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- MaxWidth keeps a readable centred column on desktop; full width on phones (lesson 9). -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.DataContext>
                <mock:MenuPageData />
            </Grid.DataContext>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource BrewHeaderBrush}"
                        Padding="20,20,20,16"
                        Spacing="2">
                <TextBlock Text="Our Menu"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="Find your perfect brew"
                           FontSize="13"
                           Foreground="#CCF5EFE6" />
            </StackPanel>

            <!-- Category Chip Filter Bar -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled"
                          Background="{ThemeResource BrewCreamBrush}"
                          Padding="0,12,0,12">
                <ItemsControl ItemsSource="{Binding Categories}"
                              Padding="16,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    CornerRadius="10"
                                    Padding="16,8"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:ItemsControlBinding Path=DataContext.FilterByCategoryCommand}"
                                    CommandParameter="{Binding Id}">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource BrewEspressoBrush}"
                                           VerticalAlignment="Center" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--
                Product list: a UniformGridLayout reflows the cards into 1 column on phones
                and 2-3 on desktop as width grows (lesson 9) - no breakpoints, and an
                ItemsRepeater has no item chrome so the lesson-12 hover rectangle never
                appears. Commands reach the page VM via {utu:AncestorBinding} on the repeater.
            -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="16,4,16,16">
                <ItemsRepeater ItemsSource="{Binding FilteredProducts}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="340"
                                           MinColumnSpacing="12"
                                           MinRowSpacing="12"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <controls:ProductCard Product="{Binding}"
                                                  AddCommand="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCartCommand}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
