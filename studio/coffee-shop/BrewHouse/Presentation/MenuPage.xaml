<Page x:Class="BrewHouse.Presentation.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- Centred, capped content; the product grid below reflows to fill the width on desktop/web -->
        <Grid x:Name="Root" MaxWidth="1100" HorizontalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource BrewHeaderBrush}"
                        Padding="20,20,20,16"
                        Spacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="Our Menu"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{ThemeResource BrewOnHeaderBrush}" />
                    <TextBlock Text="Find your perfect brew"
                               FontSize="13"
                               Foreground="{ThemeResource BrewOnHeaderBrush}"
                               Opacity="0.8" />
                </StackPanel>
                <!-- Live text search; RequestedTheme=Light keeps it a readable light box on the
                     fixed-dark header in both app themes -->
                <AutoSuggestBox PlaceholderText="Search the menu"
                                RequestedTheme="Light"
                                Text="{Binding SearchText, Mode=TwoWay}"
                                QueryIcon="Find"
                                AutomationProperties.Name="Search the menu" />
            </StackPanel>

            <!-- Category Chip Filter Bar -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled"
                          Background="{ThemeResource BackgroundBrush}"
                          Padding="0,12,0,12">
                <ItemsControl ItemsSource="{Binding Categories}"
                              Padding="16,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    CornerRadius="18"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:ItemsControlBinding Path=DataContext.FilterByCategory}"
                                    CommandParameter="{Binding Id}">
                                <Grid>
                                    <!-- unselected pill -->
                                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                                            CornerRadius="18"
                                            Padding="16,8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                    </Border>
                                    <!-- selected pill overlays when this category is active -->
                                    <Border Background="{ThemeResource PrimaryBrush}"
                                            CornerRadius="18"
                                            Padding="16,8"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Product grid: 1 column on phones, reflows to 2-3 on wide screens (no breakpoints) -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="16,4,16,16">
                <ItemsRepeater ItemsSource="{Binding FilteredProducts}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="320"
                                           MinColumnSpacing="12"
                                           MinRowSpacing="12"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- The whole card is a focusable button that opens the product detail page;
                                 the inner "+ Add to Cart" is a nested button with its own command -->
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    CornerRadius="16"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.ViewProduct}"
                                    CommandParameter="{Binding}">
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="16"
                                        BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>

                                        <!-- Product image: fills the card height; corners match the card -->
                                        <Border Grid.Column="0"
                                                CornerRadius="16,0,0,16">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}"
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>

                                        <!-- Product Info -->
                                        <StackPanel Grid.Column="1"
                                                    Padding="12,8"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">

                                            <!-- Name + right-aligned "Today's Special" badge on one row, so the
                                                 badge never adds height and every tile stays the same height -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                                <Border Grid.Column="1"
                                                        Background="{ThemeResource SurfaceVariantBrush}"
                                                        CornerRadius="6"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSpecial, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="Today's Special"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource SecondaryBrush}" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />

                                            <Grid Margin="0,4,0,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="17" FontWeight="Bold"
                                                           Foreground="{ThemeResource SecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="$" /><Run Text="{Binding Price}" />
                                                </TextBlock>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource BrewButtonStyle}"
                                                        Content="+ Add to Cart"
                                                        AutomationProperties.Name="Add to cart"
                                                        CornerRadius="8"
                                                        Padding="10,4"
                                                        FontSize="11"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCart}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- No results: shown over the (empty) grid when the category/search filter matches
                 nothing. Driven by a plain bool feed so it flips reliably at zero matches. -->
            <Border Grid.Row="2"
                    VerticalAlignment="Top"
                    Margin="16,12,16,16"
                    Background="{ThemeResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="32,40"
                    BorderBrush="{ThemeResource BrewCardBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <Viewbox Width="44" Height="44" HorizontalAlignment="Center">
                        <PathIcon Data="F1 M16.1017 17.1624C14.717 18.3101 12.9391 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11C19 12.9391 18.3101 14.717 17.1624 16.1018L21.7803 20.7197C22.0732 21.0126 22.0732 21.4874 21.7803 21.7803C21.4874 22.0732 21.0125 22.0732 20.7196 21.7803L16.1017 17.1624ZM17.5 11C17.5 7.41015 14.5899 4.5 11 4.5C7.41015 4.5 4.5 7.41015 4.5 11C4.5 14.5899 7.41015 17.5 11 17.5C14.5899 17.5 17.5 14.5899 17.5 11Z"
                                  Foreground="{ThemeResource SecondaryBrush}" />
                    </Viewbox>
                    <TextBlock Text="No matches found"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Try a different category or search term."
                               FontSize="13"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="240" />
                </StackPanel>
            </Border>
        </Grid>
    </utu:SafeArea>
</Page>
