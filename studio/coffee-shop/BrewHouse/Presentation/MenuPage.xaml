<Page x:Class="BrewHouse.Presentation.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:BrewHouse.Presentation.Controls"
      xmlns:mock="using:BrewHouse.Presentation.MockData"
      Background="{ThemeResource BrewCreamBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- MaxWidth keeps a readable centred column on desktop; full width on phones (lesson 9). -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.DataContext>
                <mock:MenuPageData />
            </Grid.DataContext>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource BrewEspressoBrush}"
                        Padding="20,20,20,16"
                        Spacing="2">
                <TextBlock Text="Our Menu"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="Find your perfect brew"
                           FontSize="13"
                           Foreground="#CCF5EFE6" />
            </StackPanel>

            <!-- Category Chip Filter Bar -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled"
                          Background="{ThemeResource BrewCreamBrush}"
                          Padding="0,12,0,12">
                <ItemsControl ItemsSource="{Binding Categories}"
                              Padding="16,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    CornerRadius="20"
                                    Padding="16,8"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:ItemsControlBinding Path=DataContext.FilterByCategoryCommand}"
                                    CommandParameter="{Binding Id}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource BrewEspressoBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Product List -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectionMode="None"
                      Padding="16,4,16,16">
                <!--
                    Lesson 12: the default ListViewItem paints a grey hover/press rectangle
                    over the rounded cards. A bare ContentPresenter template (no CommonStates)
                    with zeroed container metrics removes it for this touch list.
                -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Margin="{TemplateBinding Padding}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:ProductCard Product="{Binding}"
                                              AddCommand="{utu:ItemsControlBinding Path=DataContext.AddToCartCommand}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </utu:SafeArea>
</Page>
