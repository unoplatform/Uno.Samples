<Page x:Class="BrewHouse.Presentation.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- Centred, capped content; the product grid below reflows to fill the width on desktop/web -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Background="{ThemeResource BrewHeaderBrush}"
                        Padding="20,20,20,16"
                        Spacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="Our Menu"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{ThemeResource BrewOnHeaderBrush}" />
                    <TextBlock Text="Find your perfect brew"
                               FontSize="13"
                               Foreground="{ThemeResource BrewOnHeaderBrush}"
                               Opacity="0.8" />
                </StackPanel>
                <!-- Live text search; RequestedTheme=Light keeps it a readable light box on the
                     fixed-dark header in both app themes -->
                <AutoSuggestBox PlaceholderText="Search the menu"
                                RequestedTheme="Light"
                                Text="{Binding SearchText, Mode=TwoWay}"
                                QueryIcon="Find"
                                AutomationProperties.Name="Search the menu" />
            </StackPanel>

            <!-- Category Chip Filter Bar -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled"
                          Background="{ThemeResource BackgroundBrush}"
                          Padding="0,12,0,12">
                <ItemsControl ItemsSource="{Binding Categories}"
                              Padding="16,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:ItemsControlBinding Path=DataContext.FilterByCategoryCommand}"
                                    CommandParameter="{Binding Id}">
                                <Grid>
                                    <!-- unselected pill -->
                                    <Border Background="{ThemeResource SurfaceVariantBrush}"
                                            CornerRadius="18"
                                            Padding="16,8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                    </Border>
                                    <!-- selected pill overlays when this category is active -->
                                    <Border Background="{ThemeResource PrimaryBrush}"
                                            CornerRadius="18"
                                            Padding="16,8"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OnPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Product grid: 1 column on phones, reflows to 2-3 on wide screens (no breakpoints) -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="16,4,16,16">
                <ItemsRepeater ItemsSource="{Binding FilteredProducts}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="320"
                                           MinColumnSpacing="12"
                                           MinRowSpacing="12"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- The whole card is a focusable button that opens the product detail page;
                                 the inner "+ Add to Cart" is a nested button with its own command -->
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    AutomationProperties.Name="{Binding Name}"
                                    Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.ViewProductCommand}"
                                    CommandParameter="{Binding}">
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="16"
                                        BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>

                                        <!-- Product image: fills the card height; corners match the card -->
                                        <Border Grid.Column="0"
                                                CornerRadius="16,0,0,16">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImageUrl}"
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>

                                        <!-- Product Info -->
                                        <StackPanel Grid.Column="1"
                                                    Padding="12,8"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">

                                            <!-- Name + right-aligned "Today's Special" badge on one row, so the
                                                 badge never adds height and every tile stays the same height -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                                <Border Grid.Column="1"
                                                        Background="{ThemeResource SurfaceVariantBrush}"
                                                        CornerRadius="6"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSpecial, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="Today's Special"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource SecondaryBrush}" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Stretch"
                                                        Spacing="10"
                                                        Margin="0,4,0,0">
                                                <TextBlock FontSize="17"
                                                           FontWeight="Bold"
                                                           Foreground="{ThemeResource SecondaryBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="$" /><Run Text="{Binding Price}" />
                                                </TextBlock>

                                                <Button Content="+ Add to Cart"
                                                        AutomationProperties.Name="Add to cart"
                                                        Background="{ThemeResource PrimaryBrush}"
                                                        Foreground="{ThemeResource OnPrimaryBrush}"
                                                        CornerRadius="12"
                                                        Padding="12,6"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCartCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
