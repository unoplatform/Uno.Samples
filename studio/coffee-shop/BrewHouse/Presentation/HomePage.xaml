<Page x:Class="BrewHouse.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- Phone-first; caps to a centred, width-filling column on wide desktop/WASM -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">

            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Enabled">
                <StackPanel Spacing="0">

                    <!-- Hero Carousel -->
                    <Grid Height="280">
                        <FlipView ItemsSource="{Binding HeroBanners}"
                                  AutomationProperties.Name="Featured promotions carousel">
                            <FlipView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}"
                                               Stretch="UniformToFill" />
                                        <!-- Dark scrim keeps the white caption legible over any photo -->
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0.3" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0.0" />
                                                    <GradientStop Color="#E5140800" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Padding="24,0,24,32"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="26"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="13"
                                                       Foreground="#CCFFFFFF"
                                                       TextWrapping="Wrap" />
                                            <Button Content="Order Now"
                                                    AutomationProperties.Name="Order Now"
                                                    Background="{ThemeResource PrimaryBrush}"
                                                    Foreground="{ThemeResource OnPrimaryBrush}"
                                                    CornerRadius="12"
                                                    Padding="20,10"
                                                    FontWeight="SemiBold"
                                                    FontSize="14"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,6,0,0"
                                                    Command="{utu:ItemsControlBinding Path=DataContext.OrderNowCommand}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>
                    </Grid>

                    <!-- Today's Specials Section -->
                    <StackPanel Spacing="0">

                        <StackPanel Padding="20,20,20,10" Spacing="4">
                            <TextBlock Text="Today's Specials"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />
                            <TextBlock Text="Fresh picks just for you"
                                       FontSize="13"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>

                        <!-- Specials Horizontal Scroll -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      Padding="20,0,20,4">
                            <ItemsControl ItemsSource="{Binding Specials}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="14" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="158"
                                                Background="{ThemeResource SurfaceBrush}"
                                                CornerRadius="16"
                                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="16,16,0,0"
                                                        Height="112">
                                                    <Image Source="{Binding ImageUrl}"
                                                           Stretch="UniformToFill"
                                                           Height="112" />
                                                </Border>
                                                <StackPanel Padding="10,10,10,12" Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="{ThemeResource SecondaryBrush}">
                                                        <Run Text="$" />
                                                        <Run Text="{Binding Price}" />
                                                    </TextBlock>
                                                    <Button Content="+ Add to Cart"
                                                            AutomationProperties.Name="Add special to cart"
                                                            Background="{ThemeResource PrimaryBrush}"
                                                            Foreground="{ThemeResource OnPrimaryBrush}"
                                                            CornerRadius="10"
                                                            Padding="0,7"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            HorizontalAlignment="Stretch"
                                                            Margin="0,4,0,0"
                                                            Command="{utu:ItemsControlBinding Path=DataContext.AddToCartCommand}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Category Chips -->
                        <StackPanel Padding="20,20,20,8" Spacing="10">
                            <TextBlock Text="Browse by Category"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollMode="Enabled">
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource SurfaceVariantBrush}"
                                                    CornerRadius="20"
                                                    Padding="16,8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Featured Products -->
                        <StackPanel Padding="20,4,20,0" Spacing="10">
                            <TextBlock Text="Featured Products"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />

                            <ItemsRepeater ItemsSource="{Binding FeaturedProducts}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="320"
                                                       MinColumnSpacing="12"
                                                       MinRowSpacing="12"
                                                       ItemsStretch="Fill" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource SurfaceBrush}"
                                                CornerRadius="16"
                                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="104" />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        CornerRadius="16,0,0,16"
                                                        Height="104">
                                                    <Image Source="{Binding ImageUrl}"
                                                           Stretch="UniformToFill"
                                                           Width="104"
                                                           Height="104" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Padding="14"
                                                            Spacing="3"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="2"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="10"
                                                                Margin="0,6,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock FontSize="17"
                                                                   FontWeight="Bold"
                                                                   Foreground="{ThemeResource SecondaryBrush}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="$" />
                                                            <Run Text="{Binding Price}" />
                                                        </TextBlock>
                                                        <Button Content="+ Add"
                                                                AutomationProperties.Name="Add product to cart"
                                                                Background="{ThemeResource PrimaryBrush}"
                                                                Foreground="{ThemeResource OnPrimaryBrush}"
                                                                CornerRadius="10"
                                                                Padding="14,7"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCartCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Cart Summary Strip (visible when cart has items) -->
                        <Border Visibility="{Binding Cart.HasItems, Converter={StaticResource BoolToVisibility}}"
                                Background="{ThemeResource PrimaryBrush}"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12"
                                               Foreground="{ThemeResource OnPrimaryBrush}"
                                               Opacity="0.85">
                                        <Run Text="{Binding Cart.ItemCount}" />
                                        <Run Text="items in your cart" />
                                    </TextBlock>
                                    <TextBlock FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource OnPrimaryBrush}">
                                        <Run Text="Total: $" />
                                        <Run Text="{Binding Cart.Total}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="View Cart"
                                        AutomationProperties.Name="View cart"
                                        Background="{ThemeResource SurfaceBrush}"
                                        Foreground="{ThemeResource PrimaryBrush}"
                                        CornerRadius="10"
                                        Padding="16,9"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        Command="{Binding GoToCartCommand}" />
                            </Grid>
                        </Border>

                        <!-- Empty Cart State -->
                        <Border Visibility="{Binding Cart.HasItems, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                                Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="24,28"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="10">
                                <FontIcon Glyph="&#xEC32;"
                                          FontSize="48"
                                          Foreground="{ThemeResource SecondaryBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="Your cup is empty"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Add your favourite brew above to get started"
                                           FontSize="13"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="240" />
                                <Button Content="Browse Full Menu"
                                        AutomationProperties.Name="Browse full menu"
                                        Background="{ThemeResource PrimaryBrush}"
                                        Foreground="{ThemeResource OnPrimaryBrush}"
                                        CornerRadius="12"
                                        Padding="28,11"
                                        FontWeight="SemiBold"
                                        FontSize="14"
                                        HorizontalAlignment="Center"
                                        Margin="0,6,0,0"
                                        Command="{Binding GoToMenuCommand}" />
                            </StackPanel>
                        </Border>

                        <!-- Bottom padding -->
                        <Border Height="24" />

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
