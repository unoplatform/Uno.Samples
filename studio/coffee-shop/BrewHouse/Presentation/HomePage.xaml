<Page x:Class="BrewHouse.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:BrewHouse.Presentation.Controls"
      xmlns:mock="using:BrewHouse.Presentation.MockData"
      Background="{ThemeResource BrewCreamBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid>
            <Grid.DataContext>
                <mock:HomePageData />
            </Grid.DataContext>

            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Enabled">
                <!-- Outer Grid fills the viewport; the inner column caps its width and
                     centres on desktop while filling the screen on phones (lessons 2, 9). -->
                <Grid>
                    <StackPanel Spacing="0"
                                MaxWidth="1100"
                                HorizontalAlignment="Stretch">

                    <!-- Hero Carousel -->
                    <Grid Height="280">
                        <FlipView ItemsSource="{Binding HeroBanners}"
                                  AutomationProperties.Name="Featured promotions carousel">
                            <FlipView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}"
                                               Stretch="UniformToFill" />
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0.3" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0.0" />
                                                    <GradientStop Color="#E5140800" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Padding="24,0,24,32"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="26"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="13"
                                                       Foreground="#CCF5EFE6"
                                                       TextWrapping="Wrap" />
                                            <Button Content="Order Now"
                                                    AutomationProperties.Name="Order Now"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    FontSize="14"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,6,0,0"
                                                    Command="{utu:ItemsControlBinding Path=DataContext.OrderNowCommand}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>
                    </Grid>

                    <!-- Today's Specials Section -->
                    <StackPanel Spacing="0" Background="{ThemeResource BrewCreamBrush}">

                        <StackPanel Padding="20,20,20,10" Spacing="4">
                            <TextBlock Text="Today's Specials"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource BrewCocoaBrush}" />
                            <TextBlock Text="Fresh picks just for you"
                                       FontSize="13"
                                       Foreground="{ThemeResource BrewMochaBrush}" />
                        </StackPanel>

                        <!-- Specials Horizontal Scroll -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      Padding="20,0,20,4">
                            <ItemsControl ItemsSource="{Binding Specials}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="14" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="158"
                                                Background="White"
                                                CornerRadius="16"
                                                BorderBrush="#18000000"
                                                BorderThickness="1">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="16,16,0,0"
                                                        Height="112">
                                                    <Image Source="{Binding ImageUrl}"
                                                           Stretch="UniformToFill"
                                                           Height="112" />
                                                </Border>
                                                <StackPanel Padding="10,10,10,12" Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource BrewCocoaBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="{ThemeResource BrewCaramelBrush}">
                                                        <Run Text="$" />
                                                        <Run Text="{Binding Price}" />
                                                    </TextBlock>
                                                    <Button Content="+ Add to Cart"
                                                            AutomationProperties.Name="Add special to cart"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            CornerRadius="10"
                                                            Padding="0,7"
                                                            FontSize="12"
                                                            HorizontalAlignment="Stretch"
                                                            Margin="0,4,0,0"
                                                            Command="{utu:ItemsControlBinding Path=DataContext.AddToCartCommand}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Category Chips -->
                        <StackPanel Padding="20,20,20,8" Spacing="10">
                            <TextBlock Text="Browse by Category"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource BrewCocoaBrush}" />
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollMode="Enabled">
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource BrewFoamBrush}"
                                                    CornerRadius="10"
                                                    Padding="14,8"
                                                    BorderBrush="{ThemeResource BrewCaramelBrush}"
                                                    BorderThickness="1.5">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource BrewEspressoBrush}"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Featured Products -->
                        <StackPanel Padding="20,4,20,0" Spacing="10">
                            <TextBlock Text="Featured Products"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource BrewCocoaBrush}" />

                            <ItemsRepeater ItemsSource="{Binding FeaturedProducts}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="340"
                                                       MinColumnSpacing="12"
                                                       MinRowSpacing="12"
                                                       ItemsStretch="Fill" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ProductCard Product="{Binding}"
                                                              ShowSpecialBadge="False"
                                                              AddCommand="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCartCommand}" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Cart Summary Strip (visible when cart has items) -->
                        <Border Visibility="{Binding Cart.HasItems}"
                                Background="{ThemeResource BrewEspressoBrush}"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12"
                                               Foreground="#BFFDF6EE">
                                        <Run Text="{Binding Cart.ItemCount}" />
                                        <Run Text="items in your cart" />
                                    </TextBlock>
                                    <TextBlock FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="White">
                                        <Run Text="Total: $" />
                                        <Run Text="{Binding Cart.Total}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="View Cart"
                                        AutomationProperties.Name="View cart"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Background="White"
                                        CornerRadius="10"
                                        Padding="16,9"
                                        FontSize="13"
                                        Command="{Binding GoToCartCommand}" />
                            </Grid>
                        </Border>

                        <!-- Empty Cart State -->
                        <Border Visibility="{Binding Cart.IsEmpty}"
                                Background="White"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="24,28"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="10">
                                <FontIcon Glyph="&#xEC32;"
                                          FontSize="48"
                                          Foreground="{ThemeResource BrewEspressoBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="Your cup is empty"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource BrewEspressoBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Add your favourite brew above to get started"
                                           FontSize="13"
                                           Foreground="{ThemeResource BrewMochaBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="240" />
                                <Button Content="Browse Full Menu"
                                        AutomationProperties.Name="Browse full menu"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Padding="28,11"
                                        FontSize="14"
                                        HorizontalAlignment="Center"
                                        Margin="0,6,0,0"
                                        Command="{Binding GoToMenuCommand}" />
                            </StackPanel>
                        </Border>

                        <!-- Bottom padding -->
                        <Border Height="24" />

                    </StackPanel>

                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
