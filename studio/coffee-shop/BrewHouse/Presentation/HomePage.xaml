<Page x:Class="BrewHouse.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- Phone-first; caps to a centred, width-filling column on wide desktop/WASM -->
        <Grid x:Name="Root" MaxWidth="1100" HorizontalAlignment="Stretch">

            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Enabled">
                <StackPanel Spacing="0">

                    <!-- Hero Carousel -->
                    <Grid Height="280">
                        <FlipView x:Name="HeroFlip"
                                  ItemsSource="{Binding HeroBanners}"
                                  AutomationProperties.Name="Featured promotions carousel">
                            <FlipView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Decorative: the caption + carousel name carry the meaning -->
                                        <Image Source="{Binding ImageUrl}"
                                               Stretch="UniformToFill"
                                               AutomationProperties.AccessibilityView="Raw" />
                                        <!-- Dark scrim keeps the white caption legible over any photo -->
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00140800" Offset="0.0" />
                                                    <GradientStop Color="#40140800" Offset="0.45" />
                                                    <GradientStop Color="#F0140800" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Padding="24,0,24,32"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="26"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="13"
                                                       Foreground="White"
                                                       TextWrapping="Wrap" />
                                            <Button Style="{StaticResource BrewButtonStyle}"
                                                    Content="Order Now"
                                                    AutomationProperties.Name="Order Now"
                                                    CornerRadius="12"
                                                    Padding="20,10"
                                                    FontSize="14"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,6,0,0"
                                                    Command="{utu:ItemsControlBinding Path=DataContext.OrderNow}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>
                        <!-- Pager so mouse/keyboard users can page the carousel (FlipView default is
                             swipe-only); RequestedTheme=Dark gives light pips that read on the scrim -->
                        <PipsPager NumberOfPages="{Binding HeroBanners.Count}"
                                   SelectedPageIndex="{Binding SelectedIndex, ElementName=HeroFlip, Mode=TwoWay}"
                                   RequestedTheme="Dark"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,10" />
                    </Grid>

                    <!-- Today's Specials Section -->
                    <StackPanel Spacing="0">

                        <StackPanel Padding="20,20,20,10" Spacing="4">
                            <TextBlock Text="Today's Specials"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />
                            <TextBlock Text="Fresh picks just for you"
                                       FontSize="13"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>

                        <!-- Specials Horizontal Scroll -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      Padding="20,0,20,4">
                            <ItemsControl ItemsSource="{Binding Specials}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="14" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Card is a focusable button -> product detail -->
                                        <Button Style="{StaticResource FlatButtonStyle}"
                                                CornerRadius="16"
                                                AutomationProperties.Name="{Binding Name}"
                                                Command="{utu:ItemsControlBinding Path=DataContext.ViewProduct}"
                                                CommandParameter="{Binding}">
                                            <Border Width="158"
                                                    Background="{ThemeResource SurfaceBrush}"
                                                    CornerRadius="16"
                                                    BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="0">
                                                    <!-- Banner image; top corners match the card -->
                                                    <Border CornerRadius="16,16,0,0"
                                                            Height="112">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel Padding="10,10,10,12" Spacing="4">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Foreground="{ThemeResource SecondaryBrush}">
                                                            <Run Text="$" />
                                                            <Run Text="{Binding Price}" />
                                                        </TextBlock>
                                                        <Button Style="{StaticResource BrewButtonStyle}"
                                                                Content="+ Add to Cart"
                                                                AutomationProperties.Name="Add special to cart"
                                                                CornerRadius="8"
                                                                Padding="0,5"
                                                                FontSize="11"
                                                                HorizontalAlignment="Stretch"
                                                                Margin="0,4,0,0"
                                                                Command="{utu:ItemsControlBinding Path=DataContext.AddToCart}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Category Chips -->
                        <StackPanel Padding="20,20,20,8" Spacing="10">
                            <TextBlock Text="Browse by Category"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollMode="Enabled">
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Tap a category to jump to the full Menu -->
                                            <Button Style="{StaticResource FlatButtonStyle}"
                                                    CornerRadius="20"
                                                    AutomationProperties.Name="{Binding Name}"
                                                    Command="{utu:ItemsControlBinding Path=DataContext.GoToMenu}">
                                                <Border Background="{ThemeResource SurfaceVariantBrush}"
                                                        CornerRadius="20"
                                                        Padding="16,8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Featured Products -->
                        <StackPanel Padding="20,4,20,0" Spacing="10">
                            <TextBlock Text="Featured Products"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource OnBackgroundBrush}" />

                            <ItemsRepeater ItemsSource="{Binding FeaturedProducts}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="320"
                                                       MinColumnSpacing="12"
                                                       MinRowSpacing="12"
                                                       ItemsStretch="Fill" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Card is a focusable button -> product detail; inner "+ Add" is its own button -->
                                        <Button Style="{StaticResource FlatButtonStyle}"
                                                CornerRadius="16"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                AutomationProperties.Name="{Binding Name}"
                                                Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.ViewProduct}"
                                                CommandParameter="{Binding}">
                                            <Border Background="{ThemeResource SurfaceBrush}"
                                                    CornerRadius="16"
                                                    BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="104" />
                                                        <ColumnDefinition />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Image fills the card height; corners match the card -->
                                                    <Border Grid.Column="0"
                                                            CornerRadius="16,0,0,16">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                Padding="12,8"
                                                                Spacing="2"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="1"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <Grid Margin="0,4,0,0" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontSize="17" FontWeight="Bold"
                                                                       Foreground="{ThemeResource SecondaryBrush}" VerticalAlignment="Center">
                                                                <Run Text="$" /><Run Text="{Binding Price}" />
                                                            </TextBlock>
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource BrewButtonStyle}"
                                                                    Content="+ Add"
                                                                    AutomationProperties.Name="Add product to cart"
                                                                    CornerRadius="8"
                                                                    Padding="10,4"
                                                                    FontSize="11"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Command="{utu:AncestorBinding AncestorType=ItemsRepeater, Path=DataContext.AddToCart}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Cart summary strip: shown when the cart has items. Binds directly to the
                             shared cart summary feed value, so it tracks every add/remove from any
                             page; visibility = CartHasItems bool (BoolToVisibility, lesson 28).
                             Buttons reach the page VM via Root. -->
                        <Border Background="{ThemeResource PrimaryBrush}"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="18,14"
                                Visibility="{Binding CartHasItems, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12"
                                               Foreground="{ThemeResource OnPrimaryBrush}"
                                               Opacity="0.85">
                                        <Run Text="{Binding Summary.ItemCount}" />
                                        <Run Text="items in your cart" />
                                    </TextBlock>
                                    <TextBlock FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource OnPrimaryBrush}">
                                        <Run Text="Total: $" />
                                        <Run Text="{Binding Summary.SubtotalFormatted}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource BrewButtonStyle}"
                                        Content="View Cart"
                                        AutomationProperties.Name="View cart"
                                        Background="{ThemeResource SurfaceBrush}"
                                        Foreground="{ThemeResource PrimaryBrush}"
                                        CornerRadius="10"
                                        Padding="16,9"
                                        FontSize="13"
                                        Command="{Binding DataContext.GoToCart, ElementName=Root}" />
                            </Grid>
                        </Border>

                        <!-- Empty-cup card: shown when the cart is empty (CartHasItems inverted). -->
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="16"
                                Margin="20,20,20,4"
                                Padding="24,28"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding CartHasItems, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="10">
                                <FontIcon Glyph="&#xEC32;"
                                          FontSize="48"
                                          Foreground="{ThemeResource SecondaryBrush}"
                                          HorizontalAlignment="Center"
                                          AutomationProperties.AccessibilityView="Raw" />
                                <TextBlock Text="Your cup is empty"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Add your favourite brew above to get started"
                                           FontSize="13"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="240" />
                                <Button Style="{StaticResource BrewButtonStyle}"
                                        Content="Browse Full Menu"
                                        AutomationProperties.Name="Browse full menu"
                                        CornerRadius="12"
                                        Padding="28,11"
                                        FontSize="14"
                                        HorizontalAlignment="Center"
                                        Margin="0,6,0,0"
                                        Command="{Binding DataContext.GoToMenu, ElementName=Root}" />
                            </StackPanel>
                        </Border>

                        <!-- Bottom padding -->
                        <Border Height="24" />

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
