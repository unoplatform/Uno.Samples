<Page x:Class="BrewHouse.Presentation.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mock="using:BrewHouse.Presentation.MockData"
      Background="#FFFDF6EE">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- MaxWidth keeps a readable centred column on desktop; full width on phones (lesson 9). -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.DataContext>
                <mock:CartPageData />
            </Grid.DataContext>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#FFFDF6EE"
                    Padding="20,16,20,12"
                    BorderBrush="#20000000"
                    BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Your Cart"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF2C1A0E" />
                    <TextBlock Text="{Binding ItemCountText}"
                               FontSize="14"
                               Foreground="#FF8C7060" />
                </StackPanel>
            </Border>

            <!-- Empty Cart State -->
            <ScrollViewer Grid.Row="1"
                          Visibility="{Binding EmptyCartVisibility}"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16"
                            Padding="40,60,40,40">
                    <TextBlock Text="&#x2615;"
                               FontSize="72"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Your cart is empty"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF2C1A0E"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Looks like you haven't added anything yet. Browse our menu and pick your favourite brew!"
                               FontSize="14"
                               Foreground="#FF8C7060"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Border Background="#FFF5EFE6"
                            CornerRadius="16"
                            Padding="20,16"
                            Margin="0,8,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Popular choices:"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF8C5A28"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <Border Background="White"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock Text="☕ Latte"
                                               FontSize="13"
                                               Foreground="#FF4A2810" />
                                </Border>
                                <Border Background="White"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock Text="🥐 Croissant"
                                               FontSize="13"
                                               Foreground="#FF4A2810" />
                                </Border>
                                <Border Background="White"
                                        CornerRadius="20"
                                        Padding="12,6">
                                    <TextBlock Text="🍵 Matcha"
                                               FontSize="13"
                                               Foreground="#FF4A2810" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Content="Browse Menu"
                            AutomationProperties.Name="Browse menu"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="32,14"
                            FontSize="15"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>

            <!-- Cart Content -->
            <Grid Grid.Row="1"
                  Visibility="{Binding CartContentVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Cart Items List -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Hidden"
                              Padding="0,0,0,8">
                    <StackPanel Spacing="0" Padding="16,12,16,0">

                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            CornerRadius="16"
                                            Padding="12"
                                            BorderBrush="#15000000"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Product Image -->
                                            <Border Grid.Column="0"
                                                    CornerRadius="10"
                                                    Width="72"
                                                    Height="72">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>

                                            <!-- Product Info -->
                                            <StackPanel Grid.Column="1"
                                                        Padding="12,4,8,4"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF2C1A0E"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="13"
                                                           Foreground="#FF8C5A28"
                                                           FontWeight="SemiBold">
                                                    <Run Text="$" />
                                                    <Run Text="{Binding PriceFormatted}" />
                                                </TextBlock>
                                                <TextBlock FontSize="12"
                                                           Foreground="#FF8C7060">
                                                    <Run Text="Line total: $" />
                                                    <Run Text="{Binding LineTotalFormatted}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Quantity Controls -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <Button Content="+"
                                                        AutomationProperties.Name="Increase quantity"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Width="34"
                                                        Height="34"
                                                        CornerRadius="10"
                                                        FontSize="18"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalAlignment="Center"
                                                        Command="{utu:ItemsControlBinding Path=DataContext.IncrementCommand}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock Text="{Binding Quantity}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="#FF2C1A0E"
                                                           HorizontalAlignment="Center" />
                                                <Button Content="-"
                                                        AutomationProperties.Name="Decrease quantity"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Width="34"
                                                        Height="34"
                                                        CornerRadius="10"
                                                        FontSize="18"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalAlignment="Center"
                                                        Command="{utu:ItemsControlBinding Path=DataContext.DecrementCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- Order Summary + Place Order -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="20,20,0,0"
                        Padding="20,20,20,24"
                        BorderBrush="#15000000"
                        BorderThickness="0,1,0,0">
                    <StackPanel Spacing="0">

                        <!-- Order Confirmed Banner -->
                        <Border Visibility="{Binding OrderPlacedVisibility}"
                                Background="#FFE8F5E9"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="✓"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF2E7D32"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding OrderPlacedMessage}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#FF2E7D32"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Summary Title -->
                        <TextBlock Text="Order Summary"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FF2C1A0E"
                                   Margin="0,0,0,14" />

                        <!-- Subtotal Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subtotal"
                                       FontSize="14"
                                       Foreground="#FF8C7060"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       Foreground="#FF2C1A0E"
                                       FontWeight="SemiBold">
                                <Run Text="$" />
                                <Run Text="{Binding SubtotalFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Tax Row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tax (8%)"
                                       FontSize="14"
                                       Foreground="#FF8C7060"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       Foreground="#FF2C1A0E"
                                       FontWeight="SemiBold">
                                <Run Text="$" />
                                <Run Text="{Binding TaxFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1"
                                Background="#FFE8DDD0"
                                Margin="0,0,0,12" />

                        <!-- Total Row -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#FF2C1A0E"
                                       Grid.Column="0" />
                            <TextBlock Grid.Column="1"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#FF4A2810">
                                <Run Text="$" />
                                <Run Text="{Binding TotalFormatted}" />
                            </TextBlock>
                        </Grid>

                        <!-- Place Order Button -->
                        <Button Content="Place Order"
                                AutomationProperties.Name="Place order"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="0,16"
                                FontSize="16"
                                FontWeight="Bold"
                                Command="{Binding PlaceOrderCommand}" />

                    </StackPanel>
                </Border>

            </Grid>

        </Grid>
    </utu:SafeArea>
</Page>
