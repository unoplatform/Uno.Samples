<Page x:Class="BrewHouse.Presentation.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid x:Name="Root" MaxWidth="1100" HorizontalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{ThemeResource BackgroundBrush}"
                    Padding="20,16,20,12"
                    BorderBrush="{ThemeResource BrewCardBorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Your Cart"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{ThemeResource OnBackgroundBrush}" />
                    <!-- "N items" (the feed projects "0 items" on an empty cart); binds directly. -->
                    <TextBlock Text="{Binding ItemCountText}"
                               FontSize="14"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
            </Border>

            <!-- Cart body: items + order summary, shown when the cart has items. Totals bind
                 directly to the shared summary feed value; visibility = CartHasItems bool
                 (BoolToVisibility, lesson 28). The empty-cart hero below covers the empty state. -->
            <!-- Cart Content: one column on phones (items above, summary below);
                 two columns on wide desktop/web (items left, sticky summary right) -->
            <Grid Grid.Row="1"
                  Padding="16,12,16,12"
                  ColumnSpacing="16"
                  RowSpacing="12"
                  Visibility="{Binding CartHasItems, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{utu:Responsive Narrow=Auto, Wide=360}" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cart Items List. Bound to the shared cart list-state via ElementName=Root;
                             item +/- and remove commands live on the page VM, reached the same way
                             (the item template's own DataContext is the CartItem, not the page VM). -->
                        <ScrollViewer Grid.Row="0"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                      VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding DataContext.CartItems, ElementName=Root}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource SurfaceBrush}"
                                                CornerRadius="16"
                                                Padding="12"
                                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Product Image -->
                                                <Border Grid.Column="0"
                                                        CornerRadius="10"
                                                        Width="72"
                                                        Height="72">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>

                                                <!-- Product Info -->
                                                <StackPanel Grid.Column="1"
                                                            Padding="12,4,8,4"
                                                            Spacing="4"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="13"
                                                               Foreground="{ThemeResource SecondaryBrush}"
                                                               FontWeight="SemiBold">
                                                        <Run Text="$" />
                                                        <Run Text="{Binding PriceFormatted}" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="12"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                        <Run Text="Line total: $" />
                                                        <Run Text="{Binding LineTotalFormatted}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Quantity Controls -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Spacing="6"
                                                            HorizontalAlignment="Center">
                                                    <Button Content="+"
                                                            AutomationProperties.Name="Increase quantity"
                                                            Width="28"
                                                            Height="28"
                                                            Background="{ThemeResource PrimaryBrush}"
                                                            Foreground="{ThemeResource OnPrimaryBrush}"
                                                            CornerRadius="8"
                                                            FontSize="14"
                                                            FontWeight="Bold"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding DataContext.Increment, ElementName=Root}"
                                                            CommandParameter="{Binding}" />
                                                    <TextBlock Text="{Binding Quantity}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                                               HorizontalAlignment="Center" />
                                                    <Button Content="&#x2212;"
                                                            AutomationProperties.Name="Decrease quantity"
                                                            Width="28"
                                                            Height="28"
                                                            Background="{ThemeResource SurfaceVariantBrush}"
                                                            Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                            CornerRadius="8"
                                                            FontSize="14"
                                                            FontWeight="Bold"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding DataContext.Decrement, ElementName=Root}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Order Summary + Place Order: docked below on phone, sticky right column on wide -->
                        <Border Grid.Row="{utu:Responsive Narrow=1, Wide=0}"
                                Grid.Column="{utu:Responsive Narrow=0, Wide=1}"
                                Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                                VerticalAlignment="{utu:Responsive Narrow=Stretch, Wide=Top}"
                                Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="16"
                                Padding="20"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="0">

                                <!-- Summary Title -->
                                <TextBlock Text="Order Summary"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           Margin="0,0,0,14" />

                                <!-- Subtotal Row -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Subtotal"
                                               FontSize="14"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Grid.Column="0" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="14"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               FontWeight="SemiBold">
                                        <Run Text="$" />
                                        <Run Text="{Binding Summary.SubtotalFormatted}" />
                                    </TextBlock>
                                </Grid>

                                <!-- Tax Row -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Tax (8%)"
                                               FontSize="14"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Grid.Column="0" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="14"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               FontWeight="SemiBold">
                                        <Run Text="$" />
                                        <Run Text="{Binding Summary.TaxFormatted}" />
                                    </TextBlock>
                                </Grid>

                                <!-- Divider -->
                                <Border Height="1"
                                        Background="{ThemeResource OutlineVariantBrush}"
                                        Margin="0,0,0,12" />

                                <!-- Total Row -->
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Total"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource OnSurfaceBrush}"
                                               Grid.Column="0" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource SecondaryBrush}">
                                        <Run Text="$" />
                                        <Run Text="{Binding Summary.TotalFormatted}" />
                                    </TextBlock>
                                </Grid>

                                <!-- Place Order: runs the VM command (reached via Root) and the
                                     code-behind toast handler (transient confirmation banner). -->
                                <Button Content="Place Order"
                                        AutomationProperties.Name="Place order"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource PrimaryBrush}"
                                        Foreground="{ThemeResource OnPrimaryBrush}"
                                        CornerRadius="12"
                                        Padding="0,16"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Click="OnPlaceOrder"
                                        Command="{Binding DataContext.PlaceOrder, ElementName=Root}" />

                            </StackPanel>
                        </Border>

            </Grid>

            <!-- Empty-cart hero: shown when the cart is empty (CartHasItems inverted). -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          Visibility="{Binding CartHasItems, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="16"
                                        Padding="40,60,40,40">
                                <FontIcon Glyph="&#xEC32;"
                                          FontSize="64"
                                          Foreground="{ThemeResource SecondaryBrush}"
                                          HorizontalAlignment="Center"
                                          AutomationProperties.AccessibilityView="Raw" />
                                <TextBlock Text="Your cart is empty"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource OnBackgroundBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Looks like you haven't added anything yet. Browse our menu and pick your favourite brew!"
                                           FontSize="14"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Border Background="{ThemeResource SurfaceVariantBrush}"
                                        CornerRadius="16"
                                        Padding="20,16"
                                        Margin="0,8,0,0">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Popular choices:"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <!-- Pills jump to the Menu (command on the page VM, via Root) -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8">
                                            <Button Style="{StaticResource FlatButtonStyle}"
                                                    Command="{Binding DataContext.GoToMenu, ElementName=Root}"
                                                    AutomationProperties.Name="Browse Latte">
                                                <Border Background="{ThemeResource SurfaceBrush}"
                                                        CornerRadius="20"
                                                        Padding="12,6">
                                                    <TextBlock Text="Latte"
                                                               FontSize="13"
                                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                                </Border>
                                            </Button>
                                            <Button Style="{StaticResource FlatButtonStyle}"
                                                    Command="{Binding DataContext.GoToMenu, ElementName=Root}"
                                                    AutomationProperties.Name="Browse Croissant">
                                                <Border Background="{ThemeResource SurfaceBrush}"
                                                        CornerRadius="20"
                                                        Padding="12,6">
                                                    <TextBlock Text="Croissant"
                                                               FontSize="13"
                                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                                </Border>
                                            </Button>
                                            <Button Style="{StaticResource FlatButtonStyle}"
                                                    Command="{Binding DataContext.GoToMenu, ElementName=Root}"
                                                    AutomationProperties.Name="Browse Matcha">
                                                <Border Background="{ThemeResource SurfaceBrush}"
                                                        CornerRadius="20"
                                                        Padding="12,6">
                                                    <TextBlock Text="Matcha"
                                                               FontSize="13"
                                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                                </Border>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Button Content="Browse Menu"
                                        AutomationProperties.Name="Browse menu"
                                        Background="{ThemeResource PrimaryBrush}"
                                        Foreground="{ThemeResource OnPrimaryBrush}"
                                        CornerRadius="12"
                                        Padding="32,14"
                                        FontWeight="SemiBold"
                                        FontSize="15"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,0,0"
                                        Command="{Binding DataContext.GoToMenu, ElementName=Root}" />
                            </StackPanel>
            </ScrollViewer>

            <!-- Order Confirmed banner: page-level overlay so it survives the cart emptying on
                 Place Order. Shown/auto-dismissed (4 s) by the page code-behind — pure view
                 behaviour, driven by x:Name so it needs no model state. -->
            <Border x:Name="OrderConfirmedBanner"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Margin="16,12,16,0"
                    Visibility="Collapsed"
                    Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="12"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE73E;"
                              FontSize="18"
                              Foreground="{ThemeResource BrewStatusReadyBrush}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="Your order has been placed!"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </Grid>
    </utu:SafeArea>
</Page>
