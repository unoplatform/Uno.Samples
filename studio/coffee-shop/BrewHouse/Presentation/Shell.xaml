<UserControl x:Class="BrewHouse.Presentation.Shell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:BrewHouse.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:utu="using:Uno.Toolkit.UI"
      mc:Ignorable="d"
      d:DesignHeight="300"
      d:DesignWidth="400">
  <Border Background="{ThemeResource BackgroundBrush}">
    <!--
      The shell's content host is an ExtendedSplashScreen: it keeps the native (Resizetizer)
      splash on screen, overlaid with the loading content below, until the app reports ready
      (see Shell.xaml.cs). Navigation injects the active page (Main) as its Content and the splash
      reveals it once loading completes. Navigation regions live on MainPage, never on the splash.
    -->
    <utu:ExtendedSplashScreen x:Name="ShellContent"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch">
      <utu:ExtendedSplashScreen.LoadingContent>
        <!-- Mirrors the native splash: the BrewHouse cup mark on #151515, drawn with native
             shapes (a Path + Ellipse — never an SVG <Image>, which can render as a black tile),
             plus a loading ring below. -->
        <Grid Background="#151515">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Viewbox Grid.Row="1"
                   Width="132"
                   Height="132"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <Canvas Width="240" Height="240">
              <!-- The cream pour behind the cup silhouette (shows through the mark's cut-outs) -->
              <Ellipse Canvas.Left="47"
                       Canvas.Top="55"
                       Width="128"
                       Height="71"
                       Fill="White" />
              <!-- The cup mark; F1 = nonzero fill so the inner swirl reads as the SVG intends -->
              <Path Data="F1 M110.5 43C131.012 43 149.98 47.4056 164.108 54.9209C177.732 62.1677 188.746 73.4813 188.994 88H189C189 88.1208 188.998 88.2416 188.998 88.3623C188.998 88.4082 189 88.4541 189 88.5C189 88.6007 188.997 88.7013 188.996 88.8018C188.992 89.6869 188.979 90.5697 188.959 91.4502C189.416 91.4003 189.882 91.3584 190.358 91.3281C197.118 90.8985 206.292 92.7037 212.615 102.002C217.071 108.554 216.818 115.835 214.489 121.998C212.238 127.956 207.943 133.341 203.197 137.68C198.392 142.073 192.653 145.827 186.878 148.333C182.994 150.018 178.662 151.323 174.347 151.627C172.092 155.998 169.608 160.134 166.911 163.997C153.125 183.748 133.305 197 110.5 197C87.6947 197 67.8751 183.748 54.0889 163.997C40.4098 144.4 32.1534 117.816 32.0039 88.8018C32.0029 88.7013 32 88.6007 32 88.5C32 88.4541 32.0017 88.4082 32.002 88.3623C32.0017 88.2416 32 88.1208 32 88H32.0059C32.1421 80.0117 35.5372 72.9941 40.834 67.0898C40.8773 67.041 40.9213 66.9929 40.9648 66.9443C41.0168 66.887 41.0688 66.8296 41.1211 66.7725C41.5942 66.2514 42.0768 65.7466 42.5703 65.2598C46.6166 61.2238 51.5539 57.7601 56.8916 54.9209C71.0203 47.4056 89.9879 43 110.5 43ZM199.385 110.999C197.208 107.797 194.436 107.101 191.374 107.296C190.029 107.381 188.749 107.654 187.695 107.956C186.544 116.666 184.65 125.034 182.098 132.918C185.678 131.16 189.306 128.701 192.401 125.871C196.017 122.566 198.45 119.178 199.522 116.341C200.517 113.709 200.184 112.175 199.385 110.999ZM75.0977 70.5566C64.6489 69.0083 55.1927 72.6267 49.9219 81.7217C49.8643 81.8211 49.8024 81.9177 49.7412 82.0137C48.5639 84.2367 48.0165 86.4017 48.002 88.418C48.0021 88.4789 48.0027 88.5397 48.0029 88.6006C48.0553 94.5331 52.7362 101.746 64.4062 107.953C75.7935 114.01 92.0761 118 110.5 118C118.025 118 125.192 117.333 131.814 116.133C120.137 111.244 109.481 102.361 102.869 90.3604C96.6509 79.0746 85.7126 72.1297 75.0977 70.5566ZM110.5 59C104.717 59 99.145 59.3934 93.8691 60.1201C103.128 64.9472 111.356 72.6084 116.883 82.6396C123.114 93.9485 134.526 101.568 145.857 103.781C155.155 105.597 163.449 103.708 169.069 98.2734C171.762 94.9181 172.971 91.5972 172.997 88.6006C172.997 88.5397 172.997 88.4789 172.997 88.418C172.954 82.4819 168.276 75.2608 156.594 69.0469C145.207 62.9899 128.924 59 110.5 59Z">
                <Path.Fill>
                  <LinearGradientBrush StartPoint="0.2,0.25" EndPoint="0.95,0.6">
                    <GradientStop Offset="0" Color="#FF9D2E" />
                    <GradientStop Offset="1" Color="#E17618" />
                  </LinearGradientBrush>
                </Path.Fill>
              </Path>
            </Canvas>
          </Viewbox>
          <ProgressRing Grid.Row="2"
                        IsActive="True"
                        Width="48"
                        Height="48"
                        Margin="0,40,0,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Foreground="#FF9D2E" />
        </Grid>
      </utu:ExtendedSplashScreen.LoadingContent>
    </utu:ExtendedSplashScreen>
  </Border>
</UserControl>
