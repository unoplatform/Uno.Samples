<Page x:Class="BrewHouse.Presentation.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mock="using:BrewHouse.Presentation.MockData"
      Background="{ThemeResource BrewCreamBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <!-- MaxWidth keeps a readable centred column on desktop; full width on phones (lesson 9). -->
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.DataContext>
                <mock:OrdersPageData />
            </Grid.DataContext>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{ThemeResource BrewCreamBrush}"
                    Padding="20,20,20,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="My Orders"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{ThemeResource BrewCocoaBrush}" />
                    <TextBlock Text="Track your current and past orders"
                               FontSize="14"
                               Foreground="{ThemeResource BrewMochaBrush}" />
                </StackPanel>
            </Border>

            <!-- Orders List -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="20,0,20,16">
                <StackPanel Spacing="12">

                    <!-- Order cards reflow into 2 columns on desktop, 1 on phones (lesson 9). -->
                    <ItemsRepeater ItemsSource="{Binding Orders}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="420"
                                               MinColumnSpacing="12"
                                               MinRowSpacing="12"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource BrewSurfaceBrush}"
                                        CornerRadius="16"
                                        Padding="16"
                                        BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="12">

                                        <!-- Order Header Row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Id}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="{ThemeResource BrewCocoaBrush}" />
                                                <TextBlock Text="{Binding PlacedAt}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource BrewMochaBrush}" />
                                            </StackPanel>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="1"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="10"
                                                    Padding="12,6"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusColor}" />
                                            </Border>
                                        </Grid>

                                        <!-- Divider -->
                                        <Border Height="1"
                                                Background="{ThemeResource BrewFoamBrush}"
                                                HorizontalAlignment="Stretch" />

                                        <!-- Items Summary -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Items"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource BrewMochaBrush}"
                                                       CharacterSpacing="50" />
                                            <TextBlock Text="{Binding ItemSummary}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource BrewCocoaBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Total Row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="Order Total"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource BrewMochaBrush}"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="1"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       Foreground="{ThemeResource BrewEspressoBrush}">
                                                <Run Text="$" />
                                                <Run Text="{Binding TotalFormatted}" />
                                            </TextBlock>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Empty State -->
                    <Border Background="{ThemeResource BrewSurfaceBrush}"
                            CornerRadius="16"
                            Padding="32,40"
                            Visibility="{Binding EmptyStateVisibility}"
                            BorderBrush="{ThemeResource BrewCardBorderBrush}"
                            BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="12">
                            <FontIcon Glyph="&#xE7C3;"
                                      FontSize="48"
                                      Foreground="{ThemeResource BrewCaramelBrush}"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="No orders yet"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource BrewCocoaBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Your order history will appear here once you place your first order."
                                       FontSize="13"
                                       Foreground="{ThemeResource BrewMochaBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="240" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </utu:SafeArea>
</Page>
