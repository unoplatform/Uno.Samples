<Page x:Class="BrewHouse.Presentation.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid x:Name="Root" MaxWidth="1100" HorizontalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{ThemeResource BackgroundBrush}"
                    Padding="20,20,20,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="My Orders"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{ThemeResource OnBackgroundBrush}" />
                    <TextBlock Text="Track your current and past orders"
                               FontSize="14"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
            </Border>

            <!-- Orders feed: ValueTemplate shows the list, NoneTemplate the empty state. The shared
                 order book goes to None when there are no orders. -->
            <mvux:FeedView Grid.Row="1" Source="{Binding Orders}">
                <DataTemplate>
            <!-- Orders: 1 column on phones, reflows to 2 on wide screens (no breakpoints) -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          Padding="20,0,20,16">
                <StackPanel Spacing="12">

                    <ItemsRepeater ItemsSource="{Binding Data}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="360"
                                               MinColumnSpacing="12"
                                               MinRowSpacing="12"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="16"
                                        Padding="16"
                                        BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="12">

                                        <!-- Order Header Row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Id}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                                <TextBlock Text="{Binding PlacedAt}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </StackPanel>

                                            <!-- Status Badge: themed pill + semantic status dot -->
                                            <Border Grid.Column="1"
                                                    Background="{ThemeResource SurfaceVariantBrush}"
                                                    CornerRadius="20"
                                                    Padding="10,5"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <!-- Status dot: pre-styled, visibility-toggled by status flags
                                                         (the colours live in App.xaml, the choice stays in XAML) -->
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                             Fill="{StaticResource BrewStatusReadyBrush}"
                                                             Visibility="{Binding IsReady, Converter={StaticResource BoolToVisibility}}" />
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                             Fill="{StaticResource BrewStatusPreparingBrush}"
                                                             Visibility="{Binding IsPreparing, Converter={StaticResource BoolToVisibility}}" />
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                             Fill="{StaticResource BrewStatusDoneBrush}"
                                                             Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}" />
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Divider -->
                                        <Border Height="1"
                                                Background="{ThemeResource OutlineVariantBrush}"
                                                HorizontalAlignment="Stretch" />

                                        <!-- Items Summary -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Items"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       CharacterSpacing="50" />
                                            <TextBlock Text="{Binding ItemSummary}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Total Row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="Order Total"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="1"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       Foreground="{ThemeResource SecondaryBrush}">
                                                <Run Text="$" />
                                                <Run Text="{Binding TotalFormatted}" />
                                            </TextBlock>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </ScrollViewer>
                </DataTemplate>

                <!-- No orders yet -->
                <mvux:FeedView.NoneTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="16"
                                Padding="32,40"
                                Margin="20,0,20,16"
                                VerticalAlignment="Top"
                                BorderBrush="{ThemeResource BrewCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="12">
                                <FontIcon Glyph="&#xE7C3;"
                                          FontSize="44"
                                          Foreground="{ThemeResource SecondaryBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="No orders yet"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Your order history will appear here once you place your first order."
                                           FontSize="13"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="240" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </mvux:FeedView.NoneTemplate>
            </mvux:FeedView>

        </Grid>
    </utu:SafeArea>
</Page>
