<Page x:Class="BrewHouse.Presentation.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <utu:SafeArea Insets="VisibleBounds">
        <Grid MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Back bar -->
            <Button Grid.Row="0"
                    Style="{StaticResource FlatButtonStyle}"
                    CornerRadius="10"
                    Padding="12,10"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name="Back"
                    Command="{Binding GoBack}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <TextBlock Text="Back" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource OnBackgroundBrush}" />
                </StackPanel>
            </Button>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Spacing="0">

                    <!-- Hero image -->
                    <Border Height="300"
                            CornerRadius="20"
                            Margin="16,0,16,0">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding Product.ImageUrl}" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                    <StackPanel Padding="20,18,20,24" Spacing="12">

                        <!-- Special badge -->
                        <Border Background="{ThemeResource SurfaceVariantBrush}"
                                CornerRadius="6"
                                Padding="8,3"
                                HorizontalAlignment="Left"
                                Visibility="{Binding Product.IsSpecial, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Today's Special"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource SecondaryBrush}" />
                        </Border>

                        <TextBlock Text="{Binding Product.Category}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="50"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />

                        <TextBlock Text="{Binding Product.Name}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource OnBackgroundBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource SecondaryBrush}">
                            <Run Text="$" /><Run Text="{Binding Product.Price}" />
                        </TextBlock>

                        <TextBlock Text="{Binding Product.Description}"
                                   FontSize="15"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />

                        <Button Style="{StaticResource BrewButtonStyle}"
                                Content="+ Add to Cart"
                                AutomationProperties.Name="Add to cart"
                                HorizontalAlignment="Stretch"
                                CornerRadius="12"
                                Padding="0,12"
                                FontSize="14"
                                FontWeight="Bold"
                                Margin="0,8,0,0"
                                Command="{Binding AddToCart}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
