        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utus:SimpleToolkitTheme xmlns:utus="using:Uno.Toolkit.UI.Simple" ColorOverrideSource="ms-appx:///ThemeColors.xaml"><utus:SimpleToolkitTheme.FontOverrideDictionary><ResourceDictionary><FontFamily x:Key="SimpleFontFamily">Barlow</FontFamily><FontFamily x:Key="DisplayLargeFontFamily">Barlow Condensed</FontFamily><FontFamily x:Key="DisplayMediumFontFamily">Barlow Condensed</FontFamily><FontFamily x:Key="DisplaySmallFontFamily">Barlow Condensed</FontFamily><FontFamily x:Key="HeadlineLargeFontFamily">Barlow Condensed</FontFamily><FontWeight x:Key="HeadlineLargeFontWeight">700</FontWeight><FontFamily x:Key="HeadlineMediumFontFamily">Barlow Condensed</FontFamily><FontWeight x:Key="TitleLargeFontWeight">600</FontWeight><FontWeight x:Key="LabelLargeFontWeight">600</FontWeight><x:Double x:Key="BodyMediumFontSize">14</x:Double></ResourceDictionary></utus:SimpleToolkitTheme.FontOverrideDictionary></utus:SimpleToolkitTheme>
      </ResourceDictionary.MergedDictionaries><CornerRadius x:Key="ControlCornerRadiusSmall">4</CornerRadius><CornerRadius x:Key="ControlCornerRadius">10</CornerRadius><CornerRadius x:Key="OverlayCornerRadius">18</CornerRadius><SolidColorBrush x:Key="App.PageBackground.Background" Color="{ThemeResource BackgroundBrush}" /><SolidColorBrush x:Key="App.PageBackground.Foreground" Color="{ThemeResource OnBackgroundBrush}" /><SolidColorBrush x:Key="App.CardBackground.Background" Color="{ThemeResource SurfaceBrush}" /><SolidColorBrush x:Key="App.CardBackground.Foreground" Color="{ThemeResource OnSurfaceBrush}" /><SolidColorBrush x:Key="App.NestedSurface.Background" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.NestedSurface.Foreground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.TabBar.Background" Color="{ThemeResource SurfaceBrush}" /><SolidColorBrush x:Key="App.TabBar.Foreground" Color="{ThemeResource OnSurfaceBrush}" /><SolidColorBrush x:Key="App.TabBar.SelectionIndicator" Color="{ThemeResource PrimaryBrush}" /><SolidColorBrush x:Key="App.NavigationView.SidebarBackground" Color="{ThemeResource PrimaryContainerBrush}" /><SolidColorBrush x:Key="App.NavigationView.SidebarForeground" Color="{ThemeResource OnPrimaryContainerBrush}" /><SolidColorBrush x:Key="App.Accent.Indicator" Color="{ThemeResource SecondaryBrush}" /><SolidColorBrush x:Key="App.Badge.Positive" Color="{ThemeResource TertiaryBrush}" /><SolidColorBrush x:Key="App.Badge.Positive.Foreground" Color="{ThemeResource OnTertiaryBrush}" /><SolidColorBrush x:Key="App.Badge.Negative" Color="{ThemeResource ErrorBrush}" /><SolidColorBrush x:Key="App.Badge.Negative.Foreground" Color="{ThemeResource OnErrorBrush}" /><SolidColorBrush x:Key="App.Badge.Neutral" Color="{ThemeResource SurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Badge.Neutral.Foreground" Color="{ThemeResource OnSurfaceVariantBrush}" /><SolidColorBrush x:Key="App.Text.High" Color="{ThemeResource 