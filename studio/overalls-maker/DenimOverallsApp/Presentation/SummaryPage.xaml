<Page x:Class="DenimOverallsApp.Presentation.SummaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:conv="using:DenimOverallsApp.Converters"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <conv:HexColorToBrushConverter x:Key="HexToBrush"/>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Navigation Bar ─────────────────────────────────────────── -->
        <utu:NavigationBar Grid.Row="0"
                           Content="Review Your Order"
                           AutomationProperties.Name="Review Your Order navigation bar"/>

        <!-- ── Scrollable body ────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" Spacing="16">

                <!-- ── Mini overall preview + config ──────────────────── -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <Grid Padding="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mini overall silhouette -->
                        <Grid Grid.Column="0" Width="80" Height="130" Margin="0,0,16,0">
                            <!-- Legs -->
                            <Rectangle Width="48" Height="80"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       RadiusX="5" RadiusY="5"
                                       Fill="{Binding ColorHex, Converter={StaticResource HexToBrush}}"/>
                            <!-- Leg seam -->
                            <Rectangle Width="1" Height="64"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="#FF000000" Opacity="0.12"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <!-- Left strap -->
                            <Rectangle Width="8" Height="34"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Left"
                                       Margin="14,0,0,0"
                                       RadiusX="3" RadiusY="3"
                                       Fill="{ThemeResource PrimaryContainerBrush}"/>
                            <!-- Right strap -->
                            <Rectangle Width="8" Height="34"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,14,0"
                                       RadiusX="3" RadiusY="3"
                                       Fill="{ThemeResource PrimaryContainerBrush}"/>
                            <!-- Bib -->
                            <Rectangle Width="48" Height="55"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Center"
                                       RadiusX="6" RadiusY="6"
                                       Fill="{Binding ColorHex, Converter={StaticResource HexToBrush}}"
                                       Margin="0,12,0,0"/>
                            <!-- Brass buttons -->
                            <Ellipse Width="6" Height="6"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Left"
                                     Margin="22,14,0,0"
                                     Fill="{ThemeResource SecondaryBrush}"/>
                            <Ellipse Width="6" Height="6"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Right"
                                     Margin="0,14,22,0"
                                     Fill="{ThemeResource SecondaryBrush}"/>
                        </Grid>

                        <!-- Config details -->
                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="YOUR CUSTOM OVERALLS"
                                       Style="{StaticResource LabelExtraSmall}"
                                       CharacterSpacing="100"
                                       Foreground="{ThemeResource SecondaryBrush}"/>

                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Length"
                                               Style="{StaticResource LabelMedium}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Width="80"/>
                                    <TextBlock Text="{Binding LengthLabel}"
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Bib Type"
                                               Style="{StaticResource LabelMedium}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Width="80"/>
                                    <TextBlock Text="{Binding BibLabel}"
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Color"
                                               Style="{StaticResource LabelMedium}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Width="80"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="12" Height="12"
                                                 Fill="{Binding ColorHex, Converter={StaticResource HexToBrush}}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ColorName}"
                                                   Style="{StaticResource BodyMedium}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Pockets"
                                               Style="{StaticResource LabelMedium}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               Width="80"/>
                                    <TextBlock Text="{Binding PocketLabel}"
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </utu:CardContentControl>

                <!-- ── Price Breakdown ────────────────────────────────── -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BF;" FontSize="16" Foreground="{ThemeResource SecondaryBrush}"/>
                        <TextBlock Text="PRICE BREAKDOWN"
                                   Style="{StaticResource LabelLarge}"
                                   CharacterSpacing="80"
                                   Foreground="{ThemeResource OnBackgroundBrush}"/>
                    </StackPanel>

                    <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                            IsClickable="False"
                                            HorizontalAlignment="Stretch">
                        <StackPanel Padding="16" Spacing="12">
                            <ItemsRepeater ItemsSource="{Binding LineItems}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       Style="{StaticResource BodyMedium}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Amount}"
                                                       Style="{StaticResource LabelMedium}"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- Divider -->
                            <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" Margin="0,4"/>

                            <!-- Subtotal -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Subtotal"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SubtotalLabel}"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"/>
                            </Grid>

                            <!-- Shipping -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Shipping"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ShippingLabel}"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"/>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource PrimaryBrush}" Margin="0,4" Opacity="0.3"/>

                            <!-- Total -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="TOTAL"
                                           Style="{StaticResource TitleMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalLabel}"
                                           Style="{StaticResource TitleLarge}"
                                           Foreground="{ThemeResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </utu:CardContentControl>
                </StackPanel>

                <!-- ── Delivery Info ──────────────────────────────────── -->
                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}"
                                        IsClickable="False"
                                        HorizontalAlignment="Stretch">
                    <StackPanel Padding="16,12" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8A5;" FontSize="16" Foreground="{ThemeResource TertiaryBrush}"/>
                            <TextBlock Text="PRODUCTION &#x26; DELIVERY"
                                       Style="{StaticResource LabelLarge}"
                                       CharacterSpacing="60"
                                       Foreground="{ThemeResource OnSurfaceBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="{Binding LeadTime}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72D;" FontSize="13" Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="{Binding ShipMethod}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </utu:CardContentControl>

                <Border Height="16"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── CTA bar ────────────────────────────────────────────────── -->
        <utu:CardContentControl Grid.Row="2"
                                Style="{StaticResource FilledCardContentControlStyle}"
                                HorizontalAlignment="Stretch"
                                IsClickable="False">
            <Grid Padding="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="ORDER TOTAL"
                               Style="{StaticResource LabelExtraSmall}"
                               CharacterSpacing="80"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                    <TextBlock Text="{Binding TotalLabel}"
                               Style="{StaticResource HeadlineSmall}"
                               Foreground="{ThemeResource PrimaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Proceed to Checkout"
                        Style="{StaticResource FilledButtonStyle}"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Proceed to checkout"
                        Command="{Binding ProceedToCheckout}"/>
            </Grid>
        </utu:CardContentControl>
    </Grid>
</Page>
