<Page x:Class="DenimOverallsApp.Presentation.MainPage"
	  x:Name="PageRoot"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:utu="using:Uno.Toolkit.UI"
	  xmlns:uen="using:Uno.Extensions.Navigation.UI"
	  xmlns:conv="using:DenimOverallsApp.Converters"
	  Background="{ThemeResource LinenBackgroundBrush}">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<!-- Light: warm linen / ink / brass -->
				<ResourceDictionary x:Key="Light">
					<LinearGradientBrush x:Key="LinenBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
						<GradientStop Offset="0" Color="#F7F4ED" />
						<GradientStop Offset="0.55" Color="#F0EBDF" />
						<GradientStop Offset="1" Color="#E6DFCF" />
					</LinearGradientBrush>
					<RadialGradientBrush x:Key="LinenMottleBrush" Center="0.3,0.25" RadiusX="0.9" RadiusY="0.9">
						<GradientStop Offset="0" Color="#22FFFFFF" />
						<GradientStop Offset="0.6" Color="#08FFFFFF" />
						<GradientStop Offset="1" Color="#00FFFFFF" />
					</RadialGradientBrush>
					<RadialGradientBrush x:Key="VignetteBrush" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
						<GradientStop Offset="0" Color="#001F2430" />
						<GradientStop Offset="0.72" Color="#001F2430" />
						<GradientStop Offset="1" Color="#1A1F2430" />
					</RadialGradientBrush>
					<LinearGradientBrush x:Key="PreviewCardBrush" StartPoint="0,0" EndPoint="0.4,1">
						<GradientStop Offset="0" Color="#FBF8F1" />
						<GradientStop Offset="1" Color="#F1ECE0" />
					</LinearGradientBrush>
					<SolidColorBrush x:Key="MotifInkBrush"
									 Color="#1F2430"
									 Opacity="0.16" />
					<SolidColorBrush x:Key="MotifBrassBrush"
									 Color="#B07B3C"
									 Opacity="0.22" />
					<SolidColorBrush x:Key="PreviewCardBorderBrush"
									 Color="#C9A36A"
									 Opacity="0.35" />
				</ResourceDictionary>
				<!-- Dark: deep ink, soft brass accents -->
				<ResourceDictionary x:Key="Dark">
					<LinearGradientBrush x:Key="LinenBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
						<GradientStop Offset="0" Color="#15171F" />
						<GradientStop Offset="0.55" Color="#1B1F2B" />
						<GradientStop Offset="1" Color="#222739" />
					</LinearGradientBrush>
					<RadialGradientBrush x:Key="LinenMottleBrush" Center="0.3,0.25" RadiusX="0.9" RadiusY="0.9">
						<GradientStop Offset="0" Color="#18FFFFFF" />
						<GradientStop Offset="0.6" Color="#06FFFFFF" />
						<GradientStop Offset="1" Color="#00FFFFFF" />
					</RadialGradientBrush>
					<RadialGradientBrush x:Key="VignetteBrush" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
						<GradientStop Offset="0" Color="#00000000" />
						<GradientStop Offset="0.62" Color="#00000000" />
						<GradientStop Offset="1" Color="#44000000" />
					</RadialGradientBrush>
					<LinearGradientBrush x:Key="PreviewCardBrush" StartPoint="0,0" EndPoint="0.4,1">
						<GradientStop Offset="0" Color="#2B303C" />
						<GradientStop Offset="1" Color="#222734" />
					</LinearGradientBrush>
					<SolidColorBrush x:Key="MotifInkBrush"
									 Color="#EDE8DE"
									 Opacity="0.13" />
					<SolidColorBrush x:Key="MotifBrassBrush"
									 Color="#D9B877"
									 Opacity="0.26" />
					<SolidColorBrush x:Key="PreviewCardBorderBrush"
									 Color="#C9A36A"
									 Opacity="0.30" />
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<conv:HexColorToBrushConverter x:Key="HexToBrush" />
			<conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
			<conv:SelectionToThicknessConverter x:Key="SelThickness" />

			<!-- Classic golden denim topstitching -->
			<SolidColorBrush x:Key="TopStitchBrush"
							 Color="#E8B95C" />

			<!-- ════ Denim depth overlays (color-independent; painted over the bound fill) ════ -->
			<LinearGradientBrush x:Key="BibShadeBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#00000000" />
				<GradientStop Offset="0.55" Color="#14000000" />
				<GradientStop Offset="1.0" Color="#3A000000" />
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="ChestSheenBrush" StartPoint="0.1,0.05" EndPoint="0.85,0.9">
				<GradientStop Offset="0.0" Color="#26FFFFFF" />
				<GradientStop Offset="0.35" Color="#0CFFFFFF" />
				<GradientStop Offset="1.0" Color="#00FFFFFF" />
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="LegShadeBrush" StartPoint="0,0.5" EndPoint="1,0.5">
				<GradientStop Offset="0.0" Color="#33000000" />
				<GradientStop Offset="0.18" Color="#0A000000" />
				<GradientStop Offset="0.5" Color="#2E000000" />
				<GradientStop Offset="0.82" Color="#0A000000" />
				<GradientStop Offset="1.0" Color="#33000000" />
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="LegHemShadeBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#00000000" />
				<GradientStop Offset="0.78" Color="#00000000" />
				<GradientStop Offset="1.0" Color="#33000000" />
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="CuffBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#33FFFFFF" />
				<GradientStop Offset="0.22" Color="#10000000" />
				<GradientStop Offset="1.0" Color="#40000000" />
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="PocketShadeBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#08000000" />
				<GradientStop Offset="1.0" Color="#28000000" />
			</LinearGradientBrush>
			<RadialGradientBrush x:Key="WearHighlightBrush" Center="0.5,0.5" RadiusX="0.65" RadiusY="0.55">
				<GradientStop Offset="0.0" Color="#22FFFFFF" />
				<GradientStop Offset="1.0" Color="#00FFFFFF" />
			</RadialGradientBrush>
			<RadialGradientBrush x:Key="BrassBrush" Center="0.35,0.3" RadiusX="0.85" RadiusY="0.85">
				<GradientStop Offset="0.0" Color="#F2E4B8" />
				<GradientStop Offset="0.38" Color="#C9A36A" />
				<GradientStop Offset="1.0" Color="#8A5E2C" />
			</RadialGradientBrush>
			<SolidColorBrush x:Key="BrassRimBrush"
							 Color="#6E4A21" />

			<!-- Strap roll: light top face, shadow where it wraps over the shoulder -->
			<LinearGradientBrush x:Key="StrapShadeBrush" StartPoint="0,0" EndPoint="1,0.4">
				<GradientStop Offset="0.0" Color="#30FFFFFF" />
				<GradientStop Offset="0.45" Color="#00FFFFFF" />
				<GradientStop Offset="1.0" Color="#33000000" />
			</LinearGradientBrush>
			<!-- Soft form shadow cast onto the torso just above the waistband -->
			<LinearGradientBrush x:Key="WaistShadowBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#00000000" />
				<GradientStop Offset="1.0" Color="#26000000" />
			</LinearGradientBrush>
			<!-- Waistband self-shading: highlight at the top fold, shadow at the bottom -->
			<LinearGradientBrush x:Key="WaistbandShadeBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#2EFFFFFF" />
				<GradientStop Offset="0.45" Color="#00FFFFFF" />
				<GradientStop Offset="1.0" Color="#33000000" />
			</LinearGradientBrush>
			<!-- Subtle vertical highlight down each leg centre -->
			<LinearGradientBrush x:Key="LegSheenBrush" StartPoint="0,0.5" EndPoint="1,0.5">
				<GradientStop Offset="0.0" Color="#00FFFFFF" />
				<GradientStop Offset="0.5" Color="#22FFFFFF" />
				<GradientStop Offset="1.0" Color="#00FFFFFF" />
			</LinearGradientBrush>
			<!-- Gentle knee shading -->
			<RadialGradientBrush x:Key="KneeShadeBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
				<GradientStop Offset="0.0" Color="#22000000" />
				<GradientStop Offset="1.0" Color="#00000000" />
			</RadialGradientBrush>
			<!-- Inner shadow cast just under the bib lower edge and under pocket flaps -->
			<LinearGradientBrush x:Key="InnerEdgeShadowBrush" StartPoint="0.5,0" EndPoint="0.5,1">
				<GradientStop Offset="0.0" Color="#48000000" />
				<GradientStop Offset="0.55" Color="#14000000" />
				<GradientStop Offset="1.0" Color="#00000000" />
			</LinearGradientBrush>
			<!-- Soft fold/crease (crotch + knee): dark centre fading both ways -->
			<LinearGradientBrush x:Key="CreaseShadeBrush" StartPoint="0,0.5" EndPoint="1,0.5">
				<GradientStop Offset="0.0" Color="#00000000" />
				<GradientStop Offset="0.5" Color="#33000000" />
				<GradientStop Offset="1.0" Color="#00000000" />
			</LinearGradientBrush>
			<!-- Brass buckle metal face (vertical sheen) -->
			<LinearGradientBrush x:Key="BuckleFaceBrush" StartPoint="0,0" EndPoint="0,1">
				<GradientStop Offset="0.0" Color="#F2E4B8" />
				<GradientStop Offset="0.5" Color="#C9A36A" />
				<GradientStop Offset="1.0" Color="#8A5E2C" />
			</LinearGradientBrush>

			<!-- Neutral denim weave grain (bitmap overlay; works over any dynamic colour) -->
			<ImageBrush x:Key="DenimWeaveBrush"
						ImageSource="ms-appx:///Assets/Textures/denim-weave.png"
						Stretch="UniformToFill" />

			<!-- Borderless click surface: the CardContentControl inside provides all visuals -->
			<Style x:Key="OptionCardButtonStyle"
				   TargetType="Button">
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="HorizontalContentAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Stretch" />
				<Setter Property="VerticalContentAlignment" Value="Stretch" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="UseSystemFocusVisuals" Value="True" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="Button">
							<ContentPresenter Content="{TemplateBinding Content}"
											  HorizontalAlignment="Stretch"
											  VerticalAlignment="Stretch"
											  HorizontalContentAlignment="Stretch"
											  VerticalContentAlignment="Stretch" />
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="RootGrid"
		  utu:SafeArea.Insets="VisibleBounds">
		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup>
				<VisualState x:Name="WideLayout">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="900" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="PreviewCol.Width" Value="280" />
					</VisualState.Setters>
				</VisualState>
				<VisualState x:Name="NarrowLayout">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="0" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="PreviewCol.Width" Value="0" />
					</VisualState.Setters>
				</VisualState>
			</VisualStateGroup>
		</VisualStateManager.VisualStateGroups>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- ── Ambience: linen background, soft mottle, edge vignette (behind everything) ── -->
		<Rectangle Grid.Row="0"
				   Grid.RowSpan="3"
				   Fill="{ThemeResource LinenBackgroundBrush}"
				   IsHitTestVisible="False" />
		<Rectangle Grid.Row="0"
				   Grid.RowSpan="3"
				   Fill="{ThemeResource LinenMottleBrush}"
				   IsHitTestVisible="False" />
		<Rectangle Grid.Row="0"
				   Grid.RowSpan="3"
				   Fill="{ThemeResource VignetteBrush}"
				   IsHitTestVisible="False" />

		<!-- ── Header ─────────────────────────────────────────────────── -->
		<utu:CardContentControl Grid.Row="0"
								Style="{StaticResource FilledCardContentControlStyle}"
								HorizontalAlignment="Stretch"
								IsClickable="False">
			<StackPanel Padding="16,12"
						Spacing="2">
				<TextBlock Text="DENIM STUDIO"
						   Style="{StaticResource LabelExtraSmall}"
						   Foreground="{ThemeResource SecondaryBrush}"
						   CharacterSpacing="150" />
				<TextBlock Text="Build Your Overalls"
						   Style="{StaticResource HeadlineMedium}"
						   Foreground="{ThemeResource OnSurfaceBrush}" />
				<TextBlock Text="Design your perfect pair."
						   Style="{StaticResource BodySmall}"
						   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
			</StackPanel>
		</utu:CardContentControl>

		<!-- ── Body: responsive split ─────────────────────────────────── -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="PreviewCol"
								  Width="0" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<!-- LEFT — Overall Preview Panel (shown on wide screens) -->
			<ScrollViewer Grid.Column="0"
						  VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="16"
							Spacing="16">
					<TextBlock Text="PREVIEW"
							   Style="{StaticResource LabelExtraSmall}"
							   CharacterSpacing="150"
							   Foreground="{ThemeResource SecondaryBrush}"
							   HorizontalAlignment="Center" />

					<!-- Preview card — warm linen, faint motifs behind a single-coordinate "SVG" overall -->
					<Border CornerRadius="18"
							Background="{ThemeResource PreviewCardBrush}"
							BorderBrush="{ThemeResource PreviewCardBorderBrush}"
							BorderThickness="1"
							Padding="8"
							HorizontalAlignment="Stretch">
						<Grid MinHeight="578">

							<!-- ░░ Decorative line-art motifs (behind figure, non-interactive) ░░ -->
							<Grid IsHitTestVisible="False">
								<Viewbox Width="54"
										 Height="70"
										 HorizontalAlignment="Left"
										 VerticalAlignment="Top"
										 Margin="8,8,0,0">
									<Canvas Width="58"
											Height="74">
										<Path Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeLineJoin="Round"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round"
											  Data="M 29,72 C 27,52 26,34 30,8" />
										<Path Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeLineJoin="Round"
											  Data="M 28,56 C 14,52 8,44 6,34 C 18,36 26,44 28,56 Z" />
										<Path Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeLineJoin="Round"
											  Data="M 29,44 C 43,40 50,32 52,22 C 40,24 31,32 29,44 Z" />
										<Path Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeLineJoin="Round"
											  Data="M 30,30 C 20,26 15,18 14,10 C 24,12 29,20 30,30 Z" />
									</Canvas>
								</Viewbox>
								<Viewbox Width="54"
										 Height="54"
										 HorizontalAlignment="Right"
										 VerticalAlignment="Top"
										 Margin="0,10,10,0">
									<Canvas Width="60"
											Height="60">
										<Ellipse Canvas.Left="20"
												 Canvas.Top="20"
												 Width="20"
												 Height="20"
												 Stroke="{ThemeResource MotifBrassBrush}"
												 StrokeThickness="1" />
										<Line X1="30"
											  Y1="2"
											  X2="30"
											  Y2="12"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="30"
											  Y1="48"
											  X2="30"
											  Y2="58"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="2"
											  Y1="30"
											  X2="12"
											  Y2="30"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="48"
											  Y1="30"
											  X2="58"
											  Y2="30"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="11"
											  Y1="11"
											  X2="18"
											  Y2="18"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="49"
											  Y1="11"
											  X2="42"
											  Y2="18"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="11"
											  Y1="49"
											  X2="18"
											  Y2="42"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
										<Line X1="49"
											  Y1="49"
											  X2="42"
											  Y2="42"
											  Stroke="{ThemeResource MotifBrassBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round" />
									</Canvas>
								</Viewbox>
								<Viewbox Width="72"
										 Height="42"
										 HorizontalAlignment="Right"
										 VerticalAlignment="Top"
										 Margin="0,150,8,0">
									<Canvas Width="74"
											Height="44">
										<Polyline Stroke="{ThemeResource MotifInkBrush}"
												  StrokeThickness="1"
												  StrokeLineJoin="Round"
												  Points="0,42 16,18 26,30 40,6 54,26 62,16 74,42" />
										<Polyline Stroke="{ThemeResource MotifInkBrush}"
												  StrokeThickness="1"
												  StrokeLineJoin="Round"
												  Points="34,14 40,6 46,15 42,13 38,16" />
									</Canvas>
								</Viewbox>
								<Viewbox Width="150"
										 Height="34"
										 HorizontalAlignment="Center"
										 VerticalAlignment="Bottom"
										 Margin="0,0,0,14">
									<Canvas Width="150"
											Height="34">
										<Path Stroke="{ThemeResource MotifInkBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round"
											  Data="M 0,8 C 12,2 24,14 36,8 C 48,2 60,14 72,8 C 84,2 96,14 108,8 C 120,2 132,14 150,8" />
										<Path Stroke="{ThemeResource MotifInkBrush}"
											  StrokeThickness="1"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round"
											  Data="M 0,22 C 12,16 24,28 36,22 C 48,16 60,28 72,22 C 84,16 96,28 108,22 C 120,16 132,28 150,22" />
									</Canvas>
								</Viewbox>
							</Grid>

							<!-- ░░ Hero denim figure — single-coordinate "SVG", fully reactive ░░ -->
							<Viewbox MaxWidth="250"
									 MaxHeight="560"
									 StretchDirection="DownOnly"
									 HorizontalAlignment="Center">
								<Canvas Width="220"
										Height="560"
										VerticalAlignment="Bottom"
										HorizontalAlignment="Center">

									<!-- ===== LONG TROUSERS (straight legs, rolled cuffs at hem y494) ===== -->
									<Canvas Canvas.Left="0"
											Canvas.Top="0"
											Visibility="{Binding IsLongLength, Converter={StaticResource BoolToVis}}">
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{Binding SelectedColorHex, Converter={StaticResource HexToBrush}}"
											  Data="M 44,170 C 44,186 43.5,196 44,205 C 43.5,300 43,400 43,490 C 43,492 45,494 47,494 L 101,494 C 103,494 104,492 104,490 C 105,420 105,330 110,252 C 115,330 115,420 116,490 C 116,492 117,494 119,494 L 173,494 C 175,494 177,492 177,490 C 177,400 176.5,300 176,205 C 176.5,196 176,186 176,170 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Opacity="0.4"
											  Fill="{StaticResource DenimWeaveBrush}"
											  Data="M 44,170 C 44,186 43.5,196 44,205 C 43.5,300 43,400 43,490 C 43,492 45,494 47,494 L 101,494 C 103,494 104,492 104,490 C 105,420 105,330 110,252 C 115,330 115,420 116,490 C 116,492 117,494 119,494 L 173,494 C 175,494 177,492 177,490 C 177,400 176.5,300 176,205 C 176.5,196 176,186 176,170 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource LegShadeBrush}"
											  Data="M 44,205 C 43.5,300 43,400 43,490 C 43,492 45,494 47,494 L 101,494 C 103,494 104,492 104,490 C 105,420 105,330 110,252 C 115,330 115,420 116,490 C 116,492 117,494 119,494 L 173,494 C 175,494 177,492 177,490 C 177,400 176.5,300 176,205 C 150,210 70,210 44,205 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource LegHemShadeBrush}"
											  Data="M 44,205 C 43.5,300 43,400 43,490 C 43,492 45,494 47,494 L 101,494 C 103,494 104,492 104,490 C 105,420 105,330 110,252 C 115,330 115,420 116,490 C 116,492 117,494 119,494 L 173,494 C 175,494 177,492 177,490 C 177,400 176.5,300 176,205 C 150,210 70,210 44,205 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource LegSheenBrush}"
											  Data="M 60,260 C 56,340 56,420 62,488 L 86,488 C 80,420 80,340 82,258 C 74,256 66,256 60,260 Z M 160,260 C 164,340 164,420 158,488 L 134,488 C 140,420 140,340 138,258 C 146,256 154,256 160,260 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource CreaseShadeBrush}"
											  Opacity="0.65"
											  Data="M 100,256 C 106,266 114,266 120,256 C 116,276 104,276 100,256 Z" />
										<Ellipse Canvas.Left="56"
												 Canvas.Top="338"
												 Width="36"
												 Height="54"
												 Fill="{StaticResource KneeShadeBrush}" />
										<Ellipse Canvas.Left="128"
												 Canvas.Top="338"
												 Width="36"
												 Height="54"
												 Fill="{StaticResource KneeShadeBrush}" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource CreaseShadeBrush}"
											  Opacity="0.5"
											  Data="M 52,360 C 64,356 80,356 92,360 C 80,366 64,366 52,360 Z M 128,360 C 140,356 156,356 168,360 C 156,366 140,366 128,360 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Fill="{StaticResource InnerEdgeShadowBrush}"
											  Opacity="0.55"
											  Data="M 104,260 C 105,360 105,440 104,488 L 108,488 C 109,440 109,360 110,260 Z M 116,260 C 115,360 115,440 116,488 L 112,488 C 111,440 111,360 110,260 Z" />
										<Path Canvas.Left="0"
											  Canvas.Top="0"
											  Stroke="{StaticResource TopStitchBrush}"
											  StrokeThickness="1.1"
