<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Color x:Key="PrimaryColor">#1B3F7A</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#D6E3FF</Color>
			<Color x:Key="OnPrimaryContainerColor">#001B47</Color>
			<Color x:Key="SecondaryColor">#B5793A</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#FFDCBA</Color>
			<Color x:Key="OnSecondaryContainerColor">#2D1600</Color>
			<Color x:Key="TertiaryColor">#5B6B3E</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#DEF0BB</Color>
			<Color x:Key="OnTertiaryContainerColor">#192000</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<Color x:Key="SurfaceColor">#F4F2FA</Color>
			<Color x:Key="OnSurfaceColor">#1B1B24</Color>
			<Color x:Key="SurfaceVariantColor">#DFE1F2</Color>
			<Color x:Key="OnSurfaceVariantColor">#44455C</Color>
			<Color x:Key="BackgroundColor">#F4F2FA</Color>
			<Color x:Key="OnBackgroundColor">#1B1B24</Color>
			<Color x:Key="OutlineColor">#76778C</Color>
			<Color x:Key="OutlineVariantColor">#C5C6DA</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<Color x:Key="PrimaryColor">#AAC7FF</Color>
			<Color x:Key="OnPrimaryColor">#002E6C</Color>
			<Color x:Key="PrimaryContainerColor">#1B3F7A</Color>
			<Color x:Key="OnPrimaryContainerColor">#D6E3FF</Color>
			<Color x:Key="SecondaryColor">#FFB870</Color>
			<Color x:Key="OnSecondaryColor">#4A2800</Color>
			<Color x:Key="SecondaryContainerColor">#6A3D00</Color>
			<Color x:Key="OnSecondaryContainerColor">#FFDCBA</Color>
			<Color x:Key="TertiaryColor">#C3D99E</Color>
			<Color x:Key="OnTertiaryColor">#2D3D0C</Color>
			<Color x:Key="TertiaryContainerColor">#435328</Color>
			<Color x:Key="OnTertiaryContainerColor">#DEF0BB</Color>
			<Color x:Key="ErrorColor">#FFB4AB</Color>
			<Color x:Key="OnErrorColor">#690005</Color>
			<Color x:Key="SurfaceColor">#13131A</Color>
			<Color x:Key="OnSurfaceColor">#E4E1EC</Color>
			<Color x:Key="SurfaceVariantColor">#44455C</Color>
			<Color x:Key="OnSurfaceVariantColor">#C5C6DA</Color>
			<Color x:Key="BackgroundColor">#13131A</Color>
			<Color x:Key="OnBackgroundColor">#E4E1EC</Color>
			<Color x:Key="OutlineColor">#8F90A8</Color>
			<Color x:Key="OutlineVariantColor">#44455C</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
