<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Color x:Key="PrimaryColor">#2D7A3A</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#C4F5CA</Color>
			<Color x:Key="OnPrimaryContainerColor">#00210A</Color>
			<Color x:Key="SecondaryColor">#E07B1F</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#FFE2C4</Color>
			<Color x:Key="OnSecondaryContainerColor">#2E1400</Color>
			<Color x:Key="TertiaryColor">#0077B6</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#C2E9FF</Color>
			<Color x:Key="OnTertiaryContainerColor">#001E30</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<Color x:Key="SurfaceColor">#F4FBF1</Color>
			<Color x:Key="OnSurfaceColor">#182A1A</Color>
			<Color x:Key="SurfaceVariantColor">#D4EDDA</Color>
			<Color x:Key="OnSurfaceVariantColor">#3A4E3C</Color>
			<Color x:Key="BackgroundColor">#F0FAF0</Color>
			<Color x:Key="OnBackgroundColor">#182A1A</Color>
			<Color x:Key="OutlineColor">#6A8C6D</Color>
			<Color x:Key="OutlineVariantColor">#B8D4BB</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<Color x:Key="PrimaryColor">#6FCF7C</Color>
			<Color x:Key="OnPrimaryColor">#003910</Color>
			<Color x:Key="PrimaryContainerColor">#1A5626</Color>
			<Color x:Key="OnPrimaryContainerColor">#C4F5CA</Color>
			<Color x:Key="SecondaryColor">#FFB870</Color>
			<Color x:Key="OnSecondaryColor">#4A2000</Color>
			<Color x:Key="SecondaryContainerColor">#6B3500</Color>
			<Color x:Key="OnSecondaryContainerColor">#FFE2C4</Color>
			<Color x:Key="TertiaryColor">#7EC8F8</Color>
			<Color x:Key="OnTertiaryColor">#003A5C</Color>
			<Color x:Key="TertiaryContainerColor">#004F7A</Color>
			<Color x:Key="OnTertiaryContainerColor">#C2E9FF</Color>
			<Color x:Key="ErrorColor">#FFB4AB</Color>
			<Color x:Key="OnErrorColor">#690005</Color>
			<Color x:Key="SurfaceColor">#0F1F12</Color>
			<Color x:Key="OnSurfaceColor">#D8EDDA</Color>
			<Color x:Key="SurfaceVariantColor">#374B3A</Color>
			<Color x:Key="OnSurfaceVariantColor">#B8D4BB</Color>
			<Color x:Key="BackgroundColor">#0C1C0E</Color>
			<Color x:Key="OnBackgroundColor">#D8EDDA</Color>
			<Color x:Key="OutlineColor">#8BB08E</Color>
			<Color x:Key="OutlineVariantColor">#374B3A</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
