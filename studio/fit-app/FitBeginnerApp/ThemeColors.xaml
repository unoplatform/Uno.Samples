<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<!-- Ocean-blue identity -->
			<Color x:Key="PrimaryColor">#0067C0</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#D2E4FF</Color>
			<Color x:Key="OnPrimaryContainerColor">#001C3A</Color>
			<!-- Secondary: warm amber accent (calories / energy) -->
			<Color x:Key="SecondaryColor">#E07B1F</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#FFE2C4</Color>
			<Color x:Key="OnSecondaryContainerColor">#2E1400</Color>
			<!-- Tertiary: indigo accent (kept distinct from the blue primary) -->
			<Color x:Key="TertiaryColor">#4E4AC4</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#E2DFFF</Color>
			<Color x:Key="OnTertiaryContainerColor">#0D0066</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<!-- Cool blue-grey neutrals. Card surface lifts clearly off the background so the hairline
			     isn't doing all the work. -->
			<Color x:Key="SurfaceColor">#FFFFFF</Color>
			<Color x:Key="OnSurfaceColor">#1A1C22</Color>
			<Color x:Key="SurfaceVariantColor">#DCE3EC</Color>
			<Color x:Key="OnSurfaceVariantColor">#414751</Color>
			<Color x:Key="BackgroundColor">#F1F5FB</Color>
			<Color x:Key="OnBackgroundColor">#1A1C22</Color>
			<Color x:Key="OutlineColor">#71787F</Color>
			<Color x:Key="OutlineVariantColor">#C1C7D1</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<!-- Ocean-blue identity (dark) -->
			<Color x:Key="PrimaryColor">#7CC4FF</Color>
			<Color x:Key="OnPrimaryColor">#00335B</Color>
			<Color x:Key="PrimaryContainerColor">#004A7D</Color>
			<Color x:Key="OnPrimaryContainerColor">#D2E4FF</Color>
			<!-- Secondary: warm amber accent (calories / energy) -->
			<Color x:Key="SecondaryColor">#FFB870</Color>
			<Color x:Key="OnSecondaryColor">#4A2000</Color>
			<Color x:Key="SecondaryContainerColor">#6B3500</Color>
			<Color x:Key="OnSecondaryContainerColor">#FFE2C4</Color>
			<!-- Tertiary: indigo accent (kept distinct from the blue primary) -->
			<Color x:Key="TertiaryColor">#C4C0FF</Color>
			<Color x:Key="OnTertiaryColor">#1C1178</Color>
			<Color x:Key="TertiaryContainerColor">#3532A8</Color>
			<Color x:Key="OnTertiaryContainerColor">#E2DFFF</Color>
			<Color x:Key="ErrorColor">#FFB4AB</Color>
			<Color x:Key="OnErrorColor">#690005</Color>
			<!-- Cool blue-grey neutrals. Card surface lifts clearly off the background so the hairline
			     isn't doing all the work. -->
			<Color x:Key="SurfaceColor">#1A1D22</Color>
			<Color x:Key="OnSurfaceColor">#E1E3E9</Color>
			<Color x:Key="SurfaceVariantColor">#3F4750</Color>
			<Color x:Key="OnSurfaceVariantColor">#C1C7D1</Color>
			<Color x:Key="BackgroundColor">#0E1117</Color>
			<Color x:Key="OnBackgroundColor">#E1E3E9</Color>
			<Color x:Key="OutlineColor">#8B9198</Color>
			<Color x:Key="OutlineVariantColor">#3F4750</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
