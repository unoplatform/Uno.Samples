<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:utu="using:Uno.Toolkit.UI"
                    xmlns:presentation="using:FitBeginnerApp.Presentation">

  <!--
    FitStart styling vocabulary: converters, the Feeling-pill templates + selector, the type scale,
    the card/label styles, the corner-radius tokens, the responsive breakpoint, and the button
    control templates. Merged into App.xaml AFTER the Simple theme + MotionTokens so the well-known
    corner-radius overrides (ControlCornerRadius*, OverlayCornerRadius) win over the theme defaults.
    Pages CONSUME these keys via {StaticResource}/{ThemeResource}; they never re-declare the look.
  -->

  <!-- Content-free value transform so view-models expose plain bool state and XAML decides
       visibility. Pass Invert as the parameter to flip. -->
  <presentation:BoolToVisibilityConverter x:Key="BoolToVisibility" />
  <!-- Maps a workout Type / exercise Category to a distinct PathIcon geometry (dumbbell / flame /
       target / moon / sparkle) so lists don't repeat one glyph. -->
  <presentation:WorkoutIconConverter x:Key="WorkoutIcon" />
  <!-- Feeling pills: one {ThemeResource}-based template per value, chosen by a DataTemplateSelector.
       Colour lives in XAML (theme-reactive, and resolved against the correct app under Studio Live's
       ALC) rather than a brush-returning converter reading Application.Current.Resources. -->
  <DataTemplate x:Key="FeelingPillGreatTemplate">
    <Border Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
      <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnPrimaryContainerBrush}" VerticalAlignment="Center" HorizontalTextAlignment="Center" />
    </Border>
  </DataTemplate>
  <DataTemplate x:Key="FeelingPillGoodTemplate">
    <Border Background="{ThemeResource TertiaryContainerBrush}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
      <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnTertiaryContainerBrush}" VerticalAlignment="Center" HorizontalTextAlignment="Center" />
    </Border>
  </DataTemplate>
  <DataTemplate x:Key="FeelingPillToughTemplate">
    <Border Background="{ThemeResource SecondaryContainerBrush}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
      <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnSecondaryContainerBrush}" VerticalAlignment="Center" HorizontalTextAlignment="Center" />
    </Border>
  </DataTemplate>
  <DataTemplate x:Key="FeelingPillEasyTemplate">
    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
      <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnSurfaceVariantBrush}" VerticalAlignment="Center" HorizontalTextAlignment="Center" />
    </Border>
  </DataTemplate>
  <presentation:FeelingPillTemplateSelector x:Key="FeelingPillSelector"
                                            Great="{StaticResource FeelingPillGreatTemplate}"
                                            Good="{StaticResource FeelingPillGoodTemplate}"
                                            Tough="{StaticResource FeelingPillToughTemplate}"
                                            Easy="{StaticResource FeelingPillEasyTemplate}" />

  <!-- Type scale: a deliberate ramp so sizes are composed, not eyeballed. Every text element
       references one of these instead of a raw literal, so hierarchy stays consistent app-wide. -->
  <x:Double x:Key="FontSizeRing">40</x:Double>
  <x:Double x:Key="FontSizeH1">30</x:Double>
  <x:Double x:Key="FontSizeStat">28</x:Double>
  <x:Double x:Key="FontSizeStatSmall">22</x:Double>
  <x:Double x:Key="FontSizeTitle">18</x:Double>
  <x:Double x:Key="FontSizeSubtitle">15</x:Double>
  <x:Double x:Key="FontSizeBody">14</x:Double>
  <x:Double x:Key="FontSizeCaption">13</x:Double>
  <x:Double x:Key="FontSizeSection">12</x:Double>
  <x:Double x:Key="FontSizeLabel">10</x:Double>

  <!-- Card surface: a subtle raised surface defined by a hairline ring (semi-transparent
       OutlineVariant) rather than a heavy drop shadow — the de-genericised "flat + hairline"
       look. Adapts to light/dark via theme brushes. -->
  <Style x:Key="CardBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource OutlineVariantBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
  </Style>

  <!-- Section micro-label: uppercase, wide tracking — reads like an
       instrument label instead of a generic Material title. -->
  <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="{StaticResource FontSizeSection}" />
    <Setter Property="CharacterSpacing" Value="120" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
    <Setter Property="Margin" Value="2,0,0,12" />
  </Style>

  <!-- Rounder controls to match the card language -->
  <CornerRadius x:Key="ControlCornerRadiusSmall">12</CornerRadius>
  <CornerRadius x:Key="ControlCornerRadius">20</CornerRadius>
  <CornerRadius x:Key="OverlayCornerRadius">32</CornerRadius>

  <!-- Window-width breakpoint shared by the shell + page layouts: phone below 900px
       (bottom TabBar), desktop/web at or above (NavigationView pane). -->
  <utu:ResponsiveLayout x:Key="DefaultResponsiveLayout"
                        Narrow="0"
                        Wide="900" />

  <!-- Chrome-less, keyboard-focusable button: makes a card / row / chip a real, accessible
       control (focus + Invoke automation peer) while the inner content defines the look. A
       foreground-neutral state layer (rounded to the button's CornerRadius) gives hover/pressed
       feedback; set CornerRadius on the button to match the content's rounding. -->
  <Style x:Key="FlatButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="UseSystemFocusVisuals" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid Background="Transparent" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="FlatScale" />
            </Grid.RenderTransform>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="FlatStateLayer.Opacity" Value="0.06" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="FlatStateLayer.Opacity" Value="0.12" />
                    <Setter Target="FlatScale.ScaleX" Value="0.98" />
                    <Setter Target="FlatScale.ScaleY" Value="0.98" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="FlatContent.Opacity" Value="0.4" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <ContentPresenter x:Name="FlatContent"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Padding="{TemplateBinding Padding}"
                              Background="Transparent" />
            <Border x:Name="FlatStateLayer"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{ThemeResource OnSurfaceBrush}"
                    Opacity="0"
                    IsHitTestVisible="False" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Primary call-to-action: filled Primary surface, concentric radius,
       an OnPrimary state layer for hover/press, and the house 0.98 tactile press. Owns the CTA
       look so it reads as designed rather than a stock filled button. -->
  <Style x:Key="PrimaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Padding" Value="20,13" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="UseSystemFocusVisuals" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="PrimScale" />
            </Grid.RenderTransform>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="PrimOverlay.Opacity" Value="0.08" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PrimOverlay.Opacity" Value="0.16" />
                    <Setter Target="PrimScale.ScaleX" Value="0.98" />
                    <Setter Target="PrimScale.ScaleY" Value="0.98" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="PrimRoot.Opacity" Value="0.38" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Border x:Name="PrimRoot" Background="{TemplateBinding Background}" CornerRadius="14">
              <Grid>
                <ContentPresenter x:Name="PrimContent"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  Padding="{TemplateBinding Padding}"
                                  FontFamily="{TemplateBinding FontFamily}"
                                  FontSize="{TemplateBinding FontSize}"
                                  Foreground="{TemplateBinding Foreground}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                <Border x:Name="PrimOverlay"
                        CornerRadius="14"
                        Background="{ThemeResource OnPrimaryBrush}"
                        Opacity="0"
                        IsHitTestVisible="False" />
              </Grid>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
