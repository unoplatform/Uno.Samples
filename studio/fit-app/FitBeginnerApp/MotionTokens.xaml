<!--
    MotionTokens.xaml — the house motion/feel token system for FitStart.
    Values are the canonical ones from the xaml-design-polish skill; give numbers, never adjectives.

    Merged in App.xaml. Additive to the Simple theme (colour + type come from Material/Simple
    resources; these tokens add easing, duration, radius, and the entrance/press constants).

    Shadows: this sample intentionally does NOT use the Uno.Toolkit.Skia.WinUI ShadowContainer
    (it is unproven with this Uno.Sdk and a version mismatch aborts the whole merged dictionary).
    The layered-light intent is expressed instead with a semi-transparent hairline Border plus the
    Simple theme's card elevation — the alternative the skill itself endorses.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- EASING — KeySpline control points ARE the cubic-bezier handles (clamped to [0,1];
         a KeySpline cannot overshoot, so a "pop" must overshoot the animated VALUE, e.g. scale 1->1.05->1). -->
    <KeySpline x:Key="EaseSmooth" ControlPoint1="0.22,1"  ControlPoint2="0.36,1" />  <!-- default -->
    <KeySpline x:Key="EaseOut"    ControlPoint1="0.17,1"  ControlPoint2="0.32,1" />  <!-- decorative entrances -->
    <KeySpline x:Key="EaseInOut"  ControlPoint1="0.66,0"  ControlPoint2="0.34,1" />  <!-- symmetric moves -->

    <!-- DURATION -->
    <Duration x:Key="DurationFast">0:0:0.15</Duration>
    <Duration x:Key="DurationNormal">0:0:0.2</Duration>
    <Duration x:Key="DurationSlow">0:0:0.28</Duration>

    <!-- CORNER RADIUS (concentric scale) -->
    <x:Double x:Key="RadiusSm">6</x:Double>
    <x:Double x:Key="RadiusMd">12</x:Double>
    <x:Double x:Key="RadiusLg">24</x:Double>
    <CornerRadius x:Key="RadiusSmCorner">6</CornerRadius>
    <CornerRadius x:Key="RadiusMdCorner">12</CornerRadius>
    <CornerRadius x:Key="RadiusLgCorner">24</CornerRadius>

    <!-- Entrance: opacity 0->1 + Translation.Y 8->0, ~280ms EaseSmooth (blur-in omitted:
         Composition GaussianBlur is not portable across all four heads). -->
    <x:Double x:Key="EntranceRiseOffset">8</x:Double>

    <!-- Tactile press: firm 0.98, not a collapse. -->
    <x:Double x:Key="PressScale">0.98</x:Double>

</ResourceDictionary>
