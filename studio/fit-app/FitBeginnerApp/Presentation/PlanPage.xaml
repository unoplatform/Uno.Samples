<Page x:Class="FitBeginnerApp.Presentation.PlanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Padding="20,24,20,28" MaxWidth="1100" HorizontalAlignment="Stretch">

                <!-- Header -->
                <StackPanel x:Name="HeaderSection" Spacing="6" Margin="0,0,0,22">
                    <TextBlock Text="My Training Plan"
                               FontFamily="{StaticResource MontserratBold}"
                               FontSize="{StaticResource FontSizeH1}"
                               Foreground="{ThemeResource OnBackgroundBrush}" />
                    <TextBlock Text="{Binding WeekLabel}"
                               FontFamily="{StaticResource MontserratMedium}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>

                <!-- Week progress: two de-carded stat readouts -->
                <Border x:Name="SummarySection" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,26">
                    <Grid Padding="20,20" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="3" MinWidth="120">
                            <TextBlock Text="{Binding ScheduledCount}"
                                       FontFamily="{StaticResource MontserratBold}"
                                       FontSize="{StaticResource FontSizeStat}"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="SCHEDULED"
                                       FontFamily="{StaticResource MontserratSemiBold}"
                                       FontSize="{StaticResource FontSizeLabel}"
                                       CharacterSpacing="140"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="1" Margin="16,4" Background="{ThemeResource OutlineVariantBrush}" />
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="3" MinWidth="120">
                            <TextBlock Text="{Binding CompletedCount}"
                                       FontFamily="{StaticResource MontserratBold}"
                                       FontSize="{StaticResource FontSizeStat}"
                                       Foreground="{ThemeResource SecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="COMPLETED"
                                       FontFamily="{StaticResource MontserratSemiBold}"
                                       FontSize="{StaticResource FontSizeLabel}"
                                       CharacterSpacing="140"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- This week's schedule — each row opens the guided session -->
                <TextBlock Text="THIS WEEK" Style="{StaticResource SectionLabelStyle}" />
                <ItemsRepeater x:Name="WeekListSection" ItemsSource="{Binding WeeklyPlan}" Margin="0,0,0,26">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- A real Button (focus + Invoke + 0.98 press) wrapping the hairline card. -->
                            <Button Style="{StaticResource FlatButtonStyle}"
                                    CornerRadius="14"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    AutomationProperties.Name="Open workout session"
                                    uen:Navigation.Request="WorkoutSession"
                                    uen:Navigation.Data="{Binding}">
                                <Border Style="{StaticResource CardBorderStyle}" CornerRadius="14">
                                    <Grid Padding="16,13">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{ThemeResource PrimaryContainerBrush}">
                                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <PathIcon Data="{Binding Type, Converter={StaticResource WorkoutIcon}}"
                                                          Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                                            </Viewbox>
                                        </Border>
                                        <StackPanel Grid.Column="2" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="{StaticResource MontserratSemiBold}"
                                                       FontSize="{StaticResource FontSizeSubtitle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <TextBlock Text="{Binding Type}" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                                <TextBlock Text="&#x2022;" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OutlineVariantBrush}" />
                                                <TextBlock Text="{Binding DurationMinutes}" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                                <TextBlock Text="min" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="{ThemeResource TertiaryContainerBrush}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Difficulty}"
                                                       FontFamily="{StaticResource MontserratSemiBold}"
                                                       FontSize="{StaticResource FontSizeLabel}"
                                                       CharacterSpacing="140"
                                                       Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Suggested plans -->
                <TextBlock Text="SUGGESTED PLANS" Style="{StaticResource SectionLabelStyle}" />
                <ItemsRepeater x:Name="SuggestedSection" ItemsSource="{Binding SuggestedPlans}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="10" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid Padding="18,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="{StaticResource MontserratSemiBold}"
                                                   FontSize="{StaticResource FontSizeTitle}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Background="{ThemeResource SecondaryContainerBrush}" CornerRadius="8" Padding="9,4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Focus}"
                                                       FontFamily="{StaticResource MontserratSemiBold}"
                                                       FontSize="{StaticResource FontSizeLabel}"
                                                       CharacterSpacing="140"
                                                       Foreground="{ThemeResource OnSecondaryContainerBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontFamily="{StaticResource MontserratRegular}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,7,0,10" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="24">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding DaysPerWeek}" FontFamily="{StaticResource MontserratBold}" FontSize="{StaticResource FontSizeTitle}" Foreground="{ThemeResource PrimaryBrush}" />
                                            <TextBlock Text="DAYS/WEEK" FontFamily="{StaticResource MontserratSemiBold}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding MinutesPerSession}" FontFamily="{StaticResource MontserratBold}" FontSize="{StaticResource FontSizeTitle}" Foreground="{ThemeResource PrimaryBrush}" />
                                            <TextBlock Text="MIN/SESSION" FontFamily="{StaticResource MontserratSemiBold}" FontSize="{StaticResource FontSizeLabel}" CharacterSpacing="140" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
