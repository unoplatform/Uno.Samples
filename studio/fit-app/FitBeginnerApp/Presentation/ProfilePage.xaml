<Page x:Class="FitBeginnerApp.Presentation.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="Top,Left,Right">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Padding="0,0,0,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                <!-- Profile hero header -->
                <Grid x:Name="HeroSection" Background="{ThemeResource PrimaryContainerBrush}" Padding="16,28,16,24">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <Border Width="80" Height="80" CornerRadius="40" Background="{ThemeResource PrimaryBrush}" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding AvatarInitials}"
                                       FontSize="{StaticResource FontSizeStat}"
                                       Foreground="{ThemeResource OnPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Profile.DisplayName}"
                                       FontSize="{StaticResource FontSizeStatSmall}"
                                       Foreground="{ThemeResource OnPrimaryContainerBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding JoinedDate}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{ThemeResource OnPrimaryContainerBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <Border Background="{ThemeResource PrimaryBrush}" CornerRadius="8" Padding="12,6">
                                <TextBlock Text="{Binding Profile.FitnessLevel}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           HorizontalTextAlignment="Center" />
                            </Border>
                            <Border Background="{ThemeResource SecondaryContainerBrush}" CornerRadius="8" Padding="12,6">
                                <TextBlock Text="{Binding Profile.Goal}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSecondaryContainerBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           HorizontalTextAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Padding="16,20,16,0" Spacing="0">

                    <!-- My stats — three de-carded stat readouts -->
                    <TextBlock Text="MY STATS" Style="{StaticResource SectionLabelStyle}" />
                    <Border x:Name="StatsSection" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,26" HorizontalAlignment="Stretch">
                        <Grid Padding="20,20" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="3">
                                <TextBlock Text="{Binding Profile.TotalWorkouts}"
                                           FontSize="{StaticResource FontSizeStat}"
                                           Foreground="{ThemeResource PrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="WORKOUTS"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="1" Margin="14,4" Background="{ThemeResource OutlineVariantBrush}" />
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="3">
                                <TextBlock Text="{Binding Profile.CurrentStreakDays}"
                                           FontSize="{StaticResource FontSizeStat}"
                                           Foreground="{ThemeResource SecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="DAY STREAK"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="3" Width="1" Margin="14,4" Background="{ThemeResource OutlineVariantBrush}" />
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="3">
                                <TextBlock Text="{Binding Profile.WeeklyGoalDays}"
                                           FontSize="{StaticResource FontSizeStat}"
                                           Foreground="{ThemeResource TertiaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="GOAL/WEEK"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- My preferences -->
                    <TextBlock Text="MY PREFERENCES" Style="{StaticResource SectionLabelStyle}" />
                    <Border x:Name="PreferencesSection" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,26">
                        <StackPanel Padding="16,14" Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Preferred time"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding PreferredTime}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Equipment"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding EquipmentAvailable}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Session length"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SessionLengthMinutes}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{ThemeResource PrimaryBrush}" />
                                    <TextBlock Text="min"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{ThemeResource PrimaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- My goals -->
                    <TextBlock Text="MY GOALS" Style="{StaticResource SectionLabelStyle}" />
                    <ItemsRepeater x:Name="GoalsSection" ItemsSource="{Binding Goals}" Margin="0,0,0,26">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}" CornerRadius="14">
                                    <Grid Padding="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SecondaryContainerBrush}">
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="F1 M11.9982 14.0002C13.1027 14.0002 13.9982 13.1047 13.9982 12.0002C13.9982 10.8956 13.1027 10.0002 11.9982 10.0002C10.8936 10.0002 9.99817 10.8956 9.99817 12.0002C9.99817 13.1047 10.8936 14.0002 11.9982 14.0002ZM5.99817 12.0002C5.99817 8.68644 8.68446 6.00015 11.9982 6.00015C15.3119 6.00015 17.9982 8.68644 17.9982 12.0002C17.9982 15.3139 15.3119 18.0002 11.9982 18.0002C8.68446 18.0002 5.99817 15.3139 5.99817 12.0002ZM11.9982 7.50015C9.51289 7.50015 7.49817 9.51487 7.49817 12.0002C7.49817 14.4854 9.51289 16.5002 11.9982 16.5002C14.4834 16.5002 16.4982 14.4854 16.4982 12.0002C16.4982 9.51487 14.4834 7.50015 11.9982 7.50015ZM1.99609 12.0001C1.99609 6.47614 6.47419 1.99805 11.9982 1.99805C17.5222 1.99805 22.0003 6.47614 22.0003 12.0001C22.0003 17.5242 17.5222 22.0022 11.9982 22.0022C6.47419 22.0022 1.99609 17.5242 1.99609 12.0001ZM11.9982 3.49805C7.30261 3.49805 3.49609 7.30457 3.49609 12.0001C3.49609 16.6957 7.30261 20.5022 11.9982 20.5022C16.6938 20.5022 20.5003 16.6957 20.5003 12.0001C20.5003 7.30457 16.6938 3.49805 11.9982 3.49805Z"
                                                      Fill="{ThemeResource OnSecondaryContainerBrush}"
                                                      Stretch="Uniform" />
                                            </Viewbox>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Label}"
                                                   FontSize="{StaticResource FontSizeSubtitle}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center" />
                                        <!-- "Active" pill on the currently-selected goal (bool + BoolToVisibility) -->
                                        <Border Grid.Column="3" Background="{ThemeResource PrimaryBrush}" CornerRadius="8" Padding="10,4" VerticalAlignment="Center"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Active"
                                                       FontSize="{StaticResource FontSizeLabel}"
                                                       CharacterSpacing="140"
                                                       Foreground="{ThemeResource OnPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Settings -->
                    <TextBlock Text="SETTINGS" Style="{StaticResource SectionLabelStyle}" />
                    <Border x:Name="SettingsSection" Style="{StaticResource CardBorderStyle}">
                        <ItemsRepeater ItemsSource="{Binding Settings}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                            <Path Data="F1 M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z"
                                                  Fill="{ThemeResource OutlineBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
