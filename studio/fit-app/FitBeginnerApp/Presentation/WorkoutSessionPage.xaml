<Page x:Class="FitBeginnerApp.Presentation.WorkoutSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <!-- Full-screen guided session: a shell sibling of the tab shell, so it replaces the chrome
         while active and Back returns to the originating tab. SafeArea keeps the header clear of
         the notch; MaxWidth centres the column on wide screens (matching the tab pages). -->
    <utu:SafeArea Insets="VisibleBounds">
        <Grid MaxWidth="720" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Back bar: a real focusable Button (FlatButtonStyle) whose click issues a backward
                 navigation ("-" qualifier) — no view-model command needed for a static page. -->
            <Button Grid.Row="0"
                    Style="{StaticResource FlatButtonStyle}"
                    CornerRadius="10"
                    Padding="12,10"
                    Margin="4,4,0,0"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name="Back"
                    uen:Navigation.Request="-">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                        <PathIcon Data="F1 M15.5303 4.21967C15.8232 4.51256 15.8232 4.98744 15.5303 5.28033L8.81066 12L15.5303 18.7197C15.8232 19.0126 15.8232 19.4874 15.5303 19.7803C15.2374 20.0732 14.7626 20.0732 14.4697 19.7803L7.21967 12.5303C6.92678 12.2374 6.92678 11.7626 7.21967 11.4697L14.4697 4.21967C14.7626 3.92678 15.2374 3.92678 15.5303 4.21967Z"
                                  Foreground="{ThemeResource OnBackgroundBrush}" />
                    </Viewbox>
                    <TextBlock Text="Back" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource OnBackgroundBrush}" />
                </StackPanel>
            </Button>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="0"
                            Padding="16,8,16,32">

                    <TextBlock Text="{Binding WorkoutTitle}"
                               Style="{StaticResource HeadlineMedium}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <!-- Workout Summary Card -->
                    <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}"
                                            HorizontalAlignment="Stretch"
                                            IsClickable="False"
                                            Margin="0,0,0,20">
                        <Grid Padding="20,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Spacing="12"
                                        Margin="0,0,0,14">
                                <Border Width="56" Height="56"
                                        CornerRadius="16"
                                        Background="{ThemeResource PrimaryBrush}">
