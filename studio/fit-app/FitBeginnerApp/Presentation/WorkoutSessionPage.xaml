<Page x:Class="FitBeginnerApp.Presentation.WorkoutSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <!-- Full-screen guided session: a shell sibling of the tab shell, so it replaces the chrome
         while active and Back returns to the originating tab. SafeArea keeps the header clear of
         the notch; MaxWidth centres the column on wide screens (matching the tab pages). -->
    <utu:SafeArea Insets="VisibleBounds">
        <Grid MaxWidth="720" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Back bar: a real focusable Button (FlatButtonStyle) whose click issues a backward
                 navigation ("-" qualifier) — no view-model command needed for a static page. -->
            <Button Grid.Row="0"
                    Style="{StaticResource FlatButtonStyle}"
                    CornerRadius="10"
                    Padding="12,10"
                    Margin="4,4,0,0"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name="Back"
                    uen:Navigation.Request="-">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                        <Path Data="F1 M15.5303 4.21967C15.8232 4.51256 15.8232 4.98744 15.5303 5.28033L8.81066 12L15.5303 18.7197C15.8232 19.0126 15.8232 19.4874 15.5303 19.7803C15.2374 20.0732 14.7626 20.0732 14.4697 19.7803L7.21967 12.5303C6.92678 12.2374 6.92678 11.7626 7.21967 11.4697L14.4697 4.21967C14.7626 3.92678 15.2374 3.92678 15.5303 4.21967Z"
                              Fill="{ThemeResource OnBackgroundBrush}"
                              Stretch="Uniform" />
                    </Viewbox>
                    <TextBlock Text="Back"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{ThemeResource OnBackgroundBrush}" />
                </StackPanel>
            </Button>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="0"
                            Padding="16,8,16,32">

                    <TextBlock x:Name="TitleSection"
                               Text="{Binding WorkoutTitle}"
                               FontSize="{StaticResource FontSizeH1}"
                               Foreground="{ThemeResource OnBackgroundBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <!-- Workout Summary Card -->
                    <Border x:Name="SummarySection"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,20">
                        <Grid Padding="20,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Spacing="12"
                                        Margin="0,0,0,14">
                                <Border Width="56" Height="56"
                                        CornerRadius="16"
                                        Background="{ThemeResource PrimaryBrush}">
                                    <Viewbox Width="26" Height="26"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Path Data="{Binding WorkoutType, Converter={StaticResource WorkoutIcon}}"
                                              Fill="{ThemeResource OnPrimaryBrush}"
                                              Stretch="Uniform" />
                                    </Viewbox>
                                </Border>
                                <StackPanel Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WorkoutType}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                    <TextBlock Text="{Binding Difficulty}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               Foreground="{ThemeResource PrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Spacing="24">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding TotalDurationMinutes}"
                                               FontSize="{StaticResource FontSizeStatSmall}"
                                               Foreground="{ThemeResource PrimaryBrush}" />
                                    <TextBlock Text="MINUTES"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               CharacterSpacing="140"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding TotalExercises}"
                                               FontSize="{StaticResource FontSizeStatSmall}"
                                               Foreground="{ThemeResource SecondaryBrush}" />
                                    <TextBlock Text="EXERCISES"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               CharacterSpacing="140"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Motivation Quote -->
                    <Border x:Name="MotivationSection"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,20">
                        <StackPanel Padding="16,14"
                                    Spacing="10"
                                    Orientation="Horizontal">
                            <Viewbox Width="20" Height="20"
                                     VerticalAlignment="Center">
                                <Path Data="F1 M8.66535 15.7345C8.90969 15.9075 9.20192 15.9999 9.50129 15.9989V15.9949C9.78358 15.9955 10.0598 15.9132 10.2957 15.7582C10.5316 15.6031 10.7168 15.3822 10.8283 15.1229L11.4413 13.2589C11.5829 12.8366 11.8207 12.4531 12.1361 12.1386C12.4514 11.8241 12.8356 11.5873 13.2583 11.4469L15.0363 10.8689C15.3227 10.7683 15.5701 10.5799 15.7432 10.3305C15.9164 10.0812 16.0065 9.7836 16.0007 9.48009C15.9949 9.17659 15.8936 8.88262 15.7111 8.64003C15.5286 8.39744 15.2743 8.21858 14.9843 8.12889L13.2293 7.55889C12.8048 7.41763 12.419 7.1793 12.1027 6.86283C11.7864 6.54637 11.5483 6.1605 11.4073 5.73589L10.8293 3.95889C10.7285 3.67586 10.542 3.43127 10.2958 3.25908C10.0496 3.0869 9.7559 2.99567 9.45547 2.99809C9.15504 3.00051 8.86282 3.09645 8.61942 3.27258C8.37602 3.44871 8.19353 3.69628 8.09729 3.98089L7.51429 5.77289C7.37371 6.18515 7.14135 6.56012 6.83474 6.8695C6.52813 7.17888 6.15528 7.4146 5.74429 7.55889L3.96729 8.12989C3.75592 8.20382 3.56463 8.32589 3.40855 8.48647C3.25247 8.64704 3.13587 8.84172 3.06798 9.05511C3.00008 9.2685 2.98274 9.49475 3.01733 9.716C3.05193 9.93724 3.1375 10.1474 3.26729 10.3299C3.44418 10.5789 3.69508 10.7657 3.98429 10.8639L5.73829 11.4329C6.16392 11.5753 6.55049 11.815 6.86729 12.1329C6.95236 12.2173 7.03186 12.3072 7.10529 12.4019C7.30447 12.6597 7.45833 12.9495 7.56029 13.2589L8.13829 15.0339C8.23676 15.3166 8.42102 15.5615 8.66535 15.7345ZM8.29129 11.4849C8.17979 11.3392 8.05851 11.2012 7.92829 11.0719H7.93129C7.44841 10.5886 6.85948 10.2247 6.21129 10.0089L4.61129 9.50089L6.22229 8.97689C6.85983 8.75615 7.43806 8.39176 7.91229 7.91189C8.38447 7.42897 8.74047 6.84487 8.95329 6.20389L9.46829 4.62189L9.98429 6.20889C10.1997 6.85585 10.5633 7.44351 11.0462 7.92497C11.529 8.40643 12.1177 8.76837 12.7653 8.98189L14.3843 9.50389L12.7953 10.0189C12.1489 10.2338 11.5616 10.5965 11.08 11.0782C10.5984 11.56 10.2359 12.1474 10.0213 12.7939L9.50629 14.3759L8.99129 12.7909C8.83406 12.3189 8.59732 11.8772 8.29129 11.4849ZM16.332 20.7819C16.1415 20.6461 15.9981 20.4541 15.922 20.2329L15.594 19.2259C15.5302 19.0344 15.4231 18.8602 15.281 18.7169C15.1385 18.574 14.9645 18.4664 14.773 18.4029L13.782 18.0799C13.5516 18.0026 13.3516 17.8541 13.211 17.6559C13.0737 17.4636 13.0002 17.2331 13.001 16.9969C13.0013 16.7591 13.0757 16.5274 13.214 16.3339C13.3512 16.1394 13.5466 15.9934 13.772 15.9169L14.778 15.5909C14.965 15.5245 15.1343 15.4162 15.273 15.2742C15.4117 15.1322 15.516 14.9604 15.578 14.7719L15.902 13.7799C15.9782 13.5557 16.1222 13.3606 16.3141 13.2218C16.5059 13.0829 16.7362 13.0071 16.973 13.0048C17.2099 13.0025 17.4416 13.0738 17.6361 13.2089C17.8306 13.344 17.9784 13.5362 18.059 13.7589L18.388 14.7729C18.4524 14.963 18.5599 15.1356 18.7022 15.2771C18.8445 15.4187 19.0176 15.5254 19.208 15.5889L20.2 15.9119C20.4287 15.9834 20.629 16.1251 20.7727 16.3169C20.9163 16.5086 20.9959 16.7408 21.0002 16.9803C21.0045 17.2199 20.9333 17.4547 20.7967 17.6516C20.6601 17.8484 20.4649 17.9972 20.239 18.0769L19.225 18.4059C19.0349 18.4707 18.8622 18.5781 18.72 18.7199C18.5777 18.8627 18.4705 19.0366 18.407 19.2279L18.085 20.2169C18.0075 20.4472 17.8586 20.6469 17.66 20.7869C17.468 20.9249 17.2375 20.9991 17.001 20.9989C16.7607 20.9989 16.5265 20.9229 16.332 20.7819ZM15.3014 16.999C15.6943 17.1386 16.051 17.3646 16.3452 17.6602C16.6394 17.956 16.8635 18.314 17.001 18.7079C17.1399 18.3158 17.3646 17.9597 17.6587 17.6656C17.9528 17.3715 18.3089 17.1468 18.701 17.0079C18.3026 16.8685 17.9406 16.6412 17.642 16.3429C17.3469 16.049 17.1217 15.6926 16.983 15.2999C16.8449 15.6898 16.6223 16.0444 16.3312 16.3383C16.0407 16.6316 15.689 16.8572 15.3014 16.999Z"
                                      Fill="{ThemeResource SecondaryBrush}"
                                      Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="{Binding MotivationQuote}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Exercises List -->
                    <TextBlock Text="EXERCISES" Style="{StaticResource SectionLabelStyle}" />

                    <ItemsRepeater x:Name="ExercisesSection"
                                   ItemsSource="{Binding Exercises}"
                                   Margin="0,0,0,20">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="10" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel Padding="16,14"
                                                Spacing="10">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12">
                                            <Border Width="44" Height="44"
                                                    CornerRadius="12"
                                                    Background="{ThemeResource PrimaryContainerBrush}">
                                                <Viewbox Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                    <Path Data="{Binding Category, Converter={StaticResource WorkoutIcon}}"
                                                          Fill="{ThemeResource OnPrimaryContainerBrush}"
                                                          Stretch="Uniform" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="{StaticResource FontSizeSubtitle}"
                                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12">
                                            <Border Background="{ThemeResource TertiaryContainerBrush}"
                                                    CornerRadius="8"
                                                    Padding="10,4">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="4"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Sets}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{ThemeResource OnTertiaryContainerBrush}"
                                                               HorizontalTextAlignment="Center" />
                                                    <TextBlock Text="SETS"
                                                               FontSize="{StaticResource FontSizeLabel}"
                                                               CharacterSpacing="140"
                                                               Foreground="{ThemeResource OnTertiaryContainerBrush}"
                                                               HorizontalTextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{ThemeResource SecondaryContainerBrush}"
                                                    CornerRadius="8"
                                                    Padding="10,4">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="4"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DurationSeconds}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{ThemeResource OnSecondaryContainerBrush}"
                                                               HorizontalTextAlignment="Center" />
                                                    <TextBlock Text="SEC"
                                                               FontSize="{StaticResource FontSizeLabel}"
                                                               CharacterSpacing="140"
                                                               Foreground="{ThemeResource OnSecondaryContainerBrush}"
                                                               HorizontalTextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Session Tips -->
                    <TextBlock Text="SESSION TIPS" Style="{StaticResource SectionLabelStyle}" />

                    <Border x:Name="TipsSection"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,16">
                        <StackPanel Padding="16,12">
                            <ItemsRepeater ItemsSource="{Binding WarmUpNotes}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,4">
                                            <TextBlock Text="&#x2022;"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{ThemeResource PrimaryBrush}"
                                                       VerticalAlignment="Top" />
                                            <TextBlock Text="{Binding Note}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <!-- Begin CTA -> in-progress confirmation, swapped on the MVUX IsStarted state. -->
                    <Grid x:Name="BeginSection">
                        <Button Content="Begin workout"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="Begin workout session"
                                Command="{Binding Begin}"
                                Visibility="{Binding IsStarted, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        <Border Background="{ThemeResource PrimaryContainerBrush}"
                                CornerRadius="14"
                                Visibility="{Binding IsStarted, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10"
                                        Padding="16,13"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Viewbox Width="20" Height="20" VerticalAlignment="Center">
                                    <Path Data="F1 M12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2ZM12 3.5C7.30558 3.5 3.5 7.30558 3.5 12C3.5 16.6944 7.30558 20.5 12 20.5C16.6944 20.5 20.5 16.6944 20.5 12C20.5 7.30558 16.6944 3.5 12 3.5ZM8.53033 11.4697C8.23744 11.1768 7.76256 11.1768 7.46967 11.4697C7.17678 11.7626 7.17678 12.2374 7.46967 12.5303L9.96967 15.0303C10.2626 15.3232 10.7374 15.3232 11.0303 15.0303L16.5303 9.53033C16.8232 9.23744 16.8232 8.76256 16.5303 8.46967C16.2374 8.17678 15.7626 8.17678 15.4697 8.46967L10.5 13.4393L8.53033 11.4697Z"
                                          Fill="{ThemeResource OnPrimaryContainerBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>
                                <TextBlock Text="Workout in progress — nice work!"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource OnPrimaryContainerBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </utu:SafeArea>
</Page>
