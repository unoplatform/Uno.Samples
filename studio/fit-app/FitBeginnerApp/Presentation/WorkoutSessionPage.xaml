                                                  Foreground="{ThemeResource OnPrimaryBrush}" />
                                    </Viewbox>
                                </Border>
                                <StackPanel Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WorkoutType}"
                                               Style="{StaticResource LabelMedium}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                    <TextBlock Text="{Binding Difficulty}"
                                               Style="{StaticResource TitleMedium}"
                                               Foreground="{ThemeResource PrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Spacing="24">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding TotalDurationMinutes}"
                                               Style="{StaticResource HeadlineMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                    <TextBlock Text="minutes"
                                               Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding TotalExercises}"
                                               Style="{StaticResource HeadlineMedium}"
                                               Foreground="{ThemeResource OnSurfaceBrush}" />
                                    <TextBlock Text="exercises"
                                               Style="{StaticResource LabelSmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </utu:CardContentControl>

                    <!-- Motivation Quote -->
