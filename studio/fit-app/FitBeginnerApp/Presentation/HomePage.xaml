                                  Fill="{ThemeResource SecondaryBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="{Binding MotivationMessage}"
                                   FontFamily="{StaticResource MontserratMedium}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- 2. This Week — the signature ring + de-carded stat readouts -->
                <TextBlock Text="THIS WEEK" Style="{StaticResource SectionLabelStyle}" />
                <Border x:Name="WeekSection" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,26">
                    <StackPanel Padding="24,26" Spacing="22">
                        <local:WeeklyRing Completed="{Binding WeeklyCompletedDays}"
                                          Goal="{Binding WeeklyGoalDays}"
                                          HorizontalAlignment="Center" />
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="3" MinWidth="104">
                                <TextBlock Text="{Binding TotalMinutesThisWeek}"
                                           FontFamily="{StaticResource MontserratBold}"
                                           FontSize="{StaticResource FontSizeStat}"
                                           Foreground="{ThemeResource PrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="MINUTES"
                                           FontFamily="{StaticResource MontserratSemiBold}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="1" Margin="20,6"
                                    Background="{ThemeResource OutlineVariantBrush}" />
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="3" MinWidth="104">
                                <TextBlock Text="{Binding CaloriesBurnedThisWeek}"
                                           FontFamily="{StaticResource MontserratBold}"
                                           FontSize="{StaticResource FontSizeStat}"
                                           Foreground="{ThemeResource SecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="CALORIES"
                                           FontFamily="{StaticResource MontserratSemiBold}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Today's workout — the primary action -->
                <TextBlock Text="TODAY'S WORKOUT" Style="{StaticResource SectionLabelStyle}" />
                <Border x:Name="TodaySection" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,26">
                    <Grid Padding="20,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14">
                            <Border Width="52" Height="52" CornerRadius="14" Background="{ThemeResource PrimaryContainerBrush}">
                                <Viewbox Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{Binding TodayWorkout.Type, Converter={StaticResource WorkoutIcon}}"
                                          Fill="{ThemeResource OnPrimaryContainerBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Border>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TodayWorkout.Title}"
                                           FontFamily="{StaticResource MontserratSemiBold}"
                                           FontSize="{StaticResource FontSizeTitle}"
                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                <TextBlock Text="{Binding TodayWorkout.Type}"
                                           FontFamily="{StaticResource MontserratMedium}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="28" Margin="0,16">
                            <StackPanel Spacing="1">
                                <TextBlock Text="{Binding TodayWorkout.DurationMinutes}"
                                           FontFamily="{StaticResource MontserratBold}"
                                           FontSize="{StaticResource FontSizeStatSmall}"
                                           Foreground="{ThemeResource PrimaryBrush}" />
                                <TextBlock Text="MINUTES"
                                           FontFamily="{StaticResource MontserratSemiBold}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                            <StackPanel Spacing="1">
                                <TextBlock Text="{Binding TodayWorkout.Difficulty}"
                                           FontFamily="{StaticResource MontserratBold}"
                                           FontSize="{StaticResource FontSizeStatSmall}"
                                           Foreground="{ThemeResource TertiaryBrush}" />
                                <TextBlock Text="LEVEL"
                                           FontFamily="{StaticResource MontserratSemiBold}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           CharacterSpacing="140"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Tapping Start opens the full-screen guided session for today's workout. -->
                        <Button Grid.Row="2" Content="Start workout"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="Start today's workout"
                                uen:Navigation.Request="WorkoutSession" uen:Navigation.Data="{Binding TodayWorkout}" />
                    </Grid>
                </Border>

                <!-- 4. Recent results -->
                <TextBlock Text="RECENT RESULTS" Style="{StaticResource SectionLabelStyle}" />
                <ItemsRepeater x:Name="ResultsSection" ItemsSource="{Binding RecentResults}" Margin="0,0,0,26">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}" CornerRadius="14">
                                <Grid Padding="16,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock Text="{Binding WorkoutTitle}"
                                                   FontFamily="{StaticResource MontserratSemiBold}"
                                                   FontSize="{StaticResource FontSizeSubtitle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DurationMinutes}" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="min" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="&#x2022;" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OutlineVariantBrush}" />
                                            <TextBlock Text="{Binding CaloriesBurned}" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="kcal" FontFamily="{StaticResource MontserratMedium}" FontSize="{StaticResource FontSizeCaption}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{Binding Feeling, Converter={StaticResource FeelingBrush}}" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Feeling}"
                                                   FontFamily="{StaticResource MontserratSemiBold}"
                                                   FontSize="{StaticResource FontSizeLabel}"
                                                   CharacterSpacing="140"
                                                   Foreground="{Binding Feeling, Converter={StaticResource FeelingBrush}, ConverterParameter=On}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- 5. Quick tips -->
                <TextBlock Text="QUICK TIPS" Style="{StaticResource SectionLabelStyle}" />
                <ItemsRepeater x:Name="TipsSection" ItemsSource="{Binding Tips}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}" CornerRadius="14">
                                <Grid Padding="16,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{ThemeResource SecondaryContainerBrush}">
                                        <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="F1 M12 2.00098C16.0041 2.00098 19.25 5.24691 19.25 9.25098C19.25 11.347 18.3493 13.2707 16.5869 14.9929C16.51 15.0681 16.4504 15.1586 16.4118 15.2582L16.3804 15.3605L15.2493 20.2561C15.0266 21.22 14.2035 21.9183 13.2302 21.993L13.057 21.9996H10.9433C9.95374 21.9996 9.08791 21.3545 8.79629 20.4228L8.75088 20.2555L7.62132 15.3607C7.58904 15.2208 7.51728 15.0931 7.41456 14.9928C5.73515 13.3526 4.83778 11.5297 4.75613 9.54923L4.75 9.25098L4.75388 9.01166C4.88014 5.11837 8.07601 2.00098 12 2.00098ZM14.115 18.499H9.884L10.2125 19.9182C10.2831 20.2245 10.5357 20.4504 10.8401 20.4925L10.9433 20.4996H13.057C13.3713 20.4996 13.6481 20.3044 13.7577 20.0174L13.7878 19.9184L14.115 18.499ZM12 3.50098C8.89821 3.50098 6.37006 5.95699 6.25415 9.03042L6.25 9.25098L6.25672 9.52799C6.33286 11.0913 7.05722 12.5471 8.46262 13.9197C8.72675 14.1777 8.92265 14.496 9.03422 14.846L9.08291 15.0235L9.538 16.999H14.461L14.9189 15.0228C15.0019 14.6634 15.1718 14.3309 15.4124 14.0539L15.5386 13.9201C16.9432 12.5475 17.6672 11.0916 17.7433 9.52803L17.75 9.25098L17.7458 9.03042C17.6299 5.95699 15.1018 3.50098 12 3.50098Z"
                                                  Fill="{ThemeResource OnSecondaryContainerBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="{StaticResource MontserratSemiBold}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                        <TextBlock Text="{Binding Body}"
                                                   FontFamily="{StaticResource MontserratRegular}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
