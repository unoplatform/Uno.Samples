<UserControl x:Class="FitBeginnerApp.Presentation.WeeklyRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Signature: a weekly-goal progress ring. The accent arc sweeps to Completed/Goal on load
         (gated on reduced-motion); the count reads in the centre. Geometry is built in code-behind
         from the Completed/Goal properties. -->
    <Grid Width="176" Height="176">
        <!-- Track -->
        <Ellipse Width="160" Height="160"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 StrokeThickness="16"
                 Stroke="{ThemeResource SurfaceVariantBrush}" />
        <!-- Progress arc -->
        <Path x:Name="ArcPath"
              StrokeThickness="16"
              Stroke="{ThemeResource PrimaryBrush}"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round" />
        <!-- Centre readout -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
            <TextBlock x:Name="CountText"
                       FontSize="{StaticResource FontSizeRing}"
                       LineHeight="42"
                       Foreground="{ThemeResource OnBackgroundBrush}"
                       HorizontalAlignment="Center"
                       HorizontalTextAlignment="Center" />
            <TextBlock Text="DAYS DONE"
                       FontSize="{StaticResource FontSizeLabel}"
                       CharacterSpacing="140"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
