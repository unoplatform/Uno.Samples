<Page x:Class="FitBeginnerApp.Presentation.ProgressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0"
                        Padding="16,20,16,24">

                <!-- Header -->
                <TextBlock Text="My Progress"
                           Style="{StaticResource HeadlineMedium}"
                           Foreground="{ThemeResource OnBackgroundBrush}"
                           Margin="0,0,0,20" />

                <!-- All-Time Stats Grid -->
                <TextBlock Text="All-Time Stats"
                           Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnBackgroundBrush}"
                           Margin="0,0,0,10" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <utu:CardContentControl Grid.Column="0"
                                            Style="{StaticResource FilledCardContentControlStyle}"
                                            HorizontalAlignment="Stretch"
                                            IsClickable="False">
                        <StackPanel Padding="12,14"
                                    Spacing="4">
                            <FontIcon Glyph="&#xE787;"
                                      FontSize="20"
                                      Foreground="{ThemeResource PrimaryBrush}" />
                            <TextBlock Text="{Binding TotalWorkouts}"
                                       Style="{StaticResource HeadlineMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                            <TextBlock Text="sessions"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                    </utu:CardContentControl>
                    <utu:CardContentControl Grid.Column="2"
                                            Style="{StaticResource FilledCardContentControlStyle}"
                                            HorizontalAlignment="Stretch"
                                            IsClickable="False">
                        <StackPanel Padding="12,14"
                                    Spacing="4">
                            <FontIcon Glyph="&#xE945;"
                                      FontSize="20"
                                      Foreground="{ThemeResource SecondaryBrush}" />
                            <TextBlock Text="{Binding TotalMinutes}"
                                       Style="{StaticResource HeadlineMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                            <TextBlock Text="minutes"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                    </utu:CardContentControl>
                    <utu:CardContentControl Grid.Column="4"
                                            Style="{StaticResource FilledCardContentControlStyle}"
                                            HorizontalAlignment="Stretch"
                                            IsClickable="False">
                        <StackPanel Padding="12,14"
                                    Spacing="4">
                            <FontIcon Glyph="&#xE9D9;"
                                      FontSize="20"
                                      Foreground="{ThemeResource TertiaryBrush}" />
                            <TextBlock Text="{Binding TotalCalories}"
                                       Style="{StaticResource HeadlineMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                            <TextBlock Text="kcal"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                    </utu:CardContentControl>
                </Grid>

                <!-- Streak Card -->
                <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}"
                                        HorizontalAlignment="Stretch"
                                        IsClickable="False"
                                        Margin="0,8,0,24">
                    <Grid Padding="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Spacing="4"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEB51;"
                                      FontSize="24"
                                      Foreground="{ThemeResource PrimaryBrush}" />
                            <TextBlock Text="{Binding CurrentStreak}"
                                       Style="{StaticResource DisplaySmall}"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="current streak"
                                       Style="{StaticResource LabelMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="4"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE945;"
                                      FontSize="24"
                                      Foreground="{ThemeResource SecondaryBrush}" />
                            <TextBlock Text="{Binding LongestStreak}"
                                       Style="{StaticResource DisplaySmall}"
                                       Foreground="{ThemeResource SecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="best streak"
                                       Style="{StaticResource LabelMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </utu:CardContentControl>

                <!-- Milestones -->
                <TextBlock Text="Milestones"
                           Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnBackgroundBrush}"
                           Margin="0,0,0,10" />

                <ItemsRepeater ItemsSource="{Binding Milestones}"
                               Margin="0,0,0,24">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource OutlinedCardContentControlStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    IsClickable="False"
                                                    Margin="0,0,0,8">
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="12"
                                            Background="{ThemeResource PrimaryContainerBrush}">
                                        <FontIcon Glyph="{Binding IconGlyph}"
                                                  FontSize="20"
                                                  Foreground="{ThemeResource OnPrimaryContainerBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource TitleSmall}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource BodySmall}"
                                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Workout History -->
                <TextBlock Text="Workout History"
                           Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnBackgroundBrush}"
                           Margin="0,0,0,10" />

                <ItemsRepeater ItemsSource="{Binding WorkoutHistory}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource OutlinedCardContentControlStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    IsClickable="False"
                                                    Margin="0,0,0,8">
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Spacing="2">
                                        <TextBlock Text="{Binding WorkoutTitle}"
                                                   Style="{StaticResource TitleSmall}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding DurationMinutes}"
                                                       Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="min"
                                                       Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="&#x2022;"
                                                       Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OutlineVariantBrush}" />
                                            <TextBlock Text="{Binding CaloriesBurned}"
                                                       Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="kcal"
                                                       Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{ThemeResource SecondaryContainerBrush}"
                                            CornerRadius="8"
                                            Padding="8,4">
                                        <TextBlock Text="{Binding Feeling}"
                                                   Style="{StaticResource LabelSmall}"
                                                   Foreground="{ThemeResource OnSecondaryContainerBrush}" />
                                    </Border>
                                </Grid>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
