                <!-- Workout History -->
                <TextBlock Text="Workout History"
                           Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnBackgroundBrush}"
                           Margin="0,0,0,10" />

                <ItemsRepeater ItemsSource="{Binding WorkoutHistory}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource OutlinedCardContentControlStyle}" HorizontalAlignment="Stretch" IsClickable="False" Margin="0,0,0,8">
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding WorkoutTitle}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DurationMinutes}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="min" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="&#x2022;" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineVariantBrush}" />
                                            <TextBlock Text="{Binding CaloriesBurned}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="kcal" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{ThemeResource SecondaryContainerBrush}" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Feeling}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSecondaryContainerBrush}" VerticalAlignment="Center" HorizontalTextAlignment="Center" />
                                    </Border>
                                </Grid>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
