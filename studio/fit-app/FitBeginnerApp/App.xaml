<Application x:Class="FitBeginnerApp.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utus="using:Uno.Toolkit.UI.Simple">

  <!-- App.xaml is a thin manifest: it only merges the dedicated dictionaries, each with one
       concern. The palette lives in ThemeColors.xaml, the motion/feel tokens in MotionTokens.xaml,
       and the app's styling vocabulary (converters, templates, styles, tokens) in Styles.xaml. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Fresh-green FitStart palette (light + dark) layered onto the Simple theme. Uses the Simple
             theme's default font (no bundled custom font). -->
        <utus:SimpleToolkitTheme ColorOverrideSource="ms-appx:///ThemeColors.xaml" />
        <!-- House motion/feel tokens (easing, duration, radius, press) — give numbers, not adjectives. -->
        <ResourceDictionary Source="ms-appx:///MotionTokens.xaml" />
        <!-- App styling vocabulary. Merged LAST so its well-known-key overrides
             (ControlCornerRadius*, OverlayCornerRadius) beat the theme defaults. -->
        <ResourceDictionary Source="ms-appx:///Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
