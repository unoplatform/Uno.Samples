
<Page x:Class="MovieStreamApp.Presentation.SocialFeedPage" Background="{ThemeResource BackgroundBrush}" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:utu="using:Uno.Toolkit.UI" xmlns:uen="using:Uno.Extensions.Navigation.UI">

    <Grid utu:SafeArea.Insets="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Friends" Style="{StaticResource TitleLarge}" Foreground="{ThemeResource OnBackgroundBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Background="{ThemeResource TertiaryContainerBrush}" CornerRadius="10" Width="10" Height="10" VerticalAlignment="Center" />
                    <TextBlock Foreground="{ThemeResource OnSurfaceVariantBrush}" Style="{StaticResource BodySmall}">
                        <Run Text="{Binding OnlineFriendsCount}" />
                        <Run Text="friends online" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Find friends">
                <FontIcon Glyph="" FontSize="20" Foreground="{ThemeResource OnBackgroundBrush}" />
            </Button>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel Spacing="0">

                <StackPanel Padding="20,0,20,8" Spacing="8">
                    <TextBlock Text="People You May Know" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsRepeater ItemsSource="{Binding SuggestedFriends}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="10" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" Width="130" IsClickable="False" Content="{Binding}">
                                        <utu:CardContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="12,14" Spacing="8" HorizontalAlignment="Center">
                                                    <Border Width="52" Height="52" CornerRadius="26" HorizontalAlignment="Center">
                                                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSurfaceBrush}" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" />
                                                        <TextBlock Text="{Binding Reason}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineBrush}" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" />
                                                    </StackPanel>
                                                    <Button Content="Follow" Style="{StaticResource FilledTonalButtonStyle}" HorizontalAlignment="Center" AutomationProperties.Name="Follow friend" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </utu:CardContentControl.ContentTemplate>
                                    </utu:CardContentControl>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
                <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" Margin="20,8,20,16" />

                <Grid Padding="20,0,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Recent Activity" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    <Button Grid.Column="1" Content="Filter" Style="{StaticResource TextButtonStyle}" AutomationProperties.Name="Filter activity feed">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="" FontSize="13" Foreground="{ThemeResource PrimaryBrush}" />
                                    <TextBlock Text="Filter" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource PrimaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
                <ItemsRepeater ItemsSource="{Binding Activities}" Margin="20,0,20,20">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" HorizontalAlignment="Stretch" IsClickable="True" Content="{Binding}" uen:Navigation.Request="Playback">
                                <utu:CardContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="0">

                                            <Grid Padding="14,12,14,10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="44" Height="44">
                                                    <Border CornerRadius="22" Width="44" Height="44">
                                                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="{ThemeResource TertiaryContainerBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="{Binding IsOnline}" />
                                                </Grid>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Foreground="{ThemeResource OnSurfaceBrush}" Style="{StaticResource BodyMedium}" TextWrapping="Wrap">
                                                        <Run Text="{Binding FriendName}" FontWeight="SemiBold" />
                                                        <Run Text="{Binding Action}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding MovieTitle}" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource PrimaryBrush}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineVariantBrush}" VerticalAlignment="Top" />
                                                <!-- Avatar with online dot -->
                                                <!-- Name + action -->
                                                <!-- Time -->
                                            </Grid>
                                            <Grid Margin="14,0" Height="120">
                                                <Border CornerRadius="10">
                                                    <Image Source="{Binding MovieImageUrl}" Stretch="UniformToFill" />
                                                </Border>
                                                <Border CornerRadius="10">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.4" />
                                                            <GradientStop Color="#CC000000" Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10">
                                                    <TextBlock Text="{Binding MovieGenre}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                                </Border>
                                            </Grid>

                                            <StackPanel Padding="14,10,14,4" Spacing="0" Visibility="{Binding Comment}">
                                                <TextBlock Foreground="{ThemeResource OnSurfaceVariantBrush}" Style="{StaticResource BodySmall}" TextWrapping="Wrap" FontStyle="Italic">
                                                    <Run Text="“" Foreground="{ThemeResource PrimaryBrush}" />
                                                    <Run Text="{Binding Comment}" />
                                                    <Run Text="”" Foreground="{ThemeResource PrimaryBrush}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid Padding="8,6,8,8" ColumnSpacing="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Like activity">
                                                        <FontIcon Glyph="" FontSize="16" Foreground="{ThemeResource OutlineBrush}" />
                                                    </Button>
                                                    <TextBlock Text="{Binding LikeCount}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineBrush}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Button Grid.Column="2" Style="{StaticResource FilledTonalButtonStyle}" AutomationProperties.Name="Watch this movie" uen:Navigation.Request="Playback">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="" FontSize="14" Foreground="{ThemeResource OnSecondaryContainerBrush}" />
                                                        <TextBlock Text="Watch" Style="{StaticResource LabelMedium}" Foreground="{ThemeResource OnSecondaryContainerBrush}" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Share activity">
                                                    <FontIcon Glyph="" FontSize="16" Foreground="{ThemeResource OutlineBrush}" />
                                                </Button>
                                                <!-- Like button -->
                                                <!-- Watch button -->
                                                <!-- Share -->
                                            </Grid>
                                            <!-- Top row: avatar + friend info + time -->
                                            <!-- Movie thumbnail + genre -->
                                            <!-- Comment (if present) -->
                                            <!-- Action Row: Like + Watch + Share -->

                                        </StackPanel>
                                    </DataTemplate>
                                </utu:CardContentControl.ContentTemplate>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <TextBlock Text="Trending Among Friends" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnBackgroundBrush}" Margin="20,0,20,12" />
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,28">
                    <ItemsRepeater ItemsSource="{Binding TrendingAmongFriends}" Margin="20,0">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" Width="140" IsClickable="True" Content="{Binding}" uen:Navigation.Request="Playback">
                                    <utu:CardContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Border Height="190" CornerRadius="8,8,0,0">
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                                </Border>
                                                <StackPanel Padding="10,8" Spacing="3">
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="" FontSize="11" Foreground="{ThemeResource TertiaryBrush}" />
                                                        <TextBlock Text="{Binding Rating}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource TertiaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </utu:CardContentControl.ContentTemplate>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
                <!-- Friend Suggestions Strip -->
                <!-- Divider -->
                <!-- Activity Feed Header -->
                <!-- Activity Cards -->
                <!-- Trending Among Friends -->

            </StackPanel>
        </ScrollViewer>
        <!-- Header -->
        <!-- Main Feed -->
    </Grid>
</Page>