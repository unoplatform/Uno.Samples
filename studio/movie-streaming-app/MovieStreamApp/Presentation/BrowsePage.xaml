
<Page x:Class="MovieStreamApp.Presentation.BrowsePage" Background="{ThemeResource BackgroundBrush}" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:utu="using:Uno.Toolkit.UI" xmlns:uen="using:Uno.Extensions.Navigation.UI">

    <Grid utu:SafeArea.Insets="Top">
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Spacing="0">

                <Grid Padding="20,16,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="" FontSize="22" Foreground="{ThemeResource PrimaryBrush}" />
                        <TextBlock Text="CineStream" Style="{StaticResource TitleLarge}" Foreground="{ThemeResource OnBackgroundBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}" AutomationProperties.Name="Notifications">
                        <FontIcon Glyph="" FontSize="20" Foreground="{ThemeResource OnBackgroundBrush}" />
                    </Button>
                </Grid>
                <Grid Margin="20,0" Height="420">
                    <utu:CardContentControl Style="{StaticResource ElevatedCardContentControlStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsClickable="True" uen:Navigation.Request="Playback">
                        <utu:CardContentControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Image Source="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.ImageUrl}" Stretch="UniformToFill" />
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0.3" />
                                                <GradientStop Color="#E6000000" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel VerticalAlignment="Bottom" Padding="16,0,16,16" Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="{ThemeResource PrimaryBrush}" CornerRadius="4" Padding="8,3">
                                                <TextBlock Text="FEATURED" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnPrimaryBrush}" />
                                            </Border>
                                            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="4" Padding="8,3">
                                                <TextBlock Text="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.Genre}" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.Title}" Style="{StaticResource HeadlineMedium}" Foreground="White" FontWeight="Bold" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="" FontSize="12" Foreground="{ThemeResource TertiaryBrush}" />
                                                <TextBlock Text="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.Rating}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.Duration}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            <TextBlock Text="{utu:AncestorBinding AncestorType=Page, Path=DataContext.FeaturedMovie.Year}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        </StackPanel>
                                        <Button Content="▶  Watch Now" Style="{StaticResource FilledButtonStyle}" AutomationProperties.Name="Watch featured movie" HorizontalAlignment="Left" uen:Navigation.Request="Playback" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </utu:CardContentControl.ContentTemplate>
                    </utu:CardContentControl>
                </Grid>

                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,16,0,0">
                    <ItemsRepeater ItemsSource="{Binding Categories}" Margin="20,0">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Style="{StaticResource FilledTonalButtonStyle}" AutomationProperties.Name="{Binding}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
                <TextBlock Text="Trending Now" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" Margin="20,20,20,12" />

                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <ItemsRepeater ItemsSource="{Binding TrendingNow}" Margin="20,0">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" Width="140" IsClickable="True" Content="{Binding}" uen:Navigation.Request="Playback">
                                    <utu:CardContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Border Height="200" CornerRadius="8,8,0,0">
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                                </Border>
                                                <StackPanel Padding="10,8" Spacing="3">
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource LabelLarge}" Foreground="{ThemeResource OnSurfaceBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Genre}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineBrush}" />
                                                        <TextBlock Text="•" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineVariantBrush}" />
                                                        <TextBlock Text="{Binding Rating}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource TertiaryBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding IsNew}">
                                                        <Border Background="{ThemeResource PrimaryBrush}" CornerRadius="3" Padding="5,2">
                                                            <TextBlock Text="NEW" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnPrimaryBrush}" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </utu:CardContentControl.ContentTemplate>
                                </utu:CardContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
                <TextBlock Text="New Arrivals" Style="{StaticResource TitleMedium}" Foreground="{ThemeResource OnBackgroundBrush}" Margin="20,24,20,12" />

                <ItemsRepeater ItemsSource="{Binding NewArrivals}" Margin="20,0,20,24">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <utu:CardContentControl Style="{StaticResource FilledCardContentControlStyle}" HorizontalAlignment="Stretch" IsClickable="True" Content="{Binding}" uen:Navigation.Request="Playback">
                                <utu:CardContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12" Padding="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="8,0,0,8" Height="130">
                                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Padding="0,12" Spacing="4">
                                                <Border Background="{ThemeResource TertiaryContainerBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                    <TextBlock Text="NEW" Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource TitleSmall}" Foreground="{ThemeResource OnSurfaceBrush}" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Genre}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineBrush}" />
                                                    <TextBlock Text="•" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineVariantBrush}" />
                                                    <TextBlock Text="{Binding Year}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OutlineBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Duration}" Style="{StaticResource BodySmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Margin="0,0,8,0" VerticalAlignment="Center" AutomationProperties.Name="Add to watchlist">
                                                <FontIcon Glyph="" FontSize="18" Foreground="{ThemeResource PrimaryBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </utu:CardContentControl.ContentTemplate>
                            </utu:CardContentControl>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <!-- Top Bar -->
                <!-- Featured Movie Hero Card -->
                <!-- Category Chips -->
                <!-- Trending Now Section -->
                <!-- New Arrivals Section -->

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>