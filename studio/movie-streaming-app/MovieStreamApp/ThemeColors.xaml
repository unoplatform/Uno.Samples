<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Color x:Key="PrimaryColor">#E8253A</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#FFD9DC</Color>
			<Color x:Key="OnPrimaryContainerColor">#40000B</Color>
			<Color x:Key="SecondaryColor">#B53D68</Color>
			<Color x:Key="OnSecondaryColor">#FFFFFF</Color>
			<Color x:Key="SecondaryContainerColor">#FFD8E6</Color>
			<Color x:Key="OnSecondaryContainerColor">#3D0020</Color>
			<Color x:Key="TertiaryColor">#7A5080</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#F4D8FF</Color>
			<Color x:Key="OnTertiaryContainerColor">#2F0D36</Color>
			<Color x:Key="ErrorColor">#BA1A1A</Color>
			<Color x:Key="OnErrorColor">#FFFFFF</Color>
			<Color x:Key="SurfaceColor">#FFF8F7</Color>
			<Color x:Key="OnSurfaceColor">#1C1B1E</Color>
			<Color x:Key="SurfaceVariantColor">#F3DCE0</Color>
			<Color x:Key="OnSurfaceVariantColor">#524345</Color>
			<Color x:Key="BackgroundColor">#FFF8F7</Color>
			<Color x:Key="OnBackgroundColor">#1C1B1E</Color>
			<Color x:Key="OutlineColor">#857275</Color>
			<Color x:Key="OutlineVariantColor">#D8C2C5</Color>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Default">
			<Color x:Key="PrimaryColor">#FF3D55</Color>
			<Color x:Key="OnPrimaryColor">#FFFFFF</Color>
			<Color x:Key="PrimaryContainerColor">#8B0013</Color>
			<Color x:Key="OnPrimaryContainerColor">#FFD9DC</Color>
			<Color x:Key="SecondaryColor">#E5638E</Color>
			<Color x:Key="OnSecondaryColor">#3B0022</Color>
			<Color x:Key="SecondaryContainerColor">#6E1240</Color>
			<Color x:Key="OnSecondaryContainerColor">#FFD8E6</Color>
			<Color x:Key="TertiaryColor">#CF9DDA</Color>
			<Color x:Key="OnTertiaryColor">#3D1146</Color>
			<Color x:Key="TertiaryContainerColor">#572D5E</Color>
			<Color x:Key="OnTertiaryContainerColor">#F4D8FF</Color>
			<Color x:Key="ErrorColor">#FFB4AB</Color>
			<Color x:Key="OnErrorColor">#690005</Color>
			<Color x:Key="SurfaceColor">#18141A</Color>
			<Color x:Key="OnSurfaceColor">#EAE0E4</Color>
			<Color x:Key="SurfaceVariantColor">#2E1F25</Color>
			<Color x:Key="OnSurfaceVariantColor">#D8BEC2</Color>
			<Color x:Key="BackgroundColor">#0F0B10</Color>
			<Color x:Key="OnBackgroundColor">#EAE0E4</Color>
			<Color x:Key="OutlineColor">#A18D90</Color>
			<Color x:Key="OutlineVariantColor">#524345</Color>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
