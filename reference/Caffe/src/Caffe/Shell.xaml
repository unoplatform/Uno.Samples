<UserControl x:Class="Caffe.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource CaffeBackgroundBrush}">

  <!-- Bootstrap navigation host. The navigation system loads the default
       route (Main) into this ContentControl via IContentControlProvider. -->
  <ContentControl x:Name="ShellContent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch" />
</UserControl>
