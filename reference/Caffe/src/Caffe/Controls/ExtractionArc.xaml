<UserControl
    x:Class="Caffe.Controls.ExtractionArc"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI">

    <Border Background="{StaticResource CaffeSurfaceBrush}"
            CornerRadius="{utu:Responsive Narrow=12, Wide=16}"
            Padding="{utu:Responsive Narrow='8,12', Normal='12,16', Wide='20,24'}"
            Translation="0,0,4">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <Grid RowSpacing="{utu:Responsive Narrow=4, Wide=8}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Label -->
            <TextBlock Grid.Row="0"
                       Text="EXTRACTION"
                       Style="{StaticResource ParameterLabelTextStyle}"
                       HorizontalAlignment="Center" />

            <!-- Arc Visual -->
            <Viewbox Grid.Row="1"
                     Stretch="Uniform"
                     MaxWidth="{utu:Responsive Narrow=88, Normal=120, Wide=150}"
                     MaxHeight="{utu:Responsive Narrow=72, Normal=96, Wide=120}"
                     VerticalAlignment="Center"
                     Margin="{utu:Responsive Narrow='0,4', Wide='0,8'}">
                <Grid Width="110" Height="88">
                    <!-- Background arc -->
                    <Path Stroke="{StaticResource CaffeBorderBrush}"
                          StrokeThickness="6"
                          Margin="5,4,5,0">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,65" IsClosed="False">
                                    <ArcSegment Point="85,65"
                                                Size="40,40"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="True" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Sweet spot highlight (25-30s range) -->
                    <Path Stroke="{StaticResource CaffeAccentGreenBrush}"
                          StrokeThickness="6"
                          Opacity="0.3"
                          Margin="5,4,5,0">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="38,22" IsClosed="False">
                                    <ArcSegment Point="62,22"
                                                Size="40,40"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="False" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Value arc -->
                    <Path x:Name="ValueArc"
                          Stroke="{StaticResource CaffePrimaryBrush}"
                          StrokeThickness="6"
                          Margin="5,4,5,0">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure x:Name="ArcFigure" StartPoint="15,65" IsClosed="False">
                                    <ArcSegment x:Name="ArcSegment"
                                                Point="50,12"
                                                Size="40,40"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="False" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Center text -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0">
                        <TextBlock Text="{x:Bind FormatArcValue(ExtractionTime), Mode=OneWay}"
                                   Style="{StaticResource ParameterValueTextStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="SECONDS"
                                   Style="{StaticResource ArcLabelTextStyle}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Viewbox>

            <!-- Value Display (matches Temperature layout for slider alignment) -->
            <TextBlock Grid.Row="2"
                       Text="{x:Bind FormatSeconds(ExtractionTime), Mode=OneWay}"
                       Style="{StaticResource ParameterValueTextStyle}"
                       HorizontalAlignment="Center" />

            <!-- Slider -->
            <Slider Grid.Row="3"
                    x:Name="TimeSlider"
                    Width="{utu:Responsive Narrow=76, Normal=110, Wide=150}"
                    HorizontalAlignment="Center"
                    Minimum="20"
                    Maximum="35"
                    StepFrequency="1"
                    SnapsTo="StepValues"
                    AutomationProperties.Name="Extraction time"
                    ValueChanged="OnSliderValueChanged" />

            <!-- Range Labels -->
            <Grid Grid.Row="4"
                  Width="{utu:Responsive Narrow=76, Normal=110, Wide=150}"
                  HorizontalAlignment="Center">
                <TextBlock Text="20s"
                           Style="{StaticResource ParameterLabelTextStyle}"
                           HorizontalAlignment="Left" />
                <TextBlock Text="35s"
                           Style="{StaticResource ParameterLabelTextStyle}"
                           HorizontalAlignment="Right" />
            </Grid>

        </Grid>
    </Border>

</UserControl>
