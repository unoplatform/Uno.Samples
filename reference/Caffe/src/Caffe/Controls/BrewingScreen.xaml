<UserControl
    x:Class="Caffe.Controls.BrewingScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Background="{StaticResource CaffeBackgroundBrush}">
        <utu:AutoLayout
            Orientation="Vertical"
            PrimaryAxisAlignment="Center"
            CounterAxisAlignment="Center"
            Spacing="24">

            <!-- Cup with Coffee Fill -->
            <Grid Width="120" Height="100">
                <!-- Cup Body -->
                <Border Width="80"
                        Height="70"
                        CornerRadius="0,0,8,8"
                        BorderBrush="{StaticResource CaffeTextPrimaryBrush}"
                        BorderThickness="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,0">

                    <!-- Coffee Fill -->
                    <Border x:Name="CoffeeFill"
                            VerticalAlignment="Bottom"
                            CornerRadius="0,0,5,5"
                            Height="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{StaticResource CaffeCoffeeDarkColor}" Offset="0" />
                                <GradientStop Color="{StaticResource CaffeCoffeeLightColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- Handle -->
                <Border Width="20"
                        Height="40"
                        CornerRadius="0,10,10,0"
                        BorderBrush="{StaticResource CaffeTextPrimaryBrush}"
                        BorderThickness="3,3,3,3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,0,5" />

                <!-- Saucer -->
                <Border Height="6"
                        Width="100"
                        Background="{StaticResource CaffeTextPrimaryBrush}"
                        CornerRadius="3"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,10,0" />
            </Grid>

            <!-- Brewing Text -->
            <TextBlock Text="{x:Bind FormatBrewing(EspressoName), Mode=OneWay}"
                       Style="{StaticResource BrewingTitleTextStyle}"
                       HorizontalAlignment="Center" />

            <!-- Parameters -->
            <TextBlock x:Name="ParamsText"
                       Text="{x:Bind ParametersText, Mode=OneWay}"
                       Style="{StaticResource BodyTextStyle}"
                       Foreground="{StaticResource CaffeTextSecondaryBrush}"
                       HorizontalAlignment="Center" />

        </utu:AutoLayout>
    </Grid>

</UserControl>
