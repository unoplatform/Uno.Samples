<UserControl x:Class="Pens.Presentation.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ArenaDarkBrush}">

  <!-- Bootstrap navigation host. No Region.Attached here (host not ready during
       Shell construction); the navigation system loads the initial route
       (Login or Main) into this ContentControl via IContentControlProvider. -->
  <ContentControl x:Name="ShellContent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch" />
</UserControl>
