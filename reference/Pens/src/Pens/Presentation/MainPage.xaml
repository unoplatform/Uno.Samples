<Page x:Class="Pens.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Background="{StaticResource ArenaDarkBrush}">

  <!-- Root region coordinates both nav controls (rail + bottom bar) with the content. -->
  <Grid uen:Region.Attached="True"
        Background="{StaticResource ArenaDarkBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ── Desktop side rail (Wide only) ───────────────────────────── -->
    <Border Grid.Column="0"
            Width="208"
            Visibility="{utu:Responsive Narrow=Collapsed, Wide=Visible}"
            Background="{StaticResource ArenaDarkBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="0,0,1,0">
      <utu:AutoLayout Orientation="Vertical" Spacing="8" Padding="16,24">
        <!-- Branding -->
        <utu:AutoLayout Orientation="Horizontal" Spacing="12" Padding="4,0,0,16">
          <Border Width="44" Height="44" CornerRadius="10"
                  BorderBrush="{StaticResource PowderBlueBorderBrush}" BorderThickness="2">
            <Image Source="ms-appx:///Assets/images/pens-logo.png" Stretch="UniformToFill" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="PENGUINS" Style="{StaticResource BebasSubtitleTextStyle}"
                       AutomationProperties.HeadingLevel="Level1" />
            <TextBlock Text="DORVAL YOUNGTIMERS" Style="{StaticResource OverlineTextStyle}" />
          </StackPanel>
        </utu:AutoLayout>

        <utu:TabBar x:Name="RailTabBar" uen:Region.Attached="True"
                    Background="Transparent"
                    HorizontalAlignment="Stretch">
          <utu:TabBar.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Vertical" Spacing="2" />
            </ItemsPanelTemplate>
          </utu:TabBar.ItemsPanel>

          <utu:TabBarItem x:Name="RailScheduleTab" uen:Region.Name="Schedule" IsSelectable="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.Name="Schedule">
            <utu:AutoLayout Orientation="Horizontal" Spacing="14" Padding="10,10">
              <SymbolIcon Symbol="Calendar"
                          Foreground="{Binding IsSelected, ElementName=RailScheduleTab, Converter={StaticResource SelectedToBrushConverter}}" />
              <TextBlock Text="Schedule" Style="{StaticResource BodyDefaultTextStyle}" VerticalAlignment="Center"
                         Foreground="{Binding IsSelected, ElementName=RailScheduleTab, Converter={StaticResource SelectedToBrushConverter}}" />
            </utu:AutoLayout>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="RailChatTab" uen:Region.Name="Chat" IsSelectable="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.Name="Chat">
            <utu:AutoLayout Orientation="Horizontal" Spacing="14" Padding="10,10">
              <SymbolIcon Symbol="Message"
                          Foreground="{Binding IsSelected, ElementName=RailChatTab, Converter={StaticResource SelectedToBrushConverter}}" />
              <TextBlock Text="Chat" Style="{StaticResource BodyDefaultTextStyle}" VerticalAlignment="Center"
                         Foreground="{Binding IsSelected, ElementName=RailChatTab, Converter={StaticResource SelectedToBrushConverter}}" />
            </utu:AutoLayout>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="RailBeersTab" uen:Region.Name="Beers" IsSelectable="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.Name="Beers">
            <utu:AutoLayout Orientation="Horizontal" Spacing="14" Padding="10,10">
              <FontIcon Glyph="&#xE799;" FontSize="20"
                        Foreground="{Binding IsSelected, ElementName=RailBeersTab, Converter={StaticResource SelectedToBrushConverter}}" />
              <TextBlock Text="Beers" Style="{StaticResource BodyDefaultTextStyle}" VerticalAlignment="Center"
                         Foreground="{Binding IsSelected, ElementName=RailBeersTab, Converter={StaticResource SelectedToBrushConverter}}" />
            </utu:AutoLayout>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="RailDutiesTab" uen:Region.Name="Duties" IsSelectable="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.Name="Duties">
            <utu:AutoLayout Orientation="Horizontal" Spacing="14" Padding="10,10">
              <SymbolIcon Symbol="Bullets"
                          Foreground="{Binding IsSelected, ElementName=RailDutiesTab, Converter={StaticResource SelectedToBrushConverter}}" />
              <TextBlock Text="Duties" Style="{StaticResource BodyDefaultTextStyle}" VerticalAlignment="Center"
                         Foreground="{Binding IsSelected, ElementName=RailDutiesTab, Converter={StaticResource SelectedToBrushConverter}}" />
            </utu:AutoLayout>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="RailRosterTab" uen:Region.Name="Roster" IsSelectable="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.Name="Roster">
            <utu:AutoLayout Orientation="Horizontal" Spacing="14" Padding="10,10">
              <SymbolIcon Symbol="People"
                          Foreground="{Binding IsSelected, ElementName=RailRosterTab, Converter={StaticResource SelectedToBrushConverter}}" />
              <TextBlock Text="Roster" Style="{StaticResource BodyDefaultTextStyle}" VerticalAlignment="Center"
                         Foreground="{Binding IsSelected, ElementName=RailRosterTab, Converter={StaticResource SelectedToBrushConverter}}" />
            </utu:AutoLayout>
          </utu:TabBarItem>
        </utu:TabBar>
      </utu:AutoLayout>
    </Border>

    <!-- ── Content column ──────────────────────────────────────────── -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Top header (phones/tablets only; desktop branding lives in the rail) -->
      <Grid Grid.Row="0"
            Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}"
            utu:SafeArea.Insets="Top">
        <Border Padding="20,20,20,16"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{StaticResource ArenaDarkBrush}"
                AutomationProperties.Name="Team header">
          <StackPanel Orientation="Horizontal" Spacing="16"
                      MaxWidth="{StaticResource PageContentMaxWidth}"
                      HorizontalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="12"
                    BorderBrush="{StaticResource PowderBlueBorderBrush}" BorderThickness="2"
                    AutomationProperties.Name="Penguins team logo">
              <Image Source="ms-appx:///Assets/images/pens-logo.png" Stretch="UniformToFill" />
            </Border>
            <StackPanel VerticalAlignment="Center" utu:AutoLayout.PrimaryAlignment="Stretch">
              <TextBlock x:Uid="Shell_TeamName" Text="PENGUINS"
                         Style="{StaticResource BebasTitleTextStyle}"
                         AutomationProperties.HeadingLevel="Level1" />
              <TextBlock x:Uid="Shell_LeagueName" Text="DORVAL YOUNGTIMERS"
                         Style="{StaticResource LabelTextStyle}" CharacterSpacing="60" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Content region: pages load here by route name -->
      <Grid Grid.Row="1"
            uen:Region.Attached="True"
            uen:Region.Navigator="Visibility" />

      <!-- Bottom navigation (phones/tablets only) -->
      <Grid Grid.Row="2"
            Visibility="{utu:Responsive Narrow=Visible, Wide=Collapsed}"
            utu:SafeArea.Insets="Bottom">
        <Border Padding="8,8,8,20"
                Background="{StaticResource ArenaDarkBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,1,0,0">
          <utu:TabBar x:Name="TabBar"
                      uen:Region.Attached="True"
                      MaxWidth="{StaticResource PageContentMaxWidth}">
            <utu:TabBar.ItemsPanel>
              <ItemsPanelTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                </Grid>
              </ItemsPanelTemplate>
            </utu:TabBar.ItemsPanel>

            <utu:TabBarItem x:Name="ScheduleTab" Grid.Column="0"
                            uen:Region.Name="Schedule" IsSelectable="True"
                            AutomationProperties.Name="Schedule tab">
              <StackPanel HorizontalAlignment="Center" Spacing="4">
                <SymbolIcon Symbol="Calendar"
                            Foreground="{Binding IsSelected, ElementName=ScheduleTab, Converter={StaticResource SelectedToBrushConverter}}"
                            HorizontalAlignment="Center" />
                <TextBlock x:Uid="Shell_Tab_Schedule" Text="Schedule"
                           Style="{StaticResource OverlineTextStyle}" CharacterSpacing="0"
                           Foreground="{Binding IsSelected, ElementName=ScheduleTab, Converter={StaticResource SelectedToBrushConverter}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </utu:TabBarItem>

            <utu:TabBarItem x:Name="ChatTab" Grid.Column="1"
                            uen:Region.Name="Chat" IsSelectable="True"
                            AutomationProperties.Name="Chat tab">
              <StackPanel HorizontalAlignment="Center" Spacing="4">
                <SymbolIcon Symbol="Message"
                            Foreground="{Binding IsSelected, ElementName=ChatTab, Converter={StaticResource SelectedToBrushConverter}}"
                            HorizontalAlignment="Center" />
                <TextBlock x:Uid="Shell_Tab_Chat" Text="Chat"
                           Style="{StaticResource OverlineTextStyle}" CharacterSpacing="0"
                           Foreground="{Binding IsSelected, ElementName=ChatTab, Converter={StaticResource SelectedToBrushConverter}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </utu:TabBarItem>

            <utu:TabBarItem x:Name="BeersTab" Grid.Column="2"
                            uen:Region.Name="Beers" IsSelectable="True"
                            AutomationProperties.Name="Beers tab">
              <StackPanel HorizontalAlignment="Center" Spacing="4">
                <FontIcon Glyph="&#xE799;" FontSize="20"
                          Foreground="{Binding IsSelected, ElementName=BeersTab, Converter={StaticResource SelectedToBrushConverter}}"
                          HorizontalAlignment="Center" />
                <TextBlock x:Uid="Shell_Tab_Beers" Text="Beers"
                           Style="{StaticResource OverlineTextStyle}" CharacterSpacing="0"
                           Foreground="{Binding IsSelected, ElementName=BeersTab, Converter={StaticResource SelectedToBrushConverter}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </utu:TabBarItem>

            <utu:TabBarItem x:Name="DutiesTab" Grid.Column="3"
                            uen:Region.Name="Duties" IsSelectable="True"
                            AutomationProperties.Name="Duties tab">
              <StackPanel HorizontalAlignment="Center" Spacing="4">
                <SymbolIcon Symbol="Bullets"
                            Foreground="{Binding IsSelected, ElementName=DutiesTab, Converter={StaticResource SelectedToBrushConverter}}"
                            HorizontalAlignment="Center" />
                <TextBlock x:Uid="Shell_Tab_Duties" Text="Duties"
                           Style="{StaticResource OverlineTextStyle}" CharacterSpacing="0"
                           Foreground="{Binding IsSelected, ElementName=DutiesTab, Converter={StaticResource SelectedToBrushConverter}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </utu:TabBarItem>

            <utu:TabBarItem x:Name="RosterTab" Grid.Column="4"
                            uen:Region.Name="Roster" IsSelectable="True"
                            AutomationProperties.Name="Roster tab">
              <StackPanel HorizontalAlignment="Center" Spacing="4">
                <SymbolIcon Symbol="People"
                            Foreground="{Binding IsSelected, ElementName=RosterTab, Converter={StaticResource SelectedToBrushConverter}}"
                            HorizontalAlignment="Center" />
                <TextBlock x:Uid="Shell_Tab_Roster" Text="Roster"
                           Style="{StaticResource OverlineTextStyle}" CharacterSpacing="0"
                           Foreground="{Binding IsSelected, ElementName=RosterTab, Converter={StaticResource SelectedToBrushConverter}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </utu:TabBarItem>
          </utu:TabBar>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Page>
