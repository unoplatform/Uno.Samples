<Page x:Class="Pens.Presentation.DutiesPage"
      x:Name="DutiesPageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:models="using:Pens.Models"
      Background="{StaticResource ArenaDarkBrush}">

  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Padding="20">
        <utu:AutoLayout Spacing="12"
                        MaxWidth="{StaticResource PageContentMaxWidth}"
                        HorizontalAlignment="Center">
          <utu:AutoLayout.Transitions>
            <TransitionCollection>
              <EntranceThemeTransition FromVerticalOffset="24" />
            </TransitionCollection>
          </utu:AutoLayout.Transitions>

          <!-- Header Row -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <!-- Section Title -->
              <TextBlock x:Uid="DutiesPage_Title"
                         Text="THIS WEEK'S DUTIES"
                         Style="{StaticResource SectionTitleTextStyle}"
                         AutomationProperties.HeadingLevel="Level2" />

              <!-- Subheader -->
              <TextBlock Text="{Binding GameInfo}"
                         Style="{StaticResource CaptionLargeTextStyle}"
                         Margin="0,4,0,0" />
            </StackPanel>

            <!-- Randomize Button -->
            <Button Grid.Column="1"
                    Command="{Binding RandomizeDutiesCommand}"
                    IsEnabled="{Binding CanRandomize}"
                    Background="{StaticResource IceBlueSubtleBrush}"
                    BorderBrush="{StaticResource IceBlueBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource MediumCornerRadius}"
                    Padding="12,8"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Randomize duties">
              <TextBlock Text="RANDOMIZE"
                         Style="{StaticResource ButtonLabelTextStyle}"
                         Foreground="{StaticResource IceBlueBrush}" />
            </Button>
          </Grid>

          <!-- Spacer -->
          <Border Height="8" />

          <!-- Duties List -->
          <ItemsRepeater ItemsSource="{Binding Duties}">
            <ItemsRepeater.Layout>
              <StackLayout Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:Duty">
                <Border Background="{StaticResource BoardsDarkBrush}"
                        CornerRadius="{StaticResource LargeCornerRadius}"
                        Padding="20"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">
                  <utu:AutoLayout Orientation="Horizontal" Spacing="16">
                    <!-- Icon Container (carries the duty-type colour; replaces the old left accent bar) -->
                    <Border Width="52" Height="52"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            BorderThickness="1">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding Type, Converter={StaticResource DutyTypeToColorConverter}}" Opacity="0.15" />
                      </Border.Background>
                      <Border.BorderBrush>
                        <SolidColorBrush Color="{Binding Type, Converter={StaticResource DutyTypeToColorConverter}}" Opacity="0.5" />
                      </Border.BorderBrush>
                      <TextBlock Text="{Binding Type, Converter={StaticResource DutyTypeToIconConverter}}"
                                 FontSize="24"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 AutomationProperties.AccessibilityView="Raw" />
                    </Border>

                    <!-- Info Section -->
                    <StackPanel VerticalAlignment="Center" utu:AutoLayout.PrimaryAlignment="Stretch">
                      <TextBlock Text="{Binding Role, Converter={StaticResource ToUpperConverter}}"
                                 Style="{StaticResource LabelTextStyle}" />

                      <!-- Show name for non-manual duties (Ice, Cooler) -->
                      <TextBlock Text="{Binding Name}"
                                 Style="{StaticResource BodyLargeTextStyle}"
                                 Margin="0,4,0,0"
                                 Visibility="{Binding IsManuallyAssigned, Converter={StaticResource InverseBoolConverter}}" />

                      <!-- Show dropdown for manual duties (Beer, Food) -->
                      <ComboBox ItemsSource="{Binding DataContext.AvailablePlayers, ElementName=DutiesPageRoot}"
                                SelectedValue="{Binding PlayerId, Mode=OneWay}"
                                SelectedValuePath="Id"
                                DisplayMemberPath="Name"
                                PlaceholderText="Select player"
                                SelectionChanged="OnPlayerSelected"
                                Background="{StaticResource BoardsMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="12,8"
                                MinWidth="180"
                                Margin="0,4,0,0"
                                Visibility="{Binding IsManuallyAssigned}"
                                AutomationProperties.Name="{Binding Role}">
                        <ComboBox.Resources>
                          <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{ThemeResource BoardsMidColor}" />
                          <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#1AFFFFFF" />
                          <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="#26FFFFFF" />
                          <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{ThemeResource TextPrimaryColor}" />
                          <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="{ThemeResource TextPrimaryColor}" />
                          <SolidColorBrush x:Key="ComboBoxItemForegroundPressed" Color="{ThemeResource TextPrimaryColor}" />
                          <SolidColorBrush x:Key="ComboBoxPlaceholderForeground" Color="{ThemeResource TextMutedColor}" />
                        </ComboBox.Resources>
                      </ComboBox>
                    </StackPanel>
                  </utu:AutoLayout>
                </Border>
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>

          <!-- Bottom padding for nav -->
          <Border Height="24" />
        </utu:AutoLayout>
      </Grid>
    </ScrollViewer>

    <!-- Loading state -->
    <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
            Background="{StaticResource ArenaDarkBrush}"
            AutomationProperties.Name="Loading duties">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
        <ProgressRing IsActive="{Binding IsLoading}" Width="44" Height="44"
                      Foreground="{StaticResource PowderBlueBrush}" />
        <TextBlock x:Uid="DutiesPage_Loading" Text="Loading duties…"
                   Style="{StaticResource CaptionTextStyle}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Error state -->
    <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
            Background="{StaticResource ArenaDarkBrush}"
            AutomationProperties.Name="Error loading duties">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Padding="32">
        <FontIcon Glyph="&#xEA39;" FontSize="40"
                  Foreground="{StaticResource HotRedBrush}"
                  HorizontalAlignment="Center" />
        <TextBlock Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyTextStyle}"
                   Foreground="{StaticResource HotRedBrush}"
                   TextWrapping="Wrap" TextAlignment="Center"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Page>
