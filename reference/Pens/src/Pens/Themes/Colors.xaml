<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Brand palette. Chrome colours (surfaces, text, borders) are theme-aware so
    the whole UI recolours in OS High Contrast mode; accent colours stay vivid
    in both modes. The dark/base dictionary MUST be keyed "Default" (NOT "Dark")
    or ThemeResource fails to resolve in Style setters. See [[uno-theme-dictionary-default-key]].
  -->
  <ResourceDictionary.ThemeDictionaries>

    <!-- Dark "arena" theme (also serves Light; the app is dark-only by design). -->
    <ResourceDictionary x:Key="Default">
      <Color x:Key="ArenaDarkColor">#0A0C10</Color>
      <Color x:Key="BoardsDarkColor">#12161D</Color>
      <Color x:Key="BoardsMidColor">#1A1F2A</Color>
      <Color x:Key="TextPrimaryColor">#F0F4F8</Color>
      <!-- Lifted from #6B7A8F to reach WCAG AA on dark surfaces for small text. -->
      <Color x:Key="TextMutedColor">#8A98AB</Color>
      <Color x:Key="SubtleBorderColor">#0DFFFFFF</Color>
      <Color x:Key="CardBorderColor">#08FFFFFF</Color>
    </ResourceDictionary>

    <!-- Maximal-contrast variant for OS High Contrast mode. -->
    <ResourceDictionary x:Key="HighContrast">
      <Color x:Key="ArenaDarkColor">#000000</Color>
      <Color x:Key="BoardsDarkColor">#0A0A0A</Color>
      <Color x:Key="BoardsMidColor">#1A1A1A</Color>
      <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
      <Color x:Key="TextMutedColor">#FFFFFF</Color>
      <Color x:Key="SubtleBorderColor">#FFFFFF</Color>
      <Color x:Key="CardBorderColor">#FFFFFF</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- Accent colours: theme-independent (used directly by converters via flat lookup). -->
  <Color x:Key="NeonAmberColor">#FFAA00</Color>
  <Color x:Key="NeonAmberGlowColor">#99FFAA00</Color>
  <Color x:Key="PowderBlueColor">#B4D7E8</Color>
  <Color x:Key="PowderBlueDeepColor">#7EB8D4</Color>
  <Color x:Key="PowderBlueGlowColor">#66B4D7E8</Color>
  <Color x:Key="IceBlueColor">#00D4FF</Color>
  <Color x:Key="IceBlueGlowColor">#8000D4FF</Color>
  <Color x:Key="HotRedColor">#FF3B3B</Color>
  <Color x:Key="SuccessGreenColor">#10B981</Color>
  <Color x:Key="PurpleAccentColor">#8B5CF6</Color>

</ResourceDictionary>
