<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Fonts (single declaration; referenced by the type scale below). -->
  <FontFamily x:Key="BebasNeueFont">ms-appx:///Assets/Fonts/BebasNeue-Regular.ttf#Bebas Neue</FontFamily>
  <FontFamily x:Key="BarlowRegular">ms-appx:///Assets/Fonts/Barlow-Regular.ttf#Barlow</FontFamily>
  <FontFamily x:Key="BarlowMedium">ms-appx:///Assets/Fonts/Barlow-Medium.ttf#Barlow</FontFamily>
  <FontFamily x:Key="BarlowSemiBold">ms-appx:///Assets/Fonts/Barlow-SemiBold.ttf#Barlow</FontFamily>
  <FontFamily x:Key="BarlowBold">ms-appx:///Assets/Fonts/Barlow-Bold.ttf#Barlow</FontFamily>

  <!--
    Type scale. Each style sets family/size/weight/spacing and a default
    Foreground for its semantic role. Pages override Foreground only where the
    value is an accent (amber counter, green/red status, etc.).
    Sizes are device-independent and respond to OS text scaling.
  -->

  <!-- Bebas Neue display / counters -->
  <Style x:Key="BebasHeroTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="80" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BebasDisplayTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="42" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BebasCounterTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BebasTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="32" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- Smaller Bebas title used on the shell header next to the team logo. -->
  <Style x:Key="BebasSubtitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="CharacterSpacing" Value="60" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BebasSubTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BebasNeueFont}" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <!-- Barlow Medium unit label paired with a hero counter (e.g. "cases"). -->
  <Style x:Key="HeroUnitTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowMedium}" />
    <Setter Property="FontSize" Value="24" />
    <Setter Property="CharacterSpacing" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <!-- Bold scoreline digits used in result rows. Foreground set by the caller. -->
  <Style x:Key="ScoreTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowBold}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- Large bold game-time label with tracked-out spacing. -->
  <Style x:Key="GameTimeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowBold}" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CharacterSpacing" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- Status pill text; caller sets Foreground for state colour. -->
  <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowBold}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CharacterSpacing" Value="40" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Initials inside a small circular/square avatar swatch. -->
  <Style x:Key="AvatarInitialsTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowBold}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource ArenaDarkBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Chat sender name, slightly heavier than body. -->
  <Style x:Key="SenderNameTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- Small SemiBold button label with tracked-out spacing. Foreground set by caller. -->
  <Style x:Key="ButtonLabelTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="60" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Jersey number badge: bold body font on a light badge. -->
  <Style x:Key="JerseyNumberTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowBold}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource ArenaDarkBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Barlow body / labels -->
  <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="120" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{StaticResource PowderBlueBrush}" />
  </Style>

  <Style x:Key="BodyLargeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BodyTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowSemiBold}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BodyDefaultTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowRegular}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowRegular}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <!-- One-step-larger caption for subheaders sitting under a SectionTitle. -->
  <Style x:Key="CaptionLargeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowRegular}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <Style x:Key="LabelTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowRegular}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <Style x:Key="OverlineTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowMedium}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="CharacterSpacing" Value="60" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

  <!-- Heavier overline used under hero counters with wider tracking. -->
  <Style x:Key="OverlineLargeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BarlowMedium}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
  </Style>

</ResourceDictionary>
