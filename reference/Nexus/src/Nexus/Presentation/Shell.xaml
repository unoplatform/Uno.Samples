<UserControl x:Class="Nexus.Presentation.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{ThemeResource NexusBackgroundPrimaryBrush}">

    <!-- Bootstrap navigation host. No Region.Attached here (host not ready during
         Shell construction); the navigation system loads the default nested route
         ("Main") into this ContentControl via IContentControlProvider. -->
    <ContentControl x:Name="ShellContent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"/>
</UserControl>
