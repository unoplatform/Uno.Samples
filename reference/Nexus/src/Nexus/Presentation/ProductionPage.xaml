<Page x:Class="Nexus.Presentation.ProductionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:conv="using:Nexus.Converters"
      xmlns:models="using:Nexus.Models"
      Background="{ThemeResource NexusBackgroundPrimaryBrush}">

    <Page.Resources>
        <conv:NumberFormatConverter x:Key="Num"/>
        <conv:DateConverter x:Key="Date"/>
        <conv:EnumUpperConverter x:Key="Upper"/>
        <conv:PriorityBrushConverter x:Key="PriorityBrush"/>
        <conv:StockStatusBrushConverter x:Key="StockBrush"/>
        <conv:LineStatusTextConverter x:Key="StatusText"/>
        <conv:LineStatusBrushConverter x:Key="StatusBrush"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Padding="24" MinWidth="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Row: Batch Queue, Shift Info, Material Inventory -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- BATCH QUEUE Panel -->
                <Border Grid.Column="0" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Uid="Pages_Production_BatchQueue" Text="BATCH QUEUE" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="+ NEW BATCH" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="45"/>
                                <ColumnDefinition Width="Auto" MinWidth="65"/>
                                <ColumnDefinition Width="Auto" MinWidth="45"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BATCH ID" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="PRODUCT" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="QTY" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="PRIORITY" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="ETA" Style="{ThemeResource NexusTableHeaderStyle}"/>
                        </Grid>

                        <mvux:FeedView Grid.Row="2" Source="{Binding BatchQueue}">
                            <mvux:FeedView.ValueTemplate>
                                <DataTemplate>
                                    <ItemsRepeater ItemsSource="{Binding Data}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="0"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:Batch">
                                                <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" MinWidth="70"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto" MinWidth="45"/>
                                                            <ColumnDefinition Width="Auto" MinWidth="65"/>
                                                            <ColumnDefinition Width="Auto" MinWidth="45"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Id}" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Quantity, Converter={StaticResource Num}, ConverterParameter=N0}" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                                            <Ellipse Width="6" Height="6" Fill="{Binding Priority, Converter={StaticResource PriorityBrush}}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Priority, Converter={StaticResource Upper}}" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{Binding Priority, Converter={StaticResource PriorityBrush}}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="4" Text="{Binding EstimatedCompletion, Converter={StaticResource Date}, ConverterParameter='HH:mm'}" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </DataTemplate>
                            </mvux:FeedView.ValueTemplate>
                            <mvux:FeedView.ProgressTemplate>
                                <DataTemplate>
                                    <ProgressRing IsActive="True" Width="24" Height="24" Margin="0,24" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </mvux:FeedView.ProgressTemplate>
                            <mvux:FeedView.NoneTemplate>
                                <DataTemplate>
                                    <TextBlock Text="No batches queued" Style="{ThemeResource NexusTableCellStyle}" Margin="0,24" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </mvux:FeedView.NoneTemplate>
                        </mvux:FeedView>
                    </Grid>
                </Border>

                <!-- SHIFT INFORMATION Panel -->
                <Border Grid.Column="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="SHIFT INFORMATION" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        </StackPanel>

                        <mvux:FeedView Grid.Row="1" Source="{Binding Shift}">
                            <mvux:FeedView.ValueTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="0,20,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="12,8">
                                                <TextBlock Text="{Binding Data.ShiftName}" Style="{ThemeResource NexusBodyStyle}" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Style="{ThemeResource NexusBodyMonoStyle}" VerticalAlignment="Center">
                                                <Run Text="{Binding Data.StartTime, Converter={StaticResource Date}, ConverterParameter='HH:mm'}"/><Run Text=" - "/><Run Text="{Binding Data.EndTime, Converter={StaticResource Date}, ConverterParameter='HH:mm'}"/>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Margin="0,20,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="UNITS PRODUCED" Style="{ThemeResource NexusStatusLabelStyle}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Data.UnitsProduced, Converter={StaticResource Num}, ConverterParameter=N0}" Style="{ThemeResource NexusDisplayMediumStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="TARGET" Style="{ThemeResource NexusStatusLabelStyle}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Data.TargetUnits, Converter={StaticResource Num}, ConverterParameter=N0}" Style="{ThemeResource NexusDisplayMediumStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,20,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="SHIFT PROGRESS" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                                <TextBlock Grid.Column="1" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusTextSecondaryBrush}">
                                                    <Run Text="{Binding Data.ProgressPercent, Converter={StaticResource Num}, ConverterParameter=F0}"/><Run Text="%"/>
                                                </TextBlock>
                                            </Grid>
                                            <ProgressBar Value="{Binding Data.ProgressPercent}" Style="{ThemeResource NexusProgressBarStyle}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </mvux:FeedView.ValueTemplate>
                            <mvux:FeedView.ProgressTemplate>
                                <DataTemplate>
                                    <ProgressRing IsActive="True" Width="24" Height="24" Margin="0,24" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </mvux:FeedView.ProgressTemplate>
                        </mvux:FeedView>
                    </Grid>
                </Border>

                <!-- MATERIAL INVENTORY Panel -->
                <Border Grid.Column="4" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="MATERIAL INVENTORY" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="REORDER" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <mvux:FeedView Grid.Row="1" Source="{Binding Materials}" Margin="0,16,0,0">
                            <mvux:FeedView.ValueTemplate>
                                <DataTemplate>
                                    <ItemsRepeater ItemsSource="{Binding Data}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="0"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:Material">
                                                <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Style="{ThemeResource NexusBodyStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Status, Converter={StaticResource Upper}}" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{Binding Status, Converter={StaticResource StockBrush}}" HorizontalAlignment="Right"/>
                                                            <TextBlock Style="{ThemeResource NexusLabelMonoStyle}" HorizontalAlignment="Right" Margin="0,4,0,0">
                                                                <Run Text="{Binding InStock, Converter={StaticResource Num}, ConverterParameter=N0}"/><Run Text=" "/><Run Text="{Binding Unit}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </DataTemplate>
                            </mvux:FeedView.ValueTemplate>
                            <mvux:FeedView.ProgressTemplate>
                                <DataTemplate>
                                    <ProgressRing IsActive="True" Width="24" Height="24" Margin="0,24" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </mvux:FeedView.ProgressTemplate>
                            <mvux:FeedView.NoneTemplate>
                                <DataTemplate>
                                    <TextBlock Text="No materials tracked" Style="{ThemeResource NexusTableCellStyle}" Margin="0,24" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </mvux:FeedView.NoneTemplate>
                        </mvux:FeedView>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom Row: Line Status Detail (data-driven cards) -->
            <Border Grid.Row="1" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="LINE STATUS DETAIL" Style="{ThemeResource NexusPanelTitleStyle}"/>
                    </StackPanel>

                    <mvux:FeedView Grid.Row="1" Source="{Binding Lines}" Margin="0,16,0,0">
                        <mvux:FeedView.ValueTemplate>
                            <DataTemplate>
                                <ItemsRepeater ItemsSource="{Binding Data}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="180" MinColumnSpacing="16" MinRowSpacing="16" ItemsStretch="Fill"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProductionLine">
                                            <Border Style="{ThemeResource NexusCardBorderStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                                            <TextBlock Text="{Binding Id}" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                                            <Ellipse Width="6" Height="6" Fill="{Binding Status, Converter={StaticResource StatusBrush}}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusText}}" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{Binding Status, Converter={StaticResource StatusBrush}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding Name}" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                                            <TextBlock Grid.Column="1" Style="{ThemeResource NexusTableCellStyle}">
                                                                <Run Text="{Binding OutputPercent, Converter={StaticResource Num}, ConverterParameter=F0}"/><Run Text="%"/>
                                                            </TextBlock>
                                                        </Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                                            <TextBlock Grid.Column="1" Style="{ThemeResource NexusTableCellStyle}">
                                                                <Run Text="{Binding Temperature, Converter={StaticResource Num}, ConverterParameter=F1}"/><Run Text="°C"/>
                                                            </TextBlock>
                                                        </Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                                            <TextBlock Grid.Column="1" Style="{ThemeResource NexusTableCellStyle}">
                                                                <Run Text="{Binding Pressure, Converter={StaticResource Num}, ConverterParameter=F1}"/><Run Text=" bar"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </StackPanel>
                                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                                        <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </DataTemplate>
                        </mvux:FeedView.ValueTemplate>
                        <mvux:FeedView.ProgressTemplate>
                            <DataTemplate>
                                <ProgressRing IsActive="True" Width="24" Height="24" Margin="0,24" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </mvux:FeedView.ProgressTemplate>
                    </mvux:FeedView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
