<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- NEXUS Industrial Theme - Material Color System -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- Dark Theme (Primary). Keyed "Default" so ThemeResource resolves in Style setters. -->
        <ResourceDictionary x:Key="Default">
            <Color x:Key="PrimaryColor">#4ade80</Color>
            <Color x:Key="OnPrimaryColor">#0a0a0b</Color>
            <Color x:Key="PrimaryContainerColor">#18181b</Color>
            <Color x:Key="OnPrimaryContainerColor">#4ade80</Color>

            <Color x:Key="SecondaryColor">#60a5fa</Color>
            <Color x:Key="OnSecondaryColor">#0a0a0b</Color>
            <Color x:Key="SecondaryContainerColor">#18181b</Color>
            <Color x:Key="OnSecondaryContainerColor">#60a5fa</Color>

            <Color x:Key="TertiaryColor">#fbbf24</Color>
            <Color x:Key="OnTertiaryColor">#0a0a0b</Color>
            <Color x:Key="TertiaryContainerColor">#18181b</Color>
            <Color x:Key="OnTertiaryContainerColor">#fbbf24</Color>

            <Color x:Key="ErrorColor">#f87171</Color>
            <Color x:Key="OnErrorColor">#0a0a0b</Color>
            <Color x:Key="ErrorContainerColor">#18181b</Color>
            <Color x:Key="OnErrorContainerColor">#f87171</Color>

            <Color x:Key="BackgroundColor">#0a0a0b</Color>
            <Color x:Key="OnBackgroundColor">#fafafa</Color>

            <Color x:Key="SurfaceColor">#111113</Color>
            <Color x:Key="OnSurfaceColor">#fafafa</Color>
            <Color x:Key="SurfaceVariantColor">#18181b</Color>
            <Color x:Key="OnSurfaceVariantColor">#a1a1aa</Color>

            <Color x:Key="OutlineColor">#27272a</Color>
            <Color x:Key="OutlineVariantColor">#3f3f46</Color>

            <Color x:Key="SurfaceInverseColor">#fafafa</Color>
            <Color x:Key="OnSurfaceInverseColor">#0a0a0b</Color>
            <Color x:Key="PrimaryInverseColor">#4ade80</Color>
            <Color x:Key="SurfaceTintColor">#4ade80</Color>
        </ResourceDictionary>

        <!-- Light Theme -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="PrimaryColor">#16a34a</Color>
            <Color x:Key="OnPrimaryColor">#ffffff</Color>
            <Color x:Key="PrimaryContainerColor">#dcfce7</Color>
            <Color x:Key="OnPrimaryContainerColor">#16a34a</Color>

            <Color x:Key="SecondaryColor">#2563eb</Color>
            <Color x:Key="OnSecondaryColor">#ffffff</Color>
            <Color x:Key="SecondaryContainerColor">#dbeafe</Color>
            <Color x:Key="OnSecondaryContainerColor">#2563eb</Color>

            <Color x:Key="TertiaryColor">#d97706</Color>
            <Color x:Key="OnTertiaryColor">#ffffff</Color>
            <Color x:Key="TertiaryContainerColor">#fef3c7</Color>
            <Color x:Key="OnTertiaryContainerColor">#d97706</Color>

            <Color x:Key="ErrorColor">#dc2626</Color>
            <Color x:Key="OnErrorColor">#ffffff</Color>
            <Color x:Key="ErrorContainerColor">#fee2e2</Color>
            <Color x:Key="OnErrorContainerColor">#dc2626</Color>

            <Color x:Key="BackgroundColor">#fafafa</Color>
            <Color x:Key="OnBackgroundColor">#0a0a0b</Color>

            <Color x:Key="SurfaceColor">#ffffff</Color>
            <Color x:Key="OnSurfaceColor">#18181b</Color>
            <Color x:Key="SurfaceVariantColor">#f4f4f5</Color>
            <Color x:Key="OnSurfaceVariantColor">#52525b</Color>

            <Color x:Key="OutlineColor">#d4d4d8</Color>
            <Color x:Key="OutlineVariantColor">#a1a1aa</Color>

            <Color x:Key="SurfaceInverseColor">#18181b</Color>
            <Color x:Key="OnSurfaceInverseColor">#fafafa</Color>
            <Color x:Key="PrimaryInverseColor">#4ade80</Color>
            <Color x:Key="SurfaceTintColor">#16a34a</Color>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
