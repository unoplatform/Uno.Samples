<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- NEXUS Industrial Control System Theme       -->
    <!-- Theme-aware dark/light aesthetic            -->
    <!-- ============================================ -->

    <!-- Theme-aware NEXUS Colors and Brushes -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- Dark Theme. Keyed "Default" (not "Dark") so ThemeResource lookups in Style
             setters (Background/BorderBrush on panels, buttons, inputs) resolve correctly;
             WinUI maps the Dark app theme to the "Default" theme dictionary. -->
        <ResourceDictionary x:Key="Default">
            <Color x:Key="NexusBackgroundPrimaryColor">#060607</Color>
            <Color x:Key="NexusBackgroundSecondaryColor">#1a1a1f</Color>
            <Color x:Key="NexusBackgroundTertiaryColor">#222227</Color>

            <Color x:Key="NexusBorderPrimaryColor">#2e2e34</Color>
            <Color x:Key="NexusBorderSecondaryColor">#47474f</Color>

            <Color x:Key="NexusTextPrimaryColor">#fafafa</Color>
            <Color x:Key="NexusTextSecondaryColor">#a1a1aa</Color>
            <Color x:Key="NexusTextTertiaryColor">#71717a</Color>

            <Color x:Key="NexusSuccessColor">#4ade80</Color>
            <Color x:Key="NexusWarningColor">#fbbf24</Color>
            <Color x:Key="NexusDangerColor">#f87171</Color>
            <Color x:Key="NexusInfoColor">#60a5fa</Color>
            <Color x:Key="NexusAccentColor">#52525b</Color>

            <SolidColorBrush x:Key="NexusBackgroundPrimaryBrush" Color="#060607"/>
            <SolidColorBrush x:Key="NexusBackgroundSecondaryBrush" Color="#1a1a1f"/>
            <SolidColorBrush x:Key="NexusBackgroundTertiaryBrush" Color="#222227"/>

            <SolidColorBrush x:Key="NexusBorderPrimaryBrush" Color="#2e2e34"/>
            <SolidColorBrush x:Key="NexusBorderSecondaryBrush" Color="#47474f"/>
            <SolidColorBrush x:Key="NexusBorderBrush" Color="#2e2e34"/>

            <SolidColorBrush x:Key="NexusTextPrimaryBrush" Color="#fafafa"/>
            <SolidColorBrush x:Key="NexusTextSecondaryBrush" Color="#a1a1aa"/>
            <SolidColorBrush x:Key="NexusTextTertiaryBrush" Color="#71717a"/>

            <SolidColorBrush x:Key="NexusSuccessBrush" Color="#4ade80"/>
            <SolidColorBrush x:Key="NexusWarningBrush" Color="#fbbf24"/>
            <SolidColorBrush x:Key="NexusDangerBrush" Color="#f87171"/>
            <SolidColorBrush x:Key="NexusInfoBrush" Color="#60a5fa"/>
            <SolidColorBrush x:Key="NexusAccentBrush" Color="#52525b"/>

            <!-- TabBarItem lightweight-styling overrides: flat (no Material selection pill),
                 text tertiary -> secondary (hover) -> primary (selected) per the brief. -->
            <SolidColorBrush x:Key="TabBarItemBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemForeground" Color="#71717a"/>
            <SolidColorBrush x:Key="TabBarItemForegroundPointerOver" Color="#a1a1aa"/>
            <SolidColorBrush x:Key="TabBarItemForegroundPressed" Color="#fafafa"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelected" Color="#fafafa"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelectedPointerOver" Color="#fafafa"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelectedPressed" Color="#fafafa"/>
            <SolidColorBrush x:Key="TabBarItemForegroundDisabled" Color="#52525b"/>

            <!-- Material Navigation TabBarItem (the implicit style): kill the accent
                 "active indicator" pill + tinted backgrounds, set flat brief text colors. -->
            <SolidColorBrush x:Key="NavigationTabBarBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundDisabled" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemPointerFillBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarForeground" Color="#71717a"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundPointerOver" Color="#a1a1aa"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundPressed" Color="#fafafa"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelected" Color="#fafafa"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelectedPointerOver" Color="#fafafa"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelectedPressed" Color="#fafafa"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundDisabled" Color="#52525b"/>
        </ResourceDictionary>

        <!-- Light Theme -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="NexusBackgroundPrimaryColor">#fafafa</Color>
            <Color x:Key="NexusBackgroundSecondaryColor">#ffffff</Color>
            <Color x:Key="NexusBackgroundTertiaryColor">#f4f4f5</Color>

            <Color x:Key="NexusBorderPrimaryColor">#d4d4d8</Color>
            <Color x:Key="NexusBorderSecondaryColor">#a1a1aa</Color>

            <Color x:Key="NexusTextPrimaryColor">#18181b</Color>
            <Color x:Key="NexusTextSecondaryColor">#52525b</Color>
            <Color x:Key="NexusTextTertiaryColor">#71717a</Color>

            <Color x:Key="NexusSuccessColor">#16a34a</Color>
            <Color x:Key="NexusWarningColor">#d97706</Color>
            <Color x:Key="NexusDangerColor">#dc2626</Color>
            <Color x:Key="NexusInfoColor">#2563eb</Color>
            <Color x:Key="NexusAccentColor">#a1a1aa</Color>

            <SolidColorBrush x:Key="NexusBackgroundPrimaryBrush" Color="#fafafa"/>
            <SolidColorBrush x:Key="NexusBackgroundSecondaryBrush" Color="#ffffff"/>
            <SolidColorBrush x:Key="NexusBackgroundTertiaryBrush" Color="#f4f4f5"/>

            <SolidColorBrush x:Key="NexusBorderPrimaryBrush" Color="#d4d4d8"/>
            <SolidColorBrush x:Key="NexusBorderSecondaryBrush" Color="#a1a1aa"/>
            <SolidColorBrush x:Key="NexusBorderBrush" Color="#d4d4d8"/>

            <SolidColorBrush x:Key="NexusTextPrimaryBrush" Color="#18181b"/>
            <SolidColorBrush x:Key="NexusTextSecondaryBrush" Color="#52525b"/>
            <SolidColorBrush x:Key="NexusTextTertiaryBrush" Color="#71717a"/>

            <SolidColorBrush x:Key="NexusSuccessBrush" Color="#16a34a"/>
            <SolidColorBrush x:Key="NexusWarningBrush" Color="#d97706"/>
            <SolidColorBrush x:Key="NexusDangerBrush" Color="#dc2626"/>
            <SolidColorBrush x:Key="NexusInfoBrush" Color="#2563eb"/>
            <SolidColorBrush x:Key="NexusAccentBrush" Color="#a1a1aa"/>

            <!-- TabBarItem lightweight-styling overrides (light theme) -->
            <SolidColorBrush x:Key="TabBarItemBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="TabBarItemForeground" Color="#71717a"/>
            <SolidColorBrush x:Key="TabBarItemForegroundPointerOver" Color="#52525b"/>
            <SolidColorBrush x:Key="TabBarItemForegroundPressed" Color="#18181b"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelected" Color="#18181b"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelectedPointerOver" Color="#18181b"/>
            <SolidColorBrush x:Key="TabBarItemForegroundSelectedPressed" Color="#18181b"/>
            <SolidColorBrush x:Key="TabBarItemForegroundDisabled" Color="#a1a1aa"/>

            <!-- Material Navigation TabBarItem (light theme) -->
            <SolidColorBrush x:Key="NavigationTabBarBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelected" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelectedPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundSelectedPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemActiveIndicatorBackgroundDisabled" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarItemPointerFillBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationTabBarForeground" Color="#71717a"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundPointerOver" Color="#52525b"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundPressed" Color="#18181b"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelected" Color="#18181b"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelectedPointerOver" Color="#18181b"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundSelectedPressed" Color="#18181b"/>
            <SolidColorBrush x:Key="NavigationTabBarForegroundDisabled" Color="#a1a1aa"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ============================================ -->
    <!-- Typography Fonts (bundled, OFL licensed)     -->
    <!-- Display = Space Grotesk, System/UI = IBM Plex Mono -->
    <!-- ============================================ -->
    <FontFamily x:Key="NexusDisplayFont">ms-appx:///Assets/Fonts/SpaceGrotesk.ttf#Space Grotesk</FontFamily>
    <FontFamily x:Key="NexusMonoFont">ms-appx:///Assets/Fonts/IBMPlexMono-Regular.ttf#IBM Plex Mono</FontFamily>

    <!-- Spacing Constants -->
    <x:Double x:Key="NexusSpaceXS">4</x:Double>
    <x:Double x:Key="NexusSpaceSM">8</x:Double>
    <x:Double x:Key="NexusSpaceMD">12</x:Double>
    <x:Double x:Key="NexusSpaceLG">16</x:Double>
    <x:Double x:Key="NexusSpaceXL">20</x:Double>
    <x:Double x:Key="NexusSpace2XL">24</x:Double>
    <x:Double x:Key="NexusSpace3XL">32</x:Double>

    <Thickness x:Key="NexusPanelPadding">16</Thickness>
    <Thickness x:Key="NexusPagePadding">24</Thickness>
    <Thickness x:Key="NexusHeaderPadding">24,16</Thickness>

    <!-- Typography Styles -->
    <!-- Logo Style -->
    <Style x:Key="NexusLogoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusDisplayFont}"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="CharacterSpacing" Value="400"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
    </Style>

    <!-- Display Values (32px for large metrics) -->
    <Style x:Key="NexusDisplayStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusDisplayFont}"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
    </Style>

    <!-- Medium Display (24px) -->
    <Style x:Key="NexusDisplayMediumStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusDisplayFont}"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
    </Style>

    <!-- Body Style -->
    <Style x:Key="NexusBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CharacterSpacing" Value="25"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
    </Style>

    <!-- Body Mono Style (11px) -->
    <Style x:Key="NexusBodyMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="CharacterSpacing" Value="50"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextSecondaryBrush}"/>
    </Style>

    <!-- Label Mono Style (10px) -->
    <Style x:Key="NexusLabelMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="CharacterSpacing" Value="50"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Caption Style (12px) -->
    <Style x:Key="NexusCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextSecondaryBrush}"/>
    </Style>

    <!-- Caption Mono Style (9px) -->
    <Style x:Key="NexusCaptionMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="CharacterSpacing" Value="50"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Panel Title Style -->
    <Style x:Key="NexusPanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="CharacterSpacing" Value="150"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Status Label Style (uppercase) -->
    <Style x:Key="NexusStatusLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="CharacterSpacing" Value="100"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Tab Item Style -->
    <Style x:Key="NexusTabTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="CharacterSpacing" Value="150"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Value Style (for metric values) -->
    <Style x:Key="NexusValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusDisplayFont}"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
    </Style>

    <!-- Unit Style -->
    <Style x:Key="NexusUnitStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Ghost Button Style -->
    <Style x:Key="NexusGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="CharacterSpacing" Value="100"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Primary Action Button Style -->
    <Style x:Key="NexusPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource NexusSuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusSuccessBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusBackgroundPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="CharacterSpacing" Value="100"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="28"/>
    </Style>

    <!-- Panel Border Style. Border uses border-secondary so cards read clearly against the
         near-black page (border-primary at 1px is imperceptible on this background). -->
    <Style x:Key="NexusPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NexusBackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- Card Border Style -->
    <Style x:Key="NexusCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NexusBackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Table Header Style -->
    <Style x:Key="NexusTableHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="CharacterSpacing" Value="100"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextTertiaryBrush}"/>
    </Style>

    <!-- Table Cell Style -->
    <Style x:Key="NexusTableCellStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="CharacterSpacing" Value="25"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Progress Bar Styles -->
    <Style x:Key="NexusProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Background" Value="{ThemeResource NexusBackgroundTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusSuccessBrush}"/>
        <Setter Property="Height" Value="4"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
    </Style>

    <!-- TextBox Style -->
    <Style x:Key="NexusTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{ThemeResource NexusBackgroundTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <!-- ComboBox Style -->
    <Style x:Key="NexusComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{ThemeResource NexusBackgroundTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{ThemeResource NexusTextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource NexusMonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

</ResourceDictionary>
