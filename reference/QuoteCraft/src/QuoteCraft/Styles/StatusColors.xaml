<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Draft -->
      <Color x:Key="StatusDraftBackgroundColor">#F3F4F6</Color>
      <SolidColorBrush x:Key="StatusDraftBackgroundBrush" Color="{StaticResource StatusDraftBackgroundColor}" />
      <Color x:Key="StatusDraftForegroundColor">#6B7280</Color>
      <SolidColorBrush x:Key="StatusDraftForegroundBrush" Color="{StaticResource StatusDraftForegroundColor}" />
      <!-- Sent -->
      <Color x:Key="StatusSentBackgroundColor">#DBEAFE</Color>
      <SolidColorBrush x:Key="StatusSentBackgroundBrush" Color="{StaticResource StatusSentBackgroundColor}" />
      <Color x:Key="StatusSentForegroundColor">#1D4ED8</Color>
      <SolidColorBrush x:Key="StatusSentForegroundBrush" Color="{StaticResource StatusSentForegroundColor}" />
      <!-- Viewed -->
      <Color x:Key="StatusViewedBackgroundColor">#FEF3C7</Color>
      <SolidColorBrush x:Key="StatusViewedBackgroundBrush" Color="{StaticResource StatusViewedBackgroundColor}" />
      <Color x:Key="StatusViewedForegroundColor">#B45309</Color>
      <SolidColorBrush x:Key="StatusViewedForegroundBrush" Color="{StaticResource StatusViewedForegroundColor}" />
      <!-- Accepted -->
      <Color x:Key="StatusAcceptedBackgroundColor">#D1FAE5</Color>
      <SolidColorBrush x:Key="StatusAcceptedBackgroundBrush" Color="{StaticResource StatusAcceptedBackgroundColor}" />
      <Color x:Key="StatusAcceptedForegroundColor">#047857</Color>
      <SolidColorBrush x:Key="StatusAcceptedForegroundBrush" Color="{StaticResource StatusAcceptedForegroundColor}" />
      <!-- Declined -->
      <Color x:Key="StatusDeclinedBackgroundColor">#FEE2E2</Color>
      <SolidColorBrush x:Key="StatusDeclinedBackgroundBrush" Color="{StaticResource StatusDeclinedBackgroundColor}" />
      <Color x:Key="StatusDeclinedForegroundColor">#B91C1C</Color>
      <SolidColorBrush x:Key="StatusDeclinedForegroundBrush" Color="{StaticResource StatusDeclinedForegroundColor}" />

      <!-- Expired -->
      <Color x:Key="StatusExpiredBackgroundColor">#F3F4F6</Color>
      <SolidColorBrush x:Key="StatusExpiredBackgroundBrush" Color="{StaticResource StatusExpiredBackgroundColor}" />
      <Color x:Key="StatusExpiredForegroundColor">#9CA3AF</Color>
      <SolidColorBrush x:Key="StatusExpiredForegroundBrush" Color="{StaticResource StatusExpiredForegroundColor}" />

      <!-- Surface variant / outline for XAML pages -->
      <Color x:Key="SurfaceVariantColor">#F3F4F6</Color>
      <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
      <Color x:Key="OutlineColor">#D1D5DB</Color>
      <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <!-- Draft -->
      <Color x:Key="StatusDraftBackgroundColor">#374151</Color>
      <SolidColorBrush x:Key="StatusDraftBackgroundBrush" Color="{StaticResource StatusDraftBackgroundColor}" />
      <Color x:Key="StatusDraftForegroundColor">#9CA3AF</Color>
      <SolidColorBrush x:Key="StatusDraftForegroundBrush" Color="{StaticResource StatusDraftForegroundColor}" />
      <!-- Sent -->
      <Color x:Key="StatusSentBackgroundColor">#1E3A5F</Color>
      <SolidColorBrush x:Key="StatusSentBackgroundBrush" Color="{StaticResource StatusSentBackgroundColor}" />
      <Color x:Key="StatusSentForegroundColor">#93BBFD</Color>
      <SolidColorBrush x:Key="StatusSentForegroundBrush" Color="{StaticResource StatusSentForegroundColor}" />
      <!-- Viewed -->
      <Color x:Key="StatusViewedBackgroundColor">#422006</Color>
      <SolidColorBrush x:Key="StatusViewedBackgroundBrush" Color="{StaticResource StatusViewedBackgroundColor}" />
      <Color x:Key="StatusViewedForegroundColor">#FCD34D</Color>
      <SolidColorBrush x:Key="StatusViewedForegroundBrush" Color="{StaticResource StatusViewedForegroundColor}" />
      <!-- Accepted -->
      <Color x:Key="StatusAcceptedBackgroundColor">#064E3B</Color>
      <SolidColorBrush x:Key="StatusAcceptedBackgroundBrush" Color="{StaticResource StatusAcceptedBackgroundColor}" />
      <Color x:Key="StatusAcceptedForegroundColor">#6EE7B7</Color>
      <SolidColorBrush x:Key="StatusAcceptedForegroundBrush" Color="{StaticResource StatusAcceptedForegroundColor}" />
      <!-- Declined -->
      <Color x:Key="StatusDeclinedBackgroundColor">#450A0A</Color>
      <SolidColorBrush x:Key="StatusDeclinedBackgroundBrush" Color="{StaticResource StatusDeclinedBackgroundColor}" />
      <Color x:Key="StatusDeclinedForegroundColor">#FCA5A5</Color>
      <SolidColorBrush x:Key="StatusDeclinedForegroundBrush" Color="{StaticResource StatusDeclinedForegroundColor}" />

      <!-- Expired -->
      <Color x:Key="StatusExpiredBackgroundColor">#374151</Color>
      <SolidColorBrush x:Key="StatusExpiredBackgroundBrush" Color="{StaticResource StatusExpiredBackgroundColor}" />
      <Color x:Key="StatusExpiredForegroundColor">#6B7280</Color>
      <SolidColorBrush x:Key="StatusExpiredForegroundBrush" Color="{StaticResource StatusExpiredForegroundColor}" />

      <!-- Surface variant / outline for XAML pages -->
      <Color x:Key="SurfaceVariantColor">#374151</Color>
      <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
      <Color x:Key="OutlineColor">#4B5563</Color>
      <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
