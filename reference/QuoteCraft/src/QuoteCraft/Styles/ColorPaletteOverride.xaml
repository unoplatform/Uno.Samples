<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Primary: Slate Blue - Trust, professionalism -->
      <Color x:Key="PrimaryColor">#2B4C7E</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#D6E4F0</Color>
      <Color x:Key="OnPrimaryContainerColor">#0A1929</Color>

      <!-- Secondary: Amber - CTAs, construction energy -->
      <Color x:Key="SecondaryColor">#F59E0B</Color>
      <Color x:Key="OnSecondaryColor">#1F2937</Color>
      <Color x:Key="SecondaryContainerColor">#FEF3C7</Color>
      <Color x:Key="OnSecondaryContainerColor">#78350F</Color>

      <!-- Tertiary: Teal for accents -->
      <Color x:Key="TertiaryColor">#0D9488</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#CCFBF1</Color>
      <Color x:Key="OnTertiaryContainerColor">#134E4A</Color>

      <!-- Error -->
      <Color x:Key="ErrorColor">#DC2626</Color>
      <Color x:Key="ErrorContainerColor">#FEE2E2</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#7F1D1D</Color>

      <!-- Surface -->
      <Color x:Key="BackgroundColor">#F9FAFB</Color>
      <Color x:Key="OnBackgroundColor">#1F2937</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1F2937</Color>
      <Color x:Key="SurfaceVariantColor">#F3F4F6</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B7280</Color>
      <Color x:Key="OutlineColor">#D1D5DB</Color>
      <Color x:Key="OutlineVariantColor">#E5E7EB</Color>

      <!-- Inverse -->
      <Color x:Key="OnSurfaceInverseColor">#F3F4F6</Color>
      <Color x:Key="SurfaceInverseColor">#1F2937</Color>
      <Color x:Key="PrimaryInverseColor">#93B5E1</Color>
      <Color x:Key="SurfaceTintColor">#2B4C7E</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <!-- Primary -->
      <Color x:Key="PrimaryColor">#93B5E1</Color>
      <Color x:Key="OnPrimaryColor">#0A1929</Color>
      <Color x:Key="PrimaryContainerColor">#1E3A5F</Color>
      <Color x:Key="OnPrimaryContainerColor">#D6E4F0</Color>

      <!-- Secondary -->
      <Color x:Key="SecondaryColor">#FCD34D</Color>
      <Color x:Key="OnSecondaryColor">#78350F</Color>
      <Color x:Key="SecondaryContainerColor">#92400E</Color>
      <Color x:Key="OnSecondaryContainerColor">#FEF3C7</Color>

      <!-- Tertiary -->
      <Color x:Key="TertiaryColor">#5EEAD4</Color>
      <Color x:Key="OnTertiaryColor">#134E4A</Color>
      <Color x:Key="TertiaryContainerColor">#115E59</Color>
      <Color x:Key="OnTertiaryContainerColor">#CCFBF1</Color>

      <!-- Error -->
      <Color x:Key="ErrorColor">#FCA5A5</Color>
      <Color x:Key="ErrorContainerColor">#991B1B</Color>
      <Color x:Key="OnErrorColor">#7F1D1D</Color>
      <Color x:Key="OnErrorContainerColor">#FEE2E2</Color>

      <!-- Surface -->
      <Color x:Key="BackgroundColor">#111827</Color>
      <Color x:Key="OnBackgroundColor">#E5E7EB</Color>
      <Color x:Key="SurfaceColor">#1F2937</Color>
      <Color x:Key="OnSurfaceColor">#E5E7EB</Color>
      <Color x:Key="SurfaceVariantColor">#374151</Color>
      <Color x:Key="OnSurfaceVariantColor">#9CA3AF</Color>
      <Color x:Key="OutlineColor">#6B7280</Color>
      <Color x:Key="OutlineVariantColor">#4B5563</Color>

      <!-- Inverse -->
      <Color x:Key="OnSurfaceInverseColor">#1F2937</Color>
      <Color x:Key="SurfaceInverseColor">#E5E7EB</Color>
      <Color x:Key="PrimaryInverseColor">#2B4C7E</Color>
      <Color x:Key="SurfaceTintColor">#93B5E1</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
