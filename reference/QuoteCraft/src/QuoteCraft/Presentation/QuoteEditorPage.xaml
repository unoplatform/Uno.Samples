<Page x:Class="QuoteCraft.Presentation.QuoteEditorPage"
      x:Name="EditorRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <utu:NavigationBar>
      <utu:NavigationBar.Content>
        <mvux:FeedView Source="{Binding QuoteNumber}">
          <DataTemplate>
            <TextBlock Text="{Binding Data}"
                       Style="{StaticResource TitleMedium}" />
          </DataTemplate>
        </mvux:FeedView>
      </utu:NavigationBar.Content>
      <utu:NavigationBar.MainCommand>
        <AppBarButton Click="BackButton_Click"
                      AutomationProperties.Name="Go back" />
      </utu:NavigationBar.MainCommand>
      <utu:NavigationBar.PrimaryCommands>
        <AppBarButton Label="Save"
                      Command="{Binding Save}">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE74E;" />
          </AppBarButton.Icon>
        </AppBarButton>
      </utu:NavigationBar.PrimaryCommands>
    </utu:NavigationBar>

    <ScrollViewer Grid.Row="1">
      <utu:AutoLayout Padding="24"
                      Spacing="16"
                      Orientation="Vertical"
                      MaxWidth="700"
                      HorizontalAlignment="Stretch">

        <!-- Quote Title -->
        <TextBox Header="Quote Title"
                 Text="{Binding Title, Mode=TwoWay}"
                 PlaceholderText="e.g. Kitchen Renovation" />

        <!-- Client Name -->
        <AutoSuggestBox x:Name="ClientAutoSuggestBox"
                        Header="Client Name"
                        Text="{Binding ClientName, Mode=TwoWay}"
                        PlaceholderText="Search clients or type a name"
                        TextChanged="ClientAutoSuggest_TextChanged"
                        SuggestionChosen="ClientAutoSuggest_SuggestionChosen"
                        QueryIcon="Find"
                        AutomationProperties.Name="Client name" />

        <!-- Tax Rate -->
        <TextBox Header="Tax Rate (%)"
                 Text="{Binding TaxRate, Mode=TwoWay}"
                 PlaceholderText="13.0"
                 InputScope="Number" />

        <!-- Line Items Section -->
        <Grid utu:AutoLayout.PrimaryAlignment="Stretch"
              MinHeight="40">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock Text="Line Items"
                     Style="{StaticResource TitleMedium}"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Click="OpenCatalogBrowser_Click"
                  Style="{StaticResource MaterialTextButtonStyle}"
                  Margin="0,0,4,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon Glyph="&#xE82D;" FontSize="14" />
              <TextBlock Text="From Catalog" />
            </StackPanel>
          </Button>
          <Button Grid.Column="2"
                  Click="OpenAddLineItem_Click"
                  Style="{StaticResource MaterialTextButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon Glyph="&#xE710;" FontSize="14" />
              <TextBlock Text="Add Item" />
            </StackPanel>
          </Button>
        </Grid>

        <mvux:FeedView Source="{Binding LineItems}">
          <DataTemplate>
            <ItemsControl ItemsSource="{Binding Data}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <utu:CardContentControl Margin="0,4"
                                           Style="{StaticResource MaterialOutlinedCardContentControlStyle}"
                                           Tapped="LineItemCard_Tapped">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <utu:AutoLayout Padding="16"
                                      Spacing="8"
                                      Orientation="Vertical">
                        <TextBlock Text="{Binding Description}"
                                   Style="{StaticResource BodyLarge}" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <TextBlock Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     VerticalAlignment="Center">
                            <Run Text="Qty: " />
                            <Run Text="{Binding Quantity}" />
                            <Run Text=" x $" />
                            <Run Text="{Binding UnitPrice}" />
                          </TextBlock>

                          <TextBlock Grid.Column="1"
                                     Style="{StaticResource LabelLarge}"
                                     Foreground="{ThemeResource PrimaryBrush}"
                                     VerticalAlignment="Center"
                                     Margin="8,0">
                            <Run Text="$" />
                            <Run Text="{Binding LineTotal}" />
                          </TextBlock>
                        </Grid>
                      </utu:AutoLayout>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                  Spacing="2" Margin="0,0,8,0">
                        <Button Command="{Binding DataContext.MoveLineItemUp, ElementName=EditorRoot}"
                                CommandParameter="{Binding}"
                                AutomationProperties.Name="Move line item up"
                                Style="{StaticResource MaterialTextButtonStyle}"
                                MinWidth="48" MinHeight="48"
                                Padding="8"
                                VerticalAlignment="Center">
                          <FontIcon Glyph="&#xE70E;" FontSize="12" />
                        </Button>
                        <Button Command="{Binding DataContext.MoveLineItemDown, ElementName=EditorRoot}"
                                CommandParameter="{Binding}"
                                AutomationProperties.Name="Move line item down"
                                Style="{StaticResource MaterialTextButtonStyle}"
                                MinWidth="48" MinHeight="48"
                                Padding="8"
                                VerticalAlignment="Center">
                          <FontIcon Glyph="&#xE70D;" FontSize="12" />
                        </Button>
                      </StackPanel>
                    </Grid>
                  </utu:CardContentControl>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,24">
                <FontIcon Glyph="&#xE70F;" FontSize="32"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          HorizontalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="No line items yet"
                           Style="{StaticResource BodyLarge}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Add items from catalog or create custom entries"
                           Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Opacity="0.7" />
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>
        </mvux:FeedView>

        <!-- Photos Section -->
        <Grid utu:AutoLayout.PrimaryAlignment="Stretch"
              MinHeight="40">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="Photos"
                     Style="{StaticResource TitleMedium}"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Click="AddPhoto_Click"
                  Style="{StaticResource MaterialFilledTonalButtonStyle}"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <FontIcon Glyph="&#xE722;" FontSize="14" />
              <TextBlock Text="Add Photo" />
            </StackPanel>
          </Button>
        </Grid>

        <mvux:FeedView Source="{Binding Photos}">
          <DataTemplate>
            <muxc:ItemsRepeater ItemsSource="{Binding Data}">
              <muxc:ItemsRepeater.Layout>
                <muxc:UniformGridLayout MinItemWidth="100" MinItemHeight="100"
                                         MinColumnSpacing="8" MinRowSpacing="8" />
              </muxc:ItemsRepeater.Layout>
              <muxc:ItemsRepeater.ItemTemplate>
                <DataTemplate>
                  <Grid Width="100" Height="100">
                    <Border CornerRadius="8" BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1">
                      <Image Stretch="UniformToFill">
                        <Image.Source>
                          <BitmapImage UriSource="{Binding}" />
                        </Image.Source>
                      </Image>
                    </Border>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Command="{Binding DataContext.DeletePhoto, ElementName=EditorRoot}"
                            CommandParameter="{Binding}"
                            AutomationProperties.Name="Delete photo"
                            Background="{StaticResource ScrimBrush}" MinWidth="0" MinHeight="0"
                            Padding="4" CornerRadius="0,8,0,8" Margin="0">
                      <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{StaticResource AppBarForegroundBrush}" />
                    </Button>
                  </Grid>
                </DataTemplate>
              </muxc:ItemsRepeater.ItemTemplate>
            </muxc:ItemsRepeater>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,16">
                <FontIcon Glyph="&#xE722;" FontSize="32"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          HorizontalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="No photos attached"
                           Style="{StaticResource BodyLarge}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Add photos to document the job"
                           Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Opacity="0.7" />
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>
        </mvux:FeedView>

        <!-- Notes -->
        <TextBox Header="Notes"
                 Text="{Binding Notes, Mode=TwoWay}"
                 PlaceholderText="Additional notes for the client"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80" />

        <!-- Validation Error -->
        <mvux:FeedView Source="{Binding ValidationError}">
          <DataTemplate>
            <TextBlock Text="{Binding Data}"
                       Foreground="{ThemeResource ErrorBrush}"
                       Style="{StaticResource BodyMedium}"
                       Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}"
                       Margin="0,0,0,4" />
          </DataTemplate>
        </mvux:FeedView>

        <!-- Export PDF -->
        <Button Content="Export PDF"
                Command="{Binding ExportPdf}"
                HorizontalAlignment="Stretch"
                Style="{StaticResource MaterialFilledTonalButtonStyle}"
                Margin="0,8,0,0" />

        <!-- Status Actions -->
        <TextBlock Text="Status Actions"
                   Style="{StaticResource TitleMedium}"
                   Margin="0,8,0,0" />

        <utu:AutoLayout Spacing="8"
                        Orientation="Horizontal">
          <Button Content="Mark Sent"
                  Command="{Binding MarkSent}"
                  Style="{StaticResource MaterialOutlinedButtonStyle}" />
          <Button Content="Accepted"
                  Command="{Binding MarkAccepted}"
                  Style="{StaticResource MaterialFilledButtonStyle}" />
          <Button Content="Declined"
                  Command="{Binding MarkDeclined}"
                  Style="{StaticResource MaterialOutlinedButtonStyle}" />
        </utu:AutoLayout>

      </utu:AutoLayout>
    </ScrollViewer>
  </Grid>
</Page>
