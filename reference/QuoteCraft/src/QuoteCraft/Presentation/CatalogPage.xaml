<Page x:Class="QuoteCraft.Presentation.CatalogPage"
      x:Name="CatalogRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:helpers="using:QuoteCraft.Helpers"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- Desktop Header (64px) -->
    <Grid Padding="32,0" Height="64"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,0,1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Uid="CatalogPage.Label.Title"
                 Text="Catalog"
                 Style="{StaticResource TitleLarge}"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <mvux:FeedView Grid.Column="1" Source="{Binding CatalogItemCount}">
        <DataTemplate>
          <TextBlock Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" Margin="8,0,0,0">
            <Run Text="{Binding Data}" />
            <Run Text=" items" />
          </TextBlock>
        </DataTemplate>
      </mvux:FeedView>

      <!-- Search Bar (in header) -->
      <Border Grid.Column="2"
              Background="{ThemeResource SurfaceVariantBrush}"
              CornerRadius="8"
              Padding="12,0"
              Height="36"
              MaxWidth="360"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="16,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <FontIcon Glyph="&#xE721;" FontSize="14"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" Margin="0,0,8,0" />
          <TextBox Grid.Column="1"
                   x:Uid="CatalogPage.TextBox.Search"
                   Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Search catalog..."
                   AutomationProperties.Name="Search catalog"
                   BorderThickness="0" Background="Transparent"
                   Padding="0"
                   MinHeight="0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center" />
        </Grid>
      </Border>

      <Button Grid.Column="3"
              x:Uid="CatalogPage.Button.AddItem"
              Click="AddItem_Click"
              AutomationProperties.Name="Add catalog item"
              Style="{StaticResource AccentButtonStyle}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
          <TextBlock Text="Add Item" Foreground="{StaticResource AppBarBackgroundBrush}" Style="{StaticResource LabelLargeSemiBold}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Master-Detail -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left: Category List -->
      <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="{utu:Responsive Normal='0', Wide='0,0,1,0'}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition />
        </Grid.RowDefinitions>

        <!-- Instruction text -->
        <TextBlock
                   x:Uid="CatalogPage.Label.Instruction"
                   Text="Select a category to view and manage items"
                   Style="{StaticResource BodySmall}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   Margin="16,0,16,8" />

        <!-- Category Cards -->
        <mvux:FeedView Grid.Row="1" Source="{Binding CategoryCards}">
          <DataTemplate>
            <ScrollViewer Padding="12,4,12,16">
              <muxc:ItemsRepeater ItemsSource="{Binding Data}">
                <muxc:ItemsRepeater.Layout>
                  <muxc:UniformGridLayout MinItemWidth="156" MinItemHeight="130"
                                           MinColumnSpacing="8" MinRowSpacing="8"
                                           ItemsStretch="Fill" />
                </muxc:ItemsRepeater.Layout>
                <muxc:ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <Border x:Name="CategoryCard"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1" CornerRadius="12"
                            Padding="16"
                            Translation="0,0,0"
                            Tapped="CategoryCard_Tapped"
                            helpers:InteractionHelper.IsInteractive="True">
                      <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Icon Circle -->
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{ThemeResource PrimaryContainerBrush}"
                                HorizontalAlignment="Center">
                          <FontIcon Glyph="{Binding IconGlyph}"
                                    FontSize="18"
                                    Foreground="{ThemeResource PrimaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Name -->
                        <TextBlock Text="{Binding Name}"
                                   Style="{StaticResource TitleSmall}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <!-- Item Count -->
                        <TextBlock Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center">
                          <Run Text="{Binding ItemCount}" />
                          <Run Text=" items" />
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </muxc:ItemsRepeater.ItemTemplate>
              </muxc:ItemsRepeater>
            </ScrollViewer>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12" Padding="24">
                <FontIcon Glyph="&#xE82D;" FontSize="36"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Catalog is empty" Style="{StaticResource TitleSmall}"
                           HorizontalAlignment="Center" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Text="Add items to your pricing catalog for faster quoting."
                           Style="{StaticResource BodyMedium}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280" />
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>
        </mvux:FeedView>
      </Grid>

      <!-- Right: Category Detail (Wide only) -->
      <mvux:FeedView Grid.Column="1" Source="{Binding SelectedCategoryDetail}"
                     Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}">
        <DataTemplate>
          <ScrollViewer Padding="24,20,24,24">
            <StackPanel Spacing="16" HorizontalAlignment="Stretch">

              <!-- Category Detail Header (directly from composite detail, no nested FeedView) -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Category icon + name -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <Border Width="48" Height="48" CornerRadius="24"
                          Background="{ThemeResource PrimaryContainerBrush}">
                    <FontIcon Glyph="{Binding Data.IconGlyph}" FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Data.Name}"
                               Style="{StaticResource HeadlineMedium}"
                               TextWrapping="Wrap" MaxWidth="400" />
                    <TextBlock Style="{StaticResource BodySmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                      <Run Text="{Binding Data.Items.Count}" />
                      <Run Text=" items in this category" />
                    </TextBlock>
                  </StackPanel>
                </StackPanel>

                <!-- Add item to category button -->
                <Button Grid.Column="2"
                        x:Uid="CatalogPage.Button.AddItemToCategory"
                        Click="AddItemToCategory_Click"
                        AutomationProperties.Name="Add item to category"
                        Style="{StaticResource AccentButtonStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
                    <TextBlock Text="Add Item" Foreground="{StaticResource AppBarBackgroundBrush}" Style="{StaticResource LabelLargeSemiBold}" />
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Items List -->
              <Border Background="{ThemeResource SurfaceBrush}"
                      BorderBrush="{ThemeResource OutlineVariantBrush}"
                      BorderThickness="1" CornerRadius="12"
                      Padding="16">
                <muxc:ItemsRepeater ItemsSource="{Binding Data.Items}">
                  <muxc:ItemsRepeater.Layout>
                    <muxc:StackLayout Spacing="4" />
                  </muxc:ItemsRepeater.Layout>
                  <muxc:ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{ThemeResource BackgroundBrush}"
                              BorderBrush="{ThemeResource OutlineVariantBrush}"
                              BorderThickness="1" CornerRadius="8"
                              Padding="16,10"
                              Translation="0,0,0"
                              Tapped="CatalogItem_Tapped"
                              helpers:InteractionHelper.IsInteractive="True">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Description}"
                                     Style="{StaticResource BodyMedium}"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding UnitPrice, Converter={StaticResource CurrencyFormatConverter}}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <mvux:FeedView.NoneTemplate>
          <DataTemplate>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" Padding="32">
              <FontIcon Glyph="&#xE82D;" FontSize="48"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
              <TextBlock x:Uid="CatalogPage.Label.SelectCategory"
                         Text="Select a category" Style="{StaticResource TitleSmall}"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />
              <TextBlock x:Uid="CatalogPage.Label.SelectCategoryHint"
                         Text="Choose a category from the list to browse and manage items."
                         Style="{StaticResource BodyMedium}" HorizontalAlignment="Center"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320" />
            </StackPanel>
          </DataTemplate>
        </mvux:FeedView.NoneTemplate>
      </mvux:FeedView>
    </Grid>
  </Grid>
</Page>
