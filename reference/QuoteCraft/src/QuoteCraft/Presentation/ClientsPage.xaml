<Page x:Class="QuoteCraft.Presentation.ClientsPage"
      x:Name="ClientsRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:helpers="using:QuoteCraft.Helpers"
      xmlns:ctrl="using:QuoteCraft.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- Desktop Header (64px) -->
    <Grid Padding="32,0" Height="64"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,0,1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Uid="ClientsPage.Label.Title"
                 Text="Clients"
                 Style="{StaticResource TitleLarge}"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <mvux:FeedView Grid.Column="1" Source="{Binding ClientCount}">
        <DataTemplate>
          <TextBlock Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" Margin="8,0,0,0">
            <Run Text="{Binding Data}" />
            <Run Text=" contacts" />
          </TextBlock>
        </DataTemplate>
      </mvux:FeedView>

      <!-- Search Bar (in header) -->
      <Border Grid.Column="2"
              Background="{ThemeResource SurfaceVariantBrush}"
              CornerRadius="8"
              Padding="12,0"
              Height="36"
              MaxWidth="360"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="16,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <FontIcon Glyph="&#xE721;" FontSize="14"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" Margin="0,0,8,0" />
          <TextBox Grid.Column="1"
                   x:Uid="ClientsPage.TextBox.Search"
                   Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Search clients..."
                   AutomationProperties.Name="Search clients"
                   BorderThickness="0" Background="Transparent"
                   Padding="0"
                   MinHeight="0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center" />
        </Grid>
      </Border>

      <Button Grid.Column="3"
              x:Uid="ClientsPage.Button.AddClient"
              Click="AddClient_Click"
              AutomationProperties.Name="Add new client"
              Style="{StaticResource AccentButtonStyle}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
          <TextBlock Text="Add Client" Foreground="{StaticResource AppBarBackgroundBrush}" Style="{StaticResource LabelLargeSemiBold}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Analytics Cards -->
    <mvux:FeedView Grid.Row="1" Source="{Binding Analytics}">
      <DataTemplate>
        <Grid Padding="32,12" ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Total Clients -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <StackPanel Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="TOTAL CLIENTS" Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="{Binding Data.TotalClients}"
                           Style="{StaticResource HeadlineSmallBold}" />
                <TextBlock Text="contacts" Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,2" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Total Revenue -->
          <Border Grid.Column="1"
                  Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <StackPanel Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="ACCEPTED REVENUE" Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Data.TotalRevenue, Converter={StaticResource CurrencyFormatConverter}}"
                         Style="{StaticResource HeadlineSmallBold}"
                         FontFamily="{StaticResource MonospaceFontFamily}" />
            </StackPanel>
          </Border>

          <!-- Avg per Client -->
          <Border Grid.Column="2"
                  Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <StackPanel Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="AVG PER CLIENT" Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Data.AvgPerClient, Converter={StaticResource CurrencyFormatConverter}}"
                         Style="{StaticResource HeadlineSmallBold}"
                         FontFamily="{StaticResource MonospaceFontFamily}" />
            </StackPanel>
          </Border>
        </Grid>
      </DataTemplate>

      <mvux:FeedView.NoneTemplate>
        <DataTemplate>
          <Border Height="0" />
        </DataTemplate>
      </mvux:FeedView.NoneTemplate>
    </mvux:FeedView>

    <!-- Master-Detail -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left: Client List -->
      <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="{utu:Responsive Normal='0', Wide='0,0,1,0'}">
        <!-- Client Cards -->
        <mvux:FeedView Source="{Binding Clients}">
          <DataTemplate>
            <ScrollViewer Padding="12,8,12,16">
              <muxc:ItemsRepeater ItemsSource="{Binding Data}"
                                  utu:CommandExtensions.Command="{Binding Parent.SelectClient}">
                <muxc:ItemsRepeater.Layout>
                  <muxc:StackLayout Spacing="4" />
                </muxc:ItemsRepeater.Layout>
                <muxc:ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12"
                            Translation="0,0,0"
                            AutomationProperties.Name="{Binding Name}"
                            helpers:InteractionHelper.IsInteractive="True">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{ThemeResource PrimaryContainerBrush}"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                          <TextBlock Text="{Binding Initials}" Style="{StaticResource LabelLarge}"
                                     Foreground="{ThemeResource PrimaryBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding Name}" Style="{StaticResource BodyMedium}"
                                     FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}">
                            <Run Text="{Binding QuoteCount}" />
                            <Run Text="{Binding QuoteCount, Converter={StaticResource PluralConverter}, ConverterParameter=quote}" />
                            <Run Text=" · " />
                            <Run Text="{Binding City}" />
                          </TextBlock>
                        </StackPanel>

                        <!-- Value -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Right" Spacing="0">
                          <TextBlock Text="{Binding TotalValue, Converter={StaticResource CurrencyFormatConverter}}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource BodySmallSemiBold}"
                                     HorizontalAlignment="Right" />
                          <TextBlock Text="total" Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     HorizontalAlignment="Right" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </muxc:ItemsRepeater.ItemTemplate>
              </muxc:ItemsRepeater>
            </ScrollViewer>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12" Padding="24">
                <FontIcon Glyph="&#xE77B;" FontSize="36"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="No clients yet" Style="{StaticResource TitleSmall}"
                           HorizontalAlignment="Center" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Text="Add your first client to start quoting."
                           Style="{StaticResource BodyMedium}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <Button Click="AddClient_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,8,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
                    <TextBlock Text="Add Client" Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>
        </mvux:FeedView>
      </Grid>

      <!-- Right: Client Detail (Wide only) -->
      <mvux:FeedView Grid.Column="1" Source="{Binding SelectedClientDetail}"
                     Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}">
        <DataTemplate>
          <ScrollViewer Padding="36,28,36,32">
            <StackPanel Spacing="20" HorizontalAlignment="Stretch">

              <!-- Name + Actions -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Data.Client.Name}"
                           Style="{StaticResource HeadlineMedium}" />
                <Button Grid.Column="1"
                        Click="EditClient_Click"
                        AutomationProperties.Name="Edit client"
                        Style="{StaticResource MaterialOutlinedButtonStyle}"
                        CornerRadius="8" Margin="0,0,8,0">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE70F;" FontSize="14" />
                    <TextBlock Text="Edit" />
                  </StackPanel>
                </Button>

                <!-- Delete -->
                <Button Grid.Column="2"
                        Click="DeleteClient_Click"
                        AutomationProperties.Name="Delete client"
                        Style="{StaticResource MaterialOutlinedButtonStyle}"
                        BorderBrush="{ThemeResource ErrorBrush}"
                        CornerRadius="8" Margin="0,0,8,0">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"
                              Foreground="{ThemeResource ErrorBrush}" />
                    <TextBlock Text="Delete"
                               Foreground="{ThemeResource ErrorBrush}" />
                  </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Click="NewQuoteForClient_Click"
                        AutomationProperties.Name="Create new quote for client"
                        Style="{StaticResource AccentButtonStyle}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
                    <TextBlock Text="New Quote" Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Contact Info -->
              <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <FontIcon Glyph="&#xE715;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <TextBlock Text="{Binding Data.Client.Entity.Email}" Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <FontIcon Glyph="&#xE717;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <TextBlock Text="{Binding Data.Client.Entity.Phone}" Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <FontIcon Glyph="&#xE707;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <TextBlock Text="{Binding Data.Client.Entity.Address}" Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </StackPanel>

              <!-- Quote History + Summary -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- Quote History -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineVariantBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16"
                        Margin="0,0,24,0"
                        Translation="0,0,8">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold">
                      <Run Text="QUOTE HISTORY (" />
                      <Run Text="{Binding Data.Client.QuoteCount}" />
                      <Run Text=")" />
                    </TextBlock>

                    <!-- Quotes list (directly from composite detail, no nested FeedView) -->
                    <muxc:ItemsRepeater ItemsSource="{Binding Data.Quotes}">
                      <muxc:ItemsRepeater.Layout>
                        <muxc:StackLayout Spacing="0" />
                      </muxc:ItemsRepeater.Layout>
                      <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <Grid Padding="0,10"
                                BorderBrush="{ThemeResource OutlineVariantBrush}"
                                BorderThickness="0,0,0,1"
                                Tapped="QuoteRow_Tapped"
                                Background="Transparent">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Title}" Style="{StaticResource BodyMedium}" />
                              <TextBlock Style="{StaticResource BodySmall}"
                                         Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                <Run Text="{Binding QuoteNumber}" />
                                <Run Text=" · " />
                                <Run Text="{Binding CreatedAt, Converter={StaticResource RelativeDateConverter}}" />
                              </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Total, Converter={StaticResource CurrencyFormatConverter}}"
                                       FontFamily="{StaticResource MonospaceFontFamily}"
                                       Style="{StaticResource BodyMediumSemiBold}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Border Grid.Column="2"
                                    Background="{Binding Status, Converter={StaticResource StatusBackgroundConverter}}"
                                    CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="{Binding Status, Converter={StaticResource StatusIconConverter}}" FontSize="10"
                                          Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}" />
                                <TextBlock Text="{Binding Status}" Style="{StaticResource LabelSmall}"
                                           Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}" />
                              </StackPanel>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </muxc:ItemsRepeater.ItemTemplate>
                    </muxc:ItemsRepeater>
                  </StackPanel>
                </Border>

                <!-- Summary -->
                <Border Grid.Column="1"
                        Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineVariantBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16"
                        VerticalAlignment="Top"
                        Translation="0,0,8">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel Spacing="12">
                    <TextBlock Text="SUMMARY" Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Total Quotes" Style="{StaticResource BodySmall}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                      <TextBlock Grid.Column="1" Text="{Binding Data.Client.QuoteCount}" Style="{StaticResource BodySmall}" />
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Total Value" Style="{StaticResource BodySmall}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Data.Client.TotalValue, Converter={StaticResource CurrencyFormatConverter}}"
                                 FontFamily="{StaticResource MonospaceFontFamily}"
                                 Style="{StaticResource BodySmallSemiBold}" />
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <mvux:FeedView.NoneTemplate>
          <DataTemplate>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" Padding="32">
              <FontIcon Glyph="&#xE77B;" FontSize="48"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
              <TextBlock Text="Select a client" Style="{StaticResource TitleSmall}"
                         HorizontalAlignment="Center"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />
              <TextBlock Text="Choose a client from the list to view their details and quote history."
                         Style="{StaticResource BodyMedium}" HorizontalAlignment="Center"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320" />
            </StackPanel>
          </DataTemplate>
        </mvux:FeedView.NoneTemplate>
      </mvux:FeedView>
    </Grid>
  </Grid>
</Page>
