<Page x:Class="QuoteCraft.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid uen:Region.Attached="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Offline Banner -->
    <Border x:Name="OfflineBanner"
            Grid.Row="0" Grid.ColumnSpan="2"
            Background="{ThemeResource ErrorContainerBrush}"
            Padding="12,8"
            Visibility="Collapsed">
      <StackPanel Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
        <FontIcon Glyph="&#xEB5E;" FontSize="14"
                  Foreground="{ThemeResource OnErrorContainerBrush}" />
        <TextBlock Text="You're offline. Quotes will sync when connected."
                   Style="{StaticResource BodySmall}"
                   Foreground="{ThemeResource OnErrorContainerBrush}" />
      </StackPanel>
    </Border>

    <!-- Content region -->
    <Grid x:Name="NavigationGrid"
          Grid.Row="1"
          Grid.Column="1"
          uen:Region.Attached="True"
          uen:Region.Navigator="Visibility" />

    <!-- Notifications overlay panel (not routed — avoids navigation issues) -->
    <Grid x:Name="NotificationsOverlay"
          Grid.Row="0" Grid.RowSpan="3"
          Grid.Column="1"
          Background="{ThemeResource BackgroundBrush}"
          Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>

      <!-- Header -->
      <Grid Padding="16,0" Height="64"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button x:Name="NotifBackButton"
                Click="NotifBack_Click"
                Style="{StaticResource MaterialTextButtonStyle}"
                AutomationProperties.Name="Go back"
                VerticalAlignment="Center">
          <FontIcon Glyph="&#xE72B;" FontSize="18" />
        </Button>

        <TextBlock Grid.Column="1" Text="Notifications"
                   Style="{StaticResource TitleLarge}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0" />

        <Button Grid.Column="2"
                x:Name="MarkAllReadButton"
                Click="MarkAllRead_Click"
                Style="{StaticResource MaterialTextButtonStyle}"
                AutomationProperties.Name="Mark all as read"
                VerticalAlignment="Center">
          <TextBlock Text="Mark all read"
                     Style="{StaticResource BodySmall}"
                     Foreground="{ThemeResource PrimaryBrush}" />
        </Button>
      </Grid>

      <!-- Notification List -->
      <ListView x:Name="NotificationsList"
                Grid.Row="1"
                SelectionMode="None"
                Padding="0,8">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="20,16" Margin="0,0,0,1"
                  Background="{ThemeResource SurfaceBrush}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Ellipse Width="8" Height="8"
                       Fill="{ThemeResource PrimaryBrush}"
                       VerticalAlignment="Top" Margin="0,6,12,0"
                       Visibility="{Binding IsRead, Converter={StaticResource InverseBoolConverter}}" />

              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource BodyMedium}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Message}"
                           Style="{StaticResource BodySmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextWrapping="Wrap" MaxLines="2" />
              </StackPanel>

              <TextBlock Grid.Column="2"
                         Text="{Binding CreatedAt, Converter={StaticResource RelativeDateConverter}}"
                         Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Top" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <!-- Empty state -->
      <StackPanel x:Name="NotifEmptyState"
                  Grid.Row="1"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Spacing="12" Padding="32"
                  Visibility="Collapsed">
        <FontIcon Glyph="&#xEA8F;" FontSize="48"
                  Foreground="{ThemeResource OnSurfaceVariantBrush}" Opacity="0.5"
                  HorizontalAlignment="Center" />
        <TextBlock Text="No notifications yet"
                   Style="{StaticResource BodyMedium}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Grid>

    <!-- Bottom TabBar (narrow/normal screens) -->
    <utu:TabBar x:Name="BottomTabs"
                Grid.Row="2"
                Grid.Column="1"
                Height="48"
                Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}"
                uen:Region.Attached="True"
                Style="{StaticResource BottomTabBarStyle}">
      <utu:TabBarItem uen:Region.Name="Dashboard"
                      Content="Quotes"
                      IsSelectable="True"
                      Style="{StaticResource MaterialBottomTabBarItemStyle}">
        <utu:TabBarItem.Icon>
          <FontIcon Glyph="&#xE8A5;" />
        </utu:TabBarItem.Icon>
      </utu:TabBarItem>

      <utu:TabBarItem uen:Region.Name="Clients"
                      Content="Clients"
                      IsSelectable="True"
                      Style="{StaticResource MaterialBottomTabBarItemStyle}">
        <utu:TabBarItem.Icon>
          <FontIcon Glyph="&#xE77B;" />
        </utu:TabBarItem.Icon>
      </utu:TabBarItem>

      <utu:TabBarItem uen:Region.Name="Catalog"
                      Content="Catalog"
                      IsSelectable="True"
                      Style="{StaticResource MaterialBottomTabBarItemStyle}">
        <utu:TabBarItem.Icon>
          <FontIcon Glyph="&#xE7BF;" />
        </utu:TabBarItem.Icon>
      </utu:TabBarItem>

      <utu:TabBarItem uen:Region.Name="Settings"
                      Content="Settings"
                      IsSelectable="True"
                      Style="{StaticResource MaterialBottomTabBarItemStyle}">
        <utu:TabBarItem.Icon>
          <FontIcon Glyph="&#xE115;" />
        </utu:TabBarItem.Icon>
      </utu:TabBarItem>
    </utu:TabBar>

    <!-- Side rail (wide/desktop screens) -->
    <Grid x:Name="SideRail" ColumnDefinitions="*" Grid.RowSpan="3"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,1,0"
          Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}"
          Width="156">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Brand Header -->
      <Border Background="{StaticResource AppBarBackgroundBrush}"
              Height="61" HorizontalAlignment="Stretch">
        <Grid>
          <StackPanel x:Name="BrandFull" Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="QC"
                       Foreground="{StaticResource AppBarForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="18" />
            <TextBlock x:Name="BrandLabel" Text="QuoteCraft"
                       Foreground="{StaticResource AppBarForegroundBrush}"
                       FontWeight="Medium"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Opacity="0.85" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- 3px Amber accent bar -->
      <Border Grid.Row="1" Height="3"
              Background="{StaticResource AppBarAccentBrush}" />

      <!-- Tab items - horizontal icon + label, stacked vertically -->
      <utu:TabBar HorizontalAlignment="Stretch" Grid.Row="2"
                  VerticalAlignment="Top"
                  Margin="0,8,0,0"
                  uen:Region.Attached="True"
                  Style="{StaticResource VerticalTabBarStyle}">
        <utu:TabBar.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Vertical" Spacing="2" />
          </ItemsPanelTemplate>
        </utu:TabBar.ItemsPanel>

        <utu:TabBarItem uen:Region.Name="Dashboard"
                        Content="Quotes"
                        IsSelectable="True"
                        Style="{StaticResource SideNavTabBarItemStyle}">
          <utu:TabBarItem.Icon>
            <FontIcon Glyph="&#xE8A5;" FontSize="18" />
          </utu:TabBarItem.Icon>
        </utu:TabBarItem>

        <utu:TabBarItem uen:Region.Name="Clients"
                        Content="Clients"
                        IsSelectable="True"
                        Style="{StaticResource SideNavTabBarItemStyle}">
          <utu:TabBarItem.Icon>
            <FontIcon Glyph="&#xE77B;" FontSize="18" />
          </utu:TabBarItem.Icon>
        </utu:TabBarItem>

        <utu:TabBarItem uen:Region.Name="Catalog"
                        Content="Catalog"
                        IsSelectable="True"
                        Style="{StaticResource SideNavTabBarItemStyle}">
          <utu:TabBarItem.Icon>
            <FontIcon Glyph="&#xE7BF;" FontSize="18" />
          </utu:TabBarItem.Icon>
        </utu:TabBarItem>

        <utu:TabBarItem uen:Region.Name="Settings"
                        Content="Settings"
                        IsSelectable="True"
                        Style="{StaticResource SideNavTabBarItemStyle}">
          <utu:TabBarItem.Icon>
            <FontIcon Glyph="&#xE115;" FontSize="18" />
          </utu:TabBarItem.Icon>
        </utu:TabBarItem>
      </utu:TabBar>

      <!-- Bottom actions: Notifications, Theme, Collapse -->
      <StackPanel Grid.Row="3" Spacing="0">
        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" Margin="12,0" />
        <Button Click="Notifications_Click"
                Margin="6,8,6,0"
                HorizontalAlignment="Stretch"
                Style="{StaticResource MaterialTextButtonStyle}"
                AutomationProperties.Name="Open notifications">
          <Grid>
            <StackPanel Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Center">
              <FontIcon Glyph="&#xEA8F;" FontSize="16" />
              <TextBlock x:Name="NotifLabel" Text="Notifications" Style="{StaticResource BodySmall}" />
            </StackPanel>
            <!-- Unread badge -->
            <mvux:FeedView Source="{Binding UnreadNotificationCount}"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           Margin="4,-4,0,0">
              <DataTemplate>
                <Border Background="{ThemeResource ErrorBrush}"
                        CornerRadius="8" MinWidth="16" Height="16"
                        Padding="4,0"
                        Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}"
                        HorizontalAlignment="Left">
                  <TextBlock Text="{Binding Data}"
                             Style="{StaticResource LabelSmall}"
                             Foreground="{ThemeResource OnErrorBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </DataTemplate>
            </mvux:FeedView>
          </Grid>
        </Button>
        <Button x:Name="ThemeToggle"
                Margin="6,8,6,0"
                HorizontalAlignment="Stretch"
                Click="ThemeToggle_Click"
                Style="{StaticResource MaterialTextButtonStyle}"
                AutomationProperties.Name="Toggle dark mode">
          <StackPanel Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Center">
            <FontIcon x:Name="ThemeIcon" Glyph="&#xE708;" FontSize="16" />
            <TextBlock x:Name="ThemeLabel" Text="Dark Mode" Style="{StaticResource BodySmall}" />
          </StackPanel>
        </Button>

        <!-- Collapse / Expand toggle -->
        <Button x:Name="CollapseToggle"
                Margin="6,4,6,12"
                HorizontalAlignment="Stretch"
                Click="CollapseToggle_Click"
                Style="{StaticResource MaterialTextButtonStyle}"
                AutomationProperties.Name="Collapse sidebar">
          <StackPanel Orientation="Horizontal" Spacing="8"
                      HorizontalAlignment="Center">
            <FontIcon x:Name="CollapseIcon" Glyph="&#xE76B;" FontSize="14" />
            <TextBlock x:Name="CollapseLabel" Text="Collapse" Style="{StaticResource BodySmall}" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>
  </Grid>
</Page>