<ContentDialog x:Class="QuoteCraft.Presentation.CatalogBrowserDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
               CloseButtonText="Done"
               DefaultButton="Close">

  <StackPanel Spacing="12" MinWidth="400" MinHeight="300">

    <!-- Gradient Header Banner -->
    <Border x:Name="HeaderBanner" CornerRadius="12" Padding="20,16" Margin="0,0,0,4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon x:Name="HeaderIcon" Glyph="&#xE82D;" FontSize="20"
                  VerticalAlignment="Center" Margin="0,0,12,0" />
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock x:Name="HeaderTitle" Text="Add from Catalog"
                     Style="{StaticResource TitleMediumBold}" />
          <TextBlock x:Name="HeaderSubtitle"
                     Text="Browse your saved items and add to this quote"
                     Style="{StaticResource BodySmall}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Search Box -->
    <Border Background="{ThemeResource SurfaceVariantBrush}"
            CornerRadius="8" Padding="12,0" Height="36">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon Glyph="&#xE721;" FontSize="14"
                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                  VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBox x:Name="SearchBox" Grid.Column="1"
                 PlaceholderText="Search catalog..."
                 BorderThickness="0" Background="{x:Null}"
                 Padding="0" MinHeight="0"
                 VerticalAlignment="Center"
                 TextChanged="SearchBox_TextChanged" />
      </Grid>
    </Border>

    <!-- Category Chips -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Enabled" MaxHeight="36">
      <StackPanel x:Name="CategoryChips"
                  Orientation="Horizontal" Spacing="6" />
    </ScrollViewer>

    <!-- Items List -->
    <ScrollViewer MaxHeight="320">
      <muxc:ItemsRepeater x:Name="CatalogItemsList">
        <muxc:ItemsRepeater.Layout>
          <muxc:StackLayout Spacing="4" />
        </muxc:ItemsRepeater.Layout>
        <muxc:ItemsRepeater.ItemTemplate>
          <DataTemplate>
            <Border Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="12,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding Description}"
                             Style="{StaticResource BodyMedium}" />
                  <TextBlock Text="{Binding Category}"
                             Style="{StaticResource LabelSmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding UnitPrice, Converter={StaticResource CurrencyFormatConverter}}"
                           FontFamily="{StaticResource MonospaceFontFamily}"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Grid.Column="2" Click="AddItem_Click"
                        Style="{StaticResource MaterialTextButtonStyle}"
                        Padding="8,4" MinWidth="0" MinHeight="0">
                  <FontIcon Glyph="&#xE710;" FontSize="16" />
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </muxc:ItemsRepeater.ItemTemplate>
      </muxc:ItemsRepeater>
    </ScrollViewer>

  </StackPanel>
</ContentDialog>
