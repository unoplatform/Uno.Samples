<Page x:Class="QuoteCraft.Presentation.OnboardingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top,Bottom">

    <!-- Step container -->
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
          MaxWidth="520" Padding="32">

      <!-- Step 1: Welcome -->
      <StackPanel Spacing="24" HorizontalAlignment="Center"
                  Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=1}">
        <!-- Logo badge -->
        <Border Width="80" Height="80" CornerRadius="16"
                Background="{StaticResource AppBarBackgroundBrush}"
                HorizontalAlignment="Center"
                Translation="0,0,16">
          <Border.Shadow>
            <ThemeShadow />
          </Border.Shadow>
          <TextBlock Text="QC" Foreground="{StaticResource AppBarForegroundBrush}"
                     Style="{StaticResource HeadlineMediumBold}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Welcome to QuoteCraft"
                   Style="{StaticResource HeadlineMediumBold}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Set up your business in 60 seconds and start sending professional quotes today."
                   Style="{StaticResource BodyLarge}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   TextAlignment="Center" TextWrapping="Wrap"
                   HorizontalAlignment="Center" MaxWidth="400" />

        <Button Command="{Binding NextStep}"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Center"
                Padding="32,12" Margin="0,8,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Get Started" FontWeight="SemiBold"
                       Foreground="{StaticResource AppBarBackgroundBrush}" />
            <FontIcon Glyph="&#xE72A;" FontSize="14"
                      Foreground="{StaticResource AppBarBackgroundBrush}" />
          </StackPanel>
        </Button>

        <Button Command="{Binding Skip}"
                Style="{StaticResource MaterialTextButtonStyle}"
                HorizontalAlignment="Center"
                Content="Skip for now" />
      </StackPanel>

      <!-- Step 2: Business Info -->
      <StackPanel Spacing="20"
                  Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=2}">
        <StackPanel Spacing="4">
          <TextBlock Text="Your Business"
                     Style="{StaticResource TitleLargeBold}" />
          <TextBlock Text="This info appears on every quote you send."
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </StackPanel>

        <!-- Progress: Step 1 of 3 -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{StaticResource AppBarAccentBrush}" />
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{ThemeResource OutlineVariantBrush}" />
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{ThemeResource OutlineVariantBrush}" />
        </StackPanel>

        <TextBox Header="Business Name"
                 Text="{Binding BusinessName, Mode=TwoWay}"
                 PlaceholderText="e.g. Smith Plumbing LLC" />
        <TextBox Header="Phone"
                 Text="{Binding Phone, Mode=TwoWay}"
                 PlaceholderText="(555) 123-4567"
                 InputScope="TelephoneNumber" />
        <TextBox Header="Email"
                 Text="{Binding Email, Mode=TwoWay}"
                 PlaceholderText="you@yourbusiness.com"
                 InputScope="EmailSmtpAddress" />
        <TextBox Header="Address (optional)"
                 Text="{Binding Address, Mode=TwoWay}"
                 PlaceholderText="123 Trade St, Anytown USA" />

        <!-- Validation Error -->
        <mvux:FeedView Source="{Binding ValidationError}">
          <DataTemplate>
            <TextBlock Text="{Binding Data}"
                       Foreground="{ThemeResource ErrorBrush}"
                       Style="{StaticResource BodySmall}"
                       Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}" />
          </DataTemplate>
        </mvux:FeedView>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Button Command="{Binding PreviousStep}"
                  Style="{StaticResource MaterialOutlinedButtonStyle}"
                  CornerRadius="8" Content="Back" />
          <Button Grid.Column="1" Command="{Binding NextStep}"
                  Style="{StaticResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Next" FontWeight="SemiBold"
                         Foreground="{StaticResource AppBarBackgroundBrush}" />
              <FontIcon Glyph="&#xE72A;" FontSize="14"
                        Foreground="{StaticResource AppBarBackgroundBrush}" />
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>

      <!-- Step 3: Quote Settings -->
      <StackPanel Spacing="20"
                  Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=3}">
        <StackPanel Spacing="4">
          <TextBlock Text="Quote Settings"
                     Style="{StaticResource TitleLargeBold}" />
          <TextBlock Text="Set your defaults. You can change these anytime in Settings."
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </StackPanel>

        <!-- Progress: Step 2 of 3 -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{StaticResource AppBarAccentBrush}" />
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{StaticResource AppBarAccentBrush}" />
          <Border Width="40" Height="4" CornerRadius="2"
                  Background="{ThemeResource OutlineVariantBrush}" />
        </StackPanel>

        <Grid ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBox Header="Default Tax Rate (%)"
                   Text="{Binding TaxRate, Mode=TwoWay}"
                   InputScope="Number" />
          <TextBox Grid.Column="1"
                   Header="Quote Valid For (days)"
                   Text="{Binding ValidDays, Mode=TwoWay}"
                   InputScope="Number" />
        </Grid>

        <TextBox Header="Quote Number Prefix"
                 Text="{Binding QuotePrefix, Mode=TwoWay}"
                 PlaceholderText="QC-" />

        <!-- Catalog note -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                CornerRadius="8" Padding="16,12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE82D;" FontSize="18"
                      Foreground="{ThemeResource PrimaryBrush}"
                      VerticalAlignment="Top" />
            <StackPanel Spacing="4">
              <TextBlock Text="Pre-loaded catalog"
                         Style="{StaticResource BodyMediumSemiBold}" />
              <TextBlock Text="We've loaded a Plumbing catalog with suggested prices. Review and adjust them in the Catalog tab to match your market rates."
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Validation Error -->
        <mvux:FeedView Source="{Binding ValidationError}">
          <DataTemplate>
            <TextBlock Text="{Binding Data}"
                       Foreground="{ThemeResource ErrorBrush}"
                       Style="{StaticResource BodySmall}"
                       Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}" />
          </DataTemplate>
        </mvux:FeedView>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Button Command="{Binding PreviousStep}"
                  Style="{StaticResource MaterialOutlinedButtonStyle}"
                  CornerRadius="8" Content="Back" />
          <Button Grid.Column="1" Command="{Binding Complete}"
                  Style="{StaticResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Create First Quote" FontWeight="SemiBold"
                         Foreground="{StaticResource AppBarBackgroundBrush}" />
              <FontIcon Glyph="&#xE710;" FontSize="14"
                        Foreground="{StaticResource AppBarBackgroundBrush}" />
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Grid>
  </Grid>
</Page>
