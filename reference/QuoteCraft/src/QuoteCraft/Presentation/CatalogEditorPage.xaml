<Page x:Class="QuoteCraft.Presentation.CatalogEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- Custom App Bar -->
    <Grid Background="{StaticResource AppBarBackgroundBrush}"
          Padding="20,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button uen:Navigation.Request="-"
              AutomationProperties.Name="Go back"
              Style="{StaticResource AppBarPillButtonStyle}"
              Padding="8"
              MinWidth="48"
              MinHeight="48">
        <FontIcon Glyph="&#xE72B;"
                  FontSize="16"
                  Foreground="{StaticResource AppBarForegroundBrush}" />
      </Button>

      <TextBlock Grid.Column="1"
                 Text="Edit Item"
                 Style="{StaticResource TitleLarge}"
                 Foreground="{StaticResource AppBarForegroundBrush}"
                 VerticalAlignment="Center"
                 Margin="12,0,0,0" />

      <Button Grid.Column="2"
              Command="{Binding Save}"
              Style="{StaticResource AppBarPillButtonStyle}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE74E;"
                    FontSize="14"
                    Foreground="{StaticResource AppBarForegroundBrush}" />
          <TextBlock Text="Save"
                     Foreground="{StaticResource AppBarForegroundBrush}"
                     Style="{StaticResource LabelLarge}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Amber Accent Bar -->
    <Border Grid.Row="1"
            Height="3"
            Background="{StaticResource AppBarAccentBrush}" />

    <!-- Editor Form -->
    <ScrollViewer Grid.Row="2">
      <utu:AutoLayout Padding="24"
                      Spacing="16"
                      Orientation="Vertical"
                      MaxWidth="600"
                      HorizontalAlignment="Stretch">

        <TextBox Header="Description"
                 Text="{Binding Description, Mode=TwoWay}"
                 PlaceholderText="Item description" />

        <TextBox Header="Unit Price"
                 Text="{Binding UnitPrice, Mode=TwoWay}"
                 PlaceholderText="0.00"
                 InputScope="Number" />

        <TextBox Header="Category"
                 Text="{Binding Category, Mode=TwoWay}"
                 PlaceholderText="e.g. Installations, Repairs, Materials, Labor" />

        <mvux:FeedView Source="{Binding ValidationError}"
                       xmlns:mvux="using:Uno.Extensions.Reactive.UI">
          <DataTemplate>
            <TextBlock Text="{Binding Data}"
                       Foreground="{ThemeResource ErrorBrush}"
                       Style="{StaticResource BodyMedium}"
                       Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}"
                       Margin="0,0,0,4" />
          </DataTemplate>
        </mvux:FeedView>

        <Button Content="Delete Item"
                Command="{Binding Delete}"
                HorizontalAlignment="Stretch"
                Foreground="{ThemeResource ErrorBrush}"
                Style="{StaticResource MaterialOutlinedButtonStyle}"
                Margin="0,16,0,0" />

      </utu:AutoLayout>
    </ScrollViewer>
  </Grid>
</Page>
