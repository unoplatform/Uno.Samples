<Page x:Class="QuoteCraft.Presentation.DashboardPage"
      x:Name="DashboardRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:QuoteCraft.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:helpers="using:QuoteCraft.Helpers"
      xmlns:ctrl="using:QuoteCraft.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- Desktop Header (64px) -->
    <Grid Padding="32,0" Height="64"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,0,1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Uid="DashboardPage.Label.Title"
                 Text="Quotes"
                 Style="{StaticResource TitleLarge}"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <mvux:FeedView Grid.Column="1" Source="{Binding TotalCount}">
        <DataTemplate>
          <TextBlock Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center"
                     Margin="8,0,0,0">
            <Run Text="{Binding Data}" />
            <Run Text=" total" />
          </TextBlock>
        </DataTemplate>
      </mvux:FeedView>

      <!-- Search Bar (in header) -->
      <Border Grid.Column="2"
              Background="{ThemeResource SurfaceVariantBrush}"
              CornerRadius="8"
              Padding="12,0"
              Height="36"
              MaxWidth="360"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="16,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <FontIcon Glyph="&#xE721;" FontSize="14"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" Margin="0,0,8,0" />
          <TextBox Grid.Column="1"
                   x:Uid="DashboardPage.TextBox.Search"
                   Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Search quotes..."
                   AutomationProperties.Name="Search quotes"
                   BorderThickness="0" Background="Transparent"
                   Padding="0"
                   MinHeight="0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center" />
        </Grid>
      </Border>

      <Button Grid.Column="3"
              x:Uid="DashboardPage.Button.NewQuote"
              Click="CreateQuote_Click"
              AutomationProperties.Name="Create new quote"
              Style="{StaticResource AccentButtonStyle}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
          <TextBlock Text="New Quote" Foreground="{StaticResource AppBarBackgroundBrush}" Style="{StaticResource LabelLargeSemiBold}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Upgrade Prompt Banner (shown when feature gate blocks an action) -->
    <mvux:FeedView Grid.Row="1" Source="{Binding UpgradeMessage}">
      <DataTemplate>
        <Border Background="{StaticResource AppBarBackgroundBrush}"
                Padding="16,12" Margin="0"
                Visibility="{Binding Data, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="{StaticResource AppBarForegroundBrush}"
                      VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Grid.Column="1" Text="{Binding Data}"
                       Style="{StaticResource BodyMedium}" Foreground="{StaticResource AppBarForegroundBrush}"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
            <Button Grid.Column="2"
                    Style="{StaticResource AccentButtonStyle}"
                    Margin="12,0,8,0"
                    Padding="16,6">
              <TextBlock Text="Upgrade" FontWeight="SemiBold" Foreground="{StaticResource AppBarBackgroundBrush}" />
            </Button>
            <Button Grid.Column="3"
                    Command="{Binding DismissUpgrade}"
                    Background="Transparent" BorderThickness="0"
                    MinWidth="0" MinHeight="0" Padding="4">
              <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{StaticResource AppBarForegroundBrush}" />
            </Button>
          </Grid>
        </Border>
      </DataTemplate>
      <mvux:FeedView.NoneTemplate>
        <DataTemplate>
          <Border Height="0" />
        </DataTemplate>
      </mvux:FeedView.NoneTemplate>
    </mvux:FeedView>

    <!-- Analytics Cards -->
    <mvux:FeedView Grid.Row="2" Source="{Binding Analytics}">
      <DataTemplate>
        <Grid Padding="32,12" ColumnSpacing="16"
              Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Total Quoted (Wide) -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="QUOTED THIS MONTH" Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Data.TotalQuotedThisMonth, Converter={StaticResource CurrencyFormatConverter}}"
                           Style="{StaticResource HeadlineSmallBold}"
                           FontFamily="{StaticResource MonospaceFontFamily}" />
              </StackPanel>
              <ctrl:SparklineControl Grid.Column="1" Height="50" Margin="12,0,0,0"
                                      Values="{Binding Data.QuotedDailyValues}"
                                      StrokeColor="{StaticResource AppBarButtonBackgroundBrush}" />
            </Grid>
          </Border>

          <!-- Quotes Sent (Wide) -->
          <Border Grid.Column="1"
                  Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="SENT THIS MONTH" Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Data.QuotesSentThisMonth}"
                             Style="{StaticResource HeadlineSmallBold}" />
                  <TextBlock Text="quotes" Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             VerticalAlignment="Bottom" Margin="0,0,0,2" />
                </StackPanel>
              </StackPanel>
              <ctrl:SparklineControl Grid.Column="1" Height="50" Margin="12,0,0,0"
                                      Values="{Binding Data.SentDailyValues}"
                                      StrokeColor="{StaticResource AppBarAccentBrush}" />
            </Grid>
          </Border>

          <!-- Acceptance Rate (Wide) -->
          <Border Grid.Column="2"
                  Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="ACCEPTANCE RATE" Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <TextBlock Text="{Binding Data.AcceptanceRate}"
                             Style="{StaticResource HeadlineSmallBold}" />
                  <TextBlock Text="%" Style="{StaticResource HeadlineSmallBold}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </StackPanel>
              <ctrl:SparklineControl Grid.Column="1" Height="50" Margin="12,0,0,0"
                                      Values="{Binding Data.AcceptanceDailyValues}"
                                      StrokeColor="{ThemeResource PrimaryBrush}" />
            </Grid>
          </Border>
        </Grid>

        <!-- Analytics Cards (Narrow: stacked) -->
        <StackPanel Spacing="8" Padding="16,12"
                    Visibility="{utu:Responsive Normal=Visible, Wide=Collapsed}">
          <Border Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1" CornerRadius="12" Padding="16,12">
            <StackPanel Spacing="4">
              <TextBlock Text="QUOTED THIS MONTH" Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Data.TotalQuotedThisMonth, Converter={StaticResource CurrencyFormatConverter}}"
                         Style="{StaticResource HeadlineSmallBold}"
                         FontFamily="{StaticResource MonospaceFontFamily}" />
            </StackPanel>
          </Border>
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16,12">
              <StackPanel Spacing="4">
                <TextBlock Text="SENT" Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Data.QuotesSentThisMonth}"
                             Style="{StaticResource HeadlineSmallBold}" />
                  <TextBlock Text="quotes" Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             VerticalAlignment="Bottom" Margin="0,0,0,2" />
                </StackPanel>
              </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16,12">
              <StackPanel Spacing="4">
                <TextBlock Text="ACCEPTANCE" Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <TextBlock Text="{Binding Data.AcceptanceRate}"
                             Style="{StaticResource HeadlineSmallBold}" />
                  <TextBlock Text="%" Style="{StaticResource HeadlineSmallBold}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </DataTemplate>
    </mvux:FeedView>

    <!-- Main Content: Master-Detail -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left Panel: Quote List -->
      <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="{utu:Responsive Normal='0', Wide='0,0,1,0'}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition />
        </Grid.RowDefinitions>

        <!-- Filter Chips -->
        <Border Padding="16,8,16,4">
          <StackPanel Spacing="6">
            <!-- Status count badges -->
            <mvux:FeedView Source="{Binding StatusCounts}">
              <DataTemplate>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Auto"
                              Margin="0,0,0,4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                        <Run Text="Draft: " /><Run Text="{Binding Data.Draft}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                    <Border Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnPrimaryContainerBrush}">
                        <Run Text="Sent: " /><Run Text="{Binding Data.Sent}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                    <Border Background="{ThemeResource TertiaryContainerBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnTertiaryContainerBrush}">
                        <Run Text="Viewed: " /><Run Text="{Binding Data.Viewed}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                    <Border Background="{ThemeResource SecondaryContainerBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSecondaryContainerBrush}">
                        <Run Text="Accepted: " /><Run Text="{Binding Data.Accepted}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                    <Border Background="{ThemeResource ErrorContainerBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnErrorContainerBrush}">
                        <Run Text="Declined: " /><Run Text="{Binding Data.Declined}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="10" Padding="8,2">
                      <TextBlock Style="{StaticResource LabelSmall}" Foreground="{ThemeResource OnSurfaceVariantBrush}">
                        <Run Text="Expired: " /><Run Text="{Binding Data.Expired}" FontWeight="SemiBold" />
                      </TextBlock>
                    </Border>
                  </StackPanel>
                </ScrollViewer>
              </DataTemplate>
            </mvux:FeedView>

            <StackPanel Orientation="Horizontal" Spacing="6">
              <utu:Chip x:Name="FilterAll" Content="All" IsChecked="True" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
              <utu:Chip x:Name="FilterDraft" Content="Draft" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
              <utu:Chip x:Name="FilterSent" Content="Sent" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
              <utu:Chip x:Name="FilterViewed" Content="Viewed" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <utu:Chip x:Name="FilterAccepted" Content="Accepted" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
              <utu:Chip x:Name="FilterDeclined" Content="Declined" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
              <utu:Chip x:Name="FilterExpired" Content="Expired" Click="FilterChip_Click" Style="{StaticResource MaterialChipStyle}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Quote List -->
        <mvux:FeedView Grid.Row="1" Source="{Binding Quotes}">
          <DataTemplate>
            <ScrollViewer Padding="12,8,12,16">
              <muxc:ItemsRepeater ItemsSource="{Binding Data}"
                                  utu:CommandExtensions.Command="{Binding Parent.OpenQuote}">
                <muxc:ItemsRepeater.Layout>
                  <muxc:StackLayout Spacing="4" />
                </muxc:ItemsRepeater.Layout>
                <muxc:ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12"
                            Translation="0,0,0"
                            AutomationProperties.Name="{Binding Title}"
                            Tapped="QuoteCard_Tapped"
                            helpers:InteractionHelper.IsInteractive="True">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title + Status -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Title}"
                                     Style="{StaticResource BodyMedium}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <Border Grid.Column="1"
                                  Background="{Binding Status, Converter={StaticResource StatusBackgroundConverter}}"
                                  CornerRadius="10" Padding="8,2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                              <FontIcon Glyph="{Binding Status, Converter={StaticResource StatusIconConverter}}" FontSize="10"
                                        Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}" />
                              <TextBlock Text="{Binding Status, Converter={StaticResource UpperCaseConverter}}"
                                         Style="{StaticResource LabelSmall}"
                                         Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}" />
                            </StackPanel>
                          </Border>
                        </Grid>

                        <!-- Client -->
                        <TextBlock Grid.Row="1"
                                   Text="{Binding ClientName}"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   Margin="0,2,0,0" />

                        <!-- Divider -->
                        <Border Grid.Row="2" Height="1"
                                Background="{ThemeResource OutlineVariantBrush}"
                                Margin="0,8,0,0" />

                        <!-- Amount + Date -->
                        <Grid Grid.Row="3" Margin="0,8,0,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Foreground="{ThemeResource PrimaryBrush}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource BodyMedium}"
                                     FontWeight="SemiBold"
                                     Text="{Binding Total, Converter={StaticResource CurrencyFormatConverter}}" />
                          <TextBlock Grid.Column="1"
                                     Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     Text="{Binding CreatedAt, Converter={StaticResource RelativeDateConverter}}" />
                        </Grid>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </muxc:ItemsRepeater.ItemTemplate>
              </muxc:ItemsRepeater>
            </ScrollViewer>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12" Padding="24">
                <FontIcon Glyph="&#xE1D0;" FontSize="36"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No quotes yet" Style="{StaticResource TitleSmall}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Text="Create your first quote in 60 seconds."
                           Style="{StaticResource BodyMedium}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <Button Click="CreateQuote_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,8,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
                    <TextBlock Text="Create Quote" Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>
        </mvux:FeedView>
      </Grid>

      <!-- Right Panel: Detail / Preview toggle (Wide only) -->
      <Grid Grid.Column="1"
            Visibility="{utu:Responsive Normal=Collapsed, Wide=Visible}">

        <!-- === DETAIL VIEW === -->
        <mvux:FeedView Source="{Binding SelectedQuoteDetail}"
                       Visibility="{Binding IsPreviewMode, Converter={StaticResource InverseBoolConverter}, FallbackValue=Visible}">
          <DataTemplate>
            <ScrollViewer Padding="36,28,36,32">
              <StackPanel Spacing="20" HorizontalAlignment="Stretch">

                <!-- Title + Actions -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="{Binding Data.Quote.Title}"
                             Style="{StaticResource HeadlineMedium}"
                             FontWeight="Bold"
                             TextTrimming="CharacterEllipsis" />

                  <!-- Edit button (visible when NOT editing) -->
                  <Button Grid.Column="1"
                          Click="EditQuote_Click"
                          AutomationProperties.Name="Edit quote"
                          Style="{StaticResource MaterialOutlinedButtonStyle}"
                          CornerRadius="8" Margin="0,0,8,0"
                          Visibility="{Binding IsEditMode, ElementName=DashboardRoot, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE70F;" FontSize="14" />
                      <TextBlock Text="Edit" />
                    </StackPanel>
                  </Button>

                  <!-- Done button (visible when editing) -->
                  <Button Grid.Column="1"
                          Click="DoneEditing_Click"
                          AutomationProperties.Name="Done editing"
                          Style="{StaticResource AccentButtonStyle}"
                          Margin="0,0,8,0"
                          Visibility="{Binding IsEditMode, ElementName=DashboardRoot}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{StaticResource AppBarBackgroundBrush}" />
                      <TextBlock Text="Done" Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="2"
                          Command="{Binding DataContext.PreviewQuote, ElementName=DashboardRoot}"
                          AutomationProperties.Name="Preview quote"
                          Background="{ThemeResource SurfaceBrush}"
                          BorderBrush="{ThemeResource PrimaryBrush}"
                          BorderThickness="1.5" CornerRadius="8"
                          Padding="20,10" Margin="0,0,8,0"
                          Visibility="{Binding IsEditMode, ElementName=DashboardRoot, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8FF;" FontSize="14"
                                Foreground="{ThemeResource PrimaryBrush}" />
                      <TextBlock Text="Preview"
                                 Foreground="{ThemeResource PrimaryBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="3"
                          Click="SendQuote_Click"
                          AutomationProperties.Name="Send quote"
                          Style="{StaticResource AccentButtonStyle}"
                          Visibility="{Binding IsEditMode, ElementName=DashboardRoot, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="Send" Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                      <FontIcon Glyph="&#xE724;" FontSize="12" Foreground="{StaticResource AppBarBackgroundBrush}" />
                    </StackPanel>
                  </Button>
                </Grid>

                <!-- Metadata line -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE77B;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                    <TextBlock Text="{Binding Data.Quote.ClientName}" Style="{StaticResource BodySmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE1D0;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                    <TextBlock Text="{Binding Data.Quote.QuoteNumber}" Style="{StaticResource BodySmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE787;" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                    <TextBlock Style="{StaticResource BodySmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                      <Run Text="Valid " /><Run Text="{Binding Data.Quote.ValidUntil, Converter={StaticResource RelativeDateConverter}}" />
                    </TextBlock>
                  </StackPanel>
                  <Border Background="{Binding Data.Quote.Status, Converter={StaticResource StatusBackgroundConverter}}"
                          CornerRadius="10" Padding="8,2">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <FontIcon Glyph="{Binding Data.Quote.Status, Converter={StaticResource StatusIconConverter}}" FontSize="10"
                                Foreground="{Binding Data.Quote.Status, Converter={StaticResource StatusForegroundConverter}}" />
                      <TextBlock Text="{Binding Data.Quote.Status, Converter={StaticResource UpperCaseConverter}}" Style="{StaticResource LabelSmall}"
                                 Foreground="{Binding Data.Quote.Status, Converter={StaticResource StatusForegroundConverter}}" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <!-- Content: Line Items + Sidebar -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                  </Grid.ColumnDefinitions>

                  <StackPanel Spacing="16" Margin="0,0,24,0">
                    <Border Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="0"
                            Translation="0,0,8">
                      <Border.Shadow>
                        <ThemeShadow />
                      </Border.Shadow>
                      <StackPanel>
                        <TextBlock Text="LINE ITEMS" Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   FontWeight="SemiBold" Margin="16,16,16,8" />
                        <Grid Padding="16,8" Background="{ThemeResource SurfaceVariantBrush}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="DESCRIPTION" Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="QTY" Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                     HorizontalAlignment="Right" />
                          <TextBlock Grid.Column="2" Text="UNIT PRICE" Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                     HorizontalAlignment="Right" />
                          <TextBlock Grid.Column="3" Text="TOTAL" Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                     HorizontalAlignment="Right" />
                        </Grid>
                        <Border Height="2" Background="{ThemeResource OnSurfaceBrush}" />
                        <muxc:ItemsRepeater x:Name="LineItemsRepeater"
                                            ItemsSource="{Binding Data.LineItems}"
                                            ElementPrepared="LineItems_ElementPrepared">
                          <muxc:ItemsRepeater.Layout>
                            <muxc:StackLayout Spacing="0" />
                          </muxc:ItemsRepeater.Layout>
                          <muxc:ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                              <Grid Padding="16,14"
                                    MinHeight="48"
                                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                                    BorderThickness="0,0,0,1"
                                    Tapped="InlineLineItem_Tapped">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="60" />
                                  <ColumnDefinition Width="90" />
                                  <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource BodySmall}" />
                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" Style="{StaticResource BodySmall}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding UnitPrice, Converter={StaticResource CurrencyFormatConverter}}"
                                           Style="{StaticResource BodySmall}" FontFamily="{StaticResource MonospaceFontFamily}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding LineTotal, Converter={StaticResource CurrencyFormatConverter}}"
                                           Style="{StaticResource BodySmall}" FontFamily="{StaticResource MonospaceFontFamily}"
                                           FontWeight="SemiBold" HorizontalAlignment="Right" />
                              </Grid>
                            </DataTemplate>
                          </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>

                        <!-- Inline Edit Buttons (visible when editing) -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    Padding="16,12"
                                    Visibility="{Binding IsEditMode, ElementName=DashboardRoot}">
                          <!-- Add Line Item with dashed border -->
                          <Grid>
                            <Rectangle RadiusX="8" RadiusY="8"
                                       StrokeDashArray="4,3"
                                       Stroke="{ThemeResource OutlineBrush}"
                                       StrokeThickness="1" Fill="Transparent" />
                            <Button Click="InlineAddLineItem_Click"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="8" Padding="12,6">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                <TextBlock Text="Add Line Item" />
                              </StackPanel>
                            </Button>
                          </Grid>
                          <!-- From Catalog with orange border -->
                          <Button Click="InlineCatalogBrowser_Click"
                                  Style="{StaticResource MaterialOutlinedButtonStyle}"
                                  BorderBrush="{StaticResource AppBarAccentBrush}"
                                  CornerRadius="8" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <FontIcon Glyph="&#xE8F1;" FontSize="12" />
                              <TextBlock Text="From Catalog" />
                            </StackPanel>
                          </Button>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="0"
                            Translation="0,0,8">
                      <Border.Shadow>
                        <ThemeShadow />
                      </Border.Shadow>
                      <StackPanel>
                        <TextBlock Text="NOTES" Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                   Margin="16,14,16,14" />
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <!-- Notes display (when not editing) -->
                        <TextBlock Text="{Binding Data.Quote.Notes}"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   TextWrapping="Wrap" Margin="16,16,16,16"
                                   Visibility="{Binding IsEditMode, ElementName=DashboardRoot, Converter={StaticResource InverseBoolConverter}}" />
                        <TextBlock Text="Add notes for the client..."
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OutlineBrush}"
                                   FontStyle="Italic"
                                   Visibility="{Binding IsEditMode, ElementName=DashboardRoot, Converter={StaticResource InverseBoolConverter}}"
                                   Margin="16,0,16,16" />

                        <!-- Notes editor (when editing) -->
                        <TextBox Text="{Binding EditingNotes, ElementName=DashboardRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Add notes for the client..."
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 Margin="16,8,16,16"
                                 Visibility="{Binding IsEditMode, ElementName=DashboardRoot}" />
                      </StackPanel>
                    </Border>

                    <!-- Secondary actions -->
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                      <Button Command="{Binding DataContext.DuplicateQuote, ElementName=DashboardRoot}"
                              AutomationProperties.Name="Duplicate quote"
                              Style="{StaticResource MaterialTextButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <FontIcon Glyph="&#xE8C8;" FontSize="14"
                                    Foreground="{ThemeResource PrimaryBrush}" />
                          <TextBlock Text="Duplicate"
                                     Foreground="{ThemeResource PrimaryBrush}" />
                        </StackPanel>
                      </Button>
                      <Button Click="DeleteQuote_Click"
                              AutomationProperties.Name="Delete quote"
                              Style="{StaticResource MaterialTextButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <FontIcon Glyph="&#xE74D;" FontSize="14"
                                    Foreground="{ThemeResource ErrorBrush}" />
                          <TextBlock Text="Delete"
                                     Foreground="{ThemeResource ErrorBrush}" />
                        </StackPanel>
                      </Button>
                    </StackPanel>
                  </StackPanel>

                  <!-- Right Sidebar -->
                  <StackPanel Grid.Column="1" Spacing="24" Margin="8,0,16,0">
                    <StackPanel Spacing="8" Padding="0,4">
                      <TextBlock Text="CLIENT" Style="{StaticResource LabelSmall}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{ThemeResource PrimaryContainerBrush}">
                          <TextBlock Text="{Binding Data.Quote.ClientName, Converter={StaticResource InitialsConverter}}"
                                     Style="{StaticResource LabelMedium}"
                                     Foreground="{ThemeResource PrimaryBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding Data.Quote.ClientName}" Style="{StaticResource BodyMedium}"
                                     FontWeight="Medium" />
                          <TextBlock Text="{Binding Data.Client.Email}" Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Text="{Binding Data.Client.Phone}" Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="QUOTE DETAILS" Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <Grid Padding="0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Quote #" Style="{StaticResource BodyMediumWeightMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Grid.Column="1" Text="{Binding Data.Quote.QuoteNumber}"
                                     Style="{StaticResource BodyMediumWeightMedium}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <Grid Padding="0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Created" Style="{StaticResource BodyMediumWeightMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Quote.CreatedAt, Converter={StaticResource RelativeDateConverter}}"
                                     Style="{StaticResource BodyMediumWeightMedium}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <Grid Padding="0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Valid Until" Style="{StaticResource BodyMediumWeightMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Quote.ValidUntil, Converter={StaticResource RelativeDateConverter}}"
                                     Style="{StaticResource BodyMediumWeightMedium}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <Grid Padding="0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Status" Style="{StaticResource BodyMediumWeightMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <Border Grid.Column="1"
                                  Background="{Binding Data.Quote.Status, Converter={StaticResource StatusBackgroundConverter}}"
                                  CornerRadius="10" Padding="8,2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                              <FontIcon Glyph="{Binding Data.Quote.Status, Converter={StaticResource StatusIconConverter}}" FontSize="10"
                                        Foreground="{Binding Data.Quote.Status, Converter={StaticResource StatusForegroundConverter}}" />
                              <TextBlock Text="{Binding Data.Quote.Status, Converter={StaticResource UpperCaseConverter}}" Style="{StaticResource LabelSmall}"
                                         Foreground="{Binding Data.Quote.Status, Converter={StaticResource StatusForegroundConverter}}" />
                            </StackPanel>
                          </Border>
                        </Grid>
                      </StackPanel>

                    <StackPanel>
                        <TextBlock Text="TOTALS" Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold"
                                   Margin="0,14,0,8" />
                        <Border Height="1" Background="{ThemeResource OutlineVariantBrush}" />
                        <StackPanel Spacing="8" Margin="0,12,0,16">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subtotal" Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Data.Quote.Subtotal, Converter={StaticResource CurrencyFormatConverter}}"
                                       FontFamily="{StaticResource MonospaceFontFamily}" Style="{StaticResource BodyMedium}" />
                          </Grid>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}">
                              <Run Text="Tax (" /><Run Text="{Binding Data.Quote.TaxRate}" /><Run Text="%)" />
                            </TextBlock>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Data.Quote.TaxAmount, Converter={StaticResource CurrencyFormatConverter}}"
                                       FontFamily="{StaticResource MonospaceFontFamily}" Style="{StaticResource BodyMedium}" />
                          </Grid>
                          <Border Height="1" Background="{ThemeResource PrimaryBrush}" Margin="0,4" />
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total" Style="{StaticResource TitleMediumBold}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Data.Quote.Total, Converter={StaticResource CurrencyFormatConverter}}"
                                       FontFamily="{StaticResource MonospaceFontFamily}"
                                       Style="{StaticResource TitleMedium}"
                                       Foreground="{ThemeResource PrimaryBrush}" FontWeight="Bold" />
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12" Padding="32">
                <FontIcon Glyph="&#xE1D0;" FontSize="48"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Select a quote" Style="{StaticResource TitleSmall}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Text="Choose a quote from the list to view details, or create a new one."
                           Style="{StaticResource BodyMedium}" HorizontalAlignment="Center"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320" />
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>
        </mvux:FeedView>

        <!-- === PREVIEW VIEW === -->
        <mvux:FeedView Source="{Binding PreviewData}"
                       Visibility="{Binding IsPreviewMode, FallbackValue=Collapsed}">
          <DataTemplate>
            <Grid Background="{ThemeResource SurfaceVariantBrush}">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
              </Grid.RowDefinitions>

              <!-- Preview Action Bar -->
              <Border Background="{ThemeResource SurfaceBrush}"
                      BorderBrush="{ThemeResource OutlineVariantBrush}"
                      BorderThickness="0,0,0,1" Padding="24,12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Button Command="{Binding DataContext.BackToDetail, ElementName=DashboardRoot}"
                          AutomationProperties.Name="Back to detail view"
                          Style="{StaticResource MaterialOutlinedButtonStyle}"
                          CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE72B;" FontSize="14" />
                      <TextBlock Text="Back to Detail" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="2"
                          Command="{Binding DataContext.DownloadPdf, ElementName=DashboardRoot}"
                          AutomationProperties.Name="Download PDF"
                          Background="{ThemeResource PrimaryBrush}"
                          Foreground="{ThemeResource OnPrimaryBrush}"
                          CornerRadius="8" Padding="20,10" BorderThickness="0"
                          Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <FontIcon Glyph="&#xE896;" FontSize="14"
                                Foreground="{ThemeResource OnPrimaryBrush}" />
                      <TextBlock Text="Download PDF"
                                 Foreground="{ThemeResource OnPrimaryBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="3"
                          Click="SendQuote_Click"
                          AutomationProperties.Name="Send quote to client"
                          Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <FontIcon Glyph="&#xE724;" FontSize="14"
                                Foreground="{StaticResource AppBarBackgroundBrush}" />
                      <TextBlock Text="Send Quote"
                                 Foreground="{StaticResource AppBarBackgroundBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                  </Button>
                </Grid>
              </Border>

              <!-- Preview Document -->
              <ScrollViewer Grid.Row="1" Padding="40,32">
                <Border Background="{ThemeResource SurfaceBrush}"
                        CornerRadius="12"
                        MaxWidth="720" HorizontalAlignment="Center"
                        Translation="0,0,16">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel>

                    <!-- Blue Header -->
                    <Border Background="{StaticResource AppBarBackgroundBrush}"
                            CornerRadius="12,12,0,0" Padding="32,24">
                      <StackPanel Spacing="20">
                        <!-- Company Row -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <!-- Logo or Initials badge -->
                          <Grid Width="48" Height="48">
                            <Border CornerRadius="8"
                                    Background="{StaticResource AppBarButtonBackgroundBrush}"
                                    Visibility="{Binding Data.Profile.LogoPath, Converter={StaticResource EmptyToVisibleConverter}}">
                              <TextBlock Text="{Binding Data.Profile.BusinessName, Converter={StaticResource InitialsConverter}}"
                                         Foreground="{StaticResource AppBarForegroundBrush}" FontWeight="Bold"
                                         Style="{StaticResource TitleMedium}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Image Source="{Binding Data.Profile.LogoPath}"
                                   Stretch="UniformToFill" Width="48" Height="48"
                                   Visibility="{Binding Data.Profile.LogoPath, Converter={StaticResource EmptyToVisibleConverter}, ConverterParameter=Invert}" />
                          </Grid>

                          <!-- Company info -->
                          <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                            <TextBlock Text="{Binding Data.Profile.BusinessName}"
                                       Foreground="{StaticResource AppBarForegroundBrush}" FontWeight="Bold"
                                       Style="{StaticResource TitleMedium}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding Data.Profile.Phone}"
                                       Foreground="{StaticResource UpgradeBannerSubtitleBrush}" Style="{StaticResource BodySmall}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding Data.Profile.Email}"
                                       Foreground="{StaticResource UpgradeBannerSubtitleBrush}" Style="{StaticResource BodySmall}"
                                       HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>

                        <!-- Quote meta row -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <StackPanel Spacing="2">
                            <TextBlock Text="Quote #" Foreground="{StaticResource UpgradeBannerSubtitleBrush}"
                                       Style="{StaticResource LabelSmall}" />
                            <TextBlock Text="{Binding Data.Quote.QuoteNumber}"
                                       Foreground="{StaticResource AppBarForegroundBrush}" FontWeight="SemiBold"
                                       Style="{StaticResource BodyMedium}" />
                          </StackPanel>

                          <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="Date" Foreground="{StaticResource UpgradeBannerSubtitleBrush}"
                                       Style="{StaticResource LabelSmall}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Data.Quote.CreatedAt, Converter={StaticResource ShortDateConverter}}"
                                       Foreground="{StaticResource AppBarForegroundBrush}" FontWeight="SemiBold"
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalAlignment="Center" />
                          </StackPanel>

                          <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                            <TextBlock Text="Valid Until" Foreground="{StaticResource UpgradeBannerSubtitleBrush}"
                                       Style="{StaticResource LabelSmall}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding Data.Quote.ValidUntil, Converter={StaticResource ShortDateConverter}}"
                                       Foreground="{StaticResource AppBarForegroundBrush}" FontWeight="SemiBold"
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- White Content Area -->
                    <StackPanel Padding="32,24" Spacing="24">

                      <!-- Prepared For -->
                      <StackPanel Spacing="4">
                        <TextBlock Text="PREPARED FOR" Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Data.Quote.ClientName}"
                                   Style="{StaticResource TitleMediumBold}" />
                        <TextBlock Text="{Binding Data.Client.Address}"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                      </StackPanel>

                      <!-- Quote Title -->
                      <TextBlock Text="{Binding Data.Quote.Title}"
                                 Style="{StaticResource TitleLargeBold}" />

                      <!-- Line Items Table -->
                      <Border BorderBrush="{ThemeResource OutlineVariantBrush}"
                              BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                          <!-- Table Header -->
                          <Grid Padding="16,10"
                                Background="{ThemeResource SurfaceVariantBrush}"
                                CornerRadius="8,8,0,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="60" />
                              <ColumnDefinition Width="90" />
                              <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DESCRIPTION" Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="QTY" Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="PRICE" Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="3" Text="TOTAL" Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                          </Grid>
                          <Border Height="2" Background="{ThemeResource OnSurfaceBrush}" />

                          <muxc:ItemsRepeater ItemsSource="{Binding Data.LineItems}">
                            <muxc:ItemsRepeater.Layout>
                              <muxc:StackLayout Spacing="0" />
                            </muxc:ItemsRepeater.Layout>
                            <muxc:ItemsRepeater.ItemTemplate>
                              <DataTemplate>
                                <Grid Padding="16,12"
                                      BorderBrush="{ThemeResource OutlineVariantBrush}"
                                      BorderThickness="0,0,0,1">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="90" />
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Text="{Binding Description}"
                                             Style="{StaticResource BodyMedium}" />
                                  <TextBlock Grid.Column="1" Text="{Binding Quantity}"
                                             Style="{StaticResource BodyMedium}"
                                             HorizontalAlignment="Right" />
                                  <TextBlock Grid.Column="2"
                                             Text="{Binding UnitPrice, Converter={StaticResource CurrencyFormatConverter}}"
                                             Style="{StaticResource BodyMedium}"
                                             FontFamily="{StaticResource MonospaceFontFamily}"
                                             HorizontalAlignment="Right" />
                                  <TextBlock Grid.Column="3"
                                             Text="{Binding LineTotal, Converter={StaticResource CurrencyFormatConverter}}"
                                             Style="{StaticResource BodyMedium}"
                                             FontFamily="{StaticResource MonospaceFontFamily}"
                                             FontWeight="Bold"
                                             Foreground="{ThemeResource PrimaryBrush}"
                                             HorizontalAlignment="Right" />
                                </Grid>
                              </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                          </muxc:ItemsRepeater>
                        </StackPanel>
                      </Border>

                      <!-- Totals -->
                      <StackPanel HorizontalAlignment="Right" Spacing="4" MinWidth="240">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Subtotal" Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     HorizontalAlignment="Right" Margin="0,0,16,0" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Quote.Subtotal, Converter={StaticResource CurrencyFormatConverter}}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource BodyMedium}"
                                     HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     HorizontalAlignment="Right" Margin="0,0,16,0">
                            <Run Text="Tax (" /><Run Text="{Binding Data.Quote.TaxRate}" /><Run Text="%)" />
                          </TextBlock>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Quote.TaxAmount, Converter={StaticResource CurrencyFormatConverter}}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource BodyMedium}"
                                     HorizontalAlignment="Right" />
                        </Grid>
                        <Border Height="2" Background="{ThemeResource PrimaryBrush}" Margin="0,4" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="Total" Style="{StaticResource TitleMedium}"
                                     FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,16,0" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Quote.Total, Converter={StaticResource CurrencyFormatConverter}}"
                                     FontFamily="{StaticResource MonospaceFontFamily}"
                                     Style="{StaticResource TitleLarge}"
                                     Foreground="{ThemeResource PrimaryBrush}" FontWeight="Bold"
                                     HorizontalAlignment="Right" />
                        </Grid>
                      </StackPanel>

                      <!-- Notes -->
                      <Border Background="{ThemeResource SurfaceVariantBrush}"
                              CornerRadius="8" Padding="20,16"
                              BorderBrush="{ThemeResource OutlineVariantBrush}"
                              BorderThickness="0,3,0,0">
                        <StackPanel Spacing="6">
                          <TextBlock Text="NOTES" Style="{StaticResource LabelSmall}"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding Data.Quote.Notes}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>

                    </StackPanel>

                    <!-- Footer -->
                    <Border Padding="32,16"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="0,1,0,0">
                      <TextBlock Text="Created with QuoteCraft"
                                 Style="{StaticResource BodySmall}"
                                 Foreground="{ThemeResource PrimaryBrush}"
                                 HorizontalAlignment="Center" />
                    </Border>
                  </StackPanel>
                </Border>
              </ScrollViewer>
            </Grid>
          </DataTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" />
                <TextBlock Text="Generating preview..." Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
              </StackPanel>
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>
        </mvux:FeedView>

      </Grid>
    </Grid>
  </Grid>
</Page>
