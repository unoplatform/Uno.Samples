<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Material System Overrides -->
      <Color x:Key="PrimaryColor">#2D6A4F</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#B7E4C7</Color>
      <Color x:Key="OnPrimaryContainerColor">#1B4332</Color>
      <Color x:Key="SecondaryColor">#C9A96E</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#F5ECD7</Color>
      <Color x:Key="OnSecondaryContainerColor">#3D2E10</Color>
      <Color x:Key="TertiaryColor">#C9A96E</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#F5ECD7</Color>
      <Color x:Key="OnTertiaryContainerColor">#3D2E10</Color>
      <Color x:Key="ErrorColor">#B5342B</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#F6F4F0</Color>
      <Color x:Key="OnBackgroundColor">#1A1A2E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A2E</Color>
      <Color x:Key="SurfaceVariantColor">#F6F4F0</Color>
      <Color x:Key="OnSurfaceVariantColor">#8A8A8A</Color>
      <Color x:Key="OutlineColor">#C4C0B8</Color>
      <Color x:Key="OutlineVariantColor">#E8E4DE</Color>
      <Color x:Key="SurfaceInverseColor">#1A1A2E</Color>
      <Color x:Key="OnSurfaceInverseColor">#F6F4F0</Color>
      <Color x:Key="PrimaryInverseColor">#95D5B2</Color>
      <Color x:Key="SurfaceTintColor">#2D6A4F</Color>
    </ResourceDictionary>
    <!-- No Dark theme in v1 — force Light via RequestedTheme -->
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#2D6A4F</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#B7E4C7</Color>
      <Color x:Key="OnPrimaryContainerColor">#1B4332</Color>
      <Color x:Key="SecondaryColor">#C9A96E</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#F5ECD7</Color>
      <Color x:Key="OnSecondaryContainerColor">#3D2E10</Color>
      <Color x:Key="TertiaryColor">#C9A96E</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#F5ECD7</Color>
      <Color x:Key="OnTertiaryContainerColor">#3D2E10</Color>
      <Color x:Key="ErrorColor">#B5342B</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#F6F4F0</Color>
      <Color x:Key="OnBackgroundColor">#1A1A2E</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A2E</Color>
      <Color x:Key="SurfaceVariantColor">#F6F4F0</Color>
      <Color x:Key="OnSurfaceVariantColor">#8A8A8A</Color>
      <Color x:Key="OutlineColor">#C4C0B8</Color>
      <Color x:Key="OutlineVariantColor">#E8E4DE</Color>
      <Color x:Key="SurfaceInverseColor">#1A1A2E</Color>
      <Color x:Key="OnSurfaceInverseColor">#F6F4F0</Color>
      <Color x:Key="PrimaryInverseColor">#95D5B2</Color>
      <Color x:Key="SurfaceTintColor">#2D6A4F</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- ═══ Meridian Semantic Colors ═══ -->
  <Color x:Key="MeridianBackground">#F6F4F0</Color>
  <Color x:Key="MeridianCardColor">#FFFFFF</Color>
  <Color x:Key="MeridianTextPrimary">#1A1A2E</Color>
  <Color x:Key="MeridianTextMuted">#8A8A8A</Color>
  <Color x:Key="MeridianTextSubtle">#C4C0B8</Color>
  <Color x:Key="MeridianBorder">#E8E4DE</Color>
  <Color x:Key="MeridianGain">#2D6A4F</Color>
  <Color x:Key="MeridianLoss">#B5342B</Color>
  <Color x:Key="MeridianAccent">#C9A96E</Color>
  <Color x:Key="MeridianCardHover">#FDFCFA</Color>
  <Color x:Key="MeridianSelectedHoldingBg">#0A2D6A4F</Color>
  <Color x:Key="MeridianExpandedBg">#F8F6F2</Color>
  <Color x:Key="MeridianGainBgTint">#142D6A4F</Color>
  <Color x:Key="MeridianLossBgTint">#14B5342B</Color>
  <Color x:Key="MeridianAccentBgTint">#14C9A96E</Color>
  <Color x:Key="MeridianBackdrop">#40000000</Color>
  <Color x:Key="MeridianRowSeparator">#0A000000</Color>
  <Color x:Key="MeridianBackgroundTransparent">#00F6F4F0</Color>
  <Color x:Key="MeridianSubmitDisabled">#E0DCD5</Color>
  <Color x:Key="MeridianSurfaceHover">#FAF8F5</Color>
  <Color x:Key="MeridianSurfaceTinted">#F0ECE6</Color>

  <!-- ═══ Meridian Semantic Brushes ═══ -->
  <SolidColorBrush x:Key="MeridianBackgroundBrush" Color="{StaticResource MeridianBackground}" />
  <SolidColorBrush x:Key="MeridianCardBrush" Color="{StaticResource MeridianCardColor}" />
  <SolidColorBrush x:Key="MeridianTextPrimaryBrush" Color="{StaticResource MeridianTextPrimary}" />
  <SolidColorBrush x:Key="MeridianTextMutedBrush" Color="{StaticResource MeridianTextMuted}" />
  <SolidColorBrush x:Key="MeridianTextSubtleBrush" Color="{StaticResource MeridianTextSubtle}" />
  <SolidColorBrush x:Key="MeridianBorderBrush" Color="{StaticResource MeridianBorder}" />
  <SolidColorBrush x:Key="MeridianGainBrush" Color="{StaticResource MeridianGain}" />
  <SolidColorBrush x:Key="MeridianLossBrush" Color="{StaticResource MeridianLoss}" />
  <SolidColorBrush x:Key="MeridianAccentBrush" Color="{StaticResource MeridianAccent}" />
  <SolidColorBrush x:Key="MeridianCardHoverBrush" Color="{StaticResource MeridianCardHover}" />
  <SolidColorBrush x:Key="MeridianSelectedHoldingBgBrush" Color="{StaticResource MeridianSelectedHoldingBg}" />
  <SolidColorBrush x:Key="MeridianExpandedBgBrush" Color="{StaticResource MeridianExpandedBg}" />
  <SolidColorBrush x:Key="MeridianGainBgTintBrush" Color="{StaticResource MeridianGainBgTint}" />
  <SolidColorBrush x:Key="MeridianLossBgTintBrush" Color="{StaticResource MeridianLossBgTint}" />
  <SolidColorBrush x:Key="MeridianAccentBgTintBrush" Color="{StaticResource MeridianAccentBgTint}" />
  <SolidColorBrush x:Key="MeridianBackdropBrush" Color="{StaticResource MeridianBackdrop}" />
  <SolidColorBrush x:Key="MeridianRowSeparatorBrush" Color="{StaticResource MeridianRowSeparator}" />
  <SolidColorBrush x:Key="MeridianSubmitDisabledBrush" Color="{StaticResource MeridianSubmitDisabled}" />
  <SolidColorBrush x:Key="MeridianSurfaceHoverBrush" Color="{StaticResource MeridianSurfaceHover}" />
  <SolidColorBrush x:Key="MeridianSurfaceTintedBrush" Color="{StaticResource MeridianSurfaceTinted}" />
</ResourceDictionary>