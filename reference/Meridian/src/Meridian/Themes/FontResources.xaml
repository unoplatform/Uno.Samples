<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="InstrumentSerifFont">ms-appx:///Assets/Fonts/Instrument_Serif/InstrumentSerif-Regular.ttf#Instrument Serif</FontFamily>
    <FontFamily x:Key="InstrumentSerifItalicFont">ms-appx:///Assets/Fonts/Instrument_Serif/InstrumentSerif-Italic.ttf#Instrument Serif</FontFamily>
    <FontFamily x:Key="IBMPlexMonoFont">ms-appx:///Assets/Fonts/IBM_Plex_Mono/IBMPlexMono-Medium.ttf#IBM Plex Mono</FontFamily>
    <FontFamily x:Key="IBMPlexMonoMediumFont">ms-appx:///Assets/Fonts/IBM_Plex_Mono/IBMPlexMono-SemiBold.ttf#IBM Plex Mono</FontFamily>
    <FontFamily x:Key="OutfitFont">ms-appx:///Assets/Fonts/Outfit/static/Outfit-Medium.ttf#Outfit</FontFamily>

    <!-- Font size ramp (value-preserving; replaces inline FontSize literals) -->
    <x:Double x:Key="FontSize8">8</x:Double>
    <x:Double x:Key="FontSize9">9</x:Double>
    <x:Double x:Key="FontSize10">10</x:Double>
    <x:Double x:Key="FontSize11">11</x:Double>
    <x:Double x:Key="FontSize12">12</x:Double>
    <x:Double x:Key="FontSize13">13</x:Double>
    <x:Double x:Key="FontSize14">14</x:Double>
    <x:Double x:Key="FontSize16">16</x:Double>
    <x:Double x:Key="FontSize18">18</x:Double>
    <x:Double x:Key="FontSize20">20</x:Double>
    <x:Double x:Key="FontSize22">22</x:Double>
    <x:Double x:Key="FontSize24">24</x:Double>
    <x:Double x:Key="FontSize26">26</x:Double>
    <x:Double x:Key="FontSize48">48</x:Double>
    <x:Double x:Key="FontSize62">62</x:Double>

</ResourceDictionary>
