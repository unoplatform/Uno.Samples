<UserControl x:Class="Meridian.Views.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <!--
        Bootstrap navigation host. The framework loads the default nested
        route (Dashboard) into this Frame. Mirrors FieldOpsPro Shell.xaml.
    -->
    <utu:SafeArea Background="{ThemeResource MeridianBackgroundBrush}">
        <Frame />
    </utu:SafeArea>
</UserControl>
