<Page x:Class="Liveline.Demo.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:liveline="using:Liveline"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <StackPanel utu:SafeArea.Insets="VisibleBounds"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="16">

    <!-- Chart (hero) -->
    <Border CornerRadius="16"
            Width="520"
            Height="300"
            Translation="0,0,24">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <liveline:LivelineChart x:Name="Chart"
                              LerpSpeed="0.04"
                              Data="{Binding Data}"
                              Value="{Binding Value}"
                              Theme="{Binding Theme}"
                              IsLoading="{Binding IsLoading}"
                              IsPaused="{Binding IsPaused}"
                              ShowGrid="{Binding ShowGrid}"
                              ShowBadge="{Binding ShowBadge}"
                              ShowFill="{Binding ShowFill}"
                              Momentum="{Binding Momentum}" />
    </Border>

    <!-- Control strip -->
    <Border Padding="16,10"
            CornerRadius="12"
            HorizontalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Translation="0,0,8">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <StackPanel Orientation="Horizontal" Spacing="0">

        <!-- Layer toggles -->
        <StackPanel Orientation="Horizontal" Spacing="12">
          <ToggleSwitch IsOn="{Binding ShowGrid, Mode=TwoWay}"
                        OnContent="Grid" OffContent="Grid"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch IsOn="{Binding ShowFill, Mode=TwoWay}"
                        OnContent="Fill" OffContent="Fill"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch IsOn="{Binding ShowBadge, Mode=TwoWay}"
                        OnContent="Badge" OffContent="Badge"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch IsOn="{Binding ShowDot, Mode=TwoWay}"
                        OnContent="Dot" OffContent="Dot"
                        MinWidth="0" MinHeight="0" />
        </StackPanel>

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Playback -->
        <ToggleSwitch IsOn="{Binding IsPaused, Mode=TwoWay}"
                      OnContent="Pause" OffContent="Pause"
                      MinWidth="0" MinHeight="0" />

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Accent colors -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <Button Command="{Binding SelectColorCommand}"
                  CommandParameter="#4CAF50"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Green">
            <Border Width="24" Height="24" CornerRadius="12" Background="#4CAF50" />
          </Button>
          <Button Command="{Binding SelectColorCommand}"
                  CommandParameter="#2196F3"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Blue">
            <Border Width="24" Height="24" CornerRadius="12" Background="#2196F3" />
          </Button>
          <Button Command="{Binding SelectColorCommand}"
                  CommandParameter="#FF9800"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Amber">
            <Border Width="24" Height="24" CornerRadius="12" Background="#FF9800" />
          </Button>
          <Button Command="{Binding SelectColorCommand}"
                  CommandParameter="#9C27B0"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Purple">
            <Border Width="24" Height="24" CornerRadius="12" Background="#9C27B0" />
          </Button>
        </StackPanel>

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Theme -->
        <ToggleSwitch IsOn="{Binding IsDark, Mode=TwoWay}"
                      OnContent="Dark" OffContent="Light"
                      MinWidth="0" MinHeight="0" />

      </StackPanel>
    </Border>

  </StackPanel>
</Page>
