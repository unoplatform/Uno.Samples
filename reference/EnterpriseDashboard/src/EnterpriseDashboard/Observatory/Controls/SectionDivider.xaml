<UserControl x:Class="EnterpriseDashboard.Observatory.Controls.SectionDivider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <StackPanel Margin="0,36,0,10" Spacing="6">
    <StackPanel Orientation="Horizontal" Spacing="14">
      <TextBlock x:Name="NumberText" Style="{StaticResource ObsMonoTag}" VerticalAlignment="Bottom" />
      <TextBlock x:Name="TitleText" Style="{StaticResource ObsSectionTitle}" VerticalAlignment="Bottom" />
    </StackPanel>
    <TextBlock x:Name="DescText" Style="{StaticResource ObsMonoDesc}" />
    <Border Height="1" Background="{ThemeResource ObsBorderBrush}" Margin="0,14,0,0" />
  </StackPanel>

</UserControl>
