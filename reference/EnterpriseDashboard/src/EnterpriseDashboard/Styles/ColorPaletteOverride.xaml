<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>

    <!--
      Observatory MD3 roles — cool slate surfaces + single blue accent (Design Brief §6.1).
      Drives Material-styled chrome (NavigationView selection, focus, ripples) so it
      matches the bespoke Observatory tokens. Accent is the only chromatic role.
    -->
    <ResourceDictionary x:Key="Dark">
      <!-- Primary accent: vivid cool blue on near-black -->
      <Color x:Key="PrimaryColor">#FF5AA9FF</Color>
      <Color x:Key="OnPrimaryColor">#FF04101C</Color>
      <Color x:Key="PrimaryContainerColor">#FF14202E</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFBDD9FF</Color>

      <!-- Secondary: ink-2 slate -->
      <Color x:Key="SecondaryColor">#FFA8ADB6</Color>
      <Color x:Key="OnSecondaryColor">#FF08090C</Color>
      <Color x:Key="SecondaryContainerColor">#FF14171F</Color>
      <Color x:Key="OnSecondaryContainerColor">#FFC9CFD8</Color>

      <!-- Tertiary: ink-3 slate -->
      <Color x:Key="TertiaryColor">#FF737880</Color>
      <Color x:Key="OnTertiaryColor">#FF08090C</Color>
      <Color x:Key="TertiaryContainerColor">#FF0E1015</Color>
      <Color x:Key="OnTertiaryContainerColor">#FFA8ADB6</Color>

      <!-- Error: coral negative -->
      <Color x:Key="ErrorColor">#FFE8806F</Color>
      <Color x:Key="ErrorContainerColor">#FF2A1714</Color>
      <Color x:Key="OnErrorColor">#FF08090C</Color>
      <Color x:Key="OnErrorContainerColor">#FFF2B8AD</Color>

      <!-- Surfaces: cool slate ramp -->
      <Color x:Key="BackgroundColor">#FF08090C</Color>
      <Color x:Key="OnBackgroundColor">#FFE6E9EE</Color>
      <Color x:Key="SurfaceColor">#FF0E1015</Color>
      <Color x:Key="OnSurfaceColor">#FFE6E9EE</Color>
      <Color x:Key="SurfaceVariantColor">#FF14171F</Color>
      <Color x:Key="OnSurfaceVariantColor">#FFA8ADB6</Color>

      <!-- Borders and dividers -->
      <Color x:Key="OutlineColor">#FF232831</Color>
      <Color x:Key="OutlineVariantColor">#FF1E222B</Color>

      <!-- Inverse and tint -->
      <Color x:Key="OnSurfaceInverseColor">#FF08090C</Color>
      <Color x:Key="SurfaceInverseColor">#FFE6E9EE</Color>
      <Color x:Key="PrimaryInverseColor">#FF1F57C4</Color>
      <Color x:Key="SurfaceTintColor">#FF5AA9FF</Color>
    </ResourceDictionary>

    <!-- Light theme: cool ice surfaces + deeper blue accent -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#FF1F57C4</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#FFD7E3F7</Color>
      <Color x:Key="OnPrimaryContainerColor">#FF0A2247</Color>
      <Color x:Key="SecondaryColor">#FF3E4350</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#FFE7EBF1</Color>
      <Color x:Key="OnSecondaryContainerColor">#FF1A1E25</Color>
      <Color x:Key="TertiaryColor">#FF6C7280</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#FFDCE1EA</Color>
      <Color x:Key="OnTertiaryContainerColor">#FF3E4350</Color>
      <Color x:Key="ErrorColor">#FFB84A38</Color>
      <Color x:Key="ErrorContainerColor">#FFF7DAD3</Color>
      <Color x:Key="OnErrorColor">#FFFFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#FF3F140C</Color>
      <Color x:Key="BackgroundColor">#FFF1F3F7</Color>
      <Color x:Key="OnBackgroundColor">#FF0F1115</Color>
      <Color x:Key="SurfaceColor">#FFFAFBFD</Color>
      <Color x:Key="OnSurfaceColor">#FF0F1115</Color>
      <Color x:Key="SurfaceVariantColor">#FFE7EBF1</Color>
      <Color x:Key="OnSurfaceVariantColor">#FF3E4350</Color>
      <Color x:Key="OutlineColor">#FFCFD5DF</Color>
      <Color x:Key="OutlineVariantColor">#FFD6DBE3</Color>
      <Color x:Key="OnSurfaceInverseColor">#FFFAFBFD</Color>
      <Color x:Key="SurfaceInverseColor">#FF0F1115</Color>
      <Color x:Key="PrimaryInverseColor">#FF5AA9FF</Color>
      <Color x:Key="SurfaceTintColor">#FF1F57C4</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
