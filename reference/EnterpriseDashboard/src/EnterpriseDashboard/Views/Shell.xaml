<UserControl x:Class="EnterpriseDashboard.Views.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{ThemeResource ObsBlackBrush}">

  <!-- Bootstrap navigation host. Region.Attached is set by the navigation system
       once the host is ready; ShellViewModel triggers the initial route. -->
  <ContentControl x:Name="ShellContent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch" />
</UserControl>
