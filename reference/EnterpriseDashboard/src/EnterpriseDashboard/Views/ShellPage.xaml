<Page x:Class="EnterpriseDashboard.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Background="{ThemeResource ObsBlackBrush}">

  <Page.Resources>
    <!-- Icon-pill button: dim default → lighter on hover, slight scale on press. -->
    <Style x:Key="ObsPillStyle" TargetType="Button">
      <Setter Property="Background" Value="{ThemeResource ObsDarkBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource ObsBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid x:Name="RootGrid"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}"
                  RenderTransformOrigin="0.5,0.5">
              <Grid.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
              </Grid.RenderTransform>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal" />
                  <VisualState x:Name="PointerOver">
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="RootGrid"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                       To="1.03" Duration="0:0:0.2" />
                      <DoubleAnimation Storyboard.TargetName="RootGrid"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                       To="1.03" Duration="0:0:0.2" />
                    </Storyboard>
                  </VisualState>
                  <VisualState x:Name="Pressed">
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="RootGrid"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                       To="0.97" Duration="0:0:0.1" />
                      <DoubleAnimation Storyboard.TargetName="RootGrid"
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                       To="0.97" Duration="0:0:0.1" />
                    </Storyboard>
                  </VisualState>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Page.Resources>

  <NavigationView x:Name="NavView"
                  uen:Region.Attached="True"
                  PaneDisplayMode="Left"
                  IsBackButtonVisible="Collapsed"
                  IsSettingsVisible="False"
                  IsPaneToggleButtonVisible="False"
                  OpenPaneLength="248"
                  FontFamily="{StaticResource ObsSerifFamily}"
                  FontWeight="Light"
                  Background="{ThemeResource ObsBlackBrush}">

    <NavigationView.Resources>
      <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{ThemeResource ObsBlack}" />
      <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{ThemeResource ObsBlack}" />
      <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="{ThemeResource ObsAccent}" />
    </NavigationView.Resources>

    <!-- Brand at the top of the rail: wordmark + subtitle, then a hairline. -->
    <NavigationView.PaneHeader>
      <StackPanel Margin="16,28,16,18" Spacing="6">
        <TextBlock Text="Observatory" Style="{StaticResource ObsTopTitle}" />
        <TextBlock Text="SaaS analytics · updated 2m ago"
                   Style="{StaticResource ObsMonoSmall}"
                   Foreground="{ThemeResource ObsGreyBrush}"
                   TextWrapping="Wrap" />
        <Border Height="1" Background="{ThemeResource ObsBorderBrush}" Margin="0,14,0,0" />
      </StackPanel>
    </NavigationView.PaneHeader>

    <NavigationView.MenuItems>
      <NavigationViewItem Content="Acquisition &amp; Revenue"
                          uen:Region.Name="Acquisition"
                          AutomationProperties.Name="Acquisition and Revenue" />
      <NavigationViewItemSeparator />
      <NavigationViewItem Content="Engagement &amp; Health"
                          uen:Region.Name="Engagement"
                          AutomationProperties.Name="Engagement and Health" />
      <NavigationViewItemSeparator />
      <NavigationViewItem Content="Cohorts"
                          uen:Region.Name="Cohorts"
                          AutomationProperties.Name="Cohorts" />
    </NavigationView.MenuItems>

    <!-- Persistent chrome: top bar + swappable section content -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            Padding="40,24,40,16"
            BorderBrush="{ThemeResource ObsBorderBrush}"
            BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <Border Background="{ThemeResource ObsDarkBrush}"
                  BorderBrush="{ThemeResource ObsBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="20"
                  Padding="3"
                  VerticalAlignment="Center">
            <StackPanel x:Name="RangeHost" Orientation="Horizontal" Spacing="2" />
          </Border>

          <Button Style="{StaticResource ObsPillStyle}" Click="OnRefreshClick" ToolTipService.ToolTip="Refresh">
            <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="{ThemeResource ObsMidBrush}" />
          </Button>

          <Button Style="{StaticResource ObsPillStyle}" Click="OnThemeToggleClick">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon x:Name="ThemeGlyph" Glyph="&#xE708;" FontSize="12" Foreground="{ThemeResource ObsLightBrush}" />
              <TextBlock x:Name="ThemeLabel" Text="DARK" Style="{StaticResource ObsMonoTag}" Foreground="{ThemeResource ObsLightBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <Grid x:Name="ContentRegion" Grid.Row="1"
            uen:Region.Attached="True"
            uen:Region.Navigator="Visibility" />
    </Grid>

  </NavigationView>

</Page>
