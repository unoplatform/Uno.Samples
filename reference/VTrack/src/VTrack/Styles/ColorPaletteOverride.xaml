<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>

    <!--
      Editorial / field-journal palette: warm parchment background, deep forest
      green text and outlines, muted olive secondary for italic emphasis, and a
      terracotta tertiary used as the "+" accent on capability marks.
    -->
    <ResourceDictionary x:Key="Light">
      <!-- Primary: deep forest — active step pill, prominent buttons -->
      <Color x:Key="PrimaryColor">#2C3A2A</Color>
      <Color x:Key="OnPrimaryColor">#EFE7D5</Color>
      <Color x:Key="PrimaryContainerColor">#2C3A2A</Color>
      <Color x:Key="OnPrimaryContainerColor">#EFE7D5</Color>

      <!-- Secondary: muted olive — italic emphasis, secondary actions -->
      <Color x:Key="SecondaryColor">#5F6E47</Color>
      <Color x:Key="OnSecondaryColor">#EFE7D5</Color>
      <Color x:Key="SecondaryContainerColor">#E2D8BF</Color>
      <Color x:Key="OnSecondaryContainerColor">#2C3A2A</Color>

      <!-- Tertiary: terracotta — the "+" accent / link / alert -->
      <Color x:Key="TertiaryColor">#B83D2B</Color>
      <Color x:Key="OnTertiaryColor">#EFE7D5</Color>
      <Color x:Key="TertiaryContainerColor">#F1DECF</Color>
      <Color x:Key="OnTertiaryContainerColor">#B83D2B</Color>

      <Color x:Key="ErrorColor">#B83D2B</Color>
      <Color x:Key="OnErrorColor">#EFE7D5</Color>
      <Color x:Key="ErrorContainerColor">#F1DECF</Color>
      <Color x:Key="OnErrorContainerColor">#B83D2B</Color>

      <!-- Surfaces: parchment family -->
      <Color x:Key="BackgroundColor">#EFE7D5</Color>
      <Color x:Key="OnBackgroundColor">#1F2A1F</Color>
      <Color x:Key="SurfaceColor">#EFE7D5</Color>
      <Color x:Key="OnSurfaceColor">#1F2A1F</Color>
      <Color x:Key="SurfaceVariantColor">#E2D8BF</Color>
      <Color x:Key="OnSurfaceVariantColor">#6E6850</Color>

      <!-- Outlines: a strong olive border + a weaker variant for separators -->
      <Color x:Key="OutlineColor">#2C3A2A</Color>
      <Color x:Key="OutlineVariantColor">#B7AE96</Color>

      <Color x:Key="OnSurfaceInverseColor">#EFE7D5</Color>
      <Color x:Key="SurfaceInverseColor">#2C3A2A</Color>
      <Color x:Key="PrimaryInverseColor">#A8C0A4</Color>
      <Color x:Key="SurfaceTintColor">#2C3A2A</Color>
    </ResourceDictionary>

    <!--
      Dark palette retained for completeness. The app forces Light via
      RequestedTheme in App.xaml, so this is not currently displayed.
    -->
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#A8C0A4</Color>
      <Color x:Key="OnPrimaryColor">#1F2A1F</Color>
      <Color x:Key="PrimaryContainerColor">#2C3A2A</Color>
      <Color x:Key="OnPrimaryContainerColor">#EFE7D5</Color>
      <Color x:Key="SecondaryColor">#B0BD93</Color>
      <Color x:Key="OnSecondaryColor">#1F2A1F</Color>
      <Color x:Key="SecondaryContainerColor">#3A4A30</Color>
      <Color x:Key="OnSecondaryContainerColor">#EFE7D5</Color>
      <Color x:Key="TertiaryColor">#E89B85</Color>
      <Color x:Key="OnTertiaryColor">#1F2A1F</Color>
      <Color x:Key="TertiaryContainerColor">#7A2B1E</Color>
      <Color x:Key="OnTertiaryContainerColor">#F1DECF</Color>
      <Color x:Key="ErrorColor">#E89B85</Color>
      <Color x:Key="OnErrorColor">#1F2A1F</Color>
      <Color x:Key="ErrorContainerColor">#7A2B1E</Color>
      <Color x:Key="OnErrorContainerColor">#F1DECF</Color>
      <Color x:Key="BackgroundColor">#1A201A</Color>
      <Color x:Key="OnBackgroundColor">#E6E1D2</Color>
      <Color x:Key="SurfaceColor">#1A201A</Color>
      <Color x:Key="OnSurfaceColor">#E6E1D2</Color>
      <Color x:Key="SurfaceVariantColor">#2A322A</Color>
      <Color x:Key="OnSurfaceVariantColor">#B7AE96</Color>
      <Color x:Key="OutlineColor">#A8C0A4</Color>
      <Color x:Key="OutlineVariantColor">#4A5A4A</Color>
      <Color x:Key="OnSurfaceInverseColor">#1A201A</Color>
      <Color x:Key="SurfaceInverseColor">#E6E1D2</Color>
      <Color x:Key="PrimaryInverseColor">#2C3A2A</Color>
      <Color x:Key="SurfaceTintColor">#A8C0A4</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
