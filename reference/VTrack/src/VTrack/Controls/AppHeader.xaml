<UserControl x:Class="VTrack.Controls.AppHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Brand: small forest disc + tracked mono wordmark -->
        <StackPanel Grid.Row="0"
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
            <Ellipse Width="14"
                     Height="14"
                     Fill="{ThemeResource PrimaryBrush}" />
            <TextBlock Text="FAUNAL"
                       FontFamily="{StaticResource FaunalMonoFontFamily}"
                       FontSize="13"
                       CharacterSpacing="300"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Right-side status pill -->
        <Border Grid.Row="0"
                Grid.Column="2"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,6"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot"
                         Width="6"
                         Height="6"
                         Fill="{ThemeResource OutlineVariantBrush}"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusLabel"
                           Text="no recording loaded"
                           Style="{StaticResource FaunalCaption}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Step tabs row, right-aligned -->
        <StackPanel Grid.Row="1"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right">
            <Border x:Name="Tab1"
                    Padding="14,7"
                    CornerRadius="2">
                <TextBlock x:Name="Tab1Label"
                           Text="01 · IMPORT"
                           FontFamily="{StaticResource FaunalMonoFontFamily}"
                           FontSize="11"
                           CharacterSpacing="200"
                           FontWeight="SemiBold" />
            </Border>
            <Border x:Name="Tab2"
                    Padding="14,7"
                    CornerRadius="2">
                <TextBlock x:Name="Tab2Label"
                           Text="02 · IDENTIFY"
                           FontFamily="{StaticResource FaunalMonoFontFamily}"
                           FontSize="11"
                           CharacterSpacing="200" />
            </Border>
            <Border x:Name="Tab3"
                    Padding="14,7"
                    CornerRadius="2">
                <TextBlock x:Name="Tab3Label"
                           Text="03 · NO MATCH"
                           FontFamily="{StaticResource FaunalMonoFontFamily}"
                           FontSize="11"
                           CharacterSpacing="200" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
