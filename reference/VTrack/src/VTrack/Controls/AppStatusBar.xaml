<UserControl x:Class="VTrack.Controls.AppStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Padding="32,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left cluster: app state + media name -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <TextBlock x:Name="StateLabel"
                           Text="READY"
                           Style="{StaticResource FaunalCaption}"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           FontWeight="SemiBold"
                           CharacterSpacing="200" />
                <TextBlock Text="·"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock x:Name="MediaLabel"
                           Text="no recording loaded"
                           Style="{StaticResource FaunalCaption}" />
            </StackPanel>

            <!-- Right cluster: engine · frame · model · version -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <TextBlock x:Name="EngineLabel"
                           Text="OpenCL · GPU"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock Text="·"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock x:Name="FrameLabel"
                           Text="F 000 / 000"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock Text="·"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock x:Name="ModelLabel"
                           Text="iNat-2024.11"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock Text="·"
                           Style="{StaticResource FaunalCaption}" />
                <TextBlock x:Name="VersionLabel"
                           Text="v0.2.0"
                           Style="{StaticResource FaunalCaption}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
