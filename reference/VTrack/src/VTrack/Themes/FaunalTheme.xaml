<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Editorial / field-journal type system. Two families:
        – Serif for hero + reading copy (system Cambria, Georgia fallback)
        – Mono for UI labels, status, metadata (Cascadia Mono on Win11, Consolas fallback)
      Both are Windows-stock; no font assets shipped.
    -->
    <FontFamily x:Key="FaunalSerifFontFamily">Cambria, Georgia, serif</FontFamily>
    <FontFamily x:Key="FaunalMonoFontFamily">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

    <!-- Hero / display: serif, large, with room for italic emphasis runs. -->
    <Style x:Key="FaunalDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalSerifFontFamily}" />
        <Setter Property="FontSize" Value="56" />
        <Setter Property="LineHeight" Value="68" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FaunalDisplaySmall" TargetType="TextBlock" BasedOn="{StaticResource FaunalDisplay}">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="LineHeight" Value="44" />
    </Style>

    <!-- Section heading above hero: tracked uppercase mono, separator dots between words. -->
    <Style x:Key="FaunalEyebrow" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="250" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
    </Style>

    <!-- Body copy: serif at a reading size. -->
    <Style x:Key="FaunalBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalSerifFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- UI label / button text: mono, tracked uppercase. -->
    <Style x:Key="FaunalLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="200" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
    </Style>

    <!-- Small mono caption for metadata + status. -->
    <Style x:Key="FaunalCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="50" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
    </Style>

    <!-- Mono prose at body weight (for video name, query input echo, etc.). -->
    <Style x:Key="FaunalMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
    </Style>

    <!--
      Editorial outlined button: thin dark border, no fill, tracked mono uppercase label,
      generous padding. Hover/press just deepen the border + add a faint surface-variant
      fill — no Material elevation or ripple.
    -->
    <Style x:Key="FaunalButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="250" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="28,12" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter x:Name="ContentPresenter"
                                          Padding="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource SurfaceVariantBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource SecondaryContainerBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="ContentPresenter.Opacity" Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled variant: dark fill + cream text, for primary actions in dense UIs. -->
    <Style x:Key="FaunalFilledButton" TargetType="Button" BasedOn="{StaticResource FaunalButton}">
        <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}" />
    </Style>

    <!-- Icon-only transport-style button — square, no padding, mono glyph. -->
    <Style x:Key="FaunalIconButton" TargetType="Button" BasedOn="{StaticResource FaunalButton}">
        <Setter Property="Padding" Value="10" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

    <!-- Editorial TextBox: thin underline, mono input, no Material fill. -->
    <Style x:Key="FaunalTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FaunalMonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0,8" />
    </Style>

</ResourceDictionary>
