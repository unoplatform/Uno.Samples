<Page x:Class="VTrack.Presentation.VideoAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:VTrack.Controls"
      xmlns:local="using:VTrack.Presentation"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:AppHeader Grid.Row="0"
                            ActiveStep="2"
                            StatusText="{Binding VideoName}"
                            IsRecordingLoaded="True" />

        <!-- ============================ Main analysis area ============================ -->
        <Grid Grid.Row="1"
              Padding="32,8,32,24"
              ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Left: video stage + transport -->
            <Grid Grid.Column="0"
                  RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Back link + recording label -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="← BACK"
                            Style="{StaticResource FaunalButton}"
                            Padding="14,6"
                            Command="{Binding GoBack}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="RECORDING"
                                   Style="{StaticResource FaunalCaption}"
                                   CharacterSpacing="300" />
                        <TextBlock Text="·"
                                   Style="{StaticResource FaunalCaption}" />
                        <TextBlock Text="{Binding VideoName}"
                                   Style="{StaticResource FaunalMono}"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>

                <!-- Video stage: thin outlined frame, parchment bg, canvas inside -->
                <Border Grid.Row="1"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="1"
                        Background="#0A0F0A">
                    <Grid>
                        <local:VideoOverlayCanvas x:Name="VideoCanvas"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />

                        <Border Background="{ThemeResource SurfaceBrush}"
                                BorderBrush="{ThemeResource OutlineBrush}"
                                BorderThickness="1"
                                Visibility="{Binding MediaError, Converter={StaticResource NullToCollapsedConverter}}"
                                Padding="16,12"
                                Margin="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="·"
                                           FontFamily="{StaticResource FaunalMonoFontFamily}"
                                           FontSize="18"
                                           Foreground="{ThemeResource TertiaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding MediaError}"
                                           Style="{StaticResource FaunalMono}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Transport bar -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource OutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="20,12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding PlayPause}"
                                Style="{StaticResource FaunalIconButton}">
                            <TextBlock Text="{Binding PlayPauseIcon}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                        </Button>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentTimeText}"
                                   Style="{StaticResource FaunalMono}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   MinWidth="48" />

                        <Slider x:Name="TimelineSlider"
                                Grid.Column="2"
                                Minimum="0"
                                Maximum="{Binding VideoDuration}"
                                ValueChanged="OnTimelineSliderValueChanged"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />

                        <TextBlock Grid.Column="3"
                                   Text="{Binding DurationText}"
                                   Style="{StaticResource FaunalMono}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   MinWidth="48" />

                        <Button Grid.Column="4"
                                Command="{Binding ToggleMute}"
                                Style="{StaticResource FaunalIconButton}">
                            <TextBlock Text="{Binding MuteIcon}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: tracking sidebar -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="1"
                    Padding="24,22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="20">

                        <!-- Query section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="IDENTIFY SPECIES"
                                       Style="{StaticResource FaunalEyebrow}"
                                       CharacterSpacing="300"
                                       x:Uid="VideoAnalysis.QueryTitle" />
                            <TextBlock Style="{StaticResource FaunalBody}"
                                       FontSize="14"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       x:Uid="VideoAnalysis.QueryHint">
                                <Run Text="Name the " />
                                <Run Text="taxon"
                                     FontStyle="Italic"
                                     Foreground="{ThemeResource SecondaryBrush}" />
                                <Run Text=" you want to find." />
                            </TextBlock>
                            <TextBox Text="{Binding QueryText, Mode=TwoWay}"
                                     PlaceholderText="deer · bear · bird · all"
                                     Style="{StaticResource FaunalTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="64"
                                     x:Uid="VideoAnalysis.QueryInput" />
                            <Button Content="START IDENTIFICATION"
                                    Style="{StaticResource FaunalFilledButton}"
                                    Command="{Binding StartTracking}"
                                    IsEnabled="{Binding CanStartTracking}"
                                    HorizontalAlignment="Stretch"
                                    x:Uid="VideoAnalysis.StartButton" />
                        </StackPanel>

                        <!-- Processing -->
                        <StackPanel Spacing="8"
                                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="IDENTIFYING"
                                       Style="{StaticResource FaunalEyebrow}"
                                       CharacterSpacing="300" />
                            <ProgressBar Value="{Binding ProcessingProgress}"
                                         Maximum="100"
                                         Background="{ThemeResource OutlineVariantBrush}"
                                         Foreground="{ThemeResource PrimaryBrush}" />
                        </StackPanel>

                        <!-- Detections -->
                        <StackPanel Spacing="10"
                                    Visibility="{Binding HasSubjects, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Line X1="0"
                                  Y1="0"
                                  X2="1"
                                  Y2="0"
                                  Stretch="Fill"
                                  Stroke="{ThemeResource OutlineVariantBrush}"
                                  StrokeThickness="1"
                                  StrokeDashArray="1,3"
                                  Height="1" />
                            <TextBlock Text="OBSERVATIONS"
                                       Style="{StaticResource FaunalEyebrow}"
                                       CharacterSpacing="300"
                                       x:Uid="VideoAnalysis.SubjectsTitle" />
                            <ListView ItemsSource="{Binding TrackedSubjects}"
                                      SelectionMode="None"
                                      Background="Transparent"
                                      Padding="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0,6" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding Color}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Label}"
                                                       FontFamily="{StaticResource FaunalMonoFontFamily}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Confidence, Converter={StaticResource PercentageConverter}}"
                                                       FontFamily="{StaticResource FaunalMonoFontFamily}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TertiaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <!-- Empty state -->
                        <StackPanel Spacing="8"
                                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                    HorizontalAlignment="Center"
                                    Padding="0,16">
                            <Line X1="0"
                                  Y1="0"
                                  X2="1"
                                  Y2="0"
                                  Stretch="Fill"
                                  Stroke="{ThemeResource OutlineVariantBrush}"
                                  StrokeThickness="1"
                                  StrokeDashArray="1,3"
                                  Height="1" />
                            <TextBlock Text="NO OBSERVATIONS YET"
                                       Style="{StaticResource FaunalEyebrow}"
                                       CharacterSpacing="300"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"
                                       x:Uid="VideoAnalysis.EmptyState" />
                            <TextBlock Text="name a species above to begin"
                                       Style="{StaticResource FaunalCaption}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <controls:AppStatusBar Grid.Row="2"
                               State="IDENTIFYING"
                               Media="{Binding VideoName}"
                               Frame="{Binding FrameCounterText}" />
    </Grid>
</Page>
