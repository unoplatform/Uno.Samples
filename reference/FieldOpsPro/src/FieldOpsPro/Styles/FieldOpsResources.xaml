<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ================================================== -->
  <!-- FIELDOPS PRO MONOCHROMATIC THEME (Dark + Light)    -->
  <!-- Theme keys: "Default" = Dark, "Light" = inverted   -->
  <!-- (the memory note: dark key must be "Default", not  -->
  <!-- "Dark", or ThemeResource in Style setters silently -->
  <!-- fails for panel bg/border)                          -->
  <!-- ================================================== -->

  <ResourceDictionary.ThemeDictionaries>

    <!-- ============== DARK (Default) ============== -->
    <ResourceDictionary x:Key="Default">

      <!-- Backgrounds -->
      <Color x:Key="BgPrimary">#000000</Color>
      <Color x:Key="BgSecondary">#0A0A0A</Color>
      <Color x:Key="BgTertiary">#141414</Color>
      <Color x:Key="BgCard">#0D0D0D</Color>
      <Color x:Key="BgElevated">#1A1A1A</Color>
      <Color x:Key="BgElevated2">#2A2A2A</Color>

      <!-- Accents -->
      <Color x:Key="AccentPrimary">#FFFFFF</Color>
      <Color x:Key="AccentSecondary">#C0C0C0</Color>
      <Color x:Key="AccentTertiary">#808080</Color>
      <Color x:Key="AccentCream">#F0F0F0</Color>
      <Color x:Key="AccentMedium">#909090</Color>

      <!-- Text -->
      <Color x:Key="TextPrimary">#FFFFFF</Color>
      <Color x:Key="TextSecondary">#A0A0A0</Color>
      <Color x:Key="TextMuted">#606060</Color>
      <Color x:Key="TextOnAccent">#000000</Color>
      <Color x:Key="TextDisabled">#909090</Color>
      <Color x:Key="TextFaint">#707070</Color>

      <!-- Semantic (still greyscale in mono) -->
      <Color x:Key="Success">#E0E0E0</Color>
      <Color x:Key="Warning">#B0B0B0</Color>
      <Color x:Key="Danger">#909090</Color>
      <Color x:Key="Info">#C0C0C0</Color>

      <!-- Borders -->
      <Color x:Key="BorderColor">#252525</Color>
      <Color x:Key="BorderSubtle">#1A1A1A</Color>
      <Color x:Key="BorderStrong">#404040</Color>
      <Color x:Key="BorderHover">#505050</Color>

      <!-- Misc -->
      <Color x:Key="Gray200">#E0E0E0</Color>
      <Color x:Key="SlaCriticalBg">#303030</Color>
      <Color x:Key="SlaWarningBg">#202020</Color>

      <!-- SolidColorBrushes -->
      <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
      <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
      <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}" />
      <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
      <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
      <SolidColorBrush x:Key="BgElevated2Brush" Color="{StaticResource BgElevated2}" />
      <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
      <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />
      <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{StaticResource AccentTertiary}" />
      <SolidColorBrush x:Key="AccentCreamBrush" Color="{StaticResource AccentCream}" />
      <SolidColorBrush x:Key="AccentMediumBrush" Color="{StaticResource AccentMedium}" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
      <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccent}" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />
      <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaint}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
      <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />
      <SolidColorBrush x:Key="BorderColorBrush" Color="{StaticResource BorderColor}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
      <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHover}" />
      <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
      <SolidColorBrush x:Key="SlaCriticalBgBrush" Color="{StaticResource SlaCriticalBg}" />
      <SolidColorBrush x:Key="SlaWarningBgBrush" Color="{StaticResource SlaWarningBg}" />

      <!-- Card hover background (TaskCard) -->
      <LinearGradientBrush x:Key="CardHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1F1F1F" Offset="0" />
        <GradientStop Color="#151515" Offset="1" />
      </LinearGradientBrush>

      <!-- QuickActionButton surface gradients -->
      <LinearGradientBrush x:Key="QuickActionGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BgElevated}" Offset="0" />
        <GradientStop Color="{StaticResource BgCard}" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="QuickActionHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BorderColor}" Offset="0" />
        <GradientStop Color="{StaticResource BgElevated}" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="QuickActionPressedGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SlaCriticalBg}" Offset="0" />
        <GradientStop Color="{StaticResource BorderColor}" Offset="1" />
      </LinearGradientBrush>

      <!-- Avatar gradients (dark monochromatic surfaces) -->
      <LinearGradientBrush x:Key="AvatarOrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A2A2A" Offset="0" />
        <GradientStop Color="#1A1A1A" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarCyanGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#303030" Offset="0" />
        <GradientStop Color="#202020" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarPurpleGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#282828" Offset="0" />
        <GradientStop Color="#181818" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarPinkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#353535" Offset="0" />
        <GradientStop Color="#252525" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarBlueGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2D2D2D" Offset="0" />
        <GradientStop Color="#1D1D1D" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarGreenGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#323232" Offset="0" />
        <GradientStop Color="#222222" Offset="1" />
      </LinearGradientBrush>

    </ResourceDictionary>

    <!-- ============== LIGHT (inverted monochrome) ============== -->
    <ResourceDictionary x:Key="Light">

      <!-- Backgrounds (white-toned surfaces) -->
      <Color x:Key="BgPrimary">#FFFFFF</Color>
      <Color x:Key="BgSecondary">#F7F7F7</Color>
      <Color x:Key="BgTertiary">#F0F0F0</Color>
      <Color x:Key="BgCard">#FAFAFA</Color>
      <Color x:Key="BgElevated">#EEEEEE</Color>
      <Color x:Key="BgElevated2">#DCDCDC</Color>

      <!-- Accents (black/dark-grey emphasis on light) -->
      <Color x:Key="AccentPrimary">#0A0A0A</Color>
      <Color x:Key="AccentSecondary">#404040</Color>
      <Color x:Key="AccentTertiary">#707070</Color>
      <Color x:Key="AccentCream">#1A1A1A</Color>
      <Color x:Key="AccentMedium">#6A6A6A</Color>

      <!-- Text -->
      <Color x:Key="TextPrimary">#0A0A0A</Color>
      <Color x:Key="TextSecondary">#5A5A5A</Color>
      <Color x:Key="TextMuted">#8A8A8A</Color>
      <Color x:Key="TextOnAccent">#FFFFFF</Color>
      <Color x:Key="TextDisabled">#B0B0B0</Color>
      <Color x:Key="TextFaint">#8A8A8A</Color>

      <!-- Semantic (mid-grey in light) -->
      <Color x:Key="Success">#2A2A2A</Color>
      <Color x:Key="Warning">#4A4A4A</Color>
      <Color x:Key="Danger">#6A6A6A</Color>
      <Color x:Key="Info">#3F3F3F</Color>

      <!-- Borders -->
      <Color x:Key="BorderColor">#DDDDDD</Color>
      <Color x:Key="BorderSubtle">#ECECEC</Color>
      <Color x:Key="BorderStrong">#B5B5B5</Color>
      <Color x:Key="BorderHover">#999999</Color>

      <!-- Misc -->
      <Color x:Key="Gray200">#2A2A2A</Color>
      <Color x:Key="SlaCriticalBg">#D5D5D5</Color>
      <Color x:Key="SlaWarningBg">#E2E2E2</Color>

      <!-- SolidColorBrushes (identical keys, light values) -->
      <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
      <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
      <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}" />
      <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
      <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
      <SolidColorBrush x:Key="BgElevated2Brush" Color="{StaticResource BgElevated2}" />
      <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
      <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />
      <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{StaticResource AccentTertiary}" />
      <SolidColorBrush x:Key="AccentCreamBrush" Color="{StaticResource AccentCream}" />
      <SolidColorBrush x:Key="AccentMediumBrush" Color="{StaticResource AccentMedium}" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
      <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccent}" />
      <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />
      <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaint}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
      <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />
      <SolidColorBrush x:Key="BorderColorBrush" Color="{StaticResource BorderColor}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
      <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHover}" />
      <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
      <SolidColorBrush x:Key="SlaCriticalBgBrush" Color="{StaticResource SlaCriticalBg}" />
      <SolidColorBrush x:Key="SlaWarningBgBrush" Color="{StaticResource SlaWarningBg}" />

      <!-- Card hover background (light: a slight darken on hover) -->
      <LinearGradientBrush x:Key="CardHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8E8E8" Offset="0" />
        <GradientStop Color="#DEDEDE" Offset="1" />
      </LinearGradientBrush>

      <!-- QuickActionButton surface gradients (use light theme tokens) -->
      <LinearGradientBrush x:Key="QuickActionGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BgElevated}" Offset="0" />
        <GradientStop Color="{StaticResource BgCard}" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="QuickActionHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BorderColor}" Offset="0" />
        <GradientStop Color="{StaticResource BgElevated}" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="QuickActionPressedGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SlaCriticalBg}" Offset="0" />
        <GradientStop Color="{StaticResource BorderColor}" Offset="1" />
      </LinearGradientBrush>

      <!-- Avatar gradients (light monochromatic surfaces; inverted from dark) -->
      <LinearGradientBrush x:Key="AvatarOrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DCDCDC" Offset="0" />
        <GradientStop Color="#EEEEEE" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarCyanGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D5D5D5" Offset="0" />
        <GradientStop Color="#E2E2E2" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarPurpleGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DADADA" Offset="0" />
        <GradientStop Color="#EAEAEA" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarPinkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#CECECE" Offset="0" />
        <GradientStop Color="#DDDDDD" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarBlueGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D7D7D7" Offset="0" />
        <GradientStop Color="#E7E7E7" Offset="1" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="AvatarGreenGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D2D2D2" Offset="0" />
        <GradientStop Color="#E2E2E2" Offset="1" />
      </LinearGradientBrush>

    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- ======================= -->
  <!-- FONT SIZE RAMP (not theme-varying) -->
  <!-- ======================= -->
  <x:Double x:Key="FontDisplayLarge">42</x:Double>
  <x:Double x:Key="FontDisplayMedium">32</x:Double>
  <x:Double x:Key="FontDisplaySmall">26</x:Double>
  <x:Double x:Key="FontHeadlineLarge">22</x:Double>
  <x:Double x:Key="FontHeadlineMedium">20</x:Double>
  <x:Double x:Key="FontTitleLarge">18</x:Double>
  <x:Double x:Key="FontTitleMedium">16</x:Double>
  <x:Double x:Key="FontBodyLarge">14</x:Double>
  <x:Double x:Key="FontBodyMedium">13</x:Double>
  <x:Double x:Key="FontBodySmall">12</x:Double>
  <x:Double x:Key="FontLabelMedium">11</x:Double>
  <x:Double x:Key="FontLabelSmall">10</x:Double>
  <x:Double x:Key="FontLabelTiny">9</x:Double>

  <!-- ======================= -->
  <!-- SPACING -->
  <!-- ======================= -->
  <x:Double x:Key="Space1">4</x:Double>
  <x:Double x:Key="Space2">8</x:Double>
  <x:Double x:Key="Space3">12</x:Double>
  <x:Double x:Key="Space4">16</x:Double>
  <x:Double x:Key="Space5">20</x:Double>
  <x:Double x:Key="Space6">24</x:Double>
  <x:Double x:Key="Space8">32</x:Double>
  <x:Double x:Key="Space10">40</x:Double>
  <x:Double x:Key="Space12">48</x:Double>

  <Thickness x:Key="CardPadding">24</Thickness>
  <Thickness x:Key="PagePadding">40,32,40,32</Thickness>
  <Thickness x:Key="MobilePagePadding">24,16,24,16</Thickness>

  <!-- ======================= -->
  <!-- CORNER RADIUS -->
  <!-- ======================= -->
  <CornerRadius x:Key="RadiusSm">4</CornerRadius>
  <CornerRadius x:Key="RadiusMd">8</CornerRadius>
  <CornerRadius x:Key="RadiusLg">12</CornerRadius>
  <CornerRadius x:Key="RadiusXl">16</CornerRadius>
  <CornerRadius x:Key="Radius2Xl">20</CornerRadius>
  <CornerRadius x:Key="RadiusPill">999</CornerRadius>

  <!-- ======================= -->
  <!-- TYPOGRAPHY STYLES (theme-aware foregrounds via ThemeResource) -->
  <!-- ======================= -->

  <Style x:Key="PageTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    <Setter Property="CharacterSpacing" Value="20" />
  </Style>

  <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    <Setter Property="CharacterSpacing" Value="40" />
  </Style>

  <Style x:Key="CardTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="BodyStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
  </Style>

  <Style x:Key="BodyMediumStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="CaptionStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
    <Setter Property="CharacterSpacing" Value="60" />
  </Style>

  <Style x:Key="StatValueStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="StatValueSmallStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
  </Style>

  <Style x:Key="MonoLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
    <Setter Property="CharacterSpacing" Value="80" />
  </Style>

  <Style x:Key="NavLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
  </Style>

  <Style x:Key="AccentTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource AccentPrimaryBrush}" />
  </Style>

  <!-- ======================= -->
  <!-- CARD STYLES -->
  <!-- ======================= -->

  <Style x:Key="FieldOpsCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource BgCardBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
  </Style>

  <Style x:Key="FieldOpsCardSmallStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource BgCardBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style x:Key="ListItemCardStyle" TargetType="Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="16,12" />
  </Style>

  <Style x:Key="GlassCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource BgElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <!-- ======================= -->
  <!-- BUTTON STYLES -->
  <!-- ======================= -->

  <Style x:Key="PrimaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{ThemeResource AccentPrimaryBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource TextOnAccentBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="20,12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style x:Key="SecondaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{ThemeResource BgTertiaryBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="20,12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style x:Key="OutlineButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style x:Key="IconButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style x:Key="PillIconButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
    <Setter Property="Padding" Value="14,10" />
  </Style>

  <Style x:Key="GhostButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="CharacterSpacing" Value="60" />
  </Style>

  <Style x:Key="MobileNavButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <!-- ======================= -->
  <!-- BADGE STYLES -->
  <!-- ======================= -->

  <Style x:Key="CountBadgeStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource AccentPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="MinWidth" Value="18" />
  </Style>

  <Style x:Key="CountBadgeTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{ThemeResource TextOnAccentBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="StatusBadgeStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- ======================= -->
  <!-- INPUT STYLES -->
  <!-- ======================= -->

  <Style x:Key="SearchBoxStyle" TargetType="Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource BorderColorBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
    <Setter Property="Padding" Value="14,10" />
  </Style>

  <Style x:Key="FilterTabButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{ThemeResource AccentTertiaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
