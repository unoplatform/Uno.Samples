<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- FieldOps Pro Monochromatic Theme - Black, White, Shades of Grey -->
  <ResourceDictionary.ThemeDictionaries>

    <!-- Dark Theme (Primary) -->
    <ResourceDictionary x:Key="Dark">
      <!-- Primary: Pure White accent -->
      <Color x:Key="PrimaryColor">#FFFFFF</Color>
      <Color x:Key="OnPrimaryColor">#000000</Color>
      <Color x:Key="PrimaryContainerColor">#1A1A1A</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFFFFF</Color>

      <!-- Secondary: Light Grey -->
      <Color x:Key="SecondaryColor">#E0E0E0</Color>
      <Color x:Key="OnSecondaryColor">#000000</Color>
      <Color x:Key="SecondaryContainerColor">#252525</Color>
      <Color x:Key="OnSecondaryContainerColor">#E0E0E0</Color>

      <!-- Tertiary: Medium Grey -->
      <Color x:Key="TertiaryColor">#808080</Color>
      <Color x:Key="OnTertiaryColor">#000000</Color>
      <Color x:Key="TertiaryContainerColor">#1A1A1A</Color>
      <Color x:Key="OnTertiaryContainerColor">#808080</Color>

      <!-- Error: Dark Grey (muted) -->
      <Color x:Key="ErrorColor">#B0B0B0</Color>
      <Color x:Key="ErrorContainerColor">#1A1A1A</Color>
      <Color x:Key="OnErrorColor">#000000</Color>
      <Color x:Key="OnErrorContainerColor">#B0B0B0</Color>

      <!-- Surfaces: Pure blacks and dark greys -->
      <Color x:Key="BackgroundColor">#000000</Color>
      <Color x:Key="OnBackgroundColor">#FFFFFF</Color>
      <Color x:Key="SurfaceColor">#0A0A0A</Color>
      <Color x:Key="OnSurfaceColor">#FFFFFF</Color>
      <Color x:Key="SurfaceVariantColor">#141414</Color>
      <Color x:Key="OnSurfaceVariantColor">#909090</Color>

      <!-- Outline: Thin subtle lines -->
      <Color x:Key="OutlineColor">#2A2A2A</Color>
      <Color x:Key="OutlineVariantColor">#1A1A1A</Color>
      <Color x:Key="SurfaceInverseColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceInverseColor">#000000</Color>
      <Color x:Key="PrimaryInverseColor">#FFFFFF</Color>
      <Color x:Key="SurfaceTintColor">#FFFFFF</Color>
    </ResourceDictionary>

    <!-- Light Theme -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#000000</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#F0F0F0</Color>
      <Color x:Key="OnPrimaryContainerColor">#000000</Color>

      <Color x:Key="SecondaryColor">#404040</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E8E8E8</Color>
      <Color x:Key="OnSecondaryContainerColor">#404040</Color>

      <Color x:Key="TertiaryColor">#808080</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#F5F5F5</Color>
      <Color x:Key="OnTertiaryContainerColor">#606060</Color>

      <Color x:Key="ErrorColor">#606060</Color>
      <Color x:Key="ErrorContainerColor">#E8E8E8</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#404040</Color>

      <Color x:Key="BackgroundColor">#FFFFFF</Color>
      <Color x:Key="OnBackgroundColor">#000000</Color>
      <Color x:Key="SurfaceColor">#FAFAFA</Color>
      <Color x:Key="OnSurfaceColor">#000000</Color>
      <Color x:Key="SurfaceVariantColor">#F5F5F5</Color>
      <Color x:Key="OnSurfaceVariantColor">#606060</Color>

      <Color x:Key="OutlineColor">#E0E0E0</Color>
      <Color x:Key="OutlineVariantColor">#EBEBEB</Color>
      <Color x:Key="SurfaceInverseColor">#000000</Color>
      <Color x:Key="OnSurfaceInverseColor">#FFFFFF</Color>
      <Color x:Key="PrimaryInverseColor">#000000</Color>
      <Color x:Key="SurfaceTintColor">#000000</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
