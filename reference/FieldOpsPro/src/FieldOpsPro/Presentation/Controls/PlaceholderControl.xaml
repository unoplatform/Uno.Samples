<UserControl x:Class="FieldOpsPro.Presentation.Controls.PlaceholderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Grid Background="{ThemeResource BgPrimaryBrush}">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="20"
                MaxWidth="420">
      <Border Width="88"
              Height="88"
              CornerRadius="24"
              Background="{ThemeResource BgCardBrush}"
              BorderBrush="{ThemeResource BorderColorBrush}"
              BorderThickness="1"
              HorizontalAlignment="Center">
        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  FontSize="{StaticResource FontDisplaySmall}"
                  Foreground="{ThemeResource TextSecondaryBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
      </Border>

      <TextBlock Style="{StaticResource PageTitleStyle}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 Text="{x:Bind Title, Mode=OneWay}" />

      <TextBlock Text="This section is coming soon."
                 Style="{StaticResource BodyStyle}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center" />
    </StackPanel>
  </Grid>
</UserControl>
