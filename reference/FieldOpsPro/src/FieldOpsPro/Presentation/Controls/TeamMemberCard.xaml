<UserControl x:Class="FieldOpsPro.Presentation.Controls.TeamMemberCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited">

  <Border x:Name="CardBorder"
          Background="{ThemeResource BgTertiaryBrush}"
          BorderBrush="Transparent"
          BorderThickness="1"
          CornerRadius="14"
          Padding="16"
          AutomationProperties.Name="{x:Bind Member.Name, Mode=OneWay}">
    <Border.RenderTransform>
      <CompositeTransform x:Name="CardTransform" />
    </Border.RenderTransform>

    <Grid ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Avatar (initials/color/status all bound through to the Avatar control) -->
      <local:Avatar Grid.Column="0"
                    Size="44"
                    VerticalAlignment="Center"
                    Initials="{x:Bind Member.Initials, Mode=OneWay}"
                    AvatarColor="{x:Bind Member.AvatarColor, Mode=OneWay}"
                    Status="{x:Bind Member.Status, Mode=OneWay}" />

      <!-- Member Info -->
      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Spacing="2">
        <TextBlock Style="{StaticResource BodyMediumStyle}"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   Text="{x:Bind Member.Name, Mode=OneWay}" />
        <TextBlock Style="{StaticResource CaptionStyle}"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   Text="{x:Bind Member.LocationDescription, Mode=OneWay}" />
      </StackPanel>

      <!-- Device Status Indicators -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">

        <!-- Signal Strength: each bar's brush picked per signal level via x:Bind method -->
        <Grid Width="20" Height="16" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal"
                      Spacing="2"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom">
            <Border Width="3" Height="4"
                    CornerRadius="1"
                    VerticalAlignment="Bottom"
                    Background="{x:Bind SignalBrush(Member.SignalStrength, 1), Mode=OneWay}" />
            <Border Width="3" Height="7"
                    CornerRadius="1"
                    VerticalAlignment="Bottom"
                    Background="{x:Bind SignalBrush(Member.SignalStrength, 2), Mode=OneWay}" />
            <Border Width="3" Height="10"
                    CornerRadius="1"
                    VerticalAlignment="Bottom"
                    Background="{x:Bind SignalBrush(Member.SignalStrength, 3), Mode=OneWay}" />
            <Border Width="3" Height="14"
                    CornerRadius="1"
                    VerticalAlignment="Bottom"
                    Background="{x:Bind SignalBrush(Member.SignalStrength, 4), Mode=OneWay}" />
          </StackPanel>
        </Grid>

        <!-- Battery Indicator: fill width + brush bound via x:Bind methods on BatteryLevel -->
        <Grid Width="26" Height="14" VerticalAlignment="Center">
          <Border BorderBrush="{ThemeResource TextMutedBrush}"
                  BorderThickness="1"
                  CornerRadius="2"
                  Width="22"
                  Height="12"
                  HorizontalAlignment="Left">
            <Border CornerRadius="1"
                    Margin="1"
                    HorizontalAlignment="Left"
                    Width="{x:Bind BatteryFillWidth(Member.BatteryLevel), Mode=OneWay}"
                    Background="{x:Bind BatteryBrush(Member.BatteryLevel), Mode=OneWay}" />
          </Border>
          <!-- Battery Cap -->
          <Border Background="{ThemeResource TextMutedBrush}"
                  Width="2"
                  Height="6"
                  CornerRadius="0,1,1,0"
                  HorizontalAlignment="Right"
                  Margin="0,0,0,0" />
        </Grid>

        <!-- Low Battery Warning: visible only when level <= 20% -->
        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Glyph="&#xE7BA;"
                  FontSize="{StaticResource FontBodyLarge}"
                  Foreground="{ThemeResource TextPrimaryBrush}"
                  Visibility="{x:Bind LowBatteryVisibility(Member.BatteryLevel), Mode=OneWay}" />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
