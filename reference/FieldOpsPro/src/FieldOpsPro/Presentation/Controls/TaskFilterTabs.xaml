<UserControl x:Class="FieldOpsPro.Presentation.Controls.TaskFilterTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Filter Tabs: each tab's Background+Foreground bound through methods that compare
         its tag to the current SelectedFilter. No code-behind UpdateTabStyles needed. -->
    <Border Grid.Column="0"
            Background="{ThemeResource BgCardBrush}"
            BorderBrush="{ThemeResource BorderColorBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Content="All"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="All"
                Background="{x:Bind TabBackground(SelectedFilter, 'All'), Mode=OneWay}"
                Foreground="{x:Bind TabForeground(SelectedFilter, 'All'), Mode=OneWay}" />
        <Button Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Urgent"
                Background="{x:Bind TabBackground(SelectedFilter, 'Urgent'), Mode=OneWay}"
                Foreground="{x:Bind TabForeground(SelectedFilter, 'Urgent'), Mode=OneWay}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Urgent" VerticalAlignment="Center" />
            <Border Background="{ThemeResource TextPrimaryBrush}"
                    CornerRadius="8"
                    Padding="6,2"
                    MinWidth="20">
              <TextBlock FontSize="{StaticResource FontLabelSmall}"
                         FontWeight="Bold"
                         Foreground="{ThemeResource BgPrimaryBrush}"
                         HorizontalAlignment="Center"
                         Text="{x:Bind UrgentCount, Mode=OneWay}" />
            </Border>
          </StackPanel>
        </Button>
        <Button Content="Scheduled"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Scheduled"
                Background="{x:Bind TabBackground(SelectedFilter, 'Scheduled'), Mode=OneWay}"
                Foreground="{x:Bind TabForeground(SelectedFilter, 'Scheduled'), Mode=OneWay}" />
        <Button Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Unassigned"
                Background="{x:Bind TabBackground(SelectedFilter, 'Unassigned'), Mode=OneWay}"
                Foreground="{x:Bind TabForeground(SelectedFilter, 'Unassigned'), Mode=OneWay}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Unassigned" VerticalAlignment="Center" />
            <Border Background="{ThemeResource TextMutedBrush}"
                    CornerRadius="8"
                    Padding="6,2"
                    MinWidth="20">
              <TextBlock FontSize="{StaticResource FontLabelSmall}"
                         FontWeight="Bold"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"
                         Text="{x:Bind UnassignedCount, Mode=OneWay}" />
            </Border>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- New Task Button -->
    <Button Grid.Column="1"
            Margin="12,0,0,0"
            Background="{ThemeResource TextPrimaryBrush}"
            Foreground="{ThemeResource BgPrimaryBrush}"
            CornerRadius="6"
            Padding="14,8"
            Click="OnNewTaskClick">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Glyph="&#xE710;"
                  FontSize="{StaticResource FontBodyLarge}"
                  Foreground="{ThemeResource BgPrimaryBrush}" />
        <TextBlock Text="New Task"
                   FontSize="{StaticResource FontBodyMedium}"
                   FontWeight="SemiBold" />
      </StackPanel>
    </Button>
  </Grid>
</UserControl>
