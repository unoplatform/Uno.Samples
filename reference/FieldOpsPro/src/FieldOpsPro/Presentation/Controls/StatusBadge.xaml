<UserControl x:Class="FieldOpsPro.Presentation.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border CornerRadius="8"
          Padding="10,5"
          Background="{x:Bind BadgeType, Converter={StaticResource BadgeTypeToBrush}, ConverterParameter=bg, Mode=OneWay}">
    <TextBlock FontSize="{StaticResource FontLabelSmall}"
               FontWeight="SemiBold"
               CharacterSpacing="50"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Text="{x:Bind Text, Converter={StaticResource ToUpper}, Mode=OneWay}"
               Foreground="{x:Bind BadgeType, Converter={StaticResource BadgeTypeToBrush}, ConverterParameter=fg, Mode=OneWay}" />
  </Border>
</UserControl>
