<UserControl x:Class="FieldOpsPro.Presentation.Controls.Avatar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="48"
             d:DesignWidth="48">

  <Grid x:Name="RootGrid">
    <!-- Avatar Background: gradient brush picked per AvatarColor enum via converter -->
    <Border x:Name="AvatarBorder"
            Width="{x:Bind Size, Mode=OneWay}"
            Height="{x:Bind Size, Mode=OneWay}"
            CornerRadius="{x:Bind CornerRadiusFor(Size), Mode=OneWay}"
            Background="{x:Bind AvatarColor, Converter={StaticResource AvatarColorToGradient}, Mode=OneWay}">
      <TextBlock x:Name="InitialsText"
                 Text="{x:Bind Initials, Mode=OneWay}"
                 Foreground="{ThemeResource TextPrimaryBrush}"
                 FontWeight="SemiBold"
                 FontSize="{x:Bind Size, Converter={StaticResource AvatarSizeToFontSize}, Mode=OneWay}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Status Indicator: fill from AgentStatus via converter; stroke is the surrounding card surface -->
    <Ellipse x:Name="StatusIndicator"
             Width="14"
             Height="14"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Margin="0,0,-2,-2"
             StrokeThickness="2"
             Stroke="{ThemeResource BgTertiaryBrush}"
             Fill="{x:Bind Status, Converter={StaticResource AgentStatusToBrush}, Mode=OneWay}"
             Visibility="{x:Bind Status, Converter={StaticResource NullToVisibility}, Mode=OneWay}" />
  </Grid>
</UserControl>
