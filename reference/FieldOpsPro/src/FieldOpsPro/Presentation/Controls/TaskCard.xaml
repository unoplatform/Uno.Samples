<UserControl x:Class="FieldOpsPro.Presentation.Controls.TaskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited">

  <Border x:Name="CardBorder"
          Background="{ThemeResource BgTertiaryBrush}"
          BorderBrush="Transparent"
          BorderThickness="1"
          CornerRadius="14"
          Padding="18"
          AutomationProperties.Name="{x:Bind TaskItem.Title, Mode=OneWay}">
    <Border.RenderTransform>
      <CompositeTransform x:Name="CardTransform" />
    </Border.RenderTransform>

    <Grid RowSpacing="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Priority Indicator (theme-token brush via converter from TaskItem.Priority) -->
        <Border Grid.Column="0"
                Width="4"
                CornerRadius="2"
                VerticalAlignment="Stretch"
                Margin="-18,0,0,0"
                Background="{x:Bind TaskItem.Priority, Converter={StaticResource PriorityToBrush}, Mode=OneWay}" />

        <!-- Task Content -->
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource BodyMediumStyle}"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="2"
                     Text="{x:Bind TaskItem.Title, Mode=OneWay}" />

          <StackPanel Orientation="Horizontal" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon x:Name="LocationIcon"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE707;"
                        FontSize="{StaticResource FontBodySmall}"
                        Foreground="{ThemeResource TextMutedBrush}" />
              <TextBlock Style="{StaticResource CaptionStyle}"
                         TextTrimming="CharacterEllipsis"
                         Text="{x:Bind LocationLabel(TaskItem), Mode=OneWay}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon x:Name="DurationIcon"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE823;"
                        FontSize="{StaticResource FontBodySmall}"
                        Foreground="{ThemeResource TextMutedBrush}" />
              <TextBlock Style="{StaticResource CaptionStyle}"
                         Text="{x:Bind TaskItem.EstimatedDuration, Mode=OneWay}" />
            </StackPanel>

            <!-- SLA Timer (state + flashing animation managed by code-behind) -->
            <Border x:Name="SlaTimerBorder"
                    Background="{ThemeResource BgElevatedBrush}"
                    CornerRadius="4"
                    Padding="6,2"
                    Visibility="Collapsed">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <FontIcon x:Name="SlaIcon"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE121;"
                          FontSize="{StaticResource FontLabelMedium}"
                          Foreground="{ThemeResource AccentSecondaryBrush}" />
                <TextBlock x:Name="SlaTimerText"
                           FontSize="{StaticResource FontLabelMedium}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentSecondaryBrush}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- Assignee Avatar (bound; collapsed when no initials) -->
        <local:Avatar Grid.Column="2"
                      Size="36"
                      VerticalAlignment="Center"
                      Initials="{x:Bind TaskItem.AssigneeInitials, Mode=OneWay}"
                      AvatarColor="{x:Bind TaskItem.AssigneeAvatarColor, Converter={StaticResource AvatarColorOrDefault}, Mode=OneWay}"
                      Visibility="{x:Bind TaskItem.AssigneeInitials, Converter={StaticResource StringToVisibility}, Mode=OneWay}" />

        <!-- Status Badge -->
        <local:StatusBadge Grid.Column="3"
                           VerticalAlignment="Center"
                           Text="{x:Bind TaskItem.Status, Converter={StaticResource StatusToText}, Mode=OneWay}"
                           BadgeType="{x:Bind TaskItem.Status, Converter={StaticResource StatusToBadgeType}, Mode=OneWay}" />
      </Grid>

      <!-- Photo Thumbnails Row (image URL→source still loaded in code-behind) -->
      <StackPanel x:Name="PhotosPanel"
                  Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="8"
                  Margin="4,0,0,0"
                  Visibility="Collapsed">
        <Border x:Name="Photo1"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="{ThemeResource BgElevatedBrush}">
          <Image x:Name="PhotoImage1"
                 Stretch="UniformToFill" />
        </Border>
        <Border x:Name="Photo2"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="{ThemeResource BgElevatedBrush}">
          <Image x:Name="PhotoImage2"
                 Stretch="UniformToFill" />
        </Border>
        <Border x:Name="Photo3"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="{ThemeResource BgElevatedBrush}">
          <Image x:Name="PhotoImage3"
                 Stretch="UniformToFill" />
        </Border>
        <Border x:Name="MorePhotosIndicator"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="{ThemeResource BorderColorBrush}"
                Visibility="Collapsed">
          <TextBlock x:Name="MorePhotosText"
                     FontSize="{StaticResource FontBodySmall}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource AccentTertiaryBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
