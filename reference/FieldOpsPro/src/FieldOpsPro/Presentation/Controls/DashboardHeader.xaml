<UserControl x:Class="FieldOpsPro.Presentation.Controls.DashboardHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <!-- Animations handled in code-behind via DispatcherTimer for cross-platform compatibility -->

  <StackPanel Spacing="16">

    <!-- ========== URGENT ALERT BANNER ========== -->
    <Border x:Name="AlertBanner"
            Background="{ThemeResource BgElevatedBrush}"
            BorderBrush="{ThemeResource BgElevated2Brush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Visibility="Visible"
            RenderTransformOrigin="0.5,0.5"
            PointerEntered="OnAlertBannerPointerEntered"
            PointerExited="OnAlertBannerPointerExited">
      <Border.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
      </Border.RenderTransform>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Alert Icon with Glow Effect -->
        <Grid Grid.Column="0" Margin="0,0,14,0">
          <Ellipse x:Name="AlertIconGlow"
                   Width="32" Height="32"
                   Fill="{ThemeResource TextPrimaryBrush}"
                   Opacity="0.2" />
          <Border Width="28" Height="28"
                  CornerRadius="14"
                  Background="{ThemeResource TextPrimaryBrush}">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE7BA;"
                      FontSize="{StaticResource FontBodyLarge}"
                      Foreground="{ThemeResource BgPrimaryBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
        </Grid>

        <!-- Alert Content -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
          <TextBlock FontSize="{StaticResource FontBodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextPrimaryBrush}"
                     Text="{x:Bind AlertTitle, Mode=OneWay}" />
          <TextBlock FontSize="{StaticResource FontBodySmall}"
                     Foreground="{ThemeResource TextDisabledBrush}"
                     TextTrimming="CharacterEllipsis"
                     Text="{x:Bind AlertMessage, Mode=OneWay}" />
        </StackPanel>

        <!-- View Details Button -->
        <Button Grid.Column="2"
                Content="VIEW"
                Background="Transparent"
                BorderBrush="{ThemeResource BorderStrongBrush}"
                BorderThickness="1"
                Foreground="{ThemeResource TextPrimaryBrush}"
                FontSize="{StaticResource FontLabelMedium}"
                FontWeight="SemiBold"
                Padding="14,6"
                CornerRadius="4"
                Margin="12,0,8,0"
                VerticalAlignment="Center" />

        <!-- Dismiss Button -->
        <Button x:Name="DismissAlertButton"
                Grid.Column="3"
                Background="Transparent"
                BorderThickness="0"
                Padding="8"
                VerticalAlignment="Center"
                Click="OnDismissAlertClick">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE711;"
                    FontSize="{StaticResource FontBodyLarge}"
                    Foreground="{ThemeResource TextMutedBrush}" />
        </Button>
      </Grid>
    </Border>

    <!-- ========== HEADER INFO ROW ========== -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Title Section (left side - will be replaced by page content) -->
      <ContentPresenter x:Name="TitleContent"
                        Grid.Column="0"
                        Content="{x:Bind TitleArea, Mode=OneWay}" />

      <!-- Right Side Widgets -->
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="20">

        <!-- ========== LIVE STATUS INDICATOR ========== -->
        <Border Background="{ThemeResource BgCardBrush}"
                BorderBrush="{ThemeResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Grid>
              <!-- Outer glow ring -->
              <Ellipse Width="12" Height="12"
                       Fill="{ThemeResource BgElevatedBrush}"
                       Stroke="{ThemeResource BorderStrongBrush}"
                       StrokeThickness="1" />
              <!-- Pulsing dot (Fill bound; Opacity is driven by the pulse timer) -->
              <Ellipse x:Name="LiveStatusDot"
                       Width="8" Height="8"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Fill="{x:Bind ConnectionDotBrush(IsConnected), Mode=OneWay}" />
            </Grid>
            <TextBlock FontSize="{StaticResource FontLabelMedium}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextDisabledBrush}"
                       VerticalAlignment="Center"
                       Text="{x:Bind ConnectionLabel(IsConnected), Mode=OneWay}" />
          </StackPanel>
        </Border>

        <!-- ========== WEATHER WIDGET ========== -->
        <Border Background="{ThemeResource BgCardBrush}"
                BorderBrush="{ThemeResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Weather Icon (glyph picked from WeatherCondition via x:Bind method) -->
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      FontSize="{StaticResource FontHeadlineMedium}"
                      Foreground="{ThemeResource AccentSecondaryBrush}"
                      VerticalAlignment="Center"
                      Glyph="{x:Bind WeatherGlyph(WeatherCondition), Mode=OneWay}" />

            <!-- Temperature and Conditions -->
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock FontSize="{StaticResource FontTitleMedium}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           Text="{x:Bind Temperature, Mode=OneWay}" />
                <TextBlock Text="F"
                           FontSize="{StaticResource FontLabelMedium}"
                           Foreground="{ThemeResource TextMutedBrush}"
                           VerticalAlignment="Top"
                           Margin="0,2,0,0" />
              </StackPanel>
              <TextBlock FontSize="{StaticResource FontLabelSmall}"
                         Foreground="{ThemeResource TextMutedBrush}"
                         Text="{x:Bind WeatherCondition, Mode=OneWay}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ========== LIVE CLOCK ========== -->
        <Border Background="{ThemeResource BgCardBrush}"
                BorderBrush="{ThemeResource BorderColorBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <!-- Clock Icon -->
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE823;"
                      FontSize="{StaticResource FontTitleMedium}"
                      Foreground="{ThemeResource AccentTertiaryBrush}"
                      VerticalAlignment="Center" />

            <!-- Time Display -->
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <TextBlock x:Name="TimeText"
                         Text="12:00:00"
                         FontSize="{StaticResource FontBodyLarge}"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         FontFamily="Consolas" />
              <TextBlock x:Name="TimezoneText"
                         Text="EST"
                         FontSize="{StaticResource FontLabelSmall}"
                         Foreground="{ThemeResource TextMutedBrush}" />
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </Grid>

  </StackPanel>
</UserControl>
