<UserControl x:Class="FieldOpsPro.Presentation.Controls.QuickActionButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited"
             PointerPressed="OnPointerPressed"
             PointerReleased="OnPointerReleased">

  <Border x:Name="ActionBorder"
          CornerRadius="20"
          Padding="16,16"
          RenderTransformOrigin="0.5,0.5"
          Background="{ThemeResource QuickActionGradientBrush}">
    <Border.RenderTransform>
      <CompositeTransform x:Name="BorderTransform" />
    </Border.RenderTransform>

    <utu:AutoLayout Orientation="Vertical"
                    Spacing="10"
                    HorizontalAlignment="Center">
      <!-- Icon Container with gradient -->
      <Border Width="48"
              Height="48"
              CornerRadius="16"
              HorizontalAlignment="Center"
              Background="{ThemeResource QuickActionHoverGradientBrush}">
        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  FontSize="{StaticResource FontHeadlineLarge}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                  Foreground="{x:Bind AccentColor, Converter={StaticResource QuickActionAccentToBrush}, Mode=OneWay}" />
      </Border>

      <!-- Label -->
      <TextBlock FontSize="{StaticResource FontLabelMedium}"
                 FontWeight="Medium"
                 Foreground="{ThemeResource TextSecondaryBrush}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 Text="{x:Bind Label, Mode=OneWay}" />
    </utu:AutoLayout>
  </Border>
</UserControl>
