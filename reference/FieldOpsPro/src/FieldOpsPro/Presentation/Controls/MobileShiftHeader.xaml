<UserControl x:Class="FieldOpsPro.Presentation.Controls.MobileShiftHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border CornerRadius="0,0,24,24"
          Padding="24,16,24,24">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{ThemeResource BgElevated}" Offset="0" />
        <GradientStop Color="{ThemeResource BgCard}" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>

    <utu:AutoLayout Orientation="Vertical" Spacing="20">

      <!-- Top Row: Greeting + Avatar + Time -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock x:Name="GreetingText"
                     Text="Good Afternoon"
                     FontSize="{StaticResource FontBodySmall}"
                     Foreground="{ThemeResource TextMutedBrush}" />
          <TextBlock FontSize="{StaticResource FontHeadlineLarge}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextPrimaryBrush}"
                     Text="{x:Bind UserName, Mode=OneWay}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="CurrentTimeText"
                       Text="3:28 PM"
                       FontSize="{StaticResource FontBodyLarge}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimaryBrush}"
                       HorizontalAlignment="Right" />
            <TextBlock x:Name="TimeRemainingText"
                       Text="4h 32m left"
                       FontSize="{StaticResource FontLabelMedium}"
                       Foreground="{ThemeResource AccentTertiaryBrush}"
                       HorizontalAlignment="Right" />
          </StackPanel>
          <local:Avatar Size="44"
                        Initials="{x:Bind AvatarInitials, Mode=OneWay}"
                        AvatarColor="{x:Bind AvatarColor, Mode=OneWay}"
                        Status="{x:Bind AvatarStatus, Mode=OneWay}" />
        </StackPanel>
      </Grid>

      <!-- Compact alert for mobile (appears after delay) -->
      <Border x:Name="MobileAlertBanner"
              Background="{ThemeResource BgElevatedBrush}"
              BorderBrush="{ThemeResource BgElevated2Brush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Visibility="Collapsed"
              RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="28" Height="28" CornerRadius="14" Background="{ThemeResource TextPrimaryBrush}" Margin="0,0,10,0">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7BA;" FontSize="{StaticResource FontBodyLarge}" Foreground="{ThemeResource BgPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="MobileAlertTitle" Text="URGENT" FontSize="{StaticResource FontBodyMedium}" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBlock x:Name="MobileAlertMessage" Text="3 work orders affected" FontSize="{StaticResource FontLabelMedium}" Foreground="{ThemeResource TextDisabledBrush}" TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="6" Click="OnMobileDismissAlert">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE711;" FontSize="{StaticResource FontBodyLarge}" Foreground="{ThemeResource TextMutedBrush}" />
          </Button>
        </Grid>
      </Border>

      <!-- Current Status Banner -->
      <Border Background="{ThemeResource BorderColorBrush}"
              CornerRadius="12"
              Padding="16,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="CURRENT STATUS"
                       FontSize="{StaticResource FontLabelTiny}"
                       Foreground="{ThemeResource TextMutedBrush}"
                       FontWeight="Medium" />
            <TextBlock FontSize="{StaticResource FontTitleMedium}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimaryBrush}"
                       Text="{x:Bind Status, Mode=OneWay}" />
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE707;"
                        FontSize="{StaticResource FontBodySmall}"
                        Foreground="{ThemeResource AccentTertiaryBrush}" />
              <TextBlock FontSize="{StaticResource FontBodySmall}"
                         Foreground="{ThemeResource AccentSecondaryBrush}"
                         Text="{x:Bind Destination, Mode=OneWay}" />
              <TextBlock Text="·"
                         FontSize="{StaticResource FontBodySmall}"
                         Foreground="{ThemeResource TextMutedBrush}" />
              <TextBlock FontSize="{StaticResource FontBodySmall}"
                         Foreground="{ThemeResource AccentTertiaryBrush}"
                         Text="{x:Bind Eta, Mode=OneWay}" />
            </StackPanel>
          </StackPanel>

          <!-- Navigate Button -->
          <Border Grid.Column="1"
                  Width="44"
                  Height="44"
                  CornerRadius="12"
                  Background="{ThemeResource TextPrimaryBrush}"
                  VerticalAlignment="Center">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE816;"
                      FontSize="{StaticResource FontTitleLarge}"
                      Foreground="{ThemeResource BgPrimaryBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
        </Grid>
      </Border>

      <!-- Shift Progress Bar -->
      <StackPanel Spacing="8">
        <Grid>
          <TextBlock Text="Shift Progress"
                     FontSize="{StaticResource FontLabelMedium}"
                     Foreground="{ThemeResource TextMutedBrush}" />
          <TextBlock x:Name="ShiftPercentText"
                     Text="68%"
                     FontSize="{StaticResource FontLabelMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextPrimaryBrush}"
                     HorizontalAlignment="Right" />
        </Grid>
        <Grid>
          <Border Background="{ThemeResource BorderColorBrush}"
                  CornerRadius="4"
                  Height="6" />
          <Border x:Name="ProgressFill"
                  CornerRadius="4"
                  Height="6"
                  HorizontalAlignment="Left"
                  Width="200">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="{ThemeResource AccentTertiary}" Offset="0" />
                <GradientStop Color="{ThemeResource TextPrimary}" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </Grid>
        <Grid>
          <TextBlock Text="8:00 AM"
                     FontSize="{StaticResource FontLabelSmall}"
                     Foreground="{ThemeResource BorderStrongBrush}" />
          <TextBlock Text="5:00 PM"
                     FontSize="{StaticResource FontLabelSmall}"
                     Foreground="{ThemeResource BorderStrongBrush}"
                     HorizontalAlignment="Right" />
        </Grid>
      </StackPanel>

      <!-- Stats Row -->
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{ThemeResource BgElevatedBrush}"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="7.5h"
                       FontSize="{StaticResource FontTitleMedium}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Worked"
                       FontSize="{StaticResource FontLabelSmall}"
                       Foreground="{ThemeResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{ThemeResource BgElevatedBrush}"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontSize="{StaticResource FontTitleMedium}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource AccentSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Text="{x:Bind TasksSummary, Mode=OneWay}" />
            <TextBlock Text="Tasks"
                       FontSize="{StaticResource FontLabelSmall}"
                       Foreground="{ThemeResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{ThemeResource BgElevatedBrush}"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="4.9"
                       FontSize="{StaticResource FontTitleMedium}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource AccentTertiaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Rating"
                       FontSize="{StaticResource FontLabelSmall}"
                       Foreground="{ThemeResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

    </utu:AutoLayout>
  </Border>
</UserControl>
