<Page x:Class="FieldOpsPro.Presentation.TeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FieldOpsPro.Presentation"
      xmlns:models="using:FieldOpsPro.Models"
      xmlns:controls="using:FieldOpsPro.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BgPrimaryBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <utu:AutoLayout Orientation="Vertical"
                    Padding="40,32"
                    Spacing="24"
                    MaxWidth="1100">
      <TextBlock x:Uid="TeamPage_Title"
                 Text="Team"
                 Style="{StaticResource PageTitleStyle}" />

      <Border Style="{StaticResource FieldOpsCardStyle}">
        <ItemsRepeater ItemsSource="{Binding Members}">
          <ItemsRepeater.Layout>
            <UniformGridLayout MinColumnSpacing="12"
                               MinRowSpacing="12"
                               MinItemWidth="220"
                               ItemsStretch="Fill" />
          </ItemsRepeater.Layout>
          <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="models:TeamMember">
              <controls:TeamMemberCard Member="{x:Bind}" />
            </DataTemplate>
          </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
      </Border>
    </utu:AutoLayout>
  </ScrollViewer>
</Page>
