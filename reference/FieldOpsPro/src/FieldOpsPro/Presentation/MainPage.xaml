<Page x:Class="FieldOpsPro.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FieldOpsPro.Presentation"
      xmlns:controls="using:FieldOpsPro.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BgPrimaryBrush}">

  <!--
    Canonical Uno Navigation pattern (uno-navigation skill, references/05 & 06):
      outer Grid    : Region.Attached  (MainPage region)
      NavigationView: Region.Attached  (selection routing on item Region.Name)
      Frame         : Region.Attached  (content host, no manual nav)
    No code-behind NavigateRouteAsync; selection drives navigation.
  -->
  <Grid x:Name="RootGrid"
        uen:Region.Attached="True"
        Background="{ThemeResource BgPrimaryBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition x:Name="BottomNavRow" Height="0" />
    </Grid.RowDefinitions>

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="LayoutStates">
        <VisualState x:Name="NarrowLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopNav.IsPaneVisible" Value="False" />
            <Setter Target="MobileBottomNav.Visibility" Value="Visible" />
            <Setter Target="BottomNavRow.Height" Value="90" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="NormalLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="600" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopNav.IsPaneVisible" Value="True" />
            <Setter Target="DesktopNav.OpenPaneLength" Value="200" />
            <Setter Target="MobileBottomNav.Visibility" Value="Collapsed" />
            <Setter Target="BottomNavRow.Height" Value="0" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="WideLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1024" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopNav.IsPaneVisible" Value="True" />
            <Setter Target="DesktopNav.OpenPaneLength" Value="280" />
            <Setter Target="MobileBottomNav.Visibility" Value="Collapsed" />
            <Setter Target="BottomNavRow.Height" Value="0" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <NavigationView x:Name="DesktopNav"
                    Grid.Row="0"
                    uen:Region.Attached="True"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    OpenPaneLength="280"
                    Background="{ThemeResource BgPrimaryBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}">

      <NavigationView.Resources>
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{StaticResource BgSecondary}" />
        <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource BgSecondary}" />
        <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="{StaticResource BgSecondary}" />
        <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource BgPrimary}" />
      </NavigationView.Resources>

      <NavigationView.PaneCustomContent>
        <StackPanel Orientation="Horizontal"
                    Spacing="14"
                    Margin="24,16,24,24">
          <Border Width="44"
                  Height="44"
                  CornerRadius="12"
                  RenderTransformOrigin="0.5,0.5">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{ThemeResource TextPrimary}" Offset="0" />
                <GradientStop Color="{ThemeResource AccentSecondary}" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
              <RotateTransform Angle="-3" />
            </Border.RenderTransform>
            <TextBlock Text="FO"
                       FontSize="{StaticResource FontTitleMedium}"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock VerticalAlignment="Center">
            <Run Text="Field" FontSize="{StaticResource FontHeadlineLarge}" FontWeight="Bold" Foreground="{ThemeResource TextPrimaryBrush}" />
            <Run Text="Ops" FontSize="{StaticResource FontHeadlineLarge}" FontWeight="Bold" Foreground="{ThemeResource AccentPrimaryBrush}" />
          </TextBlock>
        </StackPanel>
      </NavigationView.PaneCustomContent>

      <NavigationView.MenuItems>
        <NavigationViewItemHeader>
          <TextBlock Text="MAIN MENU" Style="{StaticResource MonoLabelStyle}" />
        </NavigationViewItemHeader>

        <NavigationViewItem x:Name="NavDashboard"
                            Content="Dashboard"
                            uen:Region.Name="Dashboard">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xF246;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavMap"
                            Content="Live Map"
                            uen:Region.Name="Map">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE707;" />
          </NavigationViewItem.Icon>
          <NavigationViewItem.InfoBadge>
            <InfoBadge Value="12" />
          </NavigationViewItem.InfoBadge>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavTasks"
                            Content="Work Orders"
                            uen:Region.Name="Tasks">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE762;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavTeam"
                            Content="Team"
                            uen:Region.Name="Team">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE716;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavSchedule"
                            Content="Schedule"
                            uen:Region.Name="Schedule">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE787;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItemHeader>
          <TextBlock Text="MANAGEMENT" Style="{StaticResource MonoLabelStyle}" />
        </NavigationViewItemHeader>

        <NavigationViewItem x:Name="NavReports"
                            Content="Reports"
                            uen:Region.Name="Reports">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7C3;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavSettings"
                            Content="Settings"
                            uen:Region.Name="Settings">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE713;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem x:Name="NavProfile"
                            Content="Profile"
                            uen:Region.Name="Profile">
          <NavigationViewItem.Icon>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <NavigationView.PaneFooter>
        <Border Background="{ThemeResource BgTertiaryBrush}"
                CornerRadius="16"
                Padding="20"
                Margin="24,16,24,24">
          <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:Avatar Grid.Column="0"
                             Size="46"
                             Initials="{Binding CurrentUser.Initials}"
                             AvatarColor="{Binding CurrentUser.AvatarColor}" />

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Style="{StaticResource BodyMediumStyle}"
                           Text="{Binding CurrentUser.Name}" />
                <Ellipse Width="10"
                         Height="10"
                         VerticalAlignment="Center">
                  <Ellipse.Fill>
                    <SolidColorBrush Color="{ThemeResource TextPrimary}" />
                  </Ellipse.Fill>
                </Ellipse>
              </StackPanel>
              <TextBlock Style="{StaticResource CaptionStyle}"
                         Text="{Binding CurrentUser.Role}" />
            </StackPanel>
          </Grid>
        </Border>
      </NavigationView.PaneFooter>

      <Frame x:Name="ContentFrame" uen:Region.Attached="True" />
    </NavigationView>

    <!-- Mobile bottom nav: buttons drive NavigationView.SelectedItem (canonical path) -->
    <Border x:Name="MobileBottomNav"
            Grid.Row="1"
            Background="{ThemeResource BgSecondaryBrush}"
            BorderBrush="{ThemeResource BorderColorBrush}"
            BorderThickness="0,1,0,0"
            Visibility="Collapsed">

      <Grid Padding="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Style="{StaticResource MobileNavButtonStyle}"
                Tag="Dashboard"
                Click="OnMobileNavClick">
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <FontIcon x:Name="HomeIcon"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE80F;"
                      FontSize="{StaticResource FontHeadlineLarge}"
                      Foreground="{ThemeResource AccentPrimaryBrush}" />
            <TextBlock x:Name="HomeLabel"
                       x:Uid="MainPage_Nav_Home"
                       Text="Home"
                       FontSize="{StaticResource FontLabelSmall}"
                       FontWeight="Medium"
                       Foreground="{ThemeResource AccentPrimaryBrush}" />
          </StackPanel>
        </Button>

        <Button Grid.Column="1"
                Style="{StaticResource MobileNavButtonStyle}"
                Tag="Map"
                Click="OnMobileNavClick">
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <FontIcon x:Name="MapIcon"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE707;"
                      FontSize="{StaticResource FontHeadlineLarge}"
                      Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock x:Name="MapLabel"
                       x:Uid="MainPage_Nav_Map"
                       Text="Map"
                       FontSize="{StaticResource FontLabelSmall}"
                       FontWeight="Medium"
                       Foreground="{ThemeResource TextMutedBrush}" />
          </StackPanel>
        </Button>

        <Button Grid.Column="2"
                Width="60"
                Height="60"
                CornerRadius="20"
                Margin="0,-20,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Center">
          <Button.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="{ThemeResource TextPrimary}" Offset="0" />
              <GradientStop Color="{ThemeResource Gray200}" Offset="1" />
            </LinearGradientBrush>
          </Button.Background>
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE710;"
                    FontSize="{StaticResource FontDisplaySmall}"
                    Foreground="Black" />
        </Button>

        <Button Grid.Column="3"
                Style="{StaticResource MobileNavButtonStyle}"
                Tag="Tasks"
                Click="OnMobileNavClick">
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <FontIcon x:Name="TasksIcon"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE762;"
                      FontSize="{StaticResource FontHeadlineLarge}"
                      Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock x:Name="TasksLabel"
                       x:Uid="MainPage_Nav_Tasks"
                       Text="Tasks"
                       FontSize="{StaticResource FontLabelSmall}"
                       FontWeight="Medium"
                       Foreground="{ThemeResource TextMutedBrush}" />
          </StackPanel>
        </Button>

        <Button Grid.Column="4"
                Style="{StaticResource MobileNavButtonStyle}"
                Tag="Profile"
                Click="OnMobileNavClick">
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <FontIcon x:Name="ProfileIcon"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE77B;"
                      FontSize="{StaticResource FontHeadlineLarge}"
                      Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock x:Name="ProfileLabel"
                       x:Uid="MainPage_Nav_Profile"
                       Text="Profile"
                       FontSize="{StaticResource FontLabelSmall}"
                       FontWeight="Medium"
                       Foreground="{ThemeResource TextMutedBrush}" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Page>
