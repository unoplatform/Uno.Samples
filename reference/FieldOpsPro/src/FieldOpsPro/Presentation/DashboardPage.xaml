<Page x:Class="FieldOpsPro.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FieldOpsPro.Presentation"
      xmlns:models="using:FieldOpsPro.Models"
      xmlns:controls="using:FieldOpsPro.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:conv="using:FieldOpsPro.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BgPrimaryBrush}">

  <Page.Resources>
    <conv:IntSuffixConverter x:Key="IntSuffix" />
  </Page.Resources>

  <Grid>
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="LayoutStates">
        <!-- Desktop Layout -->
        <VisualState x:Name="DesktopLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1024" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopContent.Visibility" Value="Visible" />
            <Setter Target="MobileContent.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <!-- Mobile Layout -->
        <VisualState x:Name="MobileLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopContent.Visibility" Value="Collapsed" />
            <Setter Target="MobileContent.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <!-- ==================== -->
    <!-- DESKTOP CONTENT      -->
    <!-- ==================== -->
    <ScrollViewer x:Name="DesktopContent"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <utu:AutoLayout Orientation="Vertical"
                      Padding="40,32"
                      Spacing="32"
                      MaxWidth="1400">

        <!-- Enhanced Dashboard Header -->
        <controls:DashboardHeader AlertTitle="URGENT: Power Outage Reported"
                                  AlertMessage="3 work orders affected in Downtown District - Immediate attention required"
                                  ShowAlert="True"
                                  Temperature="72"
                                  WeatherCondition="Partly Cloudy"
                                  IsConnected="True">
          <controls:DashboardHeader.TitleArea>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <!-- Title Section -->
              <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock x:Uid="Dashboard_Title"
                           Text="Command Center"
                           Style="{StaticResource PageTitleStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Style="{StaticResource BodyStyle}"
                             VerticalAlignment="Center"
                             Text="{Binding CurrentDate}" />
                  <TextBlock Style="{StaticResource BodyStyle}"
                             VerticalAlignment="Center"
                             Text="-" />
                  <!-- Online-agent count is data-driven from the Stats feed -->
                  <mvux:FeedView Source="{Binding Stats}">
                    <mvux:FeedView.ValueTemplate>
                      <DataTemplate>
                        <TextBlock Style="{StaticResource BodyStyle}" VerticalAlignment="Center">
                          <Run Text="{Binding Data.OnlineAgents.Current}" /><Run Text=" active field agents" />
                        </TextBlock>
                      </DataTemplate>
                    </mvux:FeedView.ValueTemplate>
                    <mvux:FeedView.ProgressTemplate>
                      <DataTemplate>
                        <TextBlock Style="{StaticResource BodyStyle}"
                                   VerticalAlignment="Center"
                                   Text="counting agents…" />
                      </DataTemplate>
                    </mvux:FeedView.ProgressTemplate>
                  </mvux:FeedView>
                </StackPanel>
              </StackPanel>

              <!-- Search and Actions -->
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="16"
                          Margin="0,0,24,0">
                <!-- Search Bar -->
                    <Border Background="{ThemeResource BgCardBrush}"
                    BorderBrush="{ThemeResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,8"
                    Width="280"
                    VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE721;"
                              FontSize="{StaticResource FontTitleMedium}"
                      Foreground="{ThemeResource TextMutedBrush}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="Search work orders..."
                       Foreground="{ThemeResource TextMutedBrush}"
                               FontSize="{StaticResource FontBodyMedium}"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </Border>

                <!-- Notification Button -->
                <Button Style="{StaticResource IconButtonStyle}">
                  <Grid>
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xEA8F;"
                              FontSize="{StaticResource FontHeadlineMedium}"
                              Foreground="{ThemeResource TextSecondaryBrush}" />
                    <Ellipse Width="8" Height="8"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-4,-4,0"
                             Fill="{ThemeResource DangerBrush}" />
                  </Grid>
                </Button>

                <!-- Messages Button -->
                <Button Style="{StaticResource IconButtonStyle}">
                  <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Glyph="&#xE715;"
                            FontSize="{StaticResource FontHeadlineMedium}"
                            Foreground="{ThemeResource TextSecondaryBrush}" />
                </Button>
              </StackPanel>
            </Grid>
          </controls:DashboardHeader.TitleArea>
        </controls:DashboardHeader>

        <!-- Stats Grid (data-driven from the Stats feed) -->
        <mvux:FeedView Source="{Binding Stats}">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:StatCard Grid.Column="0"
                                   Label="Active Work Orders"
                                   Value="{Binding Data.ActiveWorkOrders.Current, Converter={StaticResource IntSuffix}}"
                                   ChangePercent="{Binding Data.ActiveWorkOrders.ChangePercent}"
                                   IconGlyph="&#xE762;"
                                   AccentColor="Primary" />

                <controls:StatCard Grid.Column="1"
                                   Label="Field Agents Online"
                                   Value="{Binding Data.OnlineAgents.Current, Converter={StaticResource IntSuffix}}"
                                   Subtitle="online"
                                   IconGlyph="&#xE716;"
                                   AccentColor="Secondary" />

                <controls:StatCard Grid.Column="2"
                                   Label="Avg Response Time"
                                   Value="{Binding Data.AvgResponseTime.Current, Converter={StaticResource IntSuffix}, ConverterParameter=m}"
                                   ChangePercent="{Binding Data.AvgResponseTime.ChangePercent}"
                                   IconGlyph="&#xE823;"
                                   AccentColor="Tertiary" />

                <controls:StatCard Grid.Column="3"
                                   Label="Completion Rate"
                                   Value="{Binding Data.CompletionRate.Current, Converter={StaticResource IntSuffix}, ConverterParameter=%}"
                                   ChangePercent="{Binding Data.CompletionRate.ChangePercent}"
                                   IconGlyph="&#xE73E;"
                                   AccentColor="Success" />
              </Grid>
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>
          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Left" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>
        </mvux:FeedView>

        <!-- Main Content Grid -->
        <Grid ColumnSpacing="24">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="480" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Live Map Card (FeedView unwraps the agents list feed to the MapCard's IImmutableList DP) -->
          <mvux:FeedView Grid.Column="0" Grid.Row="0" Source="{Binding MapAgents}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <controls:MapCard Agents="{Binding Data}" />
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
            <mvux:FeedView.ProgressTemplate>
              <DataTemplate>
                <controls:MapCard />
              </DataTemplate>
            </mvux:FeedView.ProgressTemplate>
          </mvux:FeedView>

          <!-- Team Status Card (aligned with Map) -->
          <Border Grid.Column="1"
                  Grid.Row="0"
                  Style="{StaticResource FieldOpsCardStyle}">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <Grid>
                <TextBlock x:Uid="Dashboard_TeamStatus"
                           Text="Team Status"
                           Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <ItemsRepeater ItemsSource="{Binding TeamMembers}">
                <ItemsRepeater.Layout>
                  <UniformGridLayout MinColumnSpacing="12"
                                     MinRowSpacing="12"
                                     MinItemWidth="180"
                                     MaximumRowsOrColumns="2"
                                     ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:TeamMember">
                    <controls:TeamMemberCard Member="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>

          <!-- Priority Tasks Card -->
          <Border Grid.Column="0"
                  Grid.Row="1"
                  Style="{StaticResource FieldOpsCardStyle}"
                  Margin="0,24,0,0">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <!-- Header -->
              <Grid>
                <TextBlock x:Uid="Dashboard_PriorityTasks"
                           Text="Priority Tasks"
                           Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <!-- Task List -->
              <ItemsRepeater ItemsSource="{Binding PriorityTasks}">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="12" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:TaskItem">
                    <controls:TaskCard TaskItem="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>

          <!-- Activity Feed Card -->
          <Border Grid.Column="1"
                  Grid.Row="1"
                  Style="{StaticResource FieldOpsCardStyle}"
                  Margin="0,24,0,0">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <Grid>
                <TextBlock x:Uid="Dashboard_RecentActivity"
                         Text="Recent Activity"
                         Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <ItemsRepeater ItemsSource="{Binding RecentActivity}">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="20" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:Activity">
                    <controls:ActivityItem Activity="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>
        </Grid>

      </utu:AutoLayout>
    </ScrollViewer>

    <!-- ==================== -->
    <!-- MOBILE CONTENT       -->
    <!-- ==================== -->
    <ScrollViewer x:Name="MobileContent"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Visibility="Collapsed">
      <StackPanel>
        <!-- New Combined Shift Header (identity + current assignment from feeds) -->
        <controls:MobileShiftHeader UserName="{Binding CurrentUser.Name}"
                                    AvatarInitials="{Binding CurrentUser.Initials}"
                                    AvatarColor="{Binding CurrentUser.AvatarColor}"
                                    AvatarStatus="{Binding CurrentUser.Status}"
                                    Status="{Binding CurrentAssignment.StatusDisplay}"
                                    Destination="{Binding CurrentAssignment.Destination}"
                                    Eta="{Binding CurrentAssignment.Eta}"
                                    TasksSummary="{Binding TodayProgress.TasksSummary}" />

        <utu:AutoLayout Orientation="Vertical"
                        Padding="24,24"
                        Spacing="28">

          <!-- Quick Actions Section -->
          <StackPanel Spacing="16">
            <TextBlock x:Uid="Dashboard_QuickActions"
                       Text="Quick Actions"
                       Style="{StaticResource SectionTitleStyle}" />

            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <controls:QuickActionButton Grid.Column="0"
                                          Label="Check In"
                                          IconGlyph="&#xE73E;"
                                          AccentColor="Success" />

              <controls:QuickActionButton Grid.Column="1"
                                          Label="Photo"
                                          IconGlyph="&#xE722;"
                                          AccentColor="Primary" />

              <controls:QuickActionButton Grid.Column="2"
                                          Label="Notes"
                                          IconGlyph="&#xE70B;"
                                          AccentColor="Tertiary" />

              <controls:QuickActionButton Grid.Column="3"
                                          Label="Call"
                                          IconGlyph="&#xE717;"
                                          AccentColor="Secondary" />
            </Grid>
          </StackPanel>

        <!-- Today's Tasks Section with Filter Tabs -->
        <StackPanel Spacing="16">
          <Grid>
            <TextBlock x:Uid="Dashboard_TodayTasks"
                       Text="Today's Tasks"
                       Style="{StaticResource SectionTitleStyle}" />
            <Button Content="ALL"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Right" />
          </Grid>

          <!-- Task Filter Tabs -->
          <controls:TaskFilterTabs UrgentCount="3"
                                   UnassignedCount="5" />

          <ItemsRepeater ItemsSource="{Binding TodayTasks}">
            <ItemsRepeater.Layout>
              <StackLayout Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:TaskItem">
                <controls:TaskCard TaskItem="{x:Bind}" />
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </StackPanel>

        <!-- Progress Stats (data-driven from the TodayProgress feed) -->
        <StackPanel Spacing="16">
          <TextBlock x:Uid="Dashboard_TodayProgress"
                     Text="Today's Progress"
                     Style="{StaticResource SectionTitleStyle}" />

          <mvux:FeedView Source="{Binding TodayProgress}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="0"
                          Background="{ThemeResource BgCardBrush}"
                          BorderBrush="{ThemeResource BorderColorBrush}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="20">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="{Binding Data.Completed}"
                                 Style="{StaticResource StatValueSmallStyle}"
                                 Foreground="{ThemeResource AccentPrimaryBrush}"
                                 HorizontalAlignment="Center" />
                      <TextBlock x:Uid="Dashboard_Completed"
                                 Text="Completed"
                                 Style="{StaticResource CaptionStyle}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                          Background="{ThemeResource BgCardBrush}"
                          BorderBrush="{ThemeResource BorderColorBrush}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="20">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="{Binding Data.Remaining}"
                                 Style="{StaticResource StatValueSmallStyle}"
                                 Foreground="{ThemeResource AccentSecondaryBrush}"
                                 HorizontalAlignment="Center" />
                      <TextBlock x:Uid="Dashboard_Remaining"
                                 Text="Remaining"
                                 Style="{StaticResource CaptionStyle}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
            <mvux:FeedView.ProgressTemplate>
              <DataTemplate>
                <ProgressRing IsActive="True" Width="24" Height="24" HorizontalAlignment="Left" />
              </DataTemplate>
            </mvux:FeedView.ProgressTemplate>
          </mvux:FeedView>
        </StackPanel>

        <!-- CSAT Score Card -->
        <controls:CSATScoreCard Score="4.8" />

        <!-- Chat Preview Card -->
        <controls:ChatPreviewCard UnreadCount="4" />

          <!-- Bottom spacing for nav bar -->
          <Border Height="100" />

        </utu:AutoLayout>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
