<Page x:Class="FieldOpsPro.Presentation.WorkOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FieldOpsPro.Presentation"
      xmlns:models="using:FieldOpsPro.Models"
      xmlns:controls="using:FieldOpsPro.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BgPrimaryBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <utu:AutoLayout Orientation="Vertical"
                    Padding="40,32"
                    Spacing="24"
                    MaxWidth="1100">
      <TextBlock x:Uid="WorkOrdersPage_Title"
                 Text="Work Orders"
                 Style="{StaticResource PageTitleStyle}" />

      <!-- Priority -->
      <Border Style="{StaticResource FieldOpsCardStyle}">
        <utu:AutoLayout Orientation="Vertical" Spacing="20">
          <TextBlock x:Uid="WorkOrdersPage_Priority"
                     Text="Priority"
                     Style="{StaticResource SectionTitleStyle}" />
          <ItemsRepeater ItemsSource="{Binding PriorityTasks}">
            <ItemsRepeater.Layout>
              <StackLayout Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:TaskItem">
                <controls:TaskCard TaskItem="{x:Bind}" />
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </utu:AutoLayout>
      </Border>

      <!-- Today -->
      <Border Style="{StaticResource FieldOpsCardStyle}">
        <utu:AutoLayout Orientation="Vertical" Spacing="20">
          <TextBlock x:Uid="WorkOrdersPage_Today"
                     Text="Scheduled Today"
                     Style="{StaticResource SectionTitleStyle}" />
          <ItemsRepeater ItemsSource="{Binding TodayTasks}">
            <ItemsRepeater.Layout>
              <StackLayout Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:TaskItem">
                <controls:TaskCard TaskItem="{x:Bind}" />
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </utu:AutoLayout>
      </Border>
    </utu:AutoLayout>
  </ScrollViewer>
</Page>
