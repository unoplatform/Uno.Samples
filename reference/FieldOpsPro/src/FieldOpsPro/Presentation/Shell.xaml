<UserControl x:Class="FieldOpsPro.Presentation.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <!--
    Shell is intentionally minimal: it's the root the framework navigates into,
    so its content is overwritten by the active route. The actual nav chrome
    (NavigationView desktop / TabBar mobile) lives in MainPage, which is the
    default nested route under Shell.
  -->
  <utu:SafeArea Background="{ThemeResource BgPrimaryBrush}">
    <Frame />
  </utu:SafeArea>
</UserControl>
