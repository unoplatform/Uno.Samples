<Page x:Class="VectorGraphicsShowcase.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:VectorGraphicsShowcase"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <SolidColorBrush x:Key="Ink" Color="#3B82F6" />
    <SolidColorBrush x:Key="Ink2" Color="#EC4899" />
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="Cap" TargetType="TextBlock">
      <Setter Property="Width" Value="130" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>
  </Page.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Padding="32,24,32,48" Spacing="24" MaxWidth="900" HorizontalAlignment="Center">

      <StackPanel Spacing="6">
        <TextBlock Text="Vector Graphics Showcase" FontSize="34" FontWeight="SemiBold" />
        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                   Text="Uno Platform 6.6 brings richer stroke styling to the Skia renderer — line caps, dash patterns and line joins — plus animatable geometry transforms." />
      </StackPanel>

      <!-- Stroke caps -->
      <Border Style="{StaticResource Card}">
        <StackPanel Spacing="16">
          <TextBlock Text="Stroke line caps" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="StrokeStartLineCap / StrokeEndLineCap — how the ends of a thick stroke are drawn." />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Flat" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="26">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="18" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat" X1="10" Y1="13" X2="350" Y2="13" />
            </Canvas>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Round" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="26">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="18" StrokeStartLineCap="Round" StrokeEndLineCap="Round" X1="10" Y1="13" X2="350" Y2="13" />
            </Canvas>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Square" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="26">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="18" StrokeStartLineCap="Square" StrokeEndLineCap="Square" X1="10" Y1="13" X2="350" Y2="13" />
            </Canvas>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Triangle" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="26">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="18" StrokeStartLineCap="Triangle" StrokeEndLineCap="Triangle" X1="10" Y1="13" X2="350" Y2="13" />
            </Canvas>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Dashes -->
      <Border Style="{StaticResource Card}">
        <StackPanel Spacing="16">
          <TextBlock Text="Dashed strokes" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="StrokeDashArray sets the dash pattern; StrokeDashCap shapes each dash." />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Flat dash" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="20">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="8" StrokeDashArray="4 2" StrokeDashCap="Flat" X1="10" Y1="10" X2="350" Y2="10" />
            </Canvas>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Round dash" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="20">
              <Line Stroke="{StaticResource Ink}" StrokeThickness="8" StrokeDashArray="1 2" StrokeDashCap="Round" X1="10" Y1="10" X2="350" Y2="10" />
            </Canvas>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Dashed box" Style="{StaticResource Cap}" />
            <Canvas Width="360" Height="80">
              <Rectangle Stroke="{StaticResource Ink2}" StrokeThickness="3" StrokeDashArray="6 3" Width="340" Height="64" Canvas.Left="10" Canvas.Top="8" RadiusX="8" RadiusY="8" />
            </Canvas>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Line joins -->
      <Border Style="{StaticResource Card}">
        <StackPanel Spacing="16">
          <TextBlock Text="Line joins" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="StrokeLineJoin — how corners between stroke segments are drawn." />
          <StackPanel Orientation="Horizontal" Spacing="40" HorizontalAlignment="Left">
            <StackPanel Spacing="8">
              <Canvas Width="120" Height="90">
                <Polyline Stroke="{StaticResource Ink}" StrokeThickness="16" StrokeLineJoin="Miter" Points="10,80 60,15 110,80" />
              </Canvas>
              <TextBlock Text="Miter" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <StackPanel Spacing="8">
              <Canvas Width="120" Height="90">
                <Polyline Stroke="{StaticResource Ink}" StrokeThickness="16" StrokeLineJoin="Bevel" Points="10,80 60,15 110,80" />
              </Canvas>
              <TextBlock Text="Bevel" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <StackPanel Spacing="8">
              <Canvas Width="120" Height="90">
                <Polyline Stroke="{StaticResource Ink}" StrokeThickness="16" StrokeLineJoin="Round" Points="10,80 60,15 110,80" />
              </Canvas>
              <TextBlock Text="Round" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Geometry.Transform -->
      <Border Style="{StaticResource Card}">
        <StackPanel Spacing="16">
          <TextBlock Text="Animated Geometry.Transform" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="A Transform applied directly to a Geometry is now honored on Skia — here a RectangleGeometry spins about its center." />
          <Canvas Width="200" Height="200" HorizontalAlignment="Left">
            <Path Fill="{StaticResource Ink2}">
              <Path.Data>
                <RectangleGeometry Rect="60,60,80,80">
                  <RectangleGeometry.Transform>
                    <RotateTransform x:Name="SpinTransform" CenterX="100" CenterY="100" />
                  </RectangleGeometry.Transform>
                </RectangleGeometry>
              </Path.Data>
            </Path>
          </Canvas>
          <ToggleButton x:Name="SpinToggle" Content="Animate" IsChecked="True" Checked="OnSpinToggled" Unchecked="OnSpinToggled" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
