<Page xmlns:hd="using:Uno.UI.HotDesign"
      xmlns:markup="using:Uno.UI.Markup"
      x:Name="Root"
      x:Class="UnoGrpc.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoGrpc"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Grid Background="{ThemeResource BrushBackground}">
        <Grid.DataContext>
            <markup:FromJson>
                <markup:FromJson.Source>
                    <![CDATA[
            {
              "City": "San Francisco",
              "Temperature": "72°F",
              "Wind": "12 mph NW",
              "Description": "Partly cloudy with a chance of sunshine",
              "HasWeatherData": true
            }
          ]]>
                </markup:FromJson.Source>
            </markup:FromJson>
        </Grid.DataContext>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{ThemeResource BrushPrimary}"
                Height="140"
                Grid.Row="0">
            
            <Grid>
                <Image Opacity="0.3"
                       Stretch="UniformToFill"
                       Source="https://images.pexels.com/photos/8726315/pexels-photo-8726315.jpeg?auto=compress&amp;cs=tinysrgb&amp;dpr=2&amp;h=650&amp;w=940" />
                <StackPanel Spacing="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{ThemeResource BrushOnPrimary}"
                               FontWeight="Bold"
                               FontSize="36"
                               x:Uid="WeatherServiceTitle"
                               Text="Weather Service" />
                    <TextBlock HorizontalAlignment="Center"
                               Opacity="0.9"
                               Foreground="{StaticResource BrushOnPrimary}"
                               FontSize="16"
                               x:Uid="WeatherServiceSubtitle"
                               Text="Get current weather conditions" />
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{StaticResource BrushOnPrimary}"
                               FontSize="10"
                               Text="This apps uses https://goweather.xyz/weather/ service." />
                </StackPanel>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1">
            
            <StackPanel Spacing="24"
                        Margin="24,32,24,32"
                        MaxWidth="600">
                
                <Border Translation="0,0,16"
                        Padding="24"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource BrushOutline}"
                        Background="{ThemeResource BrushSurface}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <StackPanel Spacing="16">
                        <TextBlock Foreground="{ThemeResource BrushOnSurface}"
                                   FontWeight="SemiBold"
                                   FontSize="20"
                                   x:Uid="SearchLocationLabel"
                                   Text="Search Location" />
                        
                        <ToggleSwitch OnContent="Mock data"
                                      OffContent="Use goweather.xyz service"
                                      VerticalAlignment="Center"
                                      IsOn="{x:Bind ViewModel.MockData, Mode=TwoWay}" />
                        
                        <TextBox Text="{x:Bind ViewModel.City, Mode=TwoWay}"
                                 Background="{ThemeResource BrushSurfaceVariant}"
                                 BorderBrush="{ThemeResource BrushOutline}"
                                 Padding="16,12"
                                 CornerRadius="8"
                                 PlaceholderText="Enter city name. Ex: NewYork"
                                 x:Name="CityInput" />
                        
                        <Button Command="{x:Bind ViewModel.GetWeatherCommand, Mode=OneWay}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Padding="16,12"
                                CornerRadius="8"
                                Foreground="{ThemeResource BrushOnPrimary}"
                                Background="{ThemeResource BrushPrimary}"
                                HorizontalAlignment="Stretch"
                                x:Uid="GetWeatherButton"
                                Content="Get Weather" />
                        
                      <InfoBar IsOpen="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                               IsClosable="False"
                               Message="Please, enter a city."
                               Severity="Error" />
                        
                    </StackPanel>
                    
                </Border>

                <Grid>

                    <Border Translation="0,0,16"
                            Visibility="{Binding HasWeatherData}"
                            Padding="24"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource BrushOutline}"
                            Background="{ThemeResource BrushSurface}">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <StackPanel Spacing="20">
                            <TextBlock Text="{x:Bind ViewModel.WeatherIn, Mode=OneWay}"
                                       Foreground="{ThemeResource BrushOnSurface}"
                                       FontWeight="SemiBold"
                                       FontSize="20">
    <Run Text="Weather in " />
        <Run Text="{Binding City}"
                                Foreground="{ThemeResource BrushPrimary}"
                                FontWeight="Bold" />
                            </TextBlock>
                            <StackPanel Spacing="16">
                                <Border Padding="16"
                                        CornerRadius="8"
                                        Background="{ThemeResource BrushSurfaceVariant}">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="Medium"
                                                   Opacity="0.7"
                                                   Foreground="{ThemeResource BrushOnSurface}"
                                                   FontSize="13"
                                                   x:Uid="TemperatureLabel"
                                                   Text="Temperature" />
                                        <TextBlock Foreground="{ThemeResource BrushAccent}"
                                                   FontWeight="Bold"
                                                   FontSize="32"
                                                   Text="{x:Bind ViewModel.Temperature, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="16"
                                        CornerRadius="8"
                                        Background="{ThemeResource BrushSurfaceVariant}">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="Medium"
                                                   Opacity="0.7"
                                                   Foreground="{ThemeResource BrushOnSurface}"
                                                   FontSize="13"
                                                   x:Uid="WindLabel"
                                                   Text="Wind" />
                                        <TextBlock Text="{x:Bind ViewModel.Wind, Mode=OneWay}"
                                                   Foreground="{ThemeResource BrushOnSurface}"
                                                   FontWeight="SemiBold"
                                                   FontSize="20" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="16"
                                        CornerRadius="8"
                                        Background="{ThemeResource BrushSurfaceVariant}">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="Medium"
                                                   Opacity="0.7"
                                                   Foreground="{ThemeResource BrushOnSurface}"
                                                   FontSize="13"
                                                   x:Uid="DescriptionLabel"
                                                   Text="Description" />
                                        <TextBlock Foreground="{ThemeResource BrushOnSurface}"
                                                   TextWrapping="Wrap"
                                                   FontSize="16"
                                                   Text="{x:Bind ViewModel.Description, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ProgressRing IsActive="True"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="80"
                                  Height="80"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="ColorPrimary">#FF0078D4</Color>
                    <Color x:Key="ColorOnPrimary">#FFFFFFFF</Color>
                    <Color x:Key="ColorSecondary">#FF005A9E</Color>
                    <Color x:Key="ColorAccent">#FF00B7C3</Color>
                    <Color x:Key="ColorOnAccent">#FFFFFFFF</Color>
                    <Color x:Key="ColorSurface">#FFFFFFFF</Color>
                    <Color x:Key="ColorOnSurface">#FF1F1F1F</Color>
                    <Color x:Key="ColorSurfaceVariant">#FFF5F5F5</Color>
                    <Color x:Key="ColorBackground">#FFF8FAFB</Color>
                    <Color x:Key="ColorOnBackground">#FF1F1F1F</Color>
                    <Color x:Key="ColorOutline">#FFE0E0E0</Color>
                    <Color x:Key="ColorOutlineVariant">#FFF0F0F0</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="ColorPrimary">#FF4CC2FF</Color>
                    <Color x:Key="ColorOnPrimary">#FF003352</Color>
                    <Color x:Key="ColorSecondary">#FF5DB8FF</Color>
                    <Color x:Key="ColorAccent">#FF00E5F0</Color>
                    <Color x:Key="ColorOnAccent">#FF003840</Color>
                    <Color x:Key="ColorSurface">#FF1E1E1E</Color>
                    <Color x:Key="ColorOnSurface">#FFE4E4E4</Color>
                    <Color x:Key="ColorSurfaceVariant">#FF2A2A2A</Color>
                    <Color x:Key="ColorBackground">#FF121212</Color>
                    <Color x:Key="ColorOnBackground">#FFE4E4E4</Color>
                    <Color x:Key="ColorOutline">#FF3A3A3A</Color>
                    <Color x:Key="ColorOutlineVariant">#FF2A2A2A</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="BrushPrimary"
                             Color="{ThemeResource ColorPrimary}" />
            <SolidColorBrush x:Key="BrushOnPrimary"
                             Color="{ThemeResource ColorOnPrimary}" />
            <SolidColorBrush x:Key="BrushSecondary"
                             Color="{ThemeResource ColorSecondary}" />
            <SolidColorBrush x:Key="BrushAccent"
                             Color="{ThemeResource ColorAccent}" />
            <SolidColorBrush x:Key="BrushOnAccent"
                             Color="{ThemeResource ColorOnAccent}" />
            <SolidColorBrush x:Key="BrushSurface"
                             Color="{ThemeResource ColorSurface}" />
            <SolidColorBrush x:Key="BrushOnSurface"
                             Color="{ThemeResource ColorOnSurface}" />
            <SolidColorBrush x:Key="BrushSurfaceVariant"
                             Color="{ThemeResource ColorSurfaceVariant}" />
            <SolidColorBrush x:Key="BrushBackground"
                             Color="{ThemeResource ColorBackground}" />
            <SolidColorBrush x:Key="BrushOnBackground"
                             Color="{ThemeResource ColorOnBackground}" />
            <SolidColorBrush x:Key="BrushOutline"
                             Color="{ThemeResource ColorOutline}" />
            <SolidColorBrush x:Key="BrushOutlineVariant"
                             Color="{ThemeResource ColorOutlineVariant}" />
        </ResourceDictionary>
    </Page.Resources>
</Page>
