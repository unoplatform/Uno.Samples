<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.7" />
		<PackageReference Include="Microsoft.Extensions.Logging.Console" Version="9.0.7" />
		<PackageReference Include="SkiaSharp" Version="3.119.0" />
		<PackageReference Include="Uno.WinUI.Skia.Wpf" Version="6.0.797" />
		<PackageReference Include="Uno.WinUI.DevServer" Version="6.0.797" Condition="'$(Configuration)'=='Debug'" />
		<PackageReference Include="Uno.UI.Adapter.Microsoft.Extensions.Logging" Version="6.0.797" />
		<PackageReference Include="Uno.WinUI.XamlHost" Version="6.0.797" />
		<PackageReference Include="Uno.WinUI.XamlHost.Skia.Wpf" Version="6.0.797" />
	</ItemGroup>
	<ItemGroup>
		<UpToDateCheckInput Include="..\UnoIslandsSampleApp.Shared\**\*.xaml" />
	</ItemGroup>
	<ItemGroup>
		<Content Include="Assets\Fonts\uno-fluentui-assets.ttf" />
	</ItemGroup>

	<Import Project="..\UnoIslandsSampleApp.Shared\UnoIslandsSampleApp.Shared.projitems" Label="Shared" />

</Project>
